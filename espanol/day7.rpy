translate spanish temp_d7a_091a76ee:

    # Q "Be wary, Stalker [persistent.player_name]. I do not forget things that quickly."
    Q "Ten cuidado, Acechador [persistent.player_name]. No olvido las cosas tan rápidamente."

# game/scripts/day7.rpy:671
translate spanish temp_d7a_267eaf58:

    # Q "That said, you are mistaken."
    Q "Dicho esto, te equivocas."

# game/scripts/day7.rpy:672
translate spanish temp_d7a_197be4b9:

    # Q "As for the reason of your presence here, I will explain that later."
    Q "En cuanto al motivo de tu presencia aquí, te lo explicaré más tarde."

# game/scripts/day7.rpy:675
translate spanish temp_d7a_ac125e7c:

    # Q "For now, why don't you step down here and watch the game together with me?"
    Q "Por ahora, ¿por qué no bajas aquí y ves el juego conmigo?"

# game/scripts/day7.rpy:676
translate spanish temp_d7a_e571a61b:

    # Q "I'm sure it will be entertaining..."
    Q "Estoy segura de que será entretenido..."

