# game/scripts/day7.rpy:4
translate spanish d7a_561f0c13:

    # Zt "It's time to prepare [S] for the Zone and discuss the map with her."
    Zt "Es hora de preparar a [S] para la Zona y discutir el mapa con ella."

# game/scripts/day7.rpy:10
translate spanish d7a_db6fb832:

    # Z "I brought you something."
    Z "Te he traído algo."

# game/scripts/day7.rpy:13
translate spanish d7a_409100c4:

    # S "What is it?"
    S "¿Qué es esto?"

# game/scripts/day7.rpy:16
translate spanish d7a_d96630aa:

    # Z "You need to be properly equipped, for your journey."
    Z "Necesitas equiparte adecuadamente, para tu viaje."

# game/scripts/day7.rpy:17
translate spanish d7a_a4720db3:

    # Z "So I have collected some protective gear I want you to try out."
    Z "Así que he reunido un equipo de protección que quiero que te pruebes."

# game/scripts/day7.rpy:20
translate spanish d7a_52dea4a1:

    # S "You want to play dress up, hmm?"
    S "¿Quieres jugar a los disfraces?"

# game/scripts/day7.rpy:21
translate spanish d7a_bfdee54c:

    # Z "Yeah, right, that's exactly..."
    Z "Sí, claro, eso es exactamente..."

# game/scripts/day7.rpy:22
translate spanish d7a_25e985d4:

    # S "I'm kidding [persistent.dad]. I'll get ready, give me a minute!"
    S "Estoy bromeando [persistent.dad]. Me voy a preparar, ¡dame un minuto!"

# game/scripts/day7.rpy:25
translate spanish d7a_5ab3574d:

    # Z "..."
    Z "..."

# game/scripts/day7.rpy:26
translate spanish d7a_8d19e126:

    # S "Soo, what's in the crate?"
    S "Entonces, ¿qué hay en la caja?"

# game/scripts/day7.rpy:29
translate spanish d7a_0aa16052:

    # Z "Is that what you call ready??!"
    Z "¡¿¿A eso le llamas estar preparada??!"

# game/scripts/day7.rpy:32
translate spanish d7a_b3386ea0:

    # S "Most of my clothes are being washed."
    S "La mayoría de mis ropas están siendo lavadas."

# game/scripts/day7.rpy:35
translate spanish d7a_a5d7c36e:

    # S "And you know how I am when it comes to surprises."
    S "Y ya sabes cómo soy cuando se trata de sorpresas."

# game/scripts/day7.rpy:39
translate spanish d7a_6bfa8479:

    # S "Let's see..."
    S "Veamos..."

# game/scripts/day7.rpy:42
translate spanish d7a_b1cceca0:

    # S "A coat... makes sense..."
    S "Un abrigo... tiene sentido..."

# game/scripts/day7.rpy:45
translate spanish d7a_31123675:

    # S "Gloves... a scarf... pants.."
    S "Guantes... una bufanda... pantalones..."

# game/scripts/day7.rpy:46
translate spanish d7a_5fd31a24:

    # S "See? I didn't need to put mine on after all."
    S "¿Ves? Al fin y al cabo, no he necesitado ponerme el mío."

# game/scripts/day7.rpy:47
translate spanish d7a_2ea2696e:

    # S "The coat looks warm though, are you sure I won't melt in the sun?"
    S "El abrigo parece calentito, ¿seguro que no me derretiré al sol?"

# game/scripts/day7.rpy:48
translate spanish d7a_5ab3574d_1:

    # Z "..."
    Z "..."

# game/scripts/day7.rpy:49
translate spanish d7a_e1fd8e00:

    # S "[persistent.dad!c]?"
    S "¿[persistent.dad!c]?"

# game/scripts/day7.rpy:50
translate spanish d7a_7839dd62:

    # Z "Uh... no. It's mostly for the night, but there's more to it."
    Z "Eh... no. Es sobre todo para la noche, pero hay algo más."

# game/scripts/day7.rpy:51
translate spanish d7a_04720beb:

    # Z "Temperatures can change quickly in the Zone, well beyond the normal day and night shift..."
    Z "Las temperaturas pueden cambiar rápidamente en la Zona, mucho más allá de la variación normal entre el día y la noche..."

# game/scripts/day7.rpy:52
translate spanish d7a_99259e8c:

    # S "Hmmm, I see. What else... boots..."
    S "Ummm, ya veo. Qué más... botas..."

# game/scripts/day7.rpy:53
translate spanish d7a_77473200:

    # S "Wait, no way!"
    S "Espera, ¡no puede ser!"

# game/scripts/day7.rpy:54
translate spanish d7a_93315fac:

    # S "I have to try this on now..."
    S "Tengo que probarme esto ahora..."

# game/scripts/day7.rpy:57
translate spanish d7a_a1a30848:

    # S "My own gas mask!!"
    S "¡¡Mi propia máscara de gas!!"

# game/scripts/day7.rpy:58
translate spanish d7a_bcacfd22:

    # Z "Looks good {i}and{/i} it saves your life."
    Z "Tiene buena pinta {i}y{/i} te salvará la vida."

# game/scripts/day7.rpy:59
translate spanish d7a_7bf454a4:

    # S "I know right? What more do I need?"
    S "Lo sé, ¿verdad? ¿Qué más necesito?"

# game/scripts/day7.rpy:60
translate spanish d7a_dc02fa45:

    # Z "Try it all on, and then I will give you the most important thing."
    Z "Pruébatelo todo y luego te daré lo más importante."

# game/scripts/day7.rpy:63
translate spanish d7a_4a713b02:

    # S "Let's do it."
    S "Vamos a hacerlo."

# game/scripts/day7.rpy:66
translate spanish d7a_40d88e91:

    # Z "Okay, first put these on."
    Z "Vale, primero ponte esto."

# game/scripts/day7.rpy:67
translate spanish d7a_971a98df:

    # S "..."
    S "..."

# game/scripts/day7.rpy:68
translate spanish d7a_df1c5e82:

    # S "Done."
    S "Ya está."

# game/scripts/day7.rpy:71
translate spanish d7a_4422c95b:

    # Z "Now... about the coat... It has 4 pockets; two are on the inside."
    Z "Ahora... sobre el abrigo... tiene 4 bolsillos; dos están en el interior."

# game/scripts/day7.rpy:72
translate spanish d7a_6992672a:

    # Z "You need to keep your meds on you at all times."
    Z "Necesitas llevar tus medicinas encima en todo momento."

# game/scripts/day7.rpy:73
translate spanish d7a_9bc8c845:

    # Z "The coat is thick enough to protect you from the dust, and it's fire resistant."
    Z "El abrigo es lo suficientemente grueso como para protegerte del polvo, y es resistente al fuego."

# game/scripts/day7.rpy:76
translate spanish d7a_73b4258e:

    # S "Okay, but what if-"
    S "Vale, pero ¿qué pasa si...?"

# game/scripts/day7.rpy:77
translate spanish d7a_49568196:

    # Z "In a case of fire you {i}have to{/i} strap the coat all the way down to your ankles."
    Z "En caso de incendio {i}tienes que{/i} abrocharte el abrigo hasta los tobillos."

# game/scripts/day7.rpy:80
translate spanish d7a_487c962e:

    # Z "The filter on the mask is new, but you need to keep track of its wear at all times."
    Z "El filtro de la máscara es nuevo, pero tienes que controlar su uso en todo momento."

# game/scripts/day7.rpy:81
translate spanish d7a_c0f1065a:

    # S "[persistent.dad!c]..."
    S "[persistent.dad!c]..."

# game/scripts/day7.rpy:84
translate spanish d7a_7835bbd5:

    # Z "Changing the filter can make noise; you need to plan ahead, don't ever run out of air while hiding from beasts."
    Z "Cambiar el filtro puede hacer ruido; debes planificar con antelación, no te quedes sin aire mientras te escondes de las bestias."

# game/scripts/day7.rpy:85
translate spanish d7a_6ca2276e:

    # Z "When in doubt, just put on two at the same ti-"
    Z "En caso de duda, ponte dos a la vez."

# game/scripts/day7.rpy:89
translate spanish d7a_ada73672:

    # S "[persistent.dad!c]!!!"
    S "¡¡¡[persistent.dad!c]!!!"

# game/scripts/day7.rpy:93
translate spanish d7a_4f872148:

    # S "I am not in the Zone yet."
    S "Todavía no estoy en la Zona."

# game/scripts/day7.rpy:94
translate spanish d7a_dd5ad923:

    # S "Calm down. I am already nervous enough."
    S "Cálmate. Ya estoy bastante nerviosa."

# game/scripts/day7.rpy:95
translate spanish d7a_42f22455:

    # Z "I... you're right."
    Z "Yo... tienes razón."

# game/scripts/day7.rpy:96
translate spanish d7a_46ddf23c:

    # Z "But these things are important."
    Z "Pero estas cosas son importantes."

# game/scripts/day7.rpy:97
translate spanish d7a_0921e95b:

    # Z "I don't want you to..."
    Z "No quiero que..."

# game/scripts/day7.rpy:100
translate spanish d7a_33b6bbc6:

    # S "...die?"
    S "¿... me muera?"

# game/scripts/day7.rpy:101
translate spanish d7a_5ab3574d_2:

    # Z "..."
    Z "..."

# game/scripts/day7.rpy:104
translate spanish d7a_971a98df_1:

    # S "..."
    S "..."

# game/scripts/day7.rpy:105
translate spanish d7a_e6ef9796:

    # Z "I am not doubting your readiness, I promise."
    Z "No dudo de tu preparación, te lo prometo."

# game/scripts/day7.rpy:106
translate spanish d7a_a721c4c3:

    # Z "I just think that-"
    Z "Sólo pienso que..."

# game/scripts/day7.rpy:109
translate spanish d7a_a5d746bf:

    # Z "...!"
    Z "¡...!"

# game/scripts/day7.rpy:112
translate spanish d7a_5ab3574d_3:

    # Z "..."
    Z "..."

# game/scripts/day7.rpy:115
translate spanish d7a_971a98df_2:

    # S "..."
    S "..."

# game/scripts/day7.rpy:116
translate spanish d7a_7f7465d4:

    # S "I know that you don't."
    S "Sé que no lo haces"

# game/scripts/day7.rpy:117
translate spanish d7a_dce7b8b1:

    # S "It's just..."
    S "Es sólo..."

# game/scripts/day7.rpy:118
translate spanish d7a_e2503466:

    # S "If you weren't here, I would have to prepare on my own."
    S "Si no estuvieras aquí, tendría que prepararme yo sola."

# game/scripts/day7.rpy:119
translate spanish d7a_87c4f05b:

    # S "And even with your help, I don't know if it will be enough..."
    S "E incluso con tu ayuda, no sé si será suficiente..."

# game/scripts/day7.rpy:120
translate spanish d7a_f567cfa2:

    # S "...if {i}I{/i} will be enough."
    S "... si {i}yo{/i} seré suficiente."

# game/scripts/day7.rpy:123
translate spanish d7a_092b091d:

    # Z "Don't say that. You are better prepared than I ever was."
    Z "No digas eso. Estás mejor preparada que yo."

# game/scripts/day7.rpy:124
translate spanish d7a_17599413:

    # Z "You're calm, focused and you don't take this lightly."
    Z "Estás tranquila, concentrada y no te lo tomas a la ligera."

# game/scripts/day7.rpy:125
translate spanish d7a_90c1b0a0:

    # Z "I have seen that every day, in your commitment... and I admire you for it."
    Z "Lo he visto cada día, en tu compromiso... y te admiro por ello."

# game/scripts/day7.rpy:126
translate spanish d7a_b3338fca:

    # Z "Everything will work out."
    Z "Todo se solucionará."

# game/scripts/day7.rpy:130
translate spanish d7a_bd9abb89:

    # Z "Now... do you want to show off what you're wearing?"
    Z "Ahora... ¿quieres enseñarme lo que llevas puesto?"

# game/scripts/day7.rpy:131
translate spanish d7a_9b22fd7f:

    # Z "I need to see if anything is missing."
    Z "Necesito ver si te falta algo."

# game/scripts/day7.rpy:132
translate spanish d7a_e84b0998:

    # S "Okay."
    S "De acuerdo."

# game/scripts/day7.rpy:133
translate spanish d7a_22b1a683:

    # S "I should take the mask off again. {i}*chuckles*"
    S "Debería volver a quitarme la máscara. {i}*risilla*"

# game/scripts/day7.rpy:137
translate spanish d7a_99a29214:

    # S "Soo... what do you think, am I cute enough to seduce the beasts into leaving me alone?"
    S "A veeerr... ¿qué piensas? ¿Estoy lo bastante guapa como para seducir a las bestias y que me dejen en paz?"

# game/scripts/day7.rpy:140
translate spanish d7a_1564e78b:

    # S "Is this outfit suitable for a place of death and despair?"
    S "¿Esta ropa es adecuada para un lugar de muerte y desesperación?"

# game/scripts/day7.rpy:141
translate spanish d7a_3acca289:

    # Z "I need to have a better look... turn around."
    Z "Necesito verte mejor... date la vuelta."

# game/scripts/day7.rpy:144
translate spanish d7a_2e6aaf4b:

    # S "Of course, Master [persistent.player_name]."
    S "Por supuesto, Amo [persistent.player_name]."

# game/scripts/day7.rpy:145
translate spanish d7a_0a7437b3:

    # Z "Really...?"
    Z "¿En serio...?"

# game/scripts/day7.rpy:148
translate spanish d7a_a64e1f45:

    # S "Hmmm?"
    S "¿Ummm?"

# game/scripts/day7.rpy:149
translate spanish d7a_5ae95700:

    # Z "How does the coat feel?"
    Z "¿Cómo se siente el abrigo?"

# game/scripts/day7.rpy:150
translate spanish d7a_a2ccc455:

    # Z "Remember, you may have to also sleep in it."
    Z "Recuerda que puede que también tengas que dormir con el."

# game/scripts/day7.rpy:151
translate spanish d7a_912df081:

    # S "It feels snug. I'll be happy to have it, when I'll need it."
    S "Se siente cómodo. Me alegraré de tenerlo cuando lo necesite."

# game/scripts/day7.rpy:154
translate spanish d7a_e11fb95e:

    # S "{i}*yawns*{/i} I can't wait to get up in the morning and have a nice stretch after sleeping a mere room away from beasts that would love to eat me..."
    S "{i}*Bostezos*{/i} Estoy deseando levantarme por la mañana y dar un buen estirón después de haber dormido a una simple habitación de distancia de bestias a las que les encantaría comerme...."

# game/scripts/day7.rpy:155
translate spanish d7a_f725fa00:

    # Z "I take back what I said about you not taking this lightly."
    Z "Retiro lo que dije sobre que no te lo tomabas a la ligera."

# game/scripts/day7.rpy:156
translate spanish d7a_f087e9da:

    # Z "In fact, you sound just as cocky as I was back when I started."
    Z "De hecho, pareces tan engreída como yo cuando empecé."

# game/scripts/day7.rpy:159
translate spanish d7a_25bc5b82:

    # S "Bleeeh..."
    S "Biiieeen..."

# game/scripts/day7.rpy:163
translate spanish d7a_6b9cb119:

    # S "Like father like daughter I guess."
    S "De tal palo tal astilla, supongo."

# game/scripts/day7.rpy:165
translate spanish d7a_fab367ae:

    # S "I guess I take after the man who raised me. Blame him!"
    S "Supongo que me parezco al hombre que me crió. ¡Cúlpenlo!"

# game/scripts/day7.rpy:168
translate spanish d7a_120c1e01:

    # Z "There is one more thing..."
    Z "Hay una cosa más..."

# game/scripts/day7.rpy:169
translate spanish d7a_3235801c:

    # Z "My old master, Zosar... I met him again."
    Z "Mi antiguo maestro, Zosar... Volví a encontrarme con él."

# game/scripts/day7.rpy:172
translate spanish d7a_f07dc974:

    # S "Wait, what?"
    S "Espera, ¿qué?"

# game/scripts/day7.rpy:175
translate spanish d7a_f2e3bd9e:

    # Z "It's a long story..."
    Z "Es una larga historia..."

# game/scripts/day7.rpy:176
translate spanish d7a_6e4c4ce1:

    # Z "The short of it is that he gave me a map."
    Z "El resumen es que me dio un mapa."

# game/scripts/day7.rpy:177
translate spanish d7a_b5e75659:

    # Z "It's supposed to lead to a place that holds something he wants."
    Z "Se supone que conduce a un lugar que contiene algo que él desea."

# game/scripts/day7.rpy:180
translate spanish d7a_d07ff809:

    # S "What is that supposed to mean?"
    S "¿Qué se supone que significa?"

# game/scripts/day7.rpy:183
translate spanish d7a_225586f6:

    # Z "He only said you'll know what it is if and when you see it."
    Z "Sólo dijo que sabrías lo que sería siempre y cuando lo vieras."

# game/scripts/day7.rpy:184
translate spanish d7a_a0574ce7:

    # Z "Even in life, he never did anything without purpose. Might be worth looking into it."
    Z "Incluso en vida, nunca hacía nada sin un propósito. Podría valer la pena investigarlo."

# game/scripts/day7.rpy:185
translate spanish d7a_fdc01c88:

    # Z "I'll tell you more once we are in the library. Follow me..."
    Z "Te contaré más cosas cuando estemos en la biblioteca. Sígueme..."

# game/scripts/day7.rpy:188
translate spanish d7a_97361982:

    # S "Okay, sure. Didn't your master..."
    S "De acuerdo, claro. ¿Tu maestro no..."

# game/scripts/day7.rpy:191
translate spanish d7a_b2091e46:

    # Z "Yes, I know..."
    Z "Sí, lo sé..."

# game/scripts/day7.rpy:192
translate spanish d7a_bc1c8931:

    # Z "As I said, I'll explain..."
    Z "Como te he dicho, te lo explicaré..."

# game/scripts/day7.rpy:196
translate spanish d7a_0ce345d8:

    # "{i}Eventually..."
    "{i}Por fin..."

# game/scripts/day7.rpy:203
translate spanish d7a_4e12f7df:

    # S "...and then he gave you this map."
    S "... y luego te dio este mapa."

# game/scripts/day7.rpy:204
translate spanish d7a_5760e940:

    # S "This seems to be a pretty detailed description of the area."
    S "Esto parece una descripción bastante detallada de la zona."

# game/scripts/day7.rpy:205
translate spanish d7a_4988d859:

    # Z "He must've compiled it over the years."
    Z "Debe haberla recopilado a lo largo de los años."

# game/scripts/day7.rpy:206
translate spanish d7a_34e945c4:

    # Z "The blueprint you see is of the building he wants you to investigate."
    Z "El plano que ves es del edificio que quiere que investigues."

# game/scripts/day7.rpy:209
translate spanish d7a_398044b6:

    # Z "We don't know whether or not the buildings will be occupied."
    Z "No sabemos si los edificios estarán ocupados o no."

# game/scripts/day7.rpy:211
translate spanish d7a_b825fcb3:

    # S "We don't know that of the entire Zone. I'll be careful."
    S "No lo sabemos de toda la Zona. Tendré cuidado."

# game/scripts/day7.rpy:212
translate spanish d7a_7bba309f:

    # S "The whole area is huge."
    S "Toda la zona es enorme."

# game/scripts/day7.rpy:218
translate spanish d7a_27d7e1df:

    # W "I know my favourite adventurers are busy, but I also know that you need to stay hydrated."
    W "Sé que mis aventureros favoritos están ocupados, pero también sé que deben mantenerse hidratados."

# game/scripts/day7.rpy:219
translate spanish d7a_eedd036c:

    # S "Thanks, [persistent.mom]."
    S "Gracias, [persistent.mom]."

# game/scripts/day7.rpy:220
translate spanish d7a_7145827c:

    # Z "Yes, thank you."
    Z "Sí, gracias."

# game/scripts/day7.rpy:224
translate spanish d7a_5dadb5b6:

    # Z "Where were we..."
    Z "Dónde estábamos..."

# game/scripts/day7.rpy:225
translate spanish d7a_fa6e8d67:

    # Z "So... the buildings annexed to the factory were most likely lodgings for the workers."
    Z "Así que... los edificios anexos a la fábrica eran probablemente alojamientos para los trabajadores."

# game/scripts/day7.rpy:226
translate spanish d7a_c9c327ed:

    # Z "You will need to figure out if you want to explore these first."
    Z "Tendrás que averiguar si quieres explorar esto primero."

# game/scripts/day7.rpy:227
translate spanish d7a_805855c7:

    # Z "Sometimes, the personal effects of people can hide unexpected treasures, even centuries later."
    Z "A veces, los efectos personales de la gente pueden esconder tesoros inesperados, incluso siglos después."

# game/scripts/day7.rpy:230
translate spanish d7a_75eeefde:

    # Z "Other than that..."
    Z "Aparte de eso..."

# game/scripts/day7.rpy:231
translate spanish d7a_012243b5:

    # Z "We don't really know anything."
    Z "Realmente no sabemos nada."

# game/scripts/day7.rpy:232
translate spanish d7a_fbd1a1c0:

    # Z "You'll just... have to go there and find out, I guess."
    Z "Tendrás que ir allí y averiguarlo, supongo."

# game/scripts/day7.rpy:235
translate spanish d7a_b16fbcee:

    # S "...and I will."
    S "... y lo haré."

# game/scripts/day7.rpy:238
translate spanish d7a_9ceb0962:

    # Z "If there is one thing I know, it's that whatever, whoever is out there, they better not get in the way of my girl."
    Z "Si hay algo que sé, es que sea lo que sea, quien sea que esté ahí fuera, será mejor que no se interponga en el camino de mi chica."

# game/scripts/day7.rpy:241
translate spanish d7a_3b2a49e7:

    # S "{i}*chuckles*{/i} They better not!"
    S "{i}*risilla*{/i} ¡Más vale que no!"

# game/scripts/day7.rpy:245
translate spanish d7a_399d9b7e:

    # "{i}After several hours spent going over even the smallest details available, you and [S] decide that it is time to rest on the balcony..."
    "{i}Después de pasar varias horas repasando hasta los más mínimos detalles disponibles, tú y [S] decidís que es hora de descansar en el balcón..."

# game/scripts/day7.rpy:252
translate spanish d7a_971a98df_3:

    # S "..."
    S "..."

# game/scripts/day7.rpy:255
translate spanish d7a_4071e967:

    # S "It's always so pretty up here..."
    S "Siempre es muy bonito estar aquí arriba..."

# game/scripts/day7.rpy:258
translate spanish d7a_e11e3b4b:

    # Z "It is..."
    Z "Lo es..."

# game/scripts/day7.rpy:261
translate spanish d7a_49d3edfb:

    # Z "Everytime I question why I decided to build my house so far away from Zeta..."
    Z "Cada vez que me pregunto por qué decidí construir mi casa tan lejos de Zeta..."

# game/scripts/day7.rpy:262
translate spanish d7a_319db595:

    # Z "...this reminds me why."
    Z "... esto me recuerda por qué."

# game/scripts/day7.rpy:263
translate spanish d7a_133ffec0:

    # Z "The city offers anything you could want to do in a day."
    Z "La ciudad ofrece todo lo que puedas querer hacer en un día."

# game/scripts/day7.rpy:264
translate spanish d7a_0cbda943:

    # Z "But only out here can you really appreciate the beginning and end of the day."
    Z "Pero sólo aquí puedes apreciar realmente el principio y el final del día."

# game/scripts/day7.rpy:267
translate spanish d7a_08ef4f59:

    # S "Tell me..."
    S "Dime..."

# game/scripts/day7.rpy:268
translate spanish d7a_865bf578:

    # S "What did it feel like, back then..."
    S "¿Cómo te sentiste, en aquel entonces...?"

# game/scripts/day7.rpy:271
translate spanish d7a_f237085f:

    # S "I mean... heading into a Zone for the first time."
    S "Quiero decir... entrar en una Zona por primera vez."

# game/scripts/day7.rpy:272
translate spanish d7a_e2b1a9e7:

    # S "You didn't know [persistent.mom] back then..."
    S "No conocías a [persistent.mom] en aquel entonces..."

# game/scripts/day7.rpy:273
translate spanish d7a_c650c111:

    # S "Did you have anyone you'd worry about when you first left?"
    S "¿Tenías a alguien por quien preocuparte cuando te fuiste?"

# game/scripts/day7.rpy:276
translate spanish d7a_d204c737:

    # Z "My old Master had left the city during my preparations for my first real mission."
    Z "Mi antiguo Amo había abandonado la ciudad durante mis preparativos para mi primera misión real."

# game/scripts/day7.rpy:277
translate spanish d7a_b339b518:

    # Z "With him gone, I had to face preparations by myself, from gathering information, to preparing supplies and establishing objectives."
    Z "Sin él, tuve que enfrentarme a los preparativos yo solo, desde la recopilación de información hasta la preparación de suministros y el establecimiento de objetivos."

# game/scripts/day7.rpy:278
translate spanish d7a_95a8fbb9:

    # Z "As you are finding out now, a lot goes into such an adventure before it even begins."
    Z "Como estás descubriendo ahora, hay mucho que hacer en una aventura de este tipo antes de que empiece."

# game/scripts/day7.rpy:279
translate spanish d7a_dd0fcef9:

    # Z "However, it wasn't so much that I worried for him; I was worried for myself, my survival."
    Z "Sin embargo, no era tanto lo que me preocupaba por él, sino por mí mismo, por mi supervivencia."

# game/scripts/day7.rpy:280
translate spanish d7a_9367cc9c:

    # Z "When I finished my preparations, I was insecure. I felt, I knew, that I was not ready to head out."
    Z "Cuando terminé mis preparativos, me sentí inseguro. Sentía, sabía, que no estaba preparado para salir."

# game/scripts/day7.rpy:281
translate spanish d7a_e7044337:

    # Z "Because in the end, nobody is ever really ready for everything that might happen."
    Z "Porque, al final, nadie está nunca realmente preparado para todo lo que puede ocurrir."

# game/scripts/day7.rpy:284
translate spanish d7a_8c59af49:

    # Z "When the day came and the Zone was burned into the ground, I packed my gear, left everything else behind and headed out."
    Z "Cuando llegó el día en que la Zona se quemó hasta los cimientos, recogí mis bártulos, dejé todo lo demás y me dirigí a ella."

# game/scripts/day7.rpy:285
translate spanish d7a_b7ffb2e8:

    # Z "I did not know what was coming next."
    Z "No sabía lo que venía a continuación."

# game/scripts/day7.rpy:286
translate spanish d7a_e970b36b:

    # Z "I was feeling alone, like a castaway with no goal other than to experience the unknown."
    Z "Me sentía solo, como un náufrago sin más objetivo que experimentar lo desconocido."

# game/scripts/day7.rpy:287
translate spanish d7a_ea943d59:

    # Z "But as I was walking down the streets, heading ever closer to the Zone, that's when it happened."
    Z "Pero mientras caminaba por las calles, acercándome cada vez más a la Zona, fue cuando ocurrió."

# game/scripts/day7.rpy:290
translate spanish d7a_3e5d441e:

    # Z "Something clicked."
    Z "Algo hizo click."

# game/scripts/day7.rpy:291
translate spanish d7a_1ca7675d:

    # Z "For the first time in my life, I felt free."
    Z "Por primera vez en mi vida, me sentí libre."

# game/scripts/day7.rpy:292
translate spanish d7a_edf8cd2a:

    # Z "And I mean truly free. Not the time you take for yourself after passing a challenge or doing your chores."
    Z "Y quiero decir verdaderamente libre. No el tiempo que te tomas para ti después de superar un reto o hacer tus tareas."

# game/scripts/day7.rpy:293
translate spanish d7a_1178648e:

    # Z "I was alone, by myself... Out there for myself and nothing and no one else mattered but me."
    Z "Estaba solo, por mí mismo... Ahí fuera para mí y nada ni nadie más importaba que yo."

# game/scripts/day7.rpy:294
translate spanish d7a_e4200f3a:

    # Z "All that I had was my equipment, my training and whatever knowledge I had gained up until that day."
    Z "Todo lo que tenía era mi equipo, mi entrenamiento y los conocimientos que había adquirido hasta ese día."

# game/scripts/day7.rpy:295
translate spanish d7a_d3a1b821:

    # Z "This freedom is what I wish for you to experience as well."
    Z "Esa libertad es la que deseo que tú también experimentes."

# game/scripts/day7.rpy:296
translate spanish d7a_bbbf5fae:

    # Z "You will learn to get to know yourself and your goals better than from any of my teachings or those of others."
    Z "Aprenderás a conocerte a ti misma y a tus objetivos mejor que con mis enseñanzas o las de otros."

# game/scripts/day7.rpy:297
translate spanish d7a_68f3b22d:

    # Z "You will learn not to be burdened by what people expect of you, or to be manipulated by them, or even, despite my best intentions, by me."
    Z "Aprenderás a no agobiarte por lo que la gente espera de ti, ni a dejarte manipular por ellos, ni siquiera, a pesar de mis mejores intenciones, por mí."

# game/scripts/day7.rpy:300
translate spanish d7a_1c0da7bf:

    # Z "Times will come where you might want to give up that freedom again so you can replace it with something else."
    Z "Llegarán momentos en los que querrás volver a renunciar a esa libertad para poder sustituirla por otra cosa."

# game/scripts/day7.rpy:301
translate spanish d7a_d0586e38:

    # Z "But when you head out and walk down those roads, and experience the emissions of the Zone lighting up the sky, maybe then you will get this feeling too."
    Z "Pero cuando salgas y camines por esos caminos, y experimentes las emisiones de la Zona iluminando el cielo, quizás entonces también tengas esa sensación."

# game/scripts/day7.rpy:305
translate spanish d7a_ab9f79fc:

    # S "That sounds peaceful..."
    S "Eso suena tranquilo..."

# game/scripts/day7.rpy:307
translate spanish d7a_6e8b7795:

    # S "Freedom to do everything I want... sounds nice."
    S "Libertad para hacer todo lo que quiera... suena bien."

# game/scripts/day7.rpy:308
translate spanish d7a_195123c2:

    # S "I will try to remember what you said... when I see it for myself."
    S "Intentaré recordar lo que has dicho... cuando lo vea por mí misma."

# game/scripts/day7.rpy:309
translate spanish d7a_0f71d6df:

    # S "But..."
    S "Pero..."

# game/scripts/day7.rpy:310
translate spanish d7a_f73c3087:

    # Z "But...?"
    Z "Pero..."

# game/scripts/day7.rpy:313
translate spanish d7a_6e037dd7:

    # Z "...?"
    Z "¿...?"

# game/scripts/day7.rpy:316
translate spanish d7a_1cefcf2f:

    # S "I understand what you're saying..."
    S "Entiendo lo que dices..."

# game/scripts/day7.rpy:317
translate spanish d7a_9324227f:

    # S "And I do get why some things have always been better left unsaid, untouched."
    S "Y entiendo que algunas cosas siempre han sido mejor no decirlas, no tocarlas."

# game/scripts/day7.rpy:320
translate spanish d7a_629866fe:

    # S "But I think I don't have to wait for the Zone... to know at least some things that I want."
    S "Pero creo que no tengo que esperar a la Zona... para saber al menos algunas cosas que quiero."

# game/scripts/day7.rpy:321
translate spanish d7a_6eb39997:

    # S "The things I want to do... where to live, and who I want to be... I have ideas, plans."
    S "Las cosas que quiero hacer... dónde vivir, y quién quiero ser... tengo ideas, planes."

# game/scripts/day7.rpy:322
translate spanish d7a_28ecadb7:

    # S "Some of them are just that, ideas that might change; but not all of them."
    S "Algunas son sólo eso, ideas que pueden cambiar; pero no todas."

# game/scripts/day7.rpy:323
translate spanish d7a_18558ff1:

    # S "A few things are clear to me, and nothing will change them."
    S "Algunas cosas están claras para mí, y nada las cambiará."

# game/scripts/day7.rpy:326
translate spanish d7a_badb50c7:

    # S "And even though I have not been out there yet..."
    S "Y aunque no haya estado allí todavía..."

# game/scripts/day7.rpy:327
translate spanish d7a_bd4e60ec:

    # S "...and the few missions I've been on with you only gave me a taste of the dread you describe..."
    S "... y las pocas misiones en las que he estado contigo sólo me han dado una muestra del espanto que describes..."

# game/scripts/day7.rpy:330
translate spanish d7a_495c04d5:

    # "{i}You both start laughing quietly..."
    "{i}Ambos empezáis a reír en silencio...*"

# game/scripts/day7.rpy:333
translate spanish d7a_8ca2595e:

    # S "...I know what I don't want to lose."
    S "... Sé lo que no quiero perder."

# game/scripts/day7.rpy:336
translate spanish d7a_b8353ec9:

    # S "And that is..."
    S "Y eso es..."

# game/scripts/day7.rpy:339
translate spanish d7a_971a98df_4:

    # S "..."
    S "..."

# game/scripts/day7.rpy:340
translate spanish d7a_8976b2d9:

    # W "[persistent.player_name!c]?! [S]? Are you guys up there?!"
    W "¿[persistent.player_name!c]? ¿[S]? ¿Estáis ahí arriba?"

# game/scripts/day7.rpy:343
translate spanish d7a_ac1b2784:

    # Zt "Damn it, really?!"
    Zt "Maldita sea, ¿en serio?"

# game/scripts/day7.rpy:344
translate spanish d7a_9654adb5:

    # Z "What is it?! Why now?"
    Z "¿Qué es? ¿Por qué ahora?"

# game/scripts/day7.rpy:345
translate spanish d7a_772584d4:

    # W "The Queen's guard is here! I need you to come down!"
    W "¡La guardia de la Reina está aquí! ¡Necesito que bajes!"

# game/scripts/day7.rpy:346
translate spanish d7a_17808bec:

    # Z "{i}*sighs*"
    Z "{i}*suspiros*"

# game/scripts/day7.rpy:349
translate spanish d7a_b433aca2:

    # S "...I guess we should go."
    S "... Creo que deberíamos irnos."

# game/scripts/day7.rpy:350
translate spanish d7a_47a2ca76:

    # Z "Yeah..."
    Z "Sí..."

# game/scripts/day7.rpy:354
translate spanish d7a_59fb84b8:

    # "{i}You head downstairs..."
    "{i}Te diriges a la planta baja..."

# game/scripts/day7.rpy:357
translate spanish d7a_3ffe2f0a:

    # G "Merneith's blessing shines bright tonight."
    G "La bendición de Merneith brilla esta noche."

# game/scripts/day7.rpy:358
translate spanish d7a_51114f46:

    # G "Revered Stalker [persistent.player_name], Lady [W]... and your pupil [S], I presume..."
    G "Reverenciado Acechador [persistent.player_name], Señora [W]... y tu pupila [S], supongo..."

# game/scripts/day7.rpy:361
translate spanish d7a_ca5341f6:

    # Z "To what do we owe a visit at such a late hour?"
    Z "¿A qué se debe una visita a una hora tan tardía?"

# game/scripts/day7.rpy:362
translate spanish d7a_1fab313a:

    # G "As you know, our gracious Queen Merneith is holding the royal games tomorrow."
    G "Como sabes, nuestra amable Reina Merneith celebrará mañana los juegos reales."

# game/scripts/day7.rpy:365
translate spanish d7a_d41b0532:

    # G "I was sent here by her majesty herself to invite you, Stalker [persistent.player_name], to attend the games with her."
    G "He sido enviada aquí por su majestad para invitarte, Acechador [persistent.player_name], a asistir a los juegos con ella."

# game/scripts/day7.rpy:368
translate spanish d7a_dcff3a0d:

    # W "Excuse me..."
    W "Perdona..."

# game/scripts/day7.rpy:371
translate spanish d7a_f508fc31:

    # W "I am sure she has her reasons. But my husband and [persistent.da] have some very busy times ahead."
    W "Estoy segura de que tiene sus razones. Pero a mi marido y a mí [persistent.da] les esperan tiempos muy ajetreados."

# game/scripts/day7.rpy:372
translate spanish d7a_bfea502a:

    # W "I'm sure you will understand that he intends to skip the games this time around."
    W "Estoy segura de que comprenderás que esta vez tiene la intención de saltarse los juegos."

# game/scripts/day7.rpy:373
translate spanish d7a_c09ec9bf:

    # W "If our Queen needs to talk to him, I'm sure that the day after will do."
    W "Si nuestra Reina necesita hablar con él, estoy segura de que el día después lo hará."

# game/scripts/day7.rpy:376
translate spanish d7a_4909691f:

    # G "I am truly sorry, Lady [W], but I was told in no uncertain terms that this was more of a summon than an invitation."
    G "Lo siento mucho, Señora [W], pero me han dicho con toda claridad que esto era más una convocatoria que una invitación."

# game/scripts/day7.rpy:379
translate spanish d7a_7fc4599a:

    # G "The Queen mentioned that she is aware of the upcoming departure of your pupil, and that she must speak to you, Stalker [persistent.player_name], before this happens."
    G "La Reina mencionó que está al tanto de la próxima partida de tu pupila, y que debe hablar contigo, Acechador [persistent.player_name], antes de que eso ocurra."

# game/scripts/day7.rpy:380
translate spanish d7a_5ab3574d_4:

    # Z "..."
    Z "..."

# game/scripts/day7.rpy:383
translate spanish d7a_6173d931:

    # Ww "Love..."
    Ww "Amor..."

# game/scripts/day7.rpy:386
translate spanish d7a_5bf4e416:

    # Ww "I remember what you told me about your last visit in the palace."
    Ww "Recuerdo lo que me contaste sobre tu última visita en el palacio."

# game/scripts/day7.rpy:388
translate spanish d7a_2127b76c:

    # Ww "If she wants to speak you this urgently, there must be something she needs."
    Ww "Si quiere hablarte con tanta urgencia, debe haber algo que ella necesite."

# game/scripts/day7.rpy:391
translate spanish d7a_45263e7e:

    # Ww "She is young, hot headed, and wields so much power..."
    Ww "Ella es joven, ardiente y tiene mucho poder..."

# game/scripts/day7.rpy:392
translate spanish d7a_fb6157a3:

    # Ww "Whatever it is she needs, convince her that you are the right man for the job..."
    Ww "Sea lo que sea lo que necesite, convéncela de que eres el hombre adecuado para el trabajo..."

# game/scripts/day7.rpy:394
translate spanish d7a_69b29f92:

    # Ww "It seems that, despite how you left things, she still needs your services."
    Ww "Parece que, a pesar de cómo dejaste las cosas, todavía necesita tus servicios."

# game/scripts/day7.rpy:397
translate spanish d7a_85753bcd:

    # Ww "You tell me she is boastful, arrogant and demanding towards anyone she meets..."
    Ww "Me dices que es jactanciosa, arrogante y exigente con cualquiera que conozca..."

# game/scripts/day7.rpy:398
translate spanish d7a_ced2899c:

    # Ww "...show her that she should know to treat you differently."
    Ww "... demuéstrale que debería saber que debe tratarte de otra manera."

# game/scripts/day7.rpy:399
translate spanish d7a_5ab3574d_5:

    # Z "..."
    Z "..."

# game/scripts/day7.rpy:402
translate spanish d7a_c6edbf82:

    # W "My lady, you can be assured that my husband will attend the games."
    W "Mi señora, puedes estar segura de que mi marido asistirá a los juegos."

# game/scripts/day7.rpy:405
translate spanish d7a_4c42b1ca:

    # G "The almighty Queen Merneith will see your husband at her pleasure."
    G "La todopoderosa Reina Merneith verá a su marido a su placer."

# game/scripts/day7.rpy:408
translate spanish d7a_5dd4b8df:

    # G "You are expected in front of the Arena at noon, tomorrow."
    G "Se le esperará frente a la Arena a mediodía, mañana."

# game/scripts/day7.rpy:409
translate spanish d7a_3222047b:

    # G "See you then, Stalker."
    G "Hasta luego, Acechador."

# game/scripts/day7.rpy:413
translate spanish d7a_9e6007c4:

    # S "Urgh..."
    S "Urgh..."

# game/scripts/day7.rpy:416
translate spanish d7a_971a98df_5:

    # S "..."
    S "..."

# game/scripts/day7.rpy:419
translate spanish d7a_1a62cd2d:

    # S "What crawled up her ass?!"
    S "¡¿Qué cojones le pasa a esta?!"

# game/scripts/day7.rpy:423
translate spanish d7a_c637725f:

    # "{i}As night falls, you all head inside and soon go to sleep."
    "{i}Cuando cae la noche, todos os dirigís al interior y pronto os dormís."

# game/scripts/day7.rpy:424
translate spanish d7a_74da7c55:

    # "{i}The following day, you get ready to head to the stadium."
    "{i}Al día siguiente, te preparas para ir al estadio."

# game/scripts/day7.rpy:425
translate spanish d7a_fd901db8:

    # "{i}You can't find [W] anywhere, so you let [S] know that you're leaving."
    "{i}No puedes encontrar a [W] en ningún sitio, así que avisas a [S] de que te vas."

# game/scripts/day7.rpy:426
translate spanish d7a_2160cbac:

    # "{i}As you're about to head out..."
    "{i}Cuando estás a punto de salir..."

# game/scripts/day7.rpy:430
translate spanish d7a_08653f90:

    # W "Is my husband leaving to deal with the Queen?"
    W "¿Mi marido se va a encargar de la Reina?"

# game/scripts/day7.rpy:431
translate spanish d7a_e9c8efc1:

    # Z "[W], I thought you were...-"
    Z "[W], pensé que estabas..."

# game/scripts/day7.rpy:434
translate spanish d7a_5ab3574d_6:

    # Z "..."
    Z "..."

# game/scripts/day7.rpy:435
translate spanish d7a_ac9cf88e:

    # Z "Wow."
    Z "Guau."

# game/scripts/day7.rpy:438
translate spanish d7a_4efaeec7:

    # W "I was feeling nostalgic today..."
    W "Hoy me sentía nostálgica..."

# game/scripts/day7.rpy:441
translate spanish d7a_5a8af1dc:

    # Z "You wore this gown at our first picnic with Rabiah..."
    Z "Llevaste este vestido en nuestro primer picnic con Rabiah..."

# game/scripts/day7.rpy:442
translate spanish d7a_b0dceaf7:

    # W "So you do remember..."
    W "Así que lo recuerdas..."

# game/scripts/day7.rpy:443
translate spanish d7a_ab081859:

    # Z "Come here."
    Z "Ven aquí."

# game/scripts/day7.rpy:446
translate spanish d7a_0ec70b3e:

    # Z "You look stunning; and it still fits you perfectly, even after all these years."
    Z "Te ves impresionante; y aún te queda perfecto, incluso después de todos estos años."

# game/scripts/day7.rpy:449
translate spanish d7a_7d473aeb:

    # W "When this is all over, and [S] is safely back home..."
    W "Cuando todo esto termine, y [S] esté a salvo en casa..."

# game/scripts/day7.rpy:452
translate spanish d7a_bb1e2231:

    # W "...you and I are going to have a little celebration of our own."
    W "... tú y yo vamos a tener una pequeña celebración propia."

# game/scripts/day7.rpy:453
translate spanish d7a_db1b99cc:

    # Z "It's a date."
    Z "Es una cita."

# game/scripts/day7.rpy:454
translate spanish d7a_6d298b8c:

    # W "Is that what they're called? Why, I do have faint memories of..."
    W "¿Así es como se llama? Por qué, tengo recuerdos débiles de..."

# game/scripts/day7.rpy:457
translate spanish d7a_60365b64:

    # "{i}*kissing*"
    "{i}*beso*{/i}"

# game/scripts/day7.rpy:460
translate spanish d7a_c2c9cc07:

    # W "..."
    W "..."

# game/scripts/day7.rpy:463
translate spanish d7a_e27a2584:

    # Z "I love you."
    Z "Te quiero."

# game/scripts/day7.rpy:464
translate spanish d7a_c881533f:

    # W "I love you too."
    W "Yo también te quiero."

# game/scripts/day7.rpy:465
translate spanish d7a_88c2c94b:

    # W "Now go and take care of our Queen, husband."
    W "Ahora ve a cuidar de nuestra Reina, marido."

# game/scripts/day7.rpy:469
translate spanish d7a_f5208188:

    # "{i}You head out and make your way to the stadium."
    "{i}Sales y te diriges al estadio."

# game/scripts/day7.rpy:470
translate spanish d7a_097c1afc:

    # "{i}As you eventually arrive, the guard from yesterday is waiting for you as expected..."
    "{i}Cuando estás a punto de llegar, la guardia de ayer te está esperando como era de esperar..."

# game/scripts/day7.rpy:474
translate spanish d7a_bbdf5381:

    # G "You see that?"
    G "¿Lo ves?"

# game/scripts/day7.rpy:477
translate spanish d7a_81db3339:

    # Gx "Yeah... it's him."
    Gx "Sí... es él."

# game/scripts/day7.rpy:478
translate spanish d7a_4ab24897:

    # G "Stalker, over here!"
    G "Acechador, ¡por aquí!"

# game/scripts/day7.rpy:481
translate spanish d7a_79f13f9c:

    # G "Blessed Merneith, you took your time!"
    G "Bendita Merneith, ¡te has tomado tu tiempo!"

# game/scripts/day7.rpy:482
translate spanish d7a_df0b0eff:

    # Z "Yes I did. Where is everyone? Am I too late?"
    Z "Sí, así es. ¿Dónde están todos? ¿Llego demasiado tarde?"

# game/scripts/day7.rpy:485
translate spanish d7a_74137286:

    # G "Almost..."
    G "Casi..."

# game/scripts/day7.rpy:486
translate spanish d7a_8cead630:

    # G "The games are about to start."
    G "Los juegos están a punto de empezar."

# game/scripts/day7.rpy:487
translate spanish d7a_c76a3ece:

    # G "The Queen is expecting you, but not waiting for you."
    G "La Reina está esperando, pero no te espera a ti."

# game/scripts/day7.rpy:490
translate spanish d7a_b52c4dbe:

    # G "Although..."
    G "Aunque..."

# game/scripts/day7.rpy:491
translate spanish d7a_ab32f053:

    # G "The adoring audience is probably keeping her entertained, and she them."
    G "El público que la adora probablemente la mantiene entretenida, y ella a ellos."

# game/scripts/day7.rpy:494
translate spanish d7a_cab1379e:

    # Gx "Do you want to escort him, or should I?"
    Gx "¿Quieres acompañarle, o debo hacerlo yo?"

# game/scripts/day7.rpy:498
translate spanish temp_d7a_1e8c2257:

    # G "I will. Call Maibe to cover for me."
    G "Lo haré. Llama a Maibe para que me cubra."

# game/scripts/day7.rpy:499
translate spanish temp_d7a_7a0550c6:

