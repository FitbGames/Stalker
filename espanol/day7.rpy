    # Z "..."
    Z "..."

# game/scripts/day7.rpy:755
translate spanish d7a115_5bd75eac:

    # Q "You see, during the games, it is customary for one of my slaves to take care of my needs as I witness the fight."
    Q "Verás, durante los juegos, es costumbre que una de mis esclavas se ocupe de mis necesidades mientras presencio la lucha."

# game/scripts/day7.rpy:756
translate spanish d7a115_5bab3603:

    # Q "When we met last time, you showed you are definitely not afraid to touch things you shouldn't..."
    Q "Cuando nos vimos la última vez, demostraste que definitivamente no tienes miedo de tocar cosas que no debes..."

# game/scripts/day7.rpy:757
translate spanish d7a115_e9133e0e:

    # Q "...and since my servants seem to have deserted their post..."
    Q "... y como mis sirvientes parecen haber abandonado su puesto..."

