    # Rai "MY AAAARMSSS!!!"
    Rai "¡¡¡MIS BRAZOOOOS!!!"

# game/scripts/day7.rpy:800
translate spanish d7a115_5137559e_1:

    # Rai "AAAHAHAHAHAAAA!"
    Rai "¡AAAAAAAAHHHHH!"

# game/scripts/day7.rpy:803
translate spanish d7a115_32a3afde:

    # Z "You don't seem pleased..."
    Z "No pareces contenta..."

# game/scripts/day7.rpy:806
translate spanish d7a115_b917e28e_1:

    # Q "He was captured after his little tribal village rebelled against my troops."
    Q "Fue capturado después de que su pequeña aldea tribal se rebelara contra mis tropas."

# game/scripts/day7.rpy:807
translate spanish d7a115_7e7aa631:

    # Q "Since then he has been seeking ways to obtain revenge against me, so they say."
    Q "Desde entonces él busca la forma de vengarse de mí, según dicen."

# game/scripts/day7.rpy:808
translate spanish d7a115_cb6a89b3:

    # Q "I would execute him... but that would cause too much upset."
    Q "Le ejecutaría... pero eso causaría demasiados disgustos."

# game/scripts/day7.rpy:809
translate spanish d7a115_ff7e2e11:

    # Q "He is strong, unreasonably aggressive and inconsiderate..."
    Q "Es fuerte, irracionalmente agresivo y desconsiderado..."

# game/scripts/day7.rpy:812
translate spanish d7a115_831baf5a:

    # Q "I appreciate strength, but it must be more measured... and focused..."
    Q "Aprecio la fuerza, pero debe ser más comedida... y enfocada..."

# game/scripts/day7.rpy:816
translate spanish d7a115_7e7b8a72_1:

    # Rai "Haaaaagh-"
    Rai "Aaaaaagh..."

# game/scripts/day7.rpy:817
translate spanish d7a115_76d630b8_2:

    # Bru "You die now."
    Bru "Muérete ya."

# game/scripts/day7.rpy:818
translate spanish d7a115_d3b0cdca_2:

    # Rai "{i}*wails with pain*"
    Rai "{i}*lamentos de dolor*"

# game/scripts/day7.rpy:821
translate spanish d7a115_f3a75670:

    # Zw "Control does not always come easy, when you're being provoked like this."
    Zw "El control no siempre es fácil, cuando te provocan así."

# game/scripts/day7.rpy:822
translate spanish d7a115_1b1941a0:

    # Qw "Knowing your life is at stake, can you find the balance between your urges and your survival instinct?"
    Qw "Sabiendo que tu vida está en juego, ¿puedes encontrar el equilibrio entre tus impulsos y tu instinto de supervivencia?"

# game/scripts/day7.rpy:825
translate spanish d7a115_d501bc84:

    # Qw "It must be so difficult... to resist..."
    Qw "Debe ser tan difícil... resistirse..."

# game/scripts/day7.rpy:826
translate spanish d7a115_207c7835:

    # Qw "...but you have to."
    Qw "... pero tienes que hacerlo."

# game/scripts/day7.rpy:829
translate spanish d7a115_934b4c95:

    # Zw "...for now."
    Zw "... por ahora."

# game/scripts/day7.rpy:832
translate spanish d7a115_2cd269e0_1:

    # Bru "ARE YOU NOT ENTERTAINED?!"
    Bru "¡¿¿NO TE ENTRETIENES??!"

# game/scripts/day7.rpy:834
translate spanish d7a115_3eb4a043_1:

    # "{i}*Applause*"
    "{i}*Aplausos*"

# game/scripts/day7.rpy:837
translate spanish d7a115_30bf0194:

    # Q "That will be enough; you can stop."
    Q "Esto es suficiente; puedes parar."

# game/scripts/day7.rpy:838
translate spanish d7a115_eb537862:

    # Q "[persistent.player_name!c], let us leave, we have other matters to attend."
    Q "[persistent.player_name!c], vámonos, tenemos otros asuntos que atender."

# game/scripts/day7.rpy:845
translate spanish d7aseperate_d9ec634c:

    # "You are led outside and follow the Queen back to her palace."
    "Te conducen fuera y sigues a la Reina de vuelta a su palacio."

# game/scripts/day7.rpy:846
translate spanish d7aseperate_806ab2f3:

    # "On your way, she signals you to follow her guards."
    "En tu camino, te indica que sigas a sus guardias."

# game/scripts/day7.rpy:848
translate spanish d7aseperate_04c52dff:

    # "Unexpectedly, the guards lead you to the royal thermae near the palace."
    "Inesperadamente, los guardias te conducen a las termas reales cercanas al palacio."

# game/scripts/day7.rpy:849
translate spanish d7aseperate_6478477e:

    # "Eventually, you find yourself relaxing in luxurious pool."
    "Con el tiempo, te encuentras relajado en una lujosa piscina."

# game/scripts/day7.rpy:852
translate spanish d7aseperate_6e8ed612:

    # "You follow her back to her private quarters."
    "La sigues hasta sus habitaciones privadas."

# game/scripts/day7.rpy:853
translate spanish d7aseperate_e8468554:

    # "Escorted by several guards, she leads the way..."
    "Escoltada por varios guardias, ella lidera el camino..."

# game/scripts/day7.rpy:865
translate spanish d7a141_9a4c6b4e:

    # Zt "So these are the famous royal thermae..."
    Zt "Así que estas son las famosas termas reales..."

# game/scripts/day7.rpy:868
translate spanish d7a141_8eebb57b:

    # Zt "Not bad..."
    Zt "No está mal..."

# game/scripts/day7.rpy:871
translate spanish d7a141_d755b349:

    # Zt "Not bad at all."
    Zt "No está mal del todo."

# game/scripts/day7.rpy:872
translate spanish d7a141_b89b835b:

    # Sl "This way, my Queen."
    Sl "Por aquí, mi Reina."

# game/scripts/day7.rpy:876
translate spanish re_d7a141_e3332669:

    # Q "There you are..."
    Q "Ahí estás..."

# game/scripts/day7.rpy:877
translate spanish re_d7a141_db70bd52:

    # Q "I hope you have made yourself comfortable, [persistent.player_name]."
    Q "Espero que te hayas puesto cómodo, [persistent.player_name]."

# game/scripts/day7.rpy:880
translate spanish re_d7a141_76a9cb38:

    # Q "Take my towel, slave."
    Q "Toma mi toalla, esclava."

# game/scripts/day7.rpy:881
translate spanish re_d7a141_4af6fd1c:

    # Sl "Of course, my Queen."
    Sl "Por supuesto, mi Reina."

# game/scripts/day7.rpy:884
translate spanish re_d7a141_90c45ae6:

    # Q "Do you remember that I promised you a day in the thermae?"
    Q "¿Recuerdas que te prometí un día en las termas?"

# game/scripts/day7.rpy:885
translate spanish re_d7a141_995a94ed:

    # Q "I thought that discussing my request would be more enjoyable in this setting."
    Q "Pensé que discutir mi petición sería más agradable en este entorno."

# game/scripts/day7.rpy:886
translate spanish re_d7a141_9ba9f28e:

    # Z "I can't wait to hear what this is about."
    Z "No puedo esperar a saber de qué se trata."

# game/scripts/day7.rpy:887
translate spanish re_d7a141_add3bc81:

    # Q "In a while..."
    Q "Dentro de un rato..."

# game/scripts/day7.rpy:890
translate spanish re_d7a141_498b5be8:

    # Q "Lend me your hand."
    Q "Échame una mano."

# game/scripts/day7.rpy:893
translate spanish re_d7a141_69bc1e13:

    # Q "You may join me, slave."
    Q "Puedes unirte a mí, esclava."

# game/scripts/day7.rpy:896
translate spanish re_d7a141_a198efba:

    # Zt "She definitely enjoys all the attention she gets."
    Zt "Definitivamente ella disfruta de toda la atención que recibe."

# game/scripts/day7.rpy:897
translate spanish re_d7a141_f4a1d20a:

    # Zt "But all of this comes at a cost."
    Zt "Pero todo esto tiene un coste."

# game/scripts/day7.rpy:900
translate spanish re_d7a141_a5231e21:

    # Zt "Despite our sexually liberated culture, the Queen is held to a different standard."
    Zt "A pesar de nuestra cultura sexualmente liberada, la Reina se rige por una norma diferente."

# game/scripts/day7.rpy:903
translate spanish re_d7a141_874f085f:

    # Zt "It must be hard to always exert control over one's urges..."
    Zt "Debe ser difícil ejercer siempre el control sobre los propios impulsos..."

# game/scripts/day7.rpy:906
translate spanish re_d7a141_8483910d:

    # Zt "...especially with a body and a temperament like that."
    Zt "... sobre todo con un cuerpo y un temperamento así."

# game/scripts/day7.rpy:910
translate spanish re_d7a141_e77467e9:

    # Q "So... about why you are here..."
    Q "Entonces... sobre por qué estás aquí..."

# game/scripts/day7.rpy:913
translate spanish re_d7a141_5d286f23:

    # Q "To make it simple, one of my most valued scouts was exploring some ruins not long ago, when the zone engulfed those buildings."
    Q "Para simplificar, uno de mis exploradores más valiosos estaba explorando unas ruinas no hace mucho, cuando la zona engulló esos edificioss."

# game/scripts/day7.rpy:914
translate spanish re_d7a141_438b66d7:

    # Q "My request is for [S] to keep an eye out for him. He is a valued man, knowledgeable in many fields."
    Q "Mi petición es que [S] esté pendiente de él. Es un hombre valioso, conocedor de muchos campos."

# game/scripts/day7.rpy:915
translate spanish re_d7a141_1f83d304:

    # Q "I would have him returned to me, preferably alive, if possible."
    Q "Me gustaría que me lo devolvieran, preferiblemente vivo, si es posible."

# game/scripts/day7.rpy:916
translate spanish re_d7a141_fa4026b5:

    # Q "The reason why I am asking {i}you{/i} this, and not your [persistent.da] is because you are still her mentor."
    Q "La razón por la que te pido esto a {i}tí{/i} y no a tu [persistent.da] es porque todavía eres su mentor."

# game/scripts/day7.rpy:917
translate spanish re_d7a141_71be2363:

    # Q "...and her [persistent.dad]. So I felt it was appropriate to talk to you instead."
    Q "... y su [persistent.dad]. Así que me pareció apropiado hablar contigo en su lugar."

# game/scripts/day7.rpy:923
translate spanish re_d7a141_8705df99:

    # Q "I know that a Zone is almost a holy place for you Stalkers, but I believe taking care of my request should not hinder her main objectives."
    Q "Sé que la Zona es casi un lugar sagrado para vosotros, los Acechadores, pero creo que atender mi petición no debe obstaculizar sus objetivos principales."

# game/scripts/day7.rpy:924
translate spanish re_d7a141_dcf56dc3:

    # C "My Queen... we are here as requested."
    C "Mi Reina... estamos aquí como se nos pidió."

# game/scripts/day7.rpy:927
translate spanish re_d7a141_24935444:

    # Q "There you are... took you long enough."
    Q "Ahí estáis... habéis tardado bastante."

# game/scripts/day7.rpy:930
translate spanish re_d7a141_784b6c08:

    # Q "I have many appetites, Stalker, but I am not ungracious and do know how to treat my guests."
    Q "Tengo muchas apetencias, Acechador, pero no soy descortés y sé cómo tratar a mis invitados."

# game/scripts/day7.rpy:933
translate spanish re_d7a141_b9936db2:

    # Q "Pick one, [persistent.player_name], and truly be my guest."
    Q "Escoge una, [persistent.player_name], y sé realmente mi invitado."

# game/scripts/day7.rpy:934
translate spanish re_d7a141_8b2bc749:

    # Q "They're both excellent, trust me."
    Q "Las dos son excelentes, créeme."

# game/scripts/day7.rpy:941
translate spanish d7a164_e3590873:

    # Z "I choose the left one."
    Z "Elijo a la de la izquierda."

# game/scripts/day7.rpy:942
translate spanish d7a164_fbea416a:

    # Q "You heard him."
    Q "Ya le has oído.."

# game/scripts/day7.rpy:945
translate spanish d7a164_6ebfe854:

    # "The slave undresses and comes over to you..."
    "La esclava se desnuda y se acerca a ti..."

# game/scripts/day7.rpy:948
translate spanish d7a164_b411e03a:

    # Sl "Master, can I join you?"
    Sl "Amo, ¿puedo unirme a ti?"

# game/scripts/day7.rpy:951
translate spanish d7a164_c5c317ee:

    # Z "You certainly can."
    Z "Sin duda, puedes."

# game/scripts/day7.rpy:954
translate spanish d7a164_84b033e1:

    # Q "I hope you enjoy her company."
    Q "Espero que disfrutes de su compañía."

# game/scripts/day7.rpy:955
translate spanish d7a164_6f12c326:

    # Z "I already am."
    Z "Ya lo estoy haciendo."

# game/scripts/day7.rpy:958
translate spanish d7a164_abeb28cc:

    # Z "She is eager for sure."
    Z "Seguro que está ansiosa."

# game/scripts/day7.rpy:959
translate spanish d7a164_ca1d716f:

    # Q "Of course, only the best slaves serve at the palace."
    Q "Por supuesto, sólo las mejores esclavas sirven en el palacio."

# game/scripts/day7.rpy:962
translate spanish d7a164_e2591535:

    # "{i}*Kissing*"
    "{i}*beso*"

# game/scripts/day7.rpy:963
translate spanish d7a164_92d29227:

    # Q "Our renewed partnership will benefit us both, I'm sure."
    Q "Nuestra renovada asociación nos beneficiará a ambos, estoy segura."

# game/scripts/day7.rpy:964
translate spanish d7a164_66d3ccfa:

    # Q "And once your [persistent.da] returns with the person I am looking for, we shall celebrate it together."
    Q "Y una vez que tu [persistent.da] vuelva con la persona que busco, lo celebraremos juntos."

# game/scripts/day7.rpy:967
translate spanish d7a164_69cc69f0:

    # Z "I can agree to that. May my [persistent.da] be successful."
    Z "Estoy de acuerdo con eso. Que mi [persistent.da] tenga éxito."

# game/scripts/day7.rpy:970
translate spanish d7a164_5ffc2079:

    # Q "I like to hear that."
    Q "Me gusta oír eso."

# game/scripts/day7.rpy:971
translate spanish d7a164_73eb8d5b:

    # Q "And yes, may your [persistent.da] come home safe."
    Q "Y sí, que tu [persistent.da] vuelva a casa sana y salva."

# game/scripts/day7.rpy:972
translate spanish d7a164_c9d8d6c3:

    # Q "I'd like to see her again..."
    Q "Me gustaría volver a verla..."

# game/scripts/day7.rpy:975
translate spanish d7a164_4d4a5787:

    # Sl "Hn..."
    Sl "Hn..."

# game/scripts/day7.rpy:978
translate spanish d7a164_7d721ac5:

    # Sl "Ah... it's very..."
    Sl "Ah... es muy..."

# game/scripts/day7.rpy:981
translate spanish d7a164_fb9f8763:

    # Q "Why is she making these noises?!"
    Q "¿Por qué hace ella esos ruidos?"

# game/scripts/day7.rpy:982
translate spanish d7a164_fd98cb48:

    # Q "Stop acting up, slave."
    Q "Deja de comportarte mal, esclava."

# game/scripts/day7.rpy:985
translate spanish d7a164_16f79aba:

    # Sl "I... he's very big..."
    Sl "Yo... es muy grande..."

# game/scripts/day7.rpy:988
translate spanish d7a164_75583f57:

    # Q "Oh stop it, it can't be that difficult."
    Q "Venga, ya vale, no puede ser tan difícil."

# game/scripts/day7.rpy:991
translate spanish d7a164_e7bd2f6d:

    # Z "She seems to be very young and inexperienced"
    Z "Ella parece ser muy joven e inexperta"

# game/scripts/day7.rpy:992
translate spanish d7a164_34b49672:

    # Z "Let's allow her to take the time she needs."
    Z "Dejemos que se tome el tiempo que necesite."

# game/scripts/day7.rpy:995
translate spanish d7a164_f5e8d45e:

    # Z "I suppose you are more experienced, my Queen?"
    Z "Supongo que tienes más experiencia, mi Reina."

# game/scripts/day7.rpy:996
translate spanish d7a164_6d677073:

    # Q "You... you shouldn't ask me that."
    Q "Tú... No deberías preguntarme eso."

# game/scripts/day7.rpy:999
translate spanish d7a164_093ade04:

    # Sl "Haa..."
    Sl "Haa..."

# game/scripts/day7.rpy:1002
translate spanish d7a164_f617e54d:

    # Sl "Haah..."
    Sl "Aaah..."

# game/scripts/day7.rpy:1003
translate spanish d7a164_5a11e0ba:

    # Sl "Does that feel good, master?"
    Sl "¿Se siente bien, amo?"

# game/scripts/day7.rpy:1004
translate spanish d7a164_5a7d90c3:

    # Z "It does, you're doing great."
    Z "Así es, lo estás haciendo muy bien."

# game/scripts/day7.rpy:1008
translate spanish d7a164_4e56ade8:

    # Zt "There is no way she will take it all."
    Zt "No hay forma de que se la trague entera."

# game/scripts/day7.rpy:1009
translate spanish d7a164_27831ec3:

    # Zt "She is still trying though to please me and her Queen."
    Zt "Ella sin embargo, sigue intentando complacerme a mí y a su Reina."

# game/scripts/day7.rpy:1013
translate spanish d7a164_46f647b0:

    # Z "Keep going."
    Z "Sigue adelante."

# game/scripts/day7.rpy:1014
translate spanish d7a164_d7406f46:

    # Sl "Yes..."
    Sl "Sí..."

# game/scripts/day7.rpy:1016
translate spanish d7a164_5ab3574d:

    # Z "..."
    Z "..."

# game/scripts/day7.rpy:1019
translate spanish d7a164_a824e482:

    # Sl "Thank you, master."
    Sl "Gracias, amo."

# game/scripts/day7.rpy:1024
translate spanish d7a164_0362edb9:

    # Z "I choose the right one."
    Z "Elijo a la de la derecha."

# game/scripts/day7.rpy:1025
translate spanish d7a164_167acaae:

    # Q "You know what to do."
    Q "Ya sabes lo que tienes que hacer."

# game/scripts/day7.rpy:1028
translate spanish d7a164_6ebfe854_1:

    # "The slave undresses and comes over to you..."
    "La esclava se desnuda y se acerca a ti..."

# game/scripts/day7.rpy:1034
translate spanish d7a164_cfffd0ce:

    # Zt "Wow..."
    Zt "Guau..."

# game/scripts/day7.rpy:1037
translate spanish d7a164_ea0d6564:

    # Sl "I hope to please you well, Master."
    Sl "Espero complacerle bien, Amo."

# game/scripts/day7.rpy:1038
translate spanish d7a164_9dab1b10:

    # Z "I'm sure you will."
    Z "Estoy seguro de que lo harás."

# game/scripts/day7.rpy:1041
translate spanish d7a164_6d205dcf:

    # Zt "Her body feels very soft and alluring."
    Zt "Su cuerpo es muy suave y seductor."

# game/scripts/day7.rpy:1044
translate spanish d7a164_65dcc4f8:

    # Z "Your servants are very well groomed."
    Z "Tus sirvientas están muy bien preparadas."

# game/scripts/day7.rpy:1047
translate spanish d7a164_41bb067b:

    # Q "Of course. The palace provides for those who serve in it."
    Q "Por supuesto. El palacio mantiene a las que sirven en él."

# game/scripts/day7.rpy:1050
translate spanish d7a164_5d5266b8:

    # Q "After all, if a servant's purpose is to provide certain services, why not make sure they look the part? Unwinding after a busy day should be a pleasure."
    Q "Al fin y al cabo, si el propósito de una sirviente es prestar ciertos servicios, ¿por qué no asegurarse de que tiene el aspecto adecuado? Desenvolverse después de un día ajetreado debería ser un placer."

# game/scripts/day7.rpy:1051
translate spanish d7a164_95985087:

    # Q "I'm sure you can tell of similar experiences in your own harem."
    Q "Estoy segura de que puedes contar experiencias similares en tu propio harén."

# game/scripts/day7.rpy:1054
translate spanish d7a164_87d14719:

    # Z "Of course. The women of my House always take good care of me, as I take care of them."
    Z "Por supuesto. Las mujeres de mi Casa siempre me cuidan bien, como yo las cuido a ellas."

# game/scripts/day7.rpy:1057
translate spanish d7a164_34635726:

    # Sl "Hnn..."
    Sl "Hnn..."

# game/scripts/day7.rpy:1060
translate spanish d7a164_f75295b8:

    # Sl "Master, let me put it in..."
    Sl "Amo, déjame ponerlo dent..."

# game/scripts/day7.rpy:1063
translate spanish d7a164_7a9cf9aa:

    # Sl "Hn... thank... you."
    Sl "Ummn... gracias."

# game/scripts/day7.rpy:1064
translate spanish d7a164_dd5bf51c:

    # Sl "Do I please you enough, Master?"
    Sl "¿Te complazco lo suficiente, Amo?"

# game/scripts/day7.rpy:1065
translate spanish d7a164_d519d5b5:

    # Z "You do."
    Z "Lo haces."

# game/scripts/day7.rpy:1069
translate spanish d7a164_093ade04_1:

    # Sl "Haa..."
    Sl "Haa..."

# game/scripts/day7.rpy:1070
translate spanish d7a164_0e7e0954:

    # Zt "She clearly enjoys it, even if she does not know me."
    Zt "Está claro que lo disfruta, aunque no me conozca."

# game/scripts/day7.rpy:1071
translate spanish d7a164_3ea6f860:

    # Zt "I guess the Queen only chooses the most passionate servants for herself..."
    Zt "Supongo que la Reina sólo elige a las sirvientas más apasionadas para ella..."

# game/scripts/day7.rpy:1072
translate spanish d7a164_f6a3668b:

    # Q "Our renewed partnership will benefit us both, I'm very sure."
    Q "Nuestra renovada asociación nos beneficiará a ambos, estoy muy segura."

# game/scripts/day7.rpy:1073
translate spanish d7a164_66d3ccfa_1:

    # Q "And once your [persistent.da] returns with the person I am looking for, we shall celebrate it together."
    Q "Y una vez que tu [persistent.da] vuelva con la persona que busco, lo celebraremos juntos."

# game/scripts/day7.rpy:1076
translate spanish d7a164_69cc69f0_1:

    # Z "I can agree to that. May my [persistent.da] be successful."
    Z "Estoy de acuerdo con eso. Que mi [persistent.da] tenga éxito."

# game/scripts/day7.rpy:1079
translate spanish d7a164_5ffc2079_1:

    # Q "I like to hear that."
    Q "Me gusta oír eso."

# game/scripts/day7.rpy:1080
translate spanish d7a164_73eb8d5b_1:

    # Q "And yes, may your [persistent.da] come home safe."
    Q "Y sí, que tu [persistent.da] vuelva a casa sana y salva."

# game/scripts/day7.rpy:1081
translate spanish d7a164_c9d8d6c3_1:

    # Q "I'd like to see her again..."
    Q "Me gustaría volver a verla..."

# game/scripts/day7.rpy:1082
translate spanish d7a164_7b78abc3:

    # Sl "Master..."
    Sl "Amo..."

# game/scripts/day7.rpy:1085
translate spanish d7a164_61185060:

    # Sl "Please, release inside me."
    Sl "Por favor, córrete dentro de mí."

# game/scripts/day7.rpy:1086
translate spanish d7a164_7bd27fa7:

    # Sl "I would be honored to breed another baby for the orphanage..."
    Sl "Tendría el honor de criar otro bebé para el orfanato..."

# game/scripts/day7.rpy:1087
translate spanish d7a164_63a2c5a3:

    # Z "I can do that..."
    Z "Puedo hacerlo..."

# game/scripts/day7.rpy:1090
translate spanish d7a164_5ab3574d_1:

    # Z "..."
    Z "..."

# game/scripts/day7.rpy:1091
translate spanish d7a164_5dc27c0c:

    # Sl "Thank you so much, Master."
    Sl "Muchas gracias, Amo."

# game/scripts/day7.rpy:1096
translate spanish d7a164_001fa923:

    # Z "They're equally pretty. I take both."
    Z "Son igualmente bonitas. Me quedo con las dos."

# game/scripts/day7.rpy:1099
translate spanish d7a164_1efcb05d:

    # Q "I know that you're used to having this choice in your harem, but this is mine."
    Q "Sé que estás acostumbrado a tener esta opción en tu harén, pero esto es mío."

# game/scripts/day7.rpy:1100
translate spanish d7a164_b876cc09:

    # Q "I grant you one."
    Q "Te concedo una."

# game/scripts/day7.rpy:1103
translate spanish d7a164_30c9016a:

    # Q "The other one will serve me, later."
    Q "La otra me servirá a mí, más adelante."

# game/scripts/day7.rpy:1107
translate spanish d7a164_f5749f24:

    # Z "I'm not interested, thanks."
    Z "No me interesa, gracias."

# game/scripts/day7.rpy:1110
translate spanish d7a164_a04e1a6c:

    # Q "As you wish. I am keeping mine; I'm sure you won't mind."
    Q "Como quieras. Yo mantengo la mía; estoy segura de que no te importará."

# game/scripts/day7.rpy:1113
translate spanish d7a164_61499127:

    # Q "You may leave."
    Q "Podéis marcharos."

# game/scripts/day7.rpy:1114
translate spanish d7a164_ec9ea178:

    # Sl "Yes, my Queen."
    Sl "Sí, mi Reina."

# game/scripts/day7.rpy:1120
translate spanish d7a180_08f7395a:

    # Sl "{i}*kissing*"
    Sl "{i}*beso*{/i}"

# game/scripts/day7.rpy:1123
translate spanish d7a180_d9b00ae2:

    # Q "Say, [persistent.player_name]... I'm curious, have you and your [persistent.da] ever enjoyed each other's company?"
    Q "Dime, [persistent.player_name]... Tengo curiosidad, ¿tú y tu [persistent.da] habéis disfrutado alguna vez de la compañía del otro?"

# game/scripts/day7.rpy:1124
translate spanish d7a180_8ab6abb3:

    # Sl "My Queen, do you want me to..."
    Sl "Mi Reina, ¿quieres que..."

# game/scripts/day7.rpy:1127
translate spanish d7a180_1f6cf3e9:

    # Z "We have not. Her training would have been undermined if I had made that sort of concessions to our baser instincts."
    Z "No, no lo hemos hecho. Su formación se habría visto perjudicada si hubiera hecho ese tipo de concesiones a nuestros bajos instintos."

# game/scripts/day7.rpy:1130
translate spanish d7a180_be1138b4:

    # Q "I see... it is... unfortunate..."
    Q "Ya veo... es... una pena..."

# game/scripts/day7.rpy:1133
translate spanish d7a180_de390625:

    # Qw "Don't... not in front of the guest..."
    Qw "No... no delante del invitado..."

# game/scripts/day7.rpy:1134
translate spanish d7a180_e2869da2:

    # Slw "But my Queen..."
    Slw "Pero mi Reina..."

# game/scripts/day7.rpy:1137
translate spanish d7a180_29b67e92:

    # Qw "I said no!"
    Qw "¡He dicho que no!"

# game/scripts/day7.rpy:1149
translate spanish d7aending_3488f4b2:

    # Z "I thank you for your hospitality, but I should head home now."
    Z "Te agradezco tu hospitalidad, pero ahora debo irme a casa."

# game/scripts/day7.rpy:1150
translate spanish d7aending_a5d76c70:

    # Z "There are still things that need doing, and I am sure [S] can use my help."
    Z "Todavía hay cosas que hay que hacer, y estoy seguro de que a [S] le vendrá bien mi ayuda."

# game/scripts/day7.rpy:1153
translate spanish d7aending_467bb784:

    # Q "You're leaving so soon? I see..."
    Q "¿Te vas tan pronto? Ya veo..."

# game/scripts/day7.rpy:1156
translate spanish d7aending_9c899221:

    # Sl "My Queen, may I direct him to the exit?"
    Sl "Mi Reina, ¿me permite guiarlo hacia la salida?"

# game/scripts/day7.rpy:1157
translate spanish d7aending_a9ff80ad:

    # Z "I don't think the Queen would have anything against it, am I right?"
    Z "No creo que la Reina tenga algo en contra, ¿me equivoco?"

# game/scripts/day7.rpy:1160
translate spanish d7aending_be589fca:

    # Q "I guess not..."
    Q "Supongo que no..."

# game/scripts/day7.rpy:1169
translate spanish d7aending_049b36f0:

    # Q "Good luck to your [persistent.da], [persistent.player_name]."
    Q "Buena suerte a tu [persistent.da], [persistent.player_name]."

# game/scripts/day7.rpy:1170
translate spanish d7aending_da3605d8:

    # Q "May she come back safe..."
    Q "Que vuelva a salvo..."

# game/scripts/day7.rpy:1171
translate spanish d7aending_60825476:

    # Sl "My Queen, our guest is gone, should I now...-"
    Sl "Mi Reina, nuestro invitado se ha ido, ¿debo ahora...?"

# game/scripts/day7.rpy:1172
translate spanish d7aending_6d694e82:

    # Q "No... I am no longer in the mood."
    Q "No... Ya no estoy de humor."

# game/scripts/day7.rpy:1176
translate spanish d7aending_b61cc1a0:

    # "You head back home..."
    "Vuelves a casa..."

# game/scripts/day7.rpy:1186
translate spanish d7a201x_bdc61a01:

    # Q "..."
    Q "..."

# game/scripts/day7.rpy:1189
translate spanish d7a201x_c8f86fbc:

    # Q "We have arrived."
    Q "Hemos llegado."

# game/scripts/day7.rpy:1190
translate spanish d7a201x_00f7e049:

    # Q "But before we head inside..."
    Q "Pero antes de entrar..."

# game/scripts/day7.rpy:1193
translate spanish d7a201x_72dd764a:

    # Q "The reason why I called you is because I need your daughter to find a scout of mine, who was exploring some buildings for me when they were engulfed in the Zone."
    Q "La razón por la que te he llamado es porque necesito que tu hija encuentre a un explorador mío, que estaba explorando unos edificios para mí cuando fueron engullidos en la Zona."

# game/scripts/day7.rpy:1194
translate spanish d7a201x_364c8ebc:

    # Q "He is a valued member of my entourage, a knowledgeable individual, and I would have him returned to me, preferably alive."
    Q "Es un miembro valioso de mi séquito, un individuo con conocimientos, y quiero que me lo devuelvan, preferiblemente vivo."

# game/scripts/day7.rpy:1195
translate spanish d7a201x_a8f64673:

    # Z "Why didn't you ask her yourself. She was with you when the Zone spawned."
    Z "¿Por qué no le pediste tú misma? Ella estaba contigo cuando surgió la Zona.."

# game/scripts/day7.rpy:1201
translate spanish d7a201x_3dfdf69b:

    # Q "Who do you take me for?! I may be young, but I have been schooled in the traditions of Zeta."
    Q "¿Por quién me tomas? Puede que sea joven, pero he sido educada en las tradiciones de Zeta."

# game/scripts/day7.rpy:1204
translate spanish d7a201x_7ad16ea4:

    # Q "I know that a Zone is some sort of holy place for you Stalkers, and that she is still your trainee."
    Q "Sé que una Zona es una especie de lugar sagrado para vosotros, los Acechadores, y que ella sigue siendo tu aprendiz."

# game/scripts/day7.rpy:1205
translate spanish d7a201x_b7adfd2f:

    # Q "Sending her on a mission without your approval would set a bad precedent."
    Q "Enviarla a una misión sin tu aprobación sentaría un mal precedente."

# game/scripts/day7.rpy:1208
translate spanish d7a201x_e6a6bb0d:

    # Z "Yet you think forcing me to be your public servant in the arena is way to earn my respect?!"
    Z "¿Y crees que obligarme a ser tu servidor público en la arena es la forma de ganarte mi respeto?"

# game/scripts/day7.rpy:1211
translate spanish d7a201x_15d7a934:

    # Q "There was no way I could have let your last outburst slide, it is not in my nature, and that too, would give the wrong idea."
    Q "No podía dejar pasar tu último arrebato, no está en mi naturaleza, y eso también daría una idea equivocada."

# game/scripts/day7.rpy:1214
translate spanish d7a201x_f8e00b90:

    # Q "Also... I must admit I like seeing you angry."
    Q "Además... Debo admitir que me gusta verte enfadado."

# game/scripts/day7.rpy:1215
translate spanish d7a201x_5ab3574d:

    # Z "..."
    Z "..."

# game/scripts/day7.rpy:1216
translate spanish d7a201x_652a9fda:

    # Zt "At least she's honest."
    Zt "Al menos es honesta."

# game/scripts/day7.rpy:1219
translate spanish d7a201x_b5d3a969:

    # Q "You're probably wondering about what you get out of helping me."
    Q "Seguramente te estarás preguntando qué ganas con ayudarme."

# game/scripts/day7.rpy:1220
translate spanish d7a201x_84f1c9e7:

    # Q "I know I promised you a day in the thermae before you decided to lose yourself, and I may still give you that opportunity after said mission."
    Q "Sé que te prometí un día en las termas antes de que decidieras perderte, y puede que aún te dé esa oportunidad después de dicha misión."

# game/scripts/day7.rpy:1223
translate spanish d7a201x_72b80aaa:

    # Q "Maybe I can arrange a little celebration once [S] returns. I want to see her again."
    Q "Tal vez pueda organizar una pequeña celebración cuando [S] regrese. Quiero volver a verla."

# game/scripts/day7.rpy:1226
translate spanish d7a201x_45b581b3:

    # Q "For now, I have something else for you, a reward of sorts, and a little task at the same time."
    Q "Por ahora, tengo algo más para ti, una especie de recompensa y una pequeña tarea al mismo tiempo."

# game/scripts/day7.rpy:1227
translate spanish d7a201x_7773283b:

    # Q "Follow me."
    Q "Sígueme."

# game/scripts/day7.rpy:1230
translate spanish d7a201x_19b34565:

    # Q "Guards, you may leave us. Wait outside."
    Q "Guardias, podéis dejarnos. Esperad fuera."

# game/scripts/day7.rpy:1233
translate spanish d7a201x_5ab3574d_1:

    # Z "..."
    Z "..."

# game/scripts/day7.rpy:1234
translate spanish d7a201x_b8258aea:

    # Z "The prison...?"
    Z "¿La prisión...?"

# game/scripts/day7.rpy:1237
translate spanish d7a201x_96727b86:

    # Q "Yep. Let me show you why."
    Q "Sí. Deja que te enseñe por qué."

# game/scripts/day7.rpy:1241
translate spanish d7a201x_b6529123:

    # Q "[S] has probably informed you that I took care of the boy who wanted to kidnap your [persistent.da]."
    Q "[S] te habrá informado de que me he encargado del chico que quería secuestrar a tu [persistent.da]."

# game/scripts/day7.rpy:1244
translate spanish d7a201x_d25d4662:

    # Q "She was gracious enough to not kill his partner in crime."
    Q "Ella tuvo la gentileza de no matar a su socio en el crimen."

# game/scripts/day7.rpy:1245
translate spanish d7a201x_71f8d7d2:

    # Q "If you were wondering what happened to her, she just decided to become a public servant to shorten her jail time..."
    Q "Si te preguntabas qué pasó con ella, simplemente decidió convertirse en una servidora pública para acortar su tiempo en la cárcel..."

# game/scripts/day7.rpy:1248
translate spanish d7a201x_2184aade:

    # Q "To the point, she will start serving the public in a few days to make up for her wrongdoings..."
    Q "Al grano, ella empezará a atender al público en unos días para compensar sus malas acciones..."

# game/scripts/day7.rpy:1249
translate spanish d7a201x_3c9c0dab:

    # Q "Should you decide to enjoy her services yourself, I will have someone inform you where to find her."
    Q "Si decides disfrutar tú mismo de sus servicios, haré que alguien te informe de dónde encontrarla."

# game/scripts/day7.rpy:1252
translate spanish d7a201x_0936ac65:

    # Tg "{i}*sighs*"
    Tg "{i}*suspiros*"

# game/scripts/day7.rpy:1253
translate spanish d7a201x_f0ba899b:

    # Q "But she is not why we are here today."
    Q "Pero ella no es la razón por la que estamos aquí hoy."

# game/scripts/day7.rpy:1256
translate spanish d7a201x_ae27ea5a:

    # Q "This one is the reason..."
    Q "Esta es la razón..."

# game/scripts/day7.rpy:1259
translate spanish d7a201x_dcb03651:

    # Q "Time to wake up! Your beloved Queen is here!"
    Q "¡Hora de despertar! ¡Tu amada Reina está aquí!"

# game/scripts/day7.rpy:1262
translate spanish d7a201x_114cc763:

    # Q "I hope you're feeling comfortable."
    Q "Espero que te sientas cómoda."

# game/scripts/day7.rpy:1265
translate spanish d7a201x_b3f1cde8:

    # Q "It's going to get much more cosy for you real soon."
    Q "Pronto será mucho más acogedor para ti."

# game/scripts/day7.rpy:1266
translate spanish d7a201x_40024258:

    # Z "Why is she here?"
    Z "¿Por qué está ella aquí?"

# game/scripts/day7.rpy:1269
translate spanish d7a201x_0438375b:

    # Q "She organized a protest during one of my speeches."
    Q "Organizó una protesta durante uno de mis discursos."

# game/scripts/day7.rpy:1270
translate spanish d7a201x_985cc3b6:

    # Q "She even went so far as to insult me in front of an audience."
    Q "Incluso llegó a insultarme delante del público."

# game/scripts/day7.rpy:1273
translate spanish d7a201x_af9585f2:

    # Q "That was her mistake; slandering the Queen in public is a punishable offense."
    Q "Ese fue su error; calumniar a la Reina en público es un delito punible."

# game/scripts/day7.rpy:1274
translate spanish d7a201x_0975c32b:

    # Q "I don't care about her little protest, but what she said that day was personal."
    Q "No me importa su pequeña protesta, pero lo que dijo ese día fue personal."

# game/scripts/day7.rpy:1275
translate spanish d7a201x_611c6739:

    # Zt "She interrupts my time to prepare [S] for her most important mission in her life because she has to deal with a random offender?!"
    Zt "¿Ella interrumpe mi tiempo de preparación de [S] para la misión más importante de su vida porque tiene que enfrentarse a una delincuente cualquiera?"

# game/scripts/day7.rpy:1278
translate spanish d7a201x_1b31c5db:

    # Q "Hey, I said wake up!"
    Q "Ey, ¡he dicho que te despiertes!"

# game/scripts/day7.rpy:1281
translate spanish d7a201x_33b586e1:

    # Q "There you are; have you missed me?!"
    Q "Ahí estás, ¿me has echado de menos?"

# game/scripts/day7.rpy:1282
translate spanish d7a201x_8e76b595:

    # Q "Remember what you said about me?"
    Q "¿Recuerdas lo que dijiste de mí?"

# game/scripts/day7.rpy:1283
translate spanish d7a201x_eeb24452:

    # Q "I figured I'd find someone to do exactly that to you!"
    Q "¡Me imaginé que encontraría a alguien que te hiciera exactamente eso!"

# game/scripts/day7.rpy:1286
translate spanish d7a201x_2b2174c5:

    # Pr "That's why you brought your big man over here?"
    Pr "¿Por eso trajiste a tu gran hombre aquí?"

# game/scripts/day7.rpy:1290
translate spanish re_d7a217_376eff37:

    # Pr "{i}You're kidding, right?"
    Pr "{i}Estás bromeando, ¿verdad?"

# game/scripts/day7.rpy:1293
translate spanish re_d7a217_24c4e2fd:

    # Pr "You can do what you want, but I won't take back what I said."
    Pr "Puedes hacerme lo que quieras, pero no me retractaré de lo que dije."

# game/scripts/day7.rpy:1296
translate spanish re_d7a217_a8ad3edb:

    # Pr "Zeta is run by a cruel and self-serving bitch."
    Pr "Zeta está dirigida por una zorra cruel e interesada."

# game/scripts/day7.rpy:1299
translate spanish re_d7a217_6d21d78a:

    # Q "{i}*sighs*"
    Q "{i}*suspiros*"

# game/scripts/day7.rpy:1302
translate spanish re_d7a217_a9cc3432:

    # Q "[persistent.player_name!c], you wanted a reward for your hard work in Old Cairo?"
    Q "[persistent.player_name!c], ¿querías una recompensa por tu duro trabajo en el Viejo Cairo?"

# game/scripts/day7.rpy:1303
translate spanish re_d7a217_54a69e65:

    # Q "Here it is..."
    Q "Aquí está..."

# game/scripts/day7.rpy:1306
translate spanish re_d7a217_1a972998:

    # Q "I know how strong your hands can be. Feel free to not hold back with her."
    Q "Sé lo fuertes que pueden ser tus manos. Siéntete libre de no contenerte con ella."

# game/scripts/day7.rpy:1307
translate spanish re_d7a217_c4b15e21:

    # Q "Someone needs a reminder on where they stand in the world."
    Q "Alguien necesita que la recuerden cuál es su posición en el mundo."

# game/scripts/day7.rpy:1310
translate spanish re_d7a217_8309c75d:

    # Z "I agree with that."
    Z "Estoy de acuerdo."

# game/scripts/day7.rpy:1315
translate spanish re_d7a217_3c8caeb1:

    # Pr "Holy shit..."
    Pr "Mierda puta..."

# game/scripts/day7.rpy:1318
translate spanish re_d7a217_40997a79:

    # Q "W-what are you doing!?"
    Q "¿¡Q-qué estás haciendo!?"

# game/scripts/day7.rpy:1319
translate spanish re_d7a217_649e8f17:

    # Z "You really can't help yourself, can you?"
    Z "Realmente no puedes evitarlo, ¿verdad?"

# game/scripts/day7.rpy:1322
translate spanish re_d7a217_b61ffee5:

    # Z "Wasting my time again and again, with trivial things you could demand off of any one of the guards."
    Z "Haciéndome perder el tiempo una y otra vez, con cosas triviales que podrías exigir a cualquiera de los guardias."

# game/scripts/day7.rpy:1325
translate spanish re_d7a217_e06552d1:

    # Q "But... I am... the Que-"
    Q "Pero... Yo soy... la Rei..."

# game/scripts/day7.rpy:1328
translate spanish re_d7a217_aba7a2ab:

    # Z "Enough of that; I know it is an act."
    Z "Basta de esto; sé que es una actuación."

# game/scripts/day7.rpy:1331
translate spanish re_d7a217_86c2160e:

    # Z "Is this really why you dragged me in here?"
    Z "¿Es esto realmente por lo que me has arrastrado hasta aquí?"

# game/scripts/day7.rpy:1332
translate spanish re_d7a217_34cfbe72:

    # Z "Because you need help with some lowly public offender?"
    Z "¿Porque necesitas ayuda con una delincuente pública de poca monta?"

# game/scripts/day7.rpy:1335
translate spanish re_d7a217_d55f6781:

    # Q "Why can't you just... behave like the rest..."
    Q "¿Por qué no puedes... comportarte como el resto..."

# game/scripts/day7.rpy:1338
translate spanish re_d7a217_196f9d47:

    # Z "Are you sure you want me to?"
    Z "¿Estás segura de que quieres que lo haga?"

# game/scripts/day7.rpy:1339
translate spanish re_d7a217_bdc61a01:

    # Q "..."
    Q "..."

# game/scripts/day7.rpy:1342
translate spanish re_d7a217_12349fb3:

    # Zw "I know why you really brought me here..."
    Zw "Sé por qué me has traído aquí..."

# game/scripts/day7.rpy:1345
translate spanish re_d7a217_c9ef3880:

    # Zw "...why you keep provoking me..."
    Zw "... por qué sigues provocándome..."

# game/scripts/day7.rpy:1348
translate spanish re_d7a217_4b896b26:

    # Zw "...and why you left the guards outside."
    Zw "... y por qué has dejado a los guardias fuera."

# game/scripts/day7.rpy:1352
translate spanish re_d7a217_23ce9cae:

    # Zw "You rarely meet people who stand up to you, people like this girl, or me..."
    Zw "Rara vez te encuentras con gente que se enfrente a ti, gente como esta chica, o como yo..."

# game/scripts/day7.rpy:1355
translate spanish re_d7a217_37911b7b:

    # Zw "...and you sense danger, which makes you curious."
    Zw "... y percibes el peligro, lo que te hace sentir curiosidad."

# game/scripts/day7.rpy:1358
translate spanish re_d7a217_ebda8734:

    # Qw "You can't just... nh..."
    Qw "No puedes... umm..."

# game/scripts/day7.rpy:1359
translate spanish re_d7a217_2633d9e7:

    # Zw "I can't what? Feel you up?"
    Zw "¿No puedo qué? ¿Sentirte bien?"

# game/scripts/day7.rpy:1362
translate spanish re_d7a217_3ef3651f:

    # Zw "I don't see what is stopping me."
    Zw "No veo qué me lo impide."

# game/scripts/day7.rpy:1363
translate spanish re_d7a217_0bf3fbb9:

    # Qw "No one... ever dared..."
    Qw "Nadie... nunca se atrevió..."

# game/scripts/day7.rpy:1366
translate spanish re_d7a217_bd37a699:

    # Zw "I have some advice for you."
    Zw "Tengo un consejo para ti."

# game/scripts/day7.rpy:1369
translate spanish re_d7a217_cdca7aaf:

    # Zw "If you really want this working relationship to function..."
    Zw "Si realmente quieres que esta relación de trabajo funcione..."

# game/scripts/day7.rpy:1372
translate spanish re_d7a217_9a3e837f:

    # Qw "Ah..."
    Qw "Ah..."

# game/scripts/day7.rpy:1375
translate spanish re_d7a217_aa5faea8:

    # Zw "Try showing some respect and learn to differentiate between your underlings."
    Zw "Intenta mostrar algo de respeto y aprende a diferenciar a tus subordinados."

# game/scripts/day7.rpy:1378
translate spanish re_d7a217_c4f407e6:

    # Zw "And not just in private."
    Zw "Y no sólo en privado."

# game/scripts/day7.rpy:1379
translate spanish re_d7a217_bdc61a01_1:

    # Q "..."
    Q "..."

# game/scripts/day7.rpy:1380
translate spanish re_d7a217_8429d3a6:

    # "You hear muffled voices from outside."
    "Oyes voces amoriguadas del exterior."

# game/scripts/day7.rpy:1381
translate spanish re_d7a217_a8a31cf1:

    # G "My Queen? Is everything alright?"
    G "¿Mi Reina? ¿Va todo bien?"

# game/scripts/day7.rpy:1385
translate spanish re_d7a217_bd37a699_1:

    # Zw "I have some advice for you."
    Zw "Tengo un consejo para ti."

# game/scripts/day7.rpy:1386
translate spanish re_d7a217_eeec5a17:

    # Zw "If you really want us to work together..."
    Zw "Si realmente quieres que trabajemos juntos..."

# game/scripts/day7.rpy:1389
translate spanish re_d7a217_7c162675:

    # Zw "Show some respect, and not just in private."
    Zw "Muestra algo de respeto, y no sólo en privado."

# game/scripts/day7.rpy:1390
translate spanish re_d7a217_bdc61a01_2:

    # Q "..."
    Q "..."

# game/scripts/day7.rpy:1391
translate spanish re_d7a217_8429d3a6_1:

    # "You hear muffled voices from outside."
    "Oyes voces amoriguadas del exterior."

# game/scripts/day7.rpy:1392
translate spanish re_d7a217_a8a31cf1_1:

    # G "My Queen? Is everything alright?"
    G "¿Mi Reina? ¿Va todo bien?"

# game/scripts/day7.rpy:1399
translate spanish d7a238_c2ab39f9:

    # "You let go of her..."
    "La sueltas..."

# game/scripts/day7.rpy:1403
translate spanish d7a238_d028d76d:

    # G "My Queen, it went really quiet in here, for a minute."
    G "Mi Reina, se ha hecho mucho silencio aquí, por un momento."

# game/scripts/day7.rpy:1406
translate spanish d7a238_78aba5c9:

    # G "Did something happen?"
    G "¿Pasó algo?"

# game/scripts/day7.rpy:1409
translate spanish d7a238_a5649404:

    # Q "Yes. I was... inconvenienced again."
    Q "Sí. He sido... incomodada de nuevo."

# game/scripts/day7.rpy:1412
translate spanish d7a238_bdc61a01:

    # Q "..."
    Q "..."

# game/scripts/day7.rpy:1415
translate spanish d7a238_1c60fded:

    # Q "But Stalker [persistent.player_name] stepped in to put an end to it..."
    Q "Pero el Acechador [persistent.player_name] intervino para ponerle fin..."

# game/scripts/day7.rpy:1418
translate spanish d7a238_c1a13a7a:

    # "You smile confidently at her..."
    "La sonríes con confianza..."

# game/scripts/day7.rpy:1419
translate spanish d7a238_36138320:

    # Pr "Wait what!? I didn't do anything?!"
    Pr "Espera, ¿qué? ¡¿Yo no he hecho nada?!"

# game/scripts/day7.rpy:1422
translate spanish d7a238_fbf6d5d8:

    # G "Quiet prisoner, or I'll rip out your tongue myself!"
    G "¡Cállate prisionera, o te arrancaré la lengua yo mismo!"

# game/scripts/day7.rpy:1425
translate spanish d7a238_ee5993bd:

    # G "What should we do with her, my Queen?"
    G "¿Qué debemos hacer con ella, mi Reina?"

# game/scripts/day7.rpy:1428
translate spanish d7a238_af4f226e:

    # Q "There is only one thing she deserves now."
    Q "Ahora sólo hay una cosa que se merece."

# game/scripts/day7.rpy:1431
translate spanish d7a238_37e6fc63:

    # Sh "I know exactly what you have in mind, my Queen..."
    Sh "Sé exactamente lo que tienes en mente, mi Reina..."

# game/scripts/day7.rpy:1434
translate spanish d7a238_d5ac0eda:

    # Q "Stalker [persistent.player_name] may stay, if he so desires."
    Q "El Acechador [persistent.player_name] puede quedarse, si así lo desea."

# game/scripts/day7.rpy:1437
translate spanish d7a238_03e9407b:

    # Q "Now, guard, as you see, I am perfectly safe. Go back to standing guard outside."
    Q "Ahora, guardia, como ves, estoy perfectamente a salvo. Vuelve a hacer guardia fuera."

# game/scripts/day7.rpy:1438
translate spanish d7a238_0b50c580:

    # G "Yes, my Queen."
    G "Sí, mi Reina."

# game/scripts/day7.rpy:1439
translate spanish d7a238_95fd0616:

    # Q "Sharifa, prepare the prisoner."
    Q "Sharifa, prepara a la prisionera."

# game/scripts/day7.rpy:1440
translate spanish d7a238_3eae2024:

    # Sh "With pleasure."
    Sh "Con mucho gusto."

# game/scripts/day7.rpy:1443
translate spanish d7a238_f82396e5:

    # "As the one guard leaves, the other drags the prisoner out of her cage and chains her up..."
    "Mientras un guardia se marcha, la otra saca a la prisionera de su jaula y la encadena..."

# game/scripts/day7.rpy:1446
translate spanish d7a238_10cadd73:

    # Q "Hmm, Sharifa..."
    Q "Umm, Sharifa..."

# game/scripts/day7.rpy:1449
translate spanish d7a238_81bbc2e6:

    # Q "I always valued your discipline."
    Q "Siempre valoré tu disciplina."

# game/scripts/day7.rpy:1450
translate spanish d7a238_636ca7e0:

    # Q "Bringing justice to these lands without a second thought on what must be done..."
    Q "Trayendo la justicia a estas tierras sin pensar en lo que hay que hacer..."

# game/scripts/day7.rpy:1451
translate spanish d7a238_d7920905:

    # Q "It has been a long time since we last had a private moment, hasn't it?"
    Q "Ha pasado mucho tiempo desde la última vez que tuvimos un momento de intimidad, ¿no es así?"

# game/scripts/day7.rpy:1454
translate spanish d7a238_ad407437:

    # Sh "I am at hand whenever you need me."
    Sh "Estoy a tu disposición siempre que me necesites."

# game/scripts/day7.rpy:1455
translate spanish d7a238_96cf6e58:

    # Q "Oh, I know that..."
    Q "Oh, ya sé que..."

# game/scripts/day7.rpy:1458
translate spanish d7a238_fd58934c:

    # Q "Say... have you had any issues lately?"
    Q "Di... ¿has tenido algún problema últimamente?"

# game/scripts/day7.rpy:1459
translate spanish d7a238_0f572d80:

    # Q "You seem more tense than usual."
    Q "Pareces más tensa que de costumbre."

# game/scripts/day7.rpy:1462
translate spanish d7a238_91f285a8:

    # Q "I can send some slaves to your house if you feel stressed..."
    Q "Puedo enviar algunos esclavos a tu casa si te sientes estresada..."

# game/scripts/day7.rpy:1463
translate spanish d7a238_a25967f9:

    # Sh "I thank you, but I would rather like to punish this prisoner for what she did to you."
    Sh "Te doy las gracias, pero preferiría castigar a esta prisionera por lo que te hizo."

# game/scripts/day7.rpy:1466
translate spanish d7a238_261e26ec:

    # "The Queen steps in front of the prisoner..."
    "La Reina se pone delante de la prisionera..."

# game/scripts/day7.rpy:1467
translate spanish d7a238_17af2442:

    # Pr "I didn't do shit, you're punishing the wrong person!"
    Pr "Yo no he hecho una mierda, ¡estás castigando a la persona equivocada!"

# game/scripts/day7.rpy:1468
translate spanish d7a238_7a7b77e0:

    # Pr "It was the Stalker who put her against the wall!"
    Pr "¡Fue el Acechador quien la puso contra la pared!"

# game/scripts/day7.rpy:1472
translate spanish d7a238_ed4d75af:

    # Pr "And you know what else he did?!"
    Pr "¡¿Y sabes qué más hizo?!"

# game/scripts/day7.rpy:1473
translate spanish d7a238_46cc26b1:

    # Pr "He actually went ahead and groped her tits!"
    Pr "¡El tío fue y le manoseó las tetas de golpe!"

# game/scripts/day7.rpy:1474
translate spanish d7a238_95f5eba6:

    # Pr "And by her reaction, I think she enjoyed it!"
    Pr "¡Y por cómo reaccionó, creo que le encantó!"

# game/scripts/day7.rpy:1477
translate spanish d7a238_8f131a2f:

    # Pr "Oh, my Queen, don't look at me like that."
    Pr "Oh, mi Reina, no me mires así."

# game/scripts/day7.rpy:1480
translate spanish d7a238_d4e847a4:

    # Pr "I thought you a prude and arrogant, but turns out it's all a farce."
    Pr "Creía que eras una mojigata y una arrogante, pero resulta que todo es una farsa."

# game/scripts/day7.rpy:1481
translate spanish d7a238_c2b033e2:

    # Pr "Seeing the Queen of Zeta getting all shy and put in her place was the hottest thing I've seen in my life..."
    Pr "Ver a la Reina de Zeta ponerse tímida y en su sitio ha sido lo más caliente que he visto en mi vida..."

# game/scripts/day7.rpy:1482
translate spanish d7a238_023b113b:

    # Pr "That would make a good story, in the taverns of Zeta."
    Pr "Eso sería una buena historia, en las posadas de Zeta."

# game/scripts/day7.rpy:1483
translate spanish d7a238_b800f5b0:

    # Pr "Hey Stalker, you should come here more often."
    Pr "Ey Acechador, deberías venir aquí más a menudo."

# game/scripts/day7.rpy:1484
translate spanish d7a238_85622a64:

    # Pr "I bet you're the kind of dick who enjoys beating arrogant stuck up people like her."
    Pr "Apuesto a que eres de esa clase de cabrones que disfrutan bajándole los humos a las estiradas arrogantes como ella."

# game/scripts/day7.rpy:1487
translate spanish d7a238_d8bb2a5f:

    # Sh "ENOUGH."
    Sh "BASTA."

# game/scripts/day7.rpy:1488
translate spanish d7a238_03e9942d:

    # Pr "Agh-"
    Pr "Agh-"

# game/scripts/day7.rpy:1489
translate spanish d7a238_dac96311:

    # Sh "Even Stalker [persistent.player_name] knows his limits, and you're talking heresy. You want me to believe that holy Merneith would allow that to happen?"
    Sh "Incluso el Acechador [persistent.player_name] conoce sus límites, y tú hablas de herejía. ¿Quieres que crea que la santa Merneith permitiría que eso ocurriera?"

# game/scripts/day7.rpy:1490
translate spanish d7a238_c0a65e29:

    # Sh "You're lying, insulting the sanctity of the throne, and you will be executed tomorrow."
    Sh "Estás mintiendo, insultando la santidad del trono, y serás ejecutada mañana."

# game/scripts/day7.rpy:1493
translate spanish d7a238_3df9c00d:

    # Q "I appreciate it, Sharifa."
    Q "Te lo agradezco, Sharifa."

# game/scripts/day7.rpy:1494
translate spanish d7a238_a1f8a012:

    # Q "But you don't run a city by killing off all dissidents."
    Q "Pero una no dirige una ciudad matando a todos los disidentes."

# game/scripts/day7.rpy:1497
translate spanish d7a238_17e097d7:

    # Q "No... there is another method to convince her of the error of her judgement..."
    Q "No... hay otro método para convencerla del error de su juicio..."

# game/scripts/day7.rpy:1498
translate spanish d7a238_167c1215:

    # Q "...and while it may not be as effective, it is certainly more fun to watch."
    Q "... y aunque no sea tan eficaz, sin duda será más divertido de ver."

# game/scripts/day7.rpy:1499
translate spanish d7a238_f62ebb05:

    # Pr "You really think punishing me will change me?"
    Pr "¿De verdad crees que castigarme me hará cambiar?"

# game/scripts/day7.rpy:1502
translate spanish d7a238_246f5b37:

    # Q "Maybe not by tonight..."
    Q "Tal vez no por esta noche..."

# game/scripts/day7.rpy:1503
translate spanish d7a238_7311a245:

    # Q "But you will stay here as long as it takes."
    Q "Pero tú te quedarás aquí el tiempo que haga falta."

# game/scripts/day7.rpy:1506
translate spanish d7a238_9d1ce4cd:

    # Sh "You saw what she did earlier and you heard about her protest."
    Sh "Viste lo que hizo antes y te enteraste de su protesta."

# game/scripts/day7.rpy:1507
translate spanish d7a238_31460665:

    # Sh "Do you want to take the lash to her, or shall I?"
    Sh "¿Quieres darla unos latigazos, o lo hago yo?"

# game/scripts/day7.rpy:1521
translate spanish d7apunishment_bcb99e3a:

    # Z "I will do it. Where do I find the tools?"
    Z "Yo lo haré. ¿Dónde encuentro las herramientas?"

# game/scripts/day7.rpy:1524
translate spanish d7apunishment_a2319c10:

    # "She points to a locker at the entrance. You take out a lash..."
    "Señala una taquilla en la entrada y tú sacas un látigo..."

# game/scripts/day7.rpy:1527
translate spanish d7apunishment_1fd845fd:

    # Sh "Don't hold back, Stalker."
    Sh "No te contengas, Acechador."

# game/scripts/day7.rpy:1530
translate spanish d7apunishment_6c3bcbdc:

    # Sh "The things she dared say before she got arrested..."
    Sh "Las cosas que se atrevió a decir antes de ser detenida..."

# game/scripts/day7.rpy:1531
translate spanish d7apunishment_5099ba40:

    # Sh "She deserves all of it."
    Sh "Se lo merece todo."

# game/scripts/day7.rpy:1541
translate spanish d7apunishment_651915fe:

    # Pr "Hrgh..."
    Pr "Hrgh..."

# game/scripts/day7.rpy:1545
translate spanish d7apunishment_03e9942d:

    # Pr "Agh-"
    Pr "Agh-"

# game/scripts/day7.rpy:1549
translate spanish d7apunishment_1b2471fb:

    # Pr "Haa..."
    Pr "Haa..."

# game/scripts/day7.rpy:1553
translate spanish d7apunishment_d134ad8a:

    # Q "Are you still so sure about what you saw earlier...?"
    Q "¿Sigues estando tan segura de lo que has visto antes...?"

# game/scripts/day7.rpy:1560
translate spanish d7apunishment_ac1c06c7:

    # Pr "Ngh..."
    Pr "Ngh..."

# game/scripts/day7.rpy:1563
translate spanish d7apunishment_4c9e8998:

    # Q "You are getting excited, aren't you..."
    Q "Te estás excitando, ¿verdad?"

# game/scripts/day7.rpy:1567
translate spanish d7apunishment_9775e6cf:

    # Q "What a filthy degenerate..."
    Q "Qué asquerosa degenerada..."

# game/scripts/day7.rpy:1570
translate spanish d7apunishment_78228670:

    # Prw "{i}*chuckles*{/i} Oh majesty..."
    Prw "{i}*risilla*{/i} Oh, majestad..."

# game/scripts/day7.rpy:1571
translate spanish d7apunishment_70577bea:

    # Prw "From what I have seen today, you are a lot less pure than you would like people to believe..."
    Prw "Por lo que he visto hoy, eres mucho menos pura de lo que te gustaría que la gente creyera..."

# game/scripts/day7.rpy:1572
translate spanish d7apunishment_18e4cb3d:

    # Prw "...and I will never forget that."
    Prw "... y nunca lo olvidaré."

# game/scripts/day7.rpy:1573
translate spanish d7apunishment_3ff51446:

    # Qw "..."
    Qw "..."

# game/scripts/day7.rpy:1580
translate spanish d7apunishment_aa249015:

    # Prw "Ahh..."
    Prw "Ahh..."

# game/scripts/day7.rpy:1581
translate spanish d7apunishment_5d12030e:

    # Prw "But... you win... I..."
    Prw "Pero... tú ganas... yo..."

# game/scripts/day7.rpy:1585
translate spanish d7apunishment_a97e1867:

    # Prw "...will not... spread rumors... I swear... Enough, please."
    Prw "... no...  difundiré rumores...  Lo juro...  Basta, por favor."

# game/scripts/day7.rpy:1586
translate spanish d7apunishment_1c7649df:

    # Qw "There you go."
    Qw "Ahí lo tienes."

# game/scripts/day7.rpy:1589
translate spanish d7apunishment_9728a34c:

    # Zt "She seems to have reached her limit."
    Zt "Parece que ella ha llegado a su límite."

# game/scripts/day7.rpy:1595
translate spanish d7a261_7bc06d90:

    # Zt "She's had enough."
    Zt "Ya ha tenido suficiente."

# game/scripts/day7.rpy:1598
translate spanish d7a261_f22a4306:

    # Sh "She swore to keep her mouth shut in the future."
    Sh "Juró mantener la boca cerrada en el futuro."

# game/scripts/day7.rpy:1599
translate spanish d7a261_9a1a9d33:

    # Sh "Well done, Stalker."
    Sh "Bien hecho, Acechador."

# game/scripts/day7.rpy:1602
translate spanish d7a261_50584929:

    # Q "Yes... I agree."
    Q "Sí... Estoy de acuerdo."

# game/scripts/day7.rpy:1605
translate spanish d7a261_aa140458:

    # Q "I knew you were the right person for the task."
    Q "Sabía que eras la persona adecuada para la tarea."

# game/scripts/day7.rpy:1606
translate spanish d7a261_052f280d:

    # Q "She will stay here for some time... her punishment is not over just."
    Q "Ella se quedará aquí durante algún tiempo... su castigo no ha terminado apenas."

# game/scripts/day7.rpy:1607
translate spanish d7a261_be3a28b3:

    # Z "If we're done here, I will head back home now."
    Z "Si hemos terminado aquí, me dirigiré a casa ahora."

# game/scripts/day7.rpy:1610
translate spanish d7a261_7ea41095:

    # Q "You can go. Don't forget to tell your [persistent.da] about my request."
    Q "Puedes irte. No te olvides de informar a tu [persistent.da] sobre mi petición."

# game/scripts/day7.rpy:1611
translate spanish d7a261_e5c826ea:

    # Q "Tell her the queen of Zeta wishes her a safe return."
    Q "Dile que la reina de Zeta le desea un buen regreso."

# game/scripts/day7.rpy:1612
translate spanish d7a261_2bdf145c:

    # Q "Until we meet again, [persistent.player_name]."
    Q "Hasta que nos volvamos a encontrar, [persistent.player_name]."

# game/scripts/day7.rpy:1615
translate spanish d7a261_7cf3a1ee:

    # Z "Until we meet again."
    Z "Hasta que nos volvamos a encontrar."

# game/scripts/day7.rpy:1622
translate spanish d7a261_439e8b96:

    # Zt "Nah..."
    Zt "Nah..."

# game/scripts/day7.rpy:1626
translate spanish d7a261_6ff79403:

    # Pr "Nhh..."
    Pr "Umm..."

# game/scripts/day7.rpy:1627
translate spanish d7a261_95e27604:

    # Q "Oh I'm so sorry..."
    Q "Oh, lo siento mucho..."

# game/scripts/day7.rpy:1631
translate spanish d7a261_679fd197:

    # Q "We are done, but it seems like he isn't."
    Q "Nosotros hemos terminado, pero parece que él no."

# game/scripts/day7.rpy:1638
translate spanish d7a261_4c2ef030:

    # Pr "..."
    Pr "..."

# game/scripts/day7.rpy:1645
translate spanish d7a261_3f390863:

    # Q "So pretty... but she's almost passed out."
    Q "Tan bonita... pero está casi desmayada."

# game/scripts/day7.rpy:1652
translate spanish d7a261_af11cd52:

    # Qw "She's so peaceful... when she's quiet."
    Qw "Es tan pacífica... cuando está tranquila."

# game/scripts/day7.rpy:1655
translate spanish d7a261_06cea501:

    # Sh "I think she has had enough; you're overdoing it."
    Sh "Creo que ya ha tenido suficiente; te estás pasando."

# game/scripts/day7.rpy:1656
translate spanish d7a261_082a5905:

    # Sh "We don't want her dead."
    Sh "No la queremos muerta."

# game/scripts/day7.rpy:1659
translate spanish d7a261_6949021b:

    # Sh "You did a good job. She swore to not run her mouth in the future."
    Sh "Has hecho un buen trabajo. Juró no abrir la boca en el futuro."

# game/scripts/day7.rpy:1660
translate spanish d7a261_f6c35e2d:

    # Zt "..."
    Zt "..."

# game/scripts/day7.rpy:1667
translate spanish d7a261_3c434f1f:

    # Z "Good. I need to head back home and finish the preparation."
    Z "Bien. Tengo que volver a casa y terminar la preparación."

# game/scripts/day7.rpy:1668
translate spanish d7a261_c446bbe4:

    # Sh "As you wish."
    Sh "Como desees."

# game/scripts/day7.rpy:1671
translate spanish d7a261_17b4a95e:

    # Q "Sharifa, unchain her and put her back in the cage."
    Q "Sharifa, desencadénala y vuelve a meterla en la jaula."

# game/scripts/day7.rpy:1672
translate spanish d7a261_a35fb109:

    # Q "I want you to test whether she'll be true to her word, before releasing her."
    Q "Quiero que pruebes si será fiel a su palabra, antes de liberarla."

# game/scripts/day7.rpy:1673
translate spanish d7a261_6e9bd7d7:

    # Sh "Of course, my Queen."
    Sh "Por supuesto, mi Reina."

# game/scripts/day7.rpy:1676
translate spanish d7a261_0b7f3756:

    # Q "I didn't expect her to give in so quickly."
    Q "No esperaba que se rindiera tan rápido."

# game/scripts/day7.rpy:1677
translate spanish d7a261_af639222:

    # Q "She will stay here for a while... I think only time will tell if the punishment needs to be repeated to ensure her compliance."
    Q "Se quedará aquí un tiempo... Creo que sólo el tiempo dirá si es necesario repetir el castigo para asegurar su cumplimiento."

# game/scripts/day7.rpy:1678
translate spanish d7a261_b2c7c604:

    # Z "If that is all..."
    Z "Si esto es todo..."

# game/scripts/day7.rpy:1681
translate spanish d7a261_91cfb566:

    # Q "Yes. Go home, Stalker."
    Q "Sí. Vete a casa, Acechador."

# game/scripts/day7.rpy:1682
translate spanish d7a261_30fe8bed:

    # Q "Don't forget to tell your [persistent.da] about my request."
    Q "No te olvides de informar a tu [persistent.da] de mi petición."

# game/scripts/day7.rpy:1683
translate spanish d7a261_e5c826ea_1:

    # Q "Tell her the queen of Zeta wishes her a safe return."
    Q "Dile que la reina de Zeta le desea un buen regreso."

# game/scripts/day7.rpy:1684
translate spanish d7a261_2bdf145c_1:

    # Q "Until we meet again, [persistent.player_name]."
    Q "Hasta que nos volvamos a encontrar, [persistent.player_name]."

# game/scripts/day7.rpy:1687
translate spanish d7a261_7cf3a1ee_1:

    # Z "Until we meet again."
    Z "Hasta que nos volvamos a encontrar."

# game/scripts/day7.rpy:1698
translate spanish d7a277_52ac7e15:

    # Zt "Fuck it. I have waited long enough."
    Zt "A la mierda. Ya he esperado bastante."

# game/scripts/day7.rpy:1701
translate spanish d7a277_768ab7a1:

    # Z "Sharifa, pull up the chains and free her legs."
    Z "Sharifa, levanta las cadenas y libera sus piernas."

# game/scripts/day7.rpy:1703
translate spanish d7a277_cf7fc56b:

    # Pr "What... are you..."
    Pr "Qué... estás..."

# game/scripts/day7.rpy:1706
translate spanish d7a277_ec5ac5ea:

    # Pr "Ngh..?!"
    Pr "¿Umm...?"

# game/scripts/day7.rpy:1708
translate spanish d7a277_6e14ebd4:

    # Sh "What is your plan?"
    Sh "¿Cuál es tu plan?"

# game/scripts/day7.rpy:1709
translate spanish d7a277_7cb11271:

    # Z "Do as you're told."
    Z "Haz lo que te dicen."

# game/scripts/day7.rpy:1712
translate spanish d7a277_5ab3574d:

    # Z "..."
    Z "..."

# game/scripts/day7.rpy:1715
translate spanish d7a277_1e15474b:

    # "You keep taking her roughly..."
    "Sigues tomándola bruscamente..."

# game/scripts/day7.rpy:1719
translate spanish d7a277_2fd05756:

    # Q "I am {i}so, so{/i} sorry what you're going through."
    Q "Siento {i}tanto, tanto{/i} por lo que estás pasando."

