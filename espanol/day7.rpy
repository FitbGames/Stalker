    Z "..."

# game/scripts/day7.rpy:777
translate spanish d7a115_968163d1:

    # Q "Why so quiet all of the sudden?"
    Q "¿Por qué tanto silencio de repente?"

# game/scripts/day7.rpy:778
translate spanish d7a115_00541e73:

    # Q "What a shame... you were so eager to voice your thoughts last time..."
    Q "Qué pena... estabas tan ansioso por expresar tus pensamientos la última vez..."

