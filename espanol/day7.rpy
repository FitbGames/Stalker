    # Q "May the strongest warrior win... {p=3.5} {nw}"
    Q "Que gane el guerrero más fuerte... {p=3.5} {nw}"

# game/scripts/day7.rpy:604
translate spanish temp_d7a_c77f65e6:

    # G "My Queen, as requested, Stalker [persistent.player_name] has arrived. {p=3.5} {nw}"
    G "Mi Reina, como se ha solicitado, ha llegado el acechador [persistent.player_name]. {p=3.5} {nw}"

# game/scripts/day7.rpy:607
translate spanish temp_d7a_f2e9338f:

    # Q "About time... not a fan of the opening parade, I guess? {p=3} {nw}"
    Q "Ya era hora... ¿No eres fan del desfile de apertura, supongo? {p=3} {nw}"

# game/scripts/day7.rpy:613
translate spanish temp_d7a_65594ca3:

    # Z "To what do I owe the privilege of being here today?"
    Z "¿A qué debo el privilegio de estar hoy aquí?"

# game/scripts/day7.rpy:616
translate spanish temp_d7a_de9e0190:

    # Q "You give proper acknowledgement to my benevolence. Good..."
    Q "Das el debido reconocimiento a mi benevolencia. Bien..."

# game/scripts/day7.rpy:617
translate spanish temp_d7a_9b1108eb:

    # Q "We will discuss the reason for this after the game."
    Q "Discutiremos la razón de esto después del juego."

# game/scripts/day7.rpy:620
translate spanish temp_d7a_e0916bdd:

    # Q "Step forward, let us watch the game together, shall we?"
    Q "Acércate, vamos a ver el juego juntos, ¿quieres?"

# game/scripts/day7.rpy:624
translate spanish temp_d7a_a0f178e6:

    # Z "As you know, my [persistent.da] is about to head to the Zone very soon."
    Z "Como sabes, mi [persistent.da] está a punto de dirigirse a la Zona muy pronto."

# game/scripts/day7.rpy:625
translate spanish temp_d7a_be003a3b:

    # Z "We were quite busy making preparations for that."
    Z "Estábamos muy ocupados haciendo los preparativos para ello."

# game/scripts/day7.rpy:628
translate spanish temp_d7a_a58b5d20:

    # Q "I indeed knew about it, and it is precisely the reason why I called you here today."
    Q "De hecho lo sabía, y es precisamente la razón por la que te he llamado hoy aquí."

# game/scripts/day7.rpy:629
translate spanish temp_d7a_38d131d9:

    # Q "But we shall discuss this matter when this fight is done."
    Q "Pero discutiremos ese asunto cuando termine este combate."

# game/scripts/day7.rpy:632
translate spanish temp_d7a_eda5ec00:

    # Q "Be my guest today, Stalker, let us watch the game together."
    Q "Hoy sé mi invitado, Acechador, veamos juntos el juego."

# game/scripts/day7.rpy:636
translate spanish temp_d7a_44b47984:

    # Z "You know I am preparing my [persistent.da] for the Zone."
    Z "Sabes que estoy preparando a mí [persistent.da] para la Zona."

# game/scripts/day7.rpy:637
translate spanish temp_d7a_19489273:

    # Z "Why did you call me today?"
    Z "¿Por qué me has llamado hoy?"

# game/scripts/day7.rpy:641
translate spanish temp_d7a_5f0ab668:

    # Q "So much for your offer to play nice..."
    Q "Hasta aquí tu propuesta de jugar limpio..."

# game/scripts/day7.rpy:642
translate spanish temp_d7a_8fec85b7:

    # Q "Connect the dots, Stalker [persistent.player_name], that is exactly the reason why you are here."
    Q "Ata los cabos, Acechador [persistent.player_name], ésa es exactamente la razón por la que estás aquí."

# game/scripts/day7.rpy:645
translate spanish temp_d7a_9c8815e1:

    # Q "But let us discuss this matter afterwards."
    Q "Pero discutamos ese asunto después."

# game/scripts/day7.rpy:646
translate spanish temp_d7a_bf5e3de9:

    # Q "We have a game to enjoy. Join me, will you."
    Q "Tenemos un juego para disfrutar. Acompáñame, ¿quieres?"

# game/scripts/day7.rpy:649
translate spanish temp_d7a_53f310b9:

    # Q "So much for your offer to cooperate..."
    Q "Hasta aquí tu oferta de colaboración..."

# game/scripts/day7.rpy:650
translate spanish temp_d7a_9107240c:

    # Q "Connect the dots, Stalker [persistent.player_name], this is exactly the reason why you are here."
    Q "Ata los cabos, Acechador [persistent.player_name], ésa es exactamente la razón por la que estás aquí."

# game/scripts/day7.rpy:653
translate spanish temp_d7a_ae561304:

    # Q "Let us discuss this matter afterwards."
    Q "Discutiremos ese asunto después."

# game/scripts/day7.rpy:654
translate spanish temp_d7a_0cf5fd35:

    # Q "We have a game to attend to. Join me, please."
    Q "Tenemos un juego que atender. Acompáñame, por favor."

# game/scripts/day7.rpy:659
translate spanish temp_d7a_700b5cc0:

    # Z "I didn't expect you to call me this soon again, after my last visit."
    Z "No esperaba que volvieras a llamarme tan pronto, después de mi última visita."

# game/scripts/day7.rpy:660
translate spanish temp_d7a_9526683f:

    # Z "Did you miss me, after all?!"
    Z "¡¿Me has echado de menos, después de todo?!"

# game/scripts/day7.rpy:663
translate spanish temp_d7a_6ae53725:

    # G "Watch your mouth Stalker; disrespecting the Queen like that!"
    G "¡Cuida esa boca, Acechador! ¡No le faltes el respeto a la Reina de esa manera!"

