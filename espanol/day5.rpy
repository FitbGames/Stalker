    # I "..."
    I "..."

# game/scripts/day5.rpy:6373
translate spanish d5b53_8ed045f0_1:

    # "{i}You hear a muffled voice from outside..."
    "{i}Oyes una voz amoriguada en el exterior..."

# game/scripts/day5.rpy:6374
translate spanish d5b53_2f0b250a_1:

    # Fa "What if he does something to her?! I told you to stand guard for fuck's sake!"
    Fa "¿Y si le hace algo?! ¡Te dije que vigilaras, maldita sea!"

# game/scripts/day5.rpy:6380
translate spanish d5b53_cf071040:

    # Fa "I knew it!"
    Fa "Lo sabía."

# game/scripts/day5.rpy:6383
translate spanish d5b53_12c28b37:

    # "Ivy quickly gets up and leaves..."
    "Ivy rápidamente se levanta y se va..."

# game/scripts/day5.rpy:6387
translate spanish d5b53_9de9d52c:

    # Fa "Trying to hook up with one of my sisters already, huh?!"
    Fa "¡¿Ya estás intentando tirarte a una de mis hermanas, eh?!"

# game/scripts/day5.rpy:6391
translate spanish d5b53_199326f3:

    # Fa "I think I forgot to tell you something..."
    Fa "Creo que he olvidado decirte algo..."

# game/scripts/day5.rpy:6395
translate spanish d5b53_6ee47e1a:

    # Fa "We skipped a part of the recruitment test..."
    Fa "Nos saltamos una parte de la prueba de reclutamiento..."

# game/scripts/day5.rpy:6398
translate spanish d5b53_ad7274c1:

    # Z "Recruitment test?!"
    Z "¡¿Prueba de reclutamiento?!"

# game/scripts/day5.rpy:6402
translate spanish d5b53_308893fd:

    # Fa "Absolutely."
    Fa "Por supuesto."

# game/scripts/day5.rpy:6405
translate spanish d5b53_fdbe71ae:

    # Z "Put the knife away."
    Z "Guarda el cuchillo."

# game/scripts/day5.rpy:6409
translate spanish d5b53_a9195c02:

    # Fa "Oh, I don't think so."
    Fa "Oh, no lo creo."

# game/scripts/day5.rpy:6412
translate spanish d5b53_5e472af6:

    # Z "Try me, crazy bitch."
    Z "Pruébame, perra loca."

# game/scripts/day5.rpy:6416
translate spanish d5b53_4dbb5ad3:

    # Fa "Oh I will..."
    Fa "Oh, lo haré..."

# game/scripts/day5.rpy:6420
translate spanish d5b53_50993a86:

    # Fa "I should warn you..."
    Fa "Debería advertirte..."

# game/scripts/day5.rpy:6421
translate spanish d5b53_b487527b:

    # Fa "Guys I don't like usually don't leave this place in one piece."
    Fa "Los tipos que no me gustan no suelen salir de este lugar de una pieza."

# game/scripts/day5.rpy:6422
translate spanish d5b53_5ab3574d_4:

    # Z "..."
    Z "..."

# game/scripts/day5.rpy:6434
translate spanish d5b_fangs_fight_p3_fed00193:

