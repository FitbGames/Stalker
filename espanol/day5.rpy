    Zt "Joder... eso fue un buen golpe."

# game/scripts/day5.rpy:6456
translate spanish d5b_fangs_fight_p3_cf5c09dc:

    # Fa "I like men who can put up a fight..."
    Fa "Me gustan los hombres que pueden dar pelea..."

# game/scripts/day5.rpy:6459
translate spanish d5b_fangs_fight_p3_3fee748a:

    # Fa "Unfortunately, you don't seem to be on my level."
    Fa "Por desgracia, no pareces estar a mi nivel."

# game/scripts/day5.rpy:6462
translate spanish d5b_fangs_fight_p3_de94ac2e:

    # Fa "Dodge this, Stalker!"
    Fa "¡Esquiva esto, Acechador!"

# game/scripts/day5.rpy:6466
translate spanish d5b_fangs_fight_p3_62367cbf:

    # Fa "Rahh!"
    Fa "¡Rahh!"

# game/scripts/day5.rpy:6467
translate spanish d5b_fangs_fight_p3_5ab3574d:

    # Z "..."
    Z "..."

