    Fa "¿Tienes miedo?"

# game/scripts/day5.rpy:6438
translate spanish d5b_fangs_fight_p3_19b701c1:

    # Z "I'm still not seeing that I should be."
    Z "Todavía no veo que deba hacerlo."

# game/scripts/day5.rpy:6443
translate spanish d5b_fangs_fight_p3_2eeb5089:

    # Fa "That's because you're not using your..."
    Fa "Eso es porque no estás usando tu..."

