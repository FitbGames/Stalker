translate spanish d5e_emilia_igor_83b7a7eb_1:

    # Ka "..."
    Ka "..."

# game/scripts/day5.rpy:5055
translate spanish d5e_emilia_igor_62e6a14d:

    # Ka "She looks very happy when she do this..."
    Ka "Ella parece muy feliz cuando hace eso..."

# game/scripts/day5.rpy:5056
translate spanish d5e_emilia_igor_ea68f4b2:

    # Z "I know... she is."
    Z "Lo sé... ella lo es."

# game/scripts/day5.rpy:5057
translate spanish d5e_emilia_igor_553352c8:

    # W "[E], take it deeper."
    W "[E], profundiza más adentro."

# game/scripts/day5.rpy:5060
translate spanish d5e_emilia_igor_222d4165:

    # W "[Ig] is a good friend of this house."
    W "[Ig] es una buen amigo de esta casa."

# game/scripts/day5.rpy:5061
translate spanish d5e_emilia_igor_f0c9e140:

    # W "So do your best."
    W "Así que hazlo lo mejor que puedas."

# game/scripts/day5.rpy:5062
translate spanish d5e_emilia_igor_76dad10f:

    # E "...yesh mistresh..."
    E "... sih amra..."

# game/scripts/day5.rpy:5065
translate spanish d5e_emilia_igor_35c529ff:

    # Ig "Hghn..."
    Ig "Hghn..."

# game/scripts/day5.rpy:5066
translate spanish d5e_emilia_igor_949c100f:

    # Ig "[persistent.player_name!c], may I use hand on her?"
    Ig "[persistent.player_name!c], ¿puedo usar la mano en ella?"

# game/scripts/day5.rpy:5068
translate spanish d5e_emilia_igor_21d7c7dc:

    # Z "Go ahead, but don't be too rough."
    Z "Adelante, pero no seas demasiado brusco."

# game/scripts/day5.rpy:5069
translate spanish d5e_emilia_igor_5b71d9b0:

    # Ig "Of course."
    Ig "Por supuesto."

# game/scripts/day5.rpy:5071
translate spanish d5e_emilia_igor_53df6087:

    # Z "Sure, she's just a slave."
    Z "Claro, sólo es una esclava."

# game/scripts/day5.rpy:5072
translate spanish d5e_emilia_igor_afd623eb:

    # Z "But treat her well, we want her to be in good shape."
    Z "Pero trátala bien, queremos que esté en buen estado."

# game/scripts/day5.rpy:5073
translate spanish d5e_emilia_igor_5b71d9b0_1:

    # Ig "Of course."
    Ig "Por supuesto."

# game/scripts/day5.rpy:5076
translate spanish d5e_emilia_igor_de0a1bd9:

    # Ig "She does good job."
    Ig "Hace un buen trabajo."

# game/scripts/day5.rpy:5077
translate spanish d5e_emilia_igor_1c9133b8_2:

    # E "*sucking*"
    E "{i}*chupando*"

# game/scripts/day5.rpy:5080
translate spanish d5e_emilia_igor_2f9ef750:

    # Ig "Nh..."
    Ig "Nh..."

# game/scripts/day5.rpy:5081
translate spanish d5e_emilia_igor_f022f430:

    # W "Yeah... I can see that."
    W "Sí... ya lo veo."

# game/scripts/day5.rpy:5082
translate spanish d5e_emilia_igor_59fc518f:

    # W "...She needs practice."
    W "... Ella necesita practicar."

# game/scripts/day5.rpy:5084
translate spanish d5e_emilia_igor_1f09956a_1:

    # Ig "Urgh..."
    Ig "Urgh..."

# game/scripts/day5.rpy:5085
translate spanish d5e_emilia_igor_47eb6613:

    # Ig "I come..."
    Ig "¡Me corro...!"

# game/scripts/day5.rpy:5087
translate spanish d5e_emilia_igor_a4de87f4:

    # E "{i}*gulp*{/i}"
    E "{i}*gulp*{/i}"

# game/scripts/day5.rpy:5090
translate spanish d5e_emilia_igor_41c27d69:

    # Ig "Oh yes."
    Ig "Oh si."

# game/scripts/day5.rpy:5091
translate spanish d5e_emilia_igor_c8c38332:

    # Ig "This was good."
    Ig "Esto estuvo bien."

# game/scripts/day5.rpy:5094
translate spanish d5e_emilia_igor_d121f2df:

    # W "Lick it all up, you don't want to let our guests leave with wet pants, do you?!"
    W "Chúpalo todo, no querrás que nuestros invitados se vayan con los pantalones mojados, ¿verdad?"

# game/scripts/day5.rpy:5095
translate spanish d5e_emilia_igor_ae7e6f90:

    # E "Yesh, mistresh..."
    E "Srih, anma..."

# game/scripts/day5.rpy:5096
translate spanish d5e_emilia_igor_9703f5ea:

    # E "{i}*slurp*"
    E "{i}*chupa*{/i}"

# game/scripts/day5.rpy:5099
translate spanish d5e_emilia_igor_d1ca392d:

    # Z "[Ig], has my wife ever served you her special dessert?"
    Z "[Ig], ¿mi mujer te ha servido alguna vez su postre especial?"

# game/scripts/day5.rpy:5100
translate spanish d5e_emilia_igor_bde01d23:

    # Ig "I am now intrigued, what is it?"
    Ig "Ahora estoy intrigado, ¿qué es?"

# game/scripts/day5.rpy:5101
translate spanish d5e_emilia_igor_696d8423:

    # Z "She is a very good cook, but dessert is where she really shines.."
    Z "Cocina de puta madre, pero con los postres es donde realmente se sale..."

# game/scripts/day5.rpy:5104
translate spanish d5e_emilia_igor_0acfe204:

    # W "Oh please, husband."
    W "Oh por favor, marido."

# game/scripts/day5.rpy:5107
translate spanish d5e_emilia_igor_04935e80:

    # Z "I mean it. Come on, [W], bring it out."
    Z "Lo digo en serio. Venga, [W], sácalo ya."

# game/scripts/day5.rpy:5112
translate spanish d5e_emilia_igor_1e185f0d:

    # Z "Please refill the drinks for us."
    Z "Por favor, rellena las bebidas para nosotros."

# game/scripts/day5.rpy:5113
translate spanish d5e_emilia_igor_34398586:

    # E "Of course, [mas]."
    E "Por supuesto, [mas]."

# game/scripts/day5.rpy:5115
translate spanish d5e_emilia_igor_21e4a1b9:

    # Z "Refill the drinks, slave."
    Z "Rellena las copas, esclava."

# game/scripts/day5.rpy:5116
translate spanish d5e_emilia_igor_5453efe1_2:

    # E "Yes, [mas]."
    E "Sí, [mas]."

# game/scripts/day5.rpy:5120
translate spanish d5e_emilia_igor_80bcde51:

    # Z "Anyway, [Ig], tell me, how is trade going?"
    Z "De todos modos, [Ig], dime, ¿cómo va el comercio?"

# game/scripts/day5.rpy:5121
translate spanish d5e_emilia_igor_5bd608bf_2:

    # Ig "Thank you for asking."
    Ig "Gracias por preguntar."

# game/scripts/day5.rpy:5122
translate spanish d5e_emilia_igor_58463682_2:

    # Ig "We had incidents lately, let me tell you more..."
    Ig "Tuvimos incidentes últimamente, déjame que te cuente más..."

# game/scripts/day5.rpy:5126
translate spanish d5e_emilia_igor_890602a5_1:

    # W "Do it like I taught you, [A]."
    W "Hazlo como te he enseñado, [A]."

# game/scripts/day5.rpy:5138
translate spanish d5e_emilia_igor_285c2777_1:

    # A "Nu uh!"
    A "¡Eh no!"

# game/scripts/day5.rpy:5139
translate spanish d5e_emilia_igor_2dc6bf6a_1:

    # Ig "Ohh, why?"
    Ig "Ohh, ¿por qué?"

# game/scripts/day5.rpy:5142
translate spanish d5e_emilia_igor_1f09956a_2:

    # Ig "Urgh..."
    Ig "Urgh..."

# game/scripts/day5.rpy:5145
translate spanish d5e_emilia_igor_83929ca0:

    # Ig "Why did you stop, short one..."
    Ig "¿Por qué te detienes, pequeñaja...?"

# game/scripts/day5.rpy:5148
translate spanish d5e_emilia_igor_059ca882_1:

    # A "Sorry Mr. [Ig]."
    A "Lo siento señor [Ig]."

# game/scripts/day5.rpy:5149
translate spanish d5e_emilia_igor_4713aae3_1:

    # A "But my [persistent.dad] did not say you can be rough with me..."
    A "Pero mi [persistent.dad] no ha dicho que puedas ser brusco conmigo..."

# game/scripts/day5.rpy:5152
translate spanish d5e_emilia_igor_b98020a7:

    # Ig "Urgh... She is right, I must to apologize."
    Ig "Urgh... Ella tiene razón, debo disculparme."

# game/scripts/day5.rpy:5153
translate spanish d5e_emilia_igor_e8744cd1:

    # W "My husband is very thorough in teaching the limits to what she can and can not do..."
    W "Mi marido es muy minucioso a la hora de enseñarle los límites de lo que puede y no puede hacer..."

# game/scripts/day5.rpy:5154
translate spanish d5e_emilia_igor_a7dfc3e3_1:

    # Ig "Is ok. Thank you, Lady [A]."
    Ig "Está bien. Gracias, Señorita [A]."

# game/scripts/day5.rpy:5155
translate spanish d5e_emilia_igor_6552db73_1:

    # W "You can leave now, [A]. I will see you later."
    W "Ya puedes irte, [A]. Nos veremos más tarde."

# game/scripts/day5.rpy:5164
translate spanish d5e_end_9da5b1ed:

    # "[W] brings everyone the dessert and you keep talking for some time."
    "[W] trae a todos el postre y seguís hablando durante un rato."

# game/scripts/day5.rpy:5165
translate spanish d5e_end_6339b3f5:

    # "Eventually, [Ig] says it is time to leave..."
    "Finalmente, [Ig] dice que es hora de irse..."

# game/scripts/day5.rpy:5170
translate spanish d5e_end_a32343ef:

    # Ig "You and your husband are great host."
    Ig "Tú y tu marido sois grandes anfitriones."

# game/scripts/day5.rpy:5171
translate spanish d5e_end_9581178c:

    # Ig "Thank you very much, Lady [W]."
    Ig "Muchas gracias, Señora [W]."

# game/scripts/day5.rpy:5172
translate spanish d5e_end_f4f0904b:

    # W "It has been my pleasure, I hope my husband and I can visit your home sometime soon."
    W "Ha sido un placer, espero que mi marido y yo podamos visitar tu casa algún día."

# game/scripts/day5.rpy:5173
translate spanish d5e_end_ec26103a:

    # Ig "Of course, we will surely find time."
    Ig "Por supuesto, seguro que encontraremos tiempo."

# game/scripts/day5.rpy:5174
translate spanish d5e_end_83b7a7eb:

    # Ka "..."
    Ka "..."

# game/scripts/day5.rpy:5177
translate spanish d5e_end_00f45af6:

    # Ka "You will show me city?"
    Ka "¿Me enseñarás la ciudad?"

# game/scripts/day5.rpy:5180
translate spanish d5e_end_2fcbbb37:

    # Z "I will."
    Z "Lo haré."

# game/scripts/day5.rpy:5181
translate spanish d5e_end_2db43347:

    # Z "When I find the time, we can visit the gardens near the temple together."
    Z "Cuando encuentre tiempo, podemos visitar juntos los jardines cercanos al templo."

# game/scripts/day5.rpy:5182
translate spanish d5e_end_d0e051cb:

    # Z "There is always something interesting happening."
    Z "Siempre ocurre algo interesante."

# game/scripts/day5.rpy:5183
translate spanish d5e_end_a9bae985:

    # Z "Now... I think your uncle is about ready to leave."
    Z "Ahora... Creo que tu tío está a punto de irse."

# game/scripts/day5.rpy:5184
translate spanish d5e_end_04aa39ff:

    # Z "See you soon, okay?"
    Z "Hasta pronto, ¿vale?"

# game/scripts/day5.rpy:5187
translate spanish d5e_end_45118a3c:

    # Ka "Okay. Bye, [persistent.player_name]."
    Ka "Vale. Adiós, [persistent.player_name]."

# game/scripts/day5.rpy:5199
translate spanish shanipalace1_36c6e0ee:

    # S "Are we going to the throne room?"
    S "¿Vamos a la sala del trono?"

# game/scripts/day5.rpy:5205
translate spanish shanipalace1_0d8d9292:

    # Ta "Not this time."
    Ta "Esta vez no."

# game/scripts/day5.rpy:5206
translate spanish shanipalace1_cd84db8f:

    # Ta "[Q] is taking a bath in the thermae."
    Ta "[Q] está tomando un baño en las termas."

# game/scripts/day5.rpy:5207
translate spanish shanipalace1_6f661383:

    # Ta "We prepared a robe for you."
    Ta "Hemos preparado una túnica para ti."

# game/scripts/day5.rpy:5208
translate spanish shanipalace1_b9676bd2:

    # S "She wants me to join her?"
    S "¿Quiere que me una a ella?"

# game/scripts/day5.rpy:5209
translate spanish shanipalace1_2563cdd4:

    # Ta "She does. Very few people get that privilege..."
    Ta "Lo quiere. Muy pocas personas tienen ese privilegio..."

# game/scripts/day5.rpy:5210
translate spanish shanipalace1_43ca57be:

    # S "Hm..."
    S "Hm..."

# game/scripts/day5.rpy:5213
translate spanish shanipalace1_4e70635a:

    # Ta "Are you nervous?"
    Ta "¿Estás nerviosa?"

# game/scripts/day5.rpy:5214
translate spanish shanipalace1_44e7e5a3:

    # S "A little."
    S "Un poco."

# game/scripts/day5.rpy:5215
translate spanish shanipalace1_3cdae2bd:

    # Ta "I wouldn't worry so much."
    Ta "Yo no me preocuparía tanto."

# game/scripts/day5.rpy:5216
translate spanish shanipalace1_2232fb82:

    # Ta "[Q] can be a little impulsive sometimes."
    Ta "[Q] puede ser un poco impulsiva a veces."

# game/scripts/day5.rpy:5217
translate spanish shanipalace1_72fefcde:

    # Ta "But I'm sure she will be excited to see you."
    Ta "Estoy segura de que se emocionará al verte."

# game/scripts/day5.rpy:5227
translate spanish shanithermae1_51d4e731:

    # St "I really am in the thermae..."
    St "Realmente estoy en las termas..."

# game/scripts/day5.rpy:5233
translate spanish shanithermae1_01e8af05:

    # St "...always wondered what they looked like."
    St "... siempre me preguntaba cómo serían."

# game/scripts/day5.rpy:5236
translate spanish shanithermae1_ad02d394:

    # St "Calm down [S], you're just going to talk to the Queen..."
    St "Cálmate [S], sólo vas a hablar con la Reina..."

# game/scripts/day5.rpy:5239
translate spanish shanithermae1_971a98df:

    # S "..."
    S "..."

# game/scripts/day5.rpy:5242
translate spanish shanithermae1_9d680564:

    # Q "Hmm..."
    Q "Hmm..."

# game/scripts/day5.rpy:5243
translate spanish shanithermae1_c4ccd9a3:

    # St "What to say, what to say..."
    St "Qué digo, qué digo..."

# game/scripts/day5.rpy:5244
translate spanish shanithermae1_71ef69af:

    # S "My Queen, I am here as requested."
    S "Mi Reina, estoy aquí como se me pidió."

# game/scripts/day5.rpy:5247
translate spanish shanithermae1_bdc61a01:

    # Q "..."
    Q "..."

# game/scripts/day5.rpy:5253
translate spanish shanithermae1_912e93b4:

    # Q "Welcome, [S]."
    Q "Bienvenida, [S]."

# game/scripts/day5.rpy:5254
translate spanish shanithermae1_0fc1882c:

    # Q "Why don't you get in as well?"
    Q "¿Por qué no entras tú también?"

# game/scripts/day5.rpy:5255
translate spanish shanithermae1_3d9020bd:

    # Q "There is enough water for both of us."
    Q "Hay suficiente agua para las dos."

# game/scripts/day5.rpy:5256
translate spanish shanithermae1_eabb9359:

    # St "..."
    St "..."

# game/scripts/day5.rpy:5259
translate spanish shanithermae1_0fc85c03:

    # Q "This is the cleanest water you will find anywhere in Egypt..."
    Q "Esta es el agua más limpia que encontrarás en todo Egipto..."

# game/scripts/day5.rpy:5260
translate spanish shanithermae1_283a1de4:

    # S "I believe you..."
    S "Te creo..."

# game/scripts/day5.rpy:5263
translate spanish shanithermae1_9d680564_1:

    # Q "Hmm..."
    Q "Hmm..."

# game/scripts/day5.rpy:5266
translate spanish shanithermae1_84ccd313:

    # Q "My, my..."
    Q "Vaya, vaya..."

# game/scripts/day5.rpy:5267
translate spanish shanithermae1_f1dc1bcf:

    # Q "If I didn't know you're about to become a Stalker, I would consider taking you to be one of my sirens..."
    Q "Si no supiera que estás a punto de convertirte en Acechadora, pensaría seriamente en nombrarte una de mis sirenas..."

# game/scripts/day5.rpy:5268
translate spanish shanithermae1_971a98df_1:

    # S "..."
    S "..."

# game/scripts/day5.rpy:5269
translate spanish shanithermae1_a5265fd7:

    # Q "Let me slide over..."
    Q "Deja que me deslice..."

# game/scripts/day5.rpy:5276
translate spanish shanithermae1_129211c2:

    # Q "I know you must be nervous."
    Q "Sé que debes estar nerviosa."

# game/scripts/day5.rpy:5277
translate spanish shanithermae1_0baf7d1d:

    # Q "But there is no need to be."
    Q "Pero no es necesario."

# game/scripts/day5.rpy:5278
translate spanish shanithermae1_34b9f76d:

    # Q "By age, we could be sisters..."
    Q "Por la edad, podríamos ser hermanas..."

# game/scripts/day5.rpy:5279
translate spanish shanithermae1_3305b488:

    # Q "And I think we have more in common than that..."
    Q "Y creo que tenemos más cosas en común que eso..."

# game/scripts/day5.rpy:5280
translate spanish shanithermae1_971a98df_2:

    # S "..."
    S "..."

# game/scripts/day5.rpy:5283
translate spanish shanithermae1_28f7794c:

    # Q "Now..."
    Q "Ahora bien..."

# game/scripts/day5.rpy:5284
translate spanish shanithermae1_4e9c99b2:

    # Q "The reason why I have summoned you here, is because I heard what happened at the market..."
    Q "La razón por la que te he convocado aquí, es porque me he enterado de lo que ha pasado en el mercado..."

# game/scripts/day5.rpy:5285
translate spanish shanithermae1_e5936c62:

    # Q "A kidnapping in the midst of day is something that is truly shameful..."
    Q "Un secuestro en pleno día es algo verdaderamente vergonzoso..."

# game/scripts/day5.rpy:5286
translate spanish shanithermae1_bd40dc44:

    # Q "Something that can not be tolerated."
    Q "Algo que no se puede tolerar."

# game/scripts/day5.rpy:5289
translate spanish shanithermae1_b9389d61:

    # Q "Something that must be punished accordingly."
    Q "Algo que debe ser castigado en consecuencia."

# game/scripts/day5.rpy:5293
translate spanish shanithermae1_11de136e:

    # Q "Fortunately you already took care of one of the thugs."
    Q "Afortunadamente ya te encargaste a una de las ladronas."

# game/scripts/day5.rpy:5294
translate spanish shanithermae1_8c98c016:

    # Q "They brought me the body to see. I have appreciated your work."
    Q "Me trajeron el cadáver para que lo viera. He apreciado tu trabajo."

# game/scripts/day5.rpy:5295
translate spanish shanithermae1_b1c6d215:

    # Q "Her skull was almost split in half."
    Q "Su cráneo está casi partido por la mitad."

# game/scripts/day5.rpy:5296
translate spanish shanithermae1_87673b12:

    # Q "She must have died instantly..."
    Q "Debió morir al instante..."

# game/scripts/day5.rpy:5299
translate spanish shanithermae1_54355a86:

    # S "They brought you the corpse?"
    S "¿Te han traído el cadáver?"

# game/scripts/day5.rpy:5302
translate spanish shanithermae1_75cc8632:

    # Q "Yes, of course... I am the Queen. Justice in Zeta, one way or another, must come from or flow through me."
    Q "Sí, por supuesto... Soy la Reina. La justicia en Zeta, de una forma u otra, debe venir de mí o fluir a través de mí."

# game/scripts/day5.rpy:5303
translate spanish shanithermae1_096ea050:

    # Q "And I have good use for dead criminals."
    Q "Y tengo un buen uso de los criminales muertos."

# game/scripts/day5.rpy:5306
translate spanish shanithermae1_dd52964b:

    # Q "I heard what you did..."
    Q "Oí lo que hiciste..."

# game/scripts/day5.rpy:5307
translate spanish shanithermae1_513860a2:

    # Q "And that you saved your sister by knocking out one of the thugs."
    Q "Y que salvaste a tu hermana derribando de una de las ladronas."

# game/scripts/day5.rpy:5308
translate spanish shanithermae1_5110a46b:

    # Q "Then you distracted the second one long enough so that my guards could step in."
    Q "Entonces distrajiste al segundo el tiempo suficiente para que mis guardias pudieran intervenir."

# game/scripts/day5.rpy:5309
translate spanish shanithermae1_21e8a5b1:

    # Q "When they brought her to me I saw you put a nice dent into her head."
    Q "Cuando me la trajeron, vi que la hiciste una buena mella en la cabeza."

# game/scripts/day5.rpy:5312
translate spanish shanithermae1_f1cec89e:

    # S "They brought her to you?"
    S "¿Te la han traído?"

# game/scripts/day5.rpy:5315
translate spanish shanithermae1_b11ec142:

    # Q "Of course... I am the Queen. Justice in Zeta, one way or another, must come from or flow through me."
    Q "Por supuesto... Soy la Reina. La justicia en Zeta, de una forma u otra, debe venir de mí o fluir a través de mí."

# game/scripts/day5.rpy:5316
translate spanish shanithermae1_ee7329bf:

    # Q "I must pass judgement on what happens to criminals like them."
    Q "Debo juzgar lo que les ocurre a los criminales como ellos."

# game/scripts/day5.rpy:5319
translate spanish shanithermae1_882eaac8:

    # Q "Which brings me to what we are going to do next..."
    Q "Lo que me lleva a lo que vamos a hacer a continuación..."

# game/scripts/day5.rpy:5320
translate spanish shanithermae1_a564c40d:

    # Q "As much as I would like to know more about you..."
    Q "Por mucho que me gustaría saber más de ti..."

# game/scripts/day5.rpy:5321
translate spanish shanithermae1_aa10e4e4:

    # Q "The situation at the market is not yet fully taken care of..."
    Q "La situación en el mercado aún no está del todo resuelta..."

# game/scripts/day5.rpy:5324
translate spanish shanithermae1_11f174c0:

    # Q "Care to join me, Stalker?"
    Q "¿Quieres unirte a mí, Acechadora?"

# game/scripts/day5.rpy:5327
translate spanish shanithermae1_546c47bb:

    # S "Certainly, [Q]."
    S "Por supuesto, [Q]."

# game/scripts/day5.rpy:5330
translate spanish shanithermae1_f97e1c4f:

    # Q "Nice..."
    Q "Genial..."

# game/scripts/day5.rpy:5333
translate spanish shanithermae1_d8121da5:

    # Q "I mean, that was more of a rhetorical question of me..."
    Q "O sea, era más una pregunta retórica mía..."

# game/scripts/day5.rpy:5336
translate spanish shanithermae1_83fa46a2:

    # Q "But still."
    Q "Pero aún así."

# game/scripts/day5.rpy:5340
translate spanish shanithermae1_9be9fc9d:

    # Q "Let's get dressed and ready."
    Q "Vistámonos y preparémonos."

# game/scripts/day5.rpy:5343
translate spanish shanithermae1_5f277563:

    # Q "An execution awaits."
    Q "Te espera una ejecución."

# game/scripts/day5.rpy:5352
translate spanish shanithermae1_9669528e:

    # "Later..."
    "Más tarde..."

# game/scripts/day5.rpy:5362
translate spanish d5b_queen_execution_94110bba:

    # S "It's him..."
    S "Es él..."

# game/scripts/day5.rpy:5366
translate spanish d5b_queen_execution_3a2de137:

    # Q "So you remember his face."
    Q "Así que recuerdas su cara."

# game/scripts/day5.rpy:5369
translate spanish d5b_queen_execution_80f9dbde:

    # Q "Normally I'd have him executed publicly..."
    Q "Normalmente haría que lo ejecutaran públicamente..."

# game/scripts/day5.rpy:5370
translate spanish d5b_queen_execution_21bc7517:

    # Q "But once in a while I make an exception."
    Q "Pero de vez en cuando hago una excepción."

# game/scripts/day5.rpy:5373
translate spanish d5b_queen_execution_8ba43ecc:

    # Q "Thank you for waiting, guard."
    Q "Gracias por esperar, guardia."

# game/scripts/day5.rpy:5375
translate spanish d5b_queen_execution_4dffe312:

    # Q "I think you deserve some time with our other prisoner..."
    Q "Creo que te mereces un tiempo con nuestra otra prisionera..."

# game/scripts/day5.rpy:5376
translate spanish d5b_queen_execution_12e314f1:

    # G "Thank you, my Queen."
    G "Gracias, mi Reina."

# game/scripts/day5.rpy:5377
translate spanish d5b_queen_execution_4e491dd4:

    # G "It was a pleasure guarding this criminal for you."
    G "Fue un placer vigilar a este criminal por ti."

# game/scripts/day5.rpy:5378
translate spanish d5b_queen_execution_0df0388c:

    # Q "Before you go, bring me my dragon, will you."
    Q "Antes de que te vayas, tráeme mi dragón, ¿quieres?"

# game/scripts/day5.rpy:5379
translate spanish d5b_queen_execution_90c058fe:

    # G "Of course, my Queen."
    G "Por supuesto, mi Reina."

# game/scripts/day5.rpy:5382
translate spanish d5b_queen_execution_541d82c8:

    # C "Please... I don't want to die."
    C "Por favor... No quiero morir."

# game/scripts/day5.rpy:5383
translate spanish d5b_queen_execution_edccca38:

    # C "I'm sorry!"
    C "Lo siento."

# game/scripts/day5.rpy:5384
translate spanish d5b_queen_execution_4d40d234:

    # Q "Na na na..."
    Q "Bueno, bueno, bueno..."

# game/scripts/day5.rpy:5385
translate spanish d5b_queen_execution_91bfafb5:

    # Q "The regrets always come so late, don't they..."
    Q "Los arrepentimientos siempre llegan tan tarde, ¿verdad?"

# game/scripts/day5.rpy:5388
translate spanish d5b_queen_execution_51648327:

    # C "I just want to go home..."
    C "Sólo quiero irme a casa..."

# game/scripts/day5.rpy:5389
translate spanish d5b_queen_execution_3dde8c64:

    # Q "No need to cry..."
    Q "No hay necesidad de llorar..."

# game/scripts/day5.rpy:5390
translate spanish d5b_queen_execution_ffa6591c:

    # Q "You knew this is how things work..."
    Q "Sabías que las cosas funcionan así..."

# game/scripts/day5.rpy:5391
translate spanish d5b_queen_execution_a331e40b:

    # Q "You almost killed the daughter of one of my Stalkers, in broad daylight..."
    Q "Casi matas a la hija de uno de mis Acechadores, a plena luz del día..."

# game/scripts/day5.rpy:5392
translate spanish d5b_queen_execution_9fdaf06d:

    # Q "What would people think if I let that just slide?"
    Q "¿Qué pensaría la gente si lo dejara pasar?"

# game/scripts/day5.rpy:5393
translate spanish d5b_queen_execution_ae41190b:

    # C "But... I don't want to die.. please..."
    C "Pero... No quiero morir... por favor..."

# game/scripts/day5.rpy:5394
translate spanish d5b_queen_execution_f46aa66a:

    # C "I'll do anything."
    C "Haré cualquier cosa."

# game/scripts/day5.rpy:5397
translate spanish d5b_queen_execution_c68a03b2:

    # Q "Hm... I almost believe you."
    Q "Umm... casi te creo."

# game/scripts/day5.rpy:5398
translate spanish d5b_queen_execution_a7a899ab:

    # Q "Unfortunately, this is how society works."
    Q "Por desgracia, así es como funciona la sociedad."

# game/scripts/day5.rpy:5399
translate spanish d5b_queen_execution_e50e5f70:

    # Q "Harsh punishments reinforce the public's trust in my governance."
    Q "Los duros castigos refuerzan la confianza del público en mi gobierno."

# game/scripts/day5.rpy:5400
translate spanish d5b_queen_execution_3fe842e2:

    # Q "And the higher that trust is, the safer my people will feel..."
    Q "Y cuanto mayor sea esa confianza, más segura se sentirá mi gente..."

# game/scripts/day5.rpy:5403
translate spanish d5b_queen_execution_dc569963:

    # Q "And I want them to feel safe..."
    Q "Y quiero que se sienta segura..."

# game/scripts/day5.rpy:5406
translate spanish d5b_queen_execution_1cff5ffb:

    # Q "But I don't want to be rude and ignore our guest."
    Q "Pero no quiero ser descortés e ignorar a nuestra invitada."

# game/scripts/day5.rpy:5407
translate spanish d5b_queen_execution_b0dd3fbc:

    # Q "After all, it was her sister you attacked."
    Q "Después de todo, fue a su hermana a quien atacaste."

# game/scripts/day5.rpy:5408
translate spanish d5b_queen_execution_79951e97:

    # Q "What do you think [S]?"
    Q "¿Qué opinas [S]?"

# game/scripts/day5.rpy:5409
translate spanish d5b_queen_execution_1f24ff9b:

    # Q "Do you think a murderous kidnapper should get what he deserves?"
    Q "¿Crees que un secuestrador asesino debe recibir su merecido?"

# game/scripts/day5.rpy:5410
translate spanish d5b_queen_execution_971a98df:

    # S "..."
    S "..."

# game/scripts/day5.rpy:5413
translate spanish d5b_queen_execution_ff1ab2d1:

    # S "He clearly regrets it."
    S "Está claro que se arrepiente."

# game/scripts/day5.rpy:5414
translate spanish d5b_queen_execution_9c2348e0:

    # S "Maybe he can change."
    S "Tal vez pueda cambiar."

# game/scripts/day5.rpy:5417
translate spanish d5b_queen_execution_afdb9b6f:

    # S "Zeta is not some lawless raider hovel."
    S "Zeta no es un tugurio de asaltantes sin ley."

# game/scripts/day5.rpy:5418
translate spanish d5b_queen_execution_dddc0e1f:

    # S "I think we can be better than that."
    S "Creo que podemos ser mejores que eso."

# game/scripts/day5.rpy:5422
translate spanish d5b_queen_execution_527fb6f8:

    # Q "Kind words, for someone who killed a girl in cold blood."
    Q "Qué bonita forma de hablar para alguien que ha matado a una tía a sangre fría."

# game/scripts/day5.rpy:5423
translate spanish d5b_queen_execution_ea30e5cf:

    # S "That was necessary... I needed to make sure she wouldn't be a threat."
    S "Era necesario... Necesitaba asegurarme de que no sería una amenaza."

# game/scripts/day5.rpy:5424
translate spanish d5b_queen_execution_8908e0f1:

    # Q "Is that so...?"
    Q "¿Es así...?"

# game/scripts/day5.rpy:5426
translate spanish d5b_queen_execution_01951c07:

    # Q "You truly believe in the good nature of people, don't you?"
    Q "Realmente crees en la buena naturaleza de las personas, ¿no es así?"

# game/scripts/day5.rpy:5431
translate spanish d5b_queen_execution_f63c07f5:

    # Q "Now... while my friend here may disagree, I am still the Queen."
    Q "Ahora... aunque mi amiga no esté de acuerdo, sigo siendo la Reina."

# game/scripts/day5.rpy:5434
translate spanish d5b_queen_execution_7c1ea25b:

    # Q "I have my duties...And I say we stick to my plan..."
    Q "Tengo mis deberes... Y digo que nos ciñamos a mi plan..."

# game/scripts/day5.rpy:5439
translate spanish d5b_queen_execution_06447bb5:

    # S "This seems a bit disproportionate."
    S "Esto parece un poco desproporcionado."

# game/scripts/day5.rpy:5442
translate spanish d5b_queen_execution_bc0e133a:

    # S "He didn't kill my sister."
    S "El no mató a mi hermana."

# game/scripts/day5.rpy:5443
translate spanish d5b_queen_execution_65fc13db:

    # S "In my opinion he should be put to hard labour, not executed. Make himself useful to society."
    S "En mi opinión, debería ser sometido a trabajos forzados, no ejecutado. Que sea útil a la sociedad."

# game/scripts/day5.rpy:5447
translate spanish d5b_queen_execution_00d44f1e:

    # Q "Do I need to remind you that you killed the other one yourself?"
    Q "¿Tengo que recordarte que tú misma mataste a la otra?"

# game/scripts/day5.rpy:5448
translate spanish d5b_queen_execution_cbbfd98f:

    # S "That was... different..."
    S "Eso fue... diferente..."

# game/scripts/day5.rpy:5450
