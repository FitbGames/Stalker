    # I "..."
    I "..."

# game/scripts/day5.rpy:6350
translate spanish d5b53_27c2507d:

    # "She opens her mouth, as if to say something..."
    "Abre la boca, como si fuera a decir algo..."

# game/scripts/day5.rpy:6354
translate spanish d5b53_8ed045f0:

    # "{i}You hear a muffled voice from outside..."
    "{i}Oyes una voz amoriguada en el exterior..."

# game/scripts/day5.rpy:6355
translate spanish d5b53_2f0b250a:

    # Fa "What if he does something to her?! I told you to stand guard for fuck's sake!"
    Fa "¿Y si le hace algo?! ¡Te dije que vigilaras, maldita sea!"

# game/scripts/day5.rpy:6362
