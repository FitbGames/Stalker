translate spanish d5f_fairy_end_b2f466e4:

    # Z "I don't want her. I don't have time to undo any conditioning she's been put through."
    Z "No la quiero. No tengo tiempo para deshacer el condicionamiento al que ha sido sometida."

# game/scripts/day5.rpy:1353
translate spanish d5f_fairy_end_3a9ac36b:

    # Ki "Alright then, [Ko]."
    Ki "Muy bien, entonces, [Ko]."

# game/scripts/day5.rpy:1354
translate spanish d5f_fairy_end_87ebabb9:

    # Ki "Guess we got ourselves a dinner for two!"
    Ki "¡Supongo que tenemos una cena para los dos!"

# game/scripts/day5.rpy:1355
translate spanish d5f_fairy_end_2fb9beeb:

    # Ko "Hmm... but we first have to wash the spunk off of her, hrhrhr..."
    Ko "Umm... pero primero tenemos que limpiarle el esperma de encima, jejeje..."

# game/scripts/day5.rpy:1359
translate spanish d5f_kinzy_end_cff24065:

    # Z "I need to go now."
    Z "Tengo que irme por ahora."

# game/scripts/day5.rpy:1360
translate spanish d5f_kinzy_end_22c98450:

    # Z "You keep your heads up, guys."
    Z "Mantened la cabeza alta, chicos."

# game/scripts/day5.rpy:1363
translate spanish d5f_kinzy_end_8bafc7b7:

    # Z "And clean this place up; it's a mess."
    Z "Y limpiad este lugar, que está hecho un desastre."

# game/scripts/day5.rpy:1370
translate spanish d5f_abrax_introduction_bfbf3af6:

    # "{i}Later..."
    "{i}Más tarde..."

# game/scripts/day5.rpy:1389
translate spanish d5f_abrax_introduction_936237ce:

    # Dec "New meat for you, slaves..."
    Dec "Carne fresca para vosotros, esclavos..."

# game/scripts/day5.rpy:1396
translate spanish d5f_abrax_introduction_13e84c66:

    # Dec "Keep it up! Unless you want to end up in this cart too."
    Dec "¡Seguid así! A menos que queráis acabar también en este carro."

# game/scripts/day5.rpy:1399
translate spanish d5f_abrax_introduction_39c49700:

    # "The horrors of Old Cairo have been a known thing for decades, however, what's displayed in front of you is..."
    "Los horrores de el Viejo Cairo han sido conocidos durante décadas, sin embargo, lo que tienes delante es..."

# game/scripts/day5.rpy:1400
translate spanish d5f_abrax_introduction_e0a7a202:

    # "...almost industrial, in scale."
    "... ¡casi industrial, en escala!"

# game/scripts/day5.rpy:1403
translate spanish d5f_abrax_introduction_ceb9338e:

    # Dec "These are fresh. Get to work!"
    Dec "Estos son frescos. ¡A trabajar!"

# game/scripts/day5.rpy:1406
translate spanish d5f_abrax_introduction_3ae0307f:

    # Sl "{i}*whimpering*{/i}"
    Sl "{i}*gimoteando*{/i}"

# game/scripts/day5.rpy:1409
translate spanish d5f_abrax_introduction_1383ddad:

    # Sl "D-do we... do we get to touch the sun, Master?"
    Sl "¿P-p... podemos nosotros tocar el sol, Amo?"

# game/scripts/day5.rpy:1410
translate spanish d5f_abrax_introduction_baf5a560:

    # Dec "Get back to work, lunatic."
    Dec "Vuelve al trabajo, lunático."

# game/scripts/day5.rpy:1413
translate spanish d5f_abrax_introduction_55d14c2d:

    # Dec "I want all of you to get this done until midnight."
    Dec "Quiero que todos hagáis esto hasta medianoche."

# game/scripts/day5.rpy:1414
translate spanish d5f_abrax_introduction_6573b05a:

    # Dec "Understood?"
    Dec "¿Entendido?"

# game/scripts/day5.rpy:1415
translate spanish d5f_abrax_introduction_0833b86e:

    # Sl "Sunlight..."
    Sl "Luz del sol..."

# game/scripts/day5.rpy:1418
translate spanish d5f_abrax_introduction_f4a4d432:

    # Dec "Hey, you, woman. Lord Abrax will visit us soon."
    Dec "Hola tú, mujer. El señor Abrax nos visitará pronto."

# game/scripts/day5.rpy:1419
translate spanish d5f_abrax_introduction_5613243e:

    # Dec "Make sure he gets his food served well!"
    Dec "¡Asegúrate de que le sirvan bien su comida!"

# game/scripts/day5.rpy:1420
translate spanish d5f_abrax_introduction_7bc371e6:

    # Sl "..."
    Sl "..."

# game/scripts/day5.rpy:1423
translate spanish d5f_abrax_introduction_6cb00c7a:

    # Sl "{i}*humming*{/i}"
    Sl "{i}*tarareando*{/i}"

# game/scripts/day5.rpy:1425
translate spanish d5f_abrax_introduction_99f0fbc0:

    # "As you roam the grotesque scenery, you spot a familiar face in one of the waste containers..."
    "Mientras recorres el grotesco paisaje, reconoces una cara familiar en uno de los contenedores de desechos..."

# game/scripts/day5.rpy:1428
translate spanish d5f_abrax_introduction_6ba4e80f:

    # Zt "That's that elf..."
    Zt "Eso es esa elfa..."

# game/scripts/day5.rpy:1429
translate spanish d5f_abrax_introduction_db66b866:

    # Zt "Looks like my friends had no use for her head... or were full already."
    Zt "Parece que mis amigos no encontraron uso para su cabeza... o ya estaban llenos."

# game/scripts/day5.rpy:1432
translate spanish d5f_abrax_introduction_35f995d7:

    # "You turn around, looking for a way down..."
    "Te das la vuelta, buscando un camino hacia abajo..."

# game/scripts/day5.rpy:1438
translate spanish d5f_abrax_introduction_af0b2670:

    # "You walk down the stairs..."
    "Bajas las escaleras..."

# game/scripts/day5.rpy:1444
translate spanish d5f_abrax_introduction_28b1dc01:

    # Dec "I will return, slaves. And when I do, that cart better be empty."
    Dec "Regresaré, esclavos. Y cuando lo haga, ese carro debería estar vacío."

# game/scripts/day5.rpy:1447
translate spanish d5f_abrax_introduction_dba558d3:

    # "You reached the ground floor. The mist is thick, and the slaves methodically continue their work."
    "Llegas al primer piso. La niebla es espesa y los esclavos continúan su trabajo metódicamente."

# game/scripts/day5.rpy:1450
translate spanish d5f_abrax_introduction_6709f9a2:

    # "You look around, and spot a short figure, standing in front of several metallic cages."
    "Miras alrededor y ves una figura pequeña, de pie frente a varias jaulas metálicas."

# game/scripts/day5.rpy:1454
translate spanish d5f_abrax_introduction_fc6f21b9:

    # "...and you approach her."
    "... y te acercas a ella."

# game/scripts/day5.rpy:1457
translate spanish d5f_abrax_introduction_2cc8404a:

    # Z "Hey, you!"
    Z "¡Eh, tú!"

# game/scripts/day5.rpy:1458
translate spanish d5f_abrax_introduction_ec776ae7:

    # C "...?"
    C "¿...?"

# game/scripts/day5.rpy:1461
translate spanish d5f_abrax_introduction_ce04286c:

    # "The short, stacked looking woman turns around, looking aware and concentrated, and raises her stern, gasmask interrupted voice..."
    "La mujer bajita y de curvas marcadas se gira, con una mirada consciente y concentrada, y alza la voz severa que suena amortiguada por su máscara de gas..."

# game/scripts/day5.rpy:1462
translate spanish d5f_abrax_introduction_5c1ecaf1:

    # C "What. I'm busy."
    C "¿Qué. Estoy ocupada."

# game/scripts/day5.rpy:1465
translate spanish d5f_abrax_introduction_fa847400:

    # Z "Any idea where they sell fuel, in this dump?"
    Z "¿Alguna idea de dónde venden combustible, en este vertedero?"

# game/scripts/day5.rpy:1466
translate spanish d5f_abrax_introduction_73177f9b:

    # C "Fuel?"
    C "¿Combustible?"

# game/scripts/day5.rpy:1469
translate spanish d5f_abrax_introduction_105fd406:

    # C "Do I look like I own this place? I trade slaves, that's it."
    C "¿Tengo cara de ser la dueña de este lugar? Yo solo trafico con esclavos, eso es todo."

# game/scripts/day5.rpy:1470
translate spanish d5f_abrax_introduction_5ab3574d:

    # Z "..."
    Z "..."

# game/scripts/day5.rpy:1471
translate spanish d5f_abrax_introduction_7ec29247:

    # "You look at her eyes. They're cold, without remorse, and able to sell slaves to their certain death."
    "Te fijas en sus ojos. Son fríos, sin remordimientos, y capaces de vender esclavos a una muerte segura."

# game/scripts/day5.rpy:1474
translate spanish d5f_abrax_introduction_fb5dc75a:

    # Sltr "Now what is that look? You look a little lost, is that it?"
    Sltr "¿Y esa mirada? ¿Estás un poco perdido, es eso?"

# game/scripts/day5.rpy:1475
translate spanish d5f_abrax_introduction_02412116:

    # Z "I am here for fuel, that's it. I don't plan to stay long."
    Z "Estoy aquí por combustible, eso es todo. No planeo quedarme mucho tiempo."

# game/scripts/day5.rpy:1478
translate spanish d5f_abrax_introduction_0cc0e45c:

    # Sltr "Well if you did, I would assume you have a death wish, running around without a mask."
    Sltr "Bueno, si lo hiciste, supondría que tienes un deseo de muerte, corriendo sin máscara."

# game/scripts/day5.rpy:1482
translate spanish d5f_abrax_introduction_540bd273:

    # Sltr "Regardless, you're out of luck with me. All I could offer you are slaves, but I ran out of anything of value."
    Sltr "De todos modos, no tienes suerte conmigo. Todo lo que podría ofrecerte son esclavos, pero me quedé sin nada de valor."

# game/scripts/day5.rpy:1485
translate spanish d5f_abrax_introduction_f4d9455f:

    # Sltr "So... try somewhere else, will you... I am busy counting my live stock."
    Sltr "Vete a intentarlo en otro lado, ¿vale? Estoy ocupada contando mi ganado."

# game/scripts/day5.rpy:1490
translate spanish d5f_abrax_introduction_1c0c9d45:

    # Sltr "Tell you what, I can't help you with your fuel issue, but you look like a man too rich for the wastes, judging by how clean you are."
    Sltr "Mira, no puedo ayudarte con tu problema de combustible, pero pareces un tipo demasiado rico para estas tierras, juzgando por lo limpio que estás."

# game/scripts/day5.rpy:1493
translate spanish d5f_abrax_introduction_94e4e514:

    # Sltr "I can offer you my wares. Slaves. Young, delicate, mindbroken."
    Sltr "Puedo ofrecerte mis mercancías. Esclavas. Jóvenes, delicadas, con la mente rota."

# game/scripts/day5.rpy:1496
translate spanish d5f_abrax_introduction_f7fddcb7:

    # Sltr "...Or call them live meat. It all depends on your tastes."
    Sltr "... ¿o llamarlos carne viva? Todo depende de tus gustos."

# game/scripts/day5.rpy:1499
translate spanish d5f_abrax_introduction_4858c534:

    # Sltr "Any demand on your side?"
    Sltr "¿Alguna demanda de tu parte?"

# game/scripts/day5.rpy:1504
translate spanish d5f_abrax_introduction_03b63fd4:

    # Z "Who do you have in those cages?"
    Z "¿Quién tienes en esas jaulas?"

# game/scripts/day5.rpy:1507
translate spanish d5f_abrax_introduction_4162c5df:

    # Sltr "Who? You mean what. These things are ready to be taken to the slaughterhouse."
    Sltr "¿Quién? Quieres decir qué. Estas cosas están listas para ser llevadas al matadero."

# game/scripts/day5.rpy:1510
translate spanish d5f_abrax_introduction_a8383f17:

    # Sltr "{i}*sigh*{/i} Whatever, I don't care what you call them."
    Sltr "{i}*suspiro*{/i} Da igual, no me importa cómo los llames."

# game/scripts/day5.rpy:1513
translate spanish d5f_abrax_introduction_4a5ef358:

    # Sltr "Here, take a look. This one is the best of the batch."
    Sltr "Aquí, echa un vistazo. Este es el mejor del lote."

# game/scripts/day5.rpy:1516
translate spanish d5f_abrax_introduction_5eb034ea:

    # Sltr "Exotic stock. I actually did not buy her, she was here for a long time."
    Sltr "Material exótico. En realidad, no la compré, ella lleva aquí mucho tiempo."

# game/scripts/day5.rpy:1517
translate spanish d5f_abrax_introduction_8c783c38:

    # Sltr "Unfortunately or not, her Masters died. Two decayed, had her used as nothing more than a living lavatory."
    Sltr "Por desgracia o no, sus Amos murieron. Dos Decaídos la usaban como poco más que un retrete viviente."

# game/scripts/day5.rpy:1518
translate spanish d5f_abrax_introduction_c19501f7:

    # Sltr "And since they died, I was tasked to take her to the slaughterhouse. So you might be lucky enough to get her before they axe her."
    Sltr "Y como murieron, me encargaron llevarla al matadero. Así que podrías tener suerte de conseguirla antes de que la ejecuten."

# game/scripts/day5.rpy:1521
translate spanish d5f_abrax_introduction_cf94cbf8:

    # Sltr "Her features... ginger, allergic to sunlight, reddish hair, and absolutely mindbroken."
    Sltr "Sus rasgos... pelirroja, alérgica a la luz del sol, cabello rojizo y completamente rota."

# game/scripts/day5.rpy:1522
translate spanish d5f_abrax_introduction_64820047:

    # Sltr "You look like someone who knows how to make use of such a thing."
    Sltr "Parece que sabes cómo sacar provecho de algo así."

# game/scripts/day5.rpy:1525
translate spanish d5f_abrax_introduction_a4bb9910:

    # Sltr "Anyway, next up is..."
    Sltr "De todos modos, el siguiente es..."

# game/scripts/day5.rpy:1526
translate spanish d5f_abrax_introduction_4501f34c:

    # Sl "{i}*whimper*{/i}"
    Sl "{i}sollozo{/i}"

# game/scripts/day5.rpy:1527
translate spanish d5f_abrax_introduction_0f300046:

    # Sltr "{i}*sigh*{/i} You know what... Screw that. Not even I would sell that thing."
    Sltr "{i}*suspiro*{/i} ¿Sabes qué...? A la mierda. Ni yo vendería esa cosa."

# game/scripts/day5.rpy:1530
translate spanish d5f_abrax_introduction_1fa675c5:

    # Sltr "So, guess that's all I have. Want to get her or not? That's twenty silver coins."
    Sltr "Supongo que eso es todo lo que tengo. ¿La quieres o no? Son veinte monedas de plata."

# game/scripts/day5.rpy:1537
translate spanish d5f_abrax_introduction_998fbe4f:

    # Z "Fine, I'll buy her."
    Z "Vale, la compraré."

# game/scripts/day5.rpy:1542
translate spanish d5f_abrax_introduction_cc9c5f0c:

    # Sltr "Perfect! Didn't expect to make a deal with these leftovers, but I won't complain."
    Sltr "¡Perfecto! No esperaba hacer un trato con estos restos, pero no me quejo."

# game/scripts/day5.rpy:1545
translate spanish d5f_abrax_introduction_15ad18ca:

    # Sltr "Hand me the coins, and I shall bring this thing to your car."
    Sltr "Dame las monedas y llevaré esto a tu coche."

# game/scripts/day5.rpy:1548
translate spanish d5f_abrax_introduction_757aaa0c:

    # "You give her the coins, and illustrate the position of your vehicle outside."
    "Le das las monedas e indicas la posición de tu vehículo fuera."

# game/scripts/day5.rpy:1549
translate spanish d5f_abrax_introduction_d55ec69e:

    # "She leaves the place, with the girl unconsciously under her arms..."
    "Deja el lugar, con la chica inconsciente bajo sus brazos..."

# game/scripts/day5.rpy:1554
translate spanish d5f_abrax_introduction_6d6b8edb:

    # Z "No thanks."
    Z "No, gracias."

# game/scripts/day5.rpy:1557
translate spanish d5f_abrax_introduction_01dcdf74:

    # Sltr "You do you..."
    Sltr "Haz lo que quieras..."

# game/scripts/day5.rpy:1560
translate spanish d5f_abrax_introduction_e564c56b:

    # Sltr "Go off then... I am busy counting my livestock."
    Sltr "Pues vete... estoy ocupado contando mi ganado."

# game/scripts/day5.rpy:1565
translate spanish d5f_abrax_introduction_6d6b8edb_1:

    # Z "No thanks."
    Z "No, gracias."

# game/scripts/day5.rpy:1568
translate spanish d5f_abrax_introduction_e564c56b_1:

    # Sltr "Go off then... I am busy counting my livestock."
    Sltr "Pues vete... estoy ocupado contando mi ganado."

# game/scripts/day5.rpy:1572
translate spanish d5f_abrax_313864b4:

    # Dec "Everyone! Lord Abrax has arrived!"
    Dec "¡Todos! ¡El Señor Abrax ha llegado!"

# game/scripts/day5.rpy:1576
translate spanish d5f_abrax_9e9f6b3a:

    # LA "..."
    LA "..."

# game/scripts/day5.rpy:1577
translate spanish d5f_abrax_c2e33210:

    # "You look up and spot three figures, watching over the hall..."
    "Miras hacia arriba y ves tres figuras, observando sobre el salón..."

# game/scripts/day5.rpy:1578
translate spanish d5f_abrax_1dd2ca5a:

    # Dec "Production seems to be going at a steady pace, my lord."
    Dec "La producción parece ir a buen ritmo, mi señor."

# game/scripts/day5.rpy:1579
translate spanish d5f_abrax_af9a64f7:

    # LA "Good..."
    LA "Bien..."

# game/scripts/day5.rpy:1581
translate spanish d5f_abrax_a66d56bf:

    # LA "You captured scavengers..."
    LA "Has capturado a los carroñeros..."

# game/scripts/day5.rpy:1582
translate spanish d5f_abrax_f6f1a30b:

    # Dec "Yes, my lord."
    Dec "Sí, mi señor."

# game/scripts/day5.rpy:1583
translate spanish d5f_abrax_d33c290f:

    # LA "Did they tell you anything about recent zone activities..."
    LA "¿Te han dicho algo sobre las actividades recientes de la zona?"

# game/scripts/day5.rpy:1584
translate spanish d5f_abrax_5fd683c4:

    # Dec "My lord, they did not tell us anything."
    Dec "Mi señor, no nos contaron nada."

# game/scripts/day5.rpy:1585
translate spanish d5f_abrax_05561286:

    # Dec "We didn't spare any method and questioned them until their death."
    Dec "No escatimamos en métodos y los interrogamos hasta su muerte."

# game/scripts/day5.rpy:1586
translate spanish d5f_abrax_782b34d8:

    # Dec "I'm fairly sure they just didn't know anything useful."
    Dec "Estoy bastante seguro de que no sabían nada útil."

# game/scripts/day5.rpy:1587
translate spanish d5f_abrax_9e9f6b3a_1:

    # LA "..."
    LA "..."

# game/scripts/day5.rpy:1590
translate spanish d5f_abrax_f4946871:

    # LA "We need more soldiers, soon..."
    LA "We need more soldiers, soon..."

# game/scripts/day5.rpy:1591
translate spanish d5f_abrax_d4f327fc:

    # LA "Make sure to turn a few more of them."
    LA "Asegúrate de convertir algunos más."

# game/scripts/day5.rpy:1594
translate spanish d5f_abrax_f6f1a30b_1:

    # Dec "Yes, my lord."
    Dec "Sí, mi señor."

# game/scripts/day5.rpy:1597
translate spanish d5f_abrax_9e9f6b3a_2:

    # LA "..."
    LA "..."

# game/scripts/day5.rpy:1598
translate spanish d5f_abrax_3a515d32:

    # "He looks downward..."
    "Él mira hacia abajo..."

# game/scripts/day5.rpy:1601
translate spanish d5f_abrax_4011986b:

    # "...right at you."
    "... directo hacia ti."

# game/scripts/day5.rpy:1603
translate spanish d5f_abrax_03bc2922:

    # LA "You..."
    LA "Tú..."

# game/scripts/day5.rpy:1606
translate spanish d5f_abrax_6fd43194:

    # LA "Guards! Take him to the temple."
    LA "¡Guardias! Llevadlo al templo."

# game/scripts/day5.rpy:1607
translate spanish d5f_abrax_f6f1a30b_2:

    # Dec "Yes, my lord."
    Dec "Sí, mi señor."

# game/scripts/day5.rpy:1609
translate spanish d5f_abrax_c8db7105:

    # Dec "Hey, you!"
    Dec "¡Ey, tú!"

# game/scripts/day5.rpy:1612
translate spanish d5f_abrax_8042383e:

    # Dec "You've heard our leader. Come with me, and quietly, if you know what's good for you.."
    Dec "Has oído a nuestro líder. Ven conmigo, y en silencio, si sabes lo que te conviene.."

# game/scripts/day5.rpy:1617
translate spanish d5f_abrax_b949b523:

    # "{i}They lead you outside, the guard close behind you."
    "{i}Te conducen al exterior, con la guardia cerca de ti."

# game/scripts/day5.rpy:1618
translate spanish d5f_abrax_6cb57431:

    # "{i}After walking even further towards the the city center, the guard indicates that you have arrived wherever he's leading you..."
    "{i}Después de caminar aún más hacia el centro de la ciudad, el guardia te indica que has llegado a donde te está llevando..."

# game/scripts/day5.rpy:1636
translate spanish d5f_abrax_f4018e66:

    # Zt "This is too deep in the city center. Not even Stalkers dare to come here, unless they can't avoid it."
    Zt "Esto está demasiado profundo en el centro de la ciudad. Ni siquiera los Stalkers se atreven a venir aquí, a menos que no puedan evitarlo."

# game/scripts/day5.rpy:1637
translate spanish d5f_abrax_ab6ff2f0:

    # Zt "The toxic air will burn your lungs in a matter of days."
    Zt "El aire tóxico quemará tus pulmones en cuestión de días."

# game/scripts/day5.rpy:1638
translate spanish d5f_abrax_b9fcd5b5:

    # Zt "Withered mummies, mutants and forces of nature make every step dangerous."
    Zt "Momias marchitas, mutantes y fuerzas de la naturaleza hacen que cada paso sea peligroso."

# game/scripts/day5.rpy:1639
translate spanish d5f_abrax_23caae4e:

    # Zt "And unlike zones, the dead heart of Old Cairo does not offer artifacts or other anomalies that I know of..."
    Zt "A diferencia de las zonas, el corazón muerto del Viejo Cairo no ofrece artefactos ni otras anomalías que yo sepa..."

# game/scripts/day5.rpy:1642
translate spanish d5f_abrax_b76050c4:

    # Dec "This way; move!"
    Dec "Por aquí; ¡muévete!"

# game/scripts/day5.rpy:1643
translate spanish d5f_abrax_963f69dd:

    # Dec "Walk straight to the entrance. It will be opened for you. Go!"
    Dec "Dirígete directamente a la entrada. Se abrirá para ti. ¡Ve!"

# game/scripts/day5.rpy:1650
translate spanish d5f_abrax_85f12b3b:

    # Dec "Enter..."
    Dec "Entra..."

# game/scripts/day5.rpy:1651
translate spanish d5f_abrax_5ab3574d:

    # Z "..."
    Z "..."

# game/scripts/day5.rpy:1654
translate spanish d5f_abrax_ce4c816f:

    # "{i}You are led inside and instructed to wait for Lord Abrax to come complete his rounds."
    "{i}Te conducen al interior y te indican que esperes a que Lord Abrax venga a completar su ronda."

# game/scripts/day5.rpy:1655
translate spanish d5f_abrax_f0eca879:

    # "{i}Eventually, he comes back to what appears to be his place of residence..."
    "{i}Eventualmente, llegas a lo que parece ser su lugar de residencia,..."

# game/scripts/day5.rpy:1658
translate spanish d5f_abrax_fd4652be:

    # Dec "He is here. Go before him."
    Dec "Él está aquí. Ve delante de él."

# game/scripts/day5.rpy:1661
translate spanish d5f_abrax_5ab3574d_1:

    # Z "..."
    Z "..."

# game/scripts/day5.rpy:1664
translate spanish d5f_abrax_9e9f6b3a_3:

    # LA "..."
    LA "..."

# game/scripts/day5.rpy:1669
translate spanish d5f_abrax_3cc4d33d:

    # Z "What is this place?"
    Z "¿Qué es este lugar?"

# game/scripts/day5.rpy:1670
translate spanish d5f_abrax_9e9f6b3a_4:

    # LA "..."
    LA "..."

# game/scripts/day5.rpy:1675
translate spanish d5f_abrax_709a7e26:

    # LA "A legacy of the past..."
    LA "Un legado del pasado..."

# game/scripts/day5.rpy:1676
translate spanish d5f_abrax_cb941d24:

    # LA "...and now, my home."
    LA "... y ahora, mi hogar."

# game/scripts/day5.rpy:1679
translate spanish d5f_abrax_5ab3574d_2:

    # Z "..."
    Z "..."

# game/scripts/day5.rpy:1683
translate spanish d5f_abrax_8d4327cb:

    # Z "I demand answers."
    Z "Exijo respuestas."

# game/scripts/day5.rpy:1684
translate spanish d5f_abrax_9e9f6b3a_5:

    # LA "..."
    LA "..."

# game/scripts/day5.rpy:1689
translate spanish d5f_abrax_253e9c03:

    # LA "And you will get them, in time."
    LA "Y los recibirás, a tiempo."

# game/scripts/day5.rpy:1692
translate spanish d5f_abrax_6e037dd7:

    # Z "...?"
    Z "¿...?"

# game/scripts/day5.rpy:1696
translate spanish d5f_abrax_ed30c2d7:

    # Z "What is this freakshow..."
    Z "¿Qué es este espectáculo de locos...?"

# game/scripts/day5.rpy:1697
translate spanish d5f_abrax_9e9f6b3a_6:

    # LA "..."
    LA "..."

# game/scripts/day5.rpy:1700
translate spanish d5f_abrax_9e9f6b3a_7:

    # LA "..."
    LA "..."

# game/scripts/day5.rpy:1701
translate spanish d5f_abrax_6e037dd7_1:

    # Z "...?"
    Z "¿...?"

# game/scripts/day5.rpy:1708
translate spanish d5f_abrax_questions_b129da36:

    # Z "Who are you?"
    Z "¿Quién eres tú?"

# game/scripts/day5.rpy:1709
translate spanish d5f_abrax_questions_9e9f6b3a:

    # LA "..."
    LA "..."

# game/scripts/day5.rpy:1712
translate spanish d5f_abrax_questions_d2c4e078:

    # LA "Time has passed..."
    LA "Ha pasado el tiempo..."

# game/scripts/day5.rpy:1713
translate spanish d5f_abrax_questions_181e83a8:

    # LA "It has been many years, [persistent.player_name]."
    LA "Han pasado muchos años, [persistent.player_name]."

# game/scripts/day5.rpy:1717
translate spanish d5f_abrax_questions_7c051698:

    # Z "...?!"
    Z "¡¿...?!"

# game/scripts/day5.rpy:1720
translate spanish d5f_abrax_questions_06c1c4a3:

    # Zt "This can't be..."
    Zt "Esto no puede ser..."

# game/scripts/day5.rpy:1724
translate spanish d5f_abrax_questions_b8c57b6e:

    # Z "But Master Zosar, you can't be leaving."
    Z "Pero Maestro Zosar, no puedes irte."

# game/scripts/day5.rpy:1725
translate spanish d5f_abrax_questions_368f7cb1:

    # Z "{i}You may have been to a few Zones, but you still have much to learn.{/i} Those were {i}your{/i} words"
    Z "{i}Puede que hayas estado en algunas Zonas, pero todavía tienes mucho que aprender.{/i} Esas fueron {i}tus{/i} palabras."

# game/scripts/day5.rpy:1726
translate spanish d5f_abrax_questions_be5dbc5a:

    # Z "Please, think about it."
    Z "Por favor, piensa en ello."

# game/scripts/day5.rpy:1729
translate spanish d5f_abrax_questions_64f54bba:

    # Zo "I have made my decision, [persistent.player_name]."
    Zo "He tomado mi decisión, [persistent.player_name]."

# game/scripts/day5.rpy:1730
translate spanish d5f_abrax_questions_bd45eb65:

    # Zo "I never said I would be the one to teach you. I have given you the foundations. Now experience will be your teacher."
    Zo "Nunca dije que sería yo quien te enseñaría. Te he dado las bases. Ahora la experiencia será tu maestra."

# game/scripts/day5.rpy:1732
translate spanish d5f_abrax_questions_e83d3706:

    # Zo "You know how to protect yourself."
    Zo "Sabes cómo protegerte."

# game/scripts/day5.rpy:1733
translate spanish d5f_abrax_questions_ed2b1f6f:

    # Zo "You passed all the trials you faced so far."
    Zo "Has superado todas las pruebas a las que te has enfrentado hasta ahora."

# game/scripts/day5.rpy:1734
translate spanish d5f_abrax_questions_b425b775:

    # Zo "And one day, you will stand where I am standing."
    Zo "Y un día, estarás donde yo estoy."

# game/scripts/day5.rpy:1735
translate spanish d5f_abrax_questions_fe49c120:

    # Zo "Maybe then you will understand the decision I have made today."
    Zo "Quizá entonces comprendas la decisión que he tomado hoy."

# game/scripts/day5.rpy:1738
translate spanish d5f_abrax_questions_a5c4d600:

    # Z "Will you come back, Master?"
    Z "¿Volverás, amo?"

# game/scripts/day5.rpy:1741
translate spanish d5f_abrax_questions_eddd051d:

    # Zo "Nobody has ever returned from the Long Walk."
    Zo "Nadie ha regresado nunca de la Larga Marcha."

# game/scripts/day5.rpy:1742
translate spanish d5f_abrax_questions_a38ae182:

    # Zo "I have chosen my path."
    Zo "He elegido mi camino."

# game/scripts/day5.rpy:1743
translate spanish d5f_abrax_questions_d92d0179:

    # Zo "Now go and prepare yourself, my old student."
    Zo "Ahora ve y prepárate, mi viejo alumno."

# game/scripts/day5.rpy:1744
translate spanish d5f_abrax_questions_177b63c4:

    # Zo "Do not forget that Zeta may be your home, but it does not have to be your destiny."
    Zo "No olvides que Zeta puede ser tu hogar, pero no tiene que ser tu destino."

# game/scripts/day5.rpy:1745
translate spanish d5f_abrax_questions_915ad6c3:

    # Zo "As for me... a true Stalker knows to find peace in solitude. That is the road I will travel."
    Zo "En cuanto a mí... un verdadero Acechador sabe encontrar la paz en la soledad. Ese es el camino que recorreré."

# game/scripts/day5.rpy:1746
translate spanish d5f_abrax_questions_d9a326fc:

    # Zo "Goodbye, [persistent.player_name]."
    Zo "Adiós, [persistent.player_name]."

# game/scripts/day5.rpy:1749
translate spanish d5f_abrax_questions_0f5413aa:

    # Zt "That was the last time I saw him."
    Zt "Esa fue la última vez que lo vi."

# game/scripts/day5.rpy:1752
translate spanish d5f_abrax_questions_e5f46c56:

    # Zt " I think some 20 years must have passed since then..."
    Zt "Creo que deben haber pasado unos 20 años desde entonces..."

# game/scripts/day5.rpy:1755
translate spanish d5f_abrax_questions_fa8101b2:

    # Zt "Yes, that's right, because that's when I was still with Rabiah and had just met her younger sister [W], who then became my wife."
    Zt "Sí, así es, porque fue cuando aún estaba con Rabiah y acababa de conocer a su hermana menor [W], quien luego se convirtió en mi mujer."

# game/scripts/day5.rpy:1756
translate spanish d5f_abrax_questions_11470a28:

    # Zt "20 years have passed since our marriage, and I think I have a better understanding of what [Zo] was saying..."
    Zt "Han pasado 20 años desde nuestro matrimonio, y creo que ahora entiendo mejor lo que decía [Zo]..."

# game/scripts/day5.rpy:1757
translate spanish d5f_abrax_questions_4c2694d6:

    # Zt "Zeta is my home, but my destiny is what I build for myself."
    Zt "Zeta es mi hogar, pero mi destino es lo que construyo por mí mismo."

# game/scripts/day5.rpy:1760
translate spanish d5f_abrax_questions_9e9f6b3a_1:

    # LA "..."
    LA "..."

# game/scripts/day5.rpy:1763
translate spanish d5f_abrax_questions_048d2b02:

    # Z "Master [Zo]."
    Z "Amo [Zo]."

# game/scripts/day5.rpy:1766
translate spanish d5f_abrax_questions_5ab3574d:

    # Z "..."
    Z "..."

# game/scripts/day5.rpy:1769
translate spanish d5f_abrax_questions_02e32a52:

    # LA "Yes. That was my name once."
    LA "Sí. Ese era mi nombre una vez."

# game/scripts/day5.rpy:1770
translate spanish d5f_abrax_questions_2cf7cd59:

    # LA "But time passes..."
    LA "Pero el tiempo pasa..."

# game/scripts/day5.rpy:1771
translate spanish d5f_abrax_questions_083c2f42:

    # LA "And in this world, the past matters little to those who live in the present."
    LA "Y en este mundo, el pasado importa poco a los que viven en el presente."

# game/scripts/day5.rpy:1778
translate spanish d5f_abrax_questions_02bea513:

    # Z "What do you mean by 'the past matters little'?"
    Z "¿Qué quieres decir con\"el pasado importa poco'?"

# game/scripts/day5.rpy:1781
translate spanish d5f_abrax_questions_28d0880c:

    # LA "Look around you, [persistent.player_name]."
    LA "Mira a tu alrededor, [persistent.player_name]."

# game/scripts/day5.rpy:1782
translate spanish d5f_abrax_questions_3a96e215:

    # LA "We live in old ruins, hide from the storms, kill mutants and try to build yet another functioning civilization."
    LA "Vivimos en viejas ruinas, nos escondemos de las tormentas, matamos mutantes e intentamos construir otra civilización que funcione."

# game/scripts/day5.rpy:1783
translate spanish d5f_abrax_questions_63d4e8ce:

    # LA "Billions of people used to live on this planet."
    LA "Miles de millones de personas vivían en este planeta."

# game/scripts/day5.rpy:1784
translate spanish d5f_abrax_questions_5789b01a:

    # LA "They are all gone, now..."
    LA "Todos se han ido, ahora..."

# game/scripts/day5.rpy:1785
translate spanish d5f_abrax_questions_2c7aa573:

    # LA "...and so is everything they held dear, everything they hoped for, everything they accomplished."
    LA "... y eso es todo lo que apreciaban, todo lo que esperaban, todo lo que lograron."

# game/scripts/day5.rpy:1786
translate spanish d5f_abrax_questions_4ed15de3:

    # LA "Those who live die, and eventually, in time, we too will perish..."
    LA "Los que viven mueren, y al final, con el tiempo, nosotros también pereceremos..."

# game/scripts/day5.rpy:1793
translate spanish d5f_abrax_questions_b88c81f5:

    # Z "Who are these women?"
    Z "¿Quiénes son estas mujeres?"

# game/scripts/day5.rpy:1796
translate spanish d5f_abrax_questions_3ee81d05:

    # LA "These are my wives..."
    LA "Estas son mis esposas..."

# game/scripts/day5.rpy:1799
translate spanish d5f_abrax_questions_ff0b8792:

    # LA "They vowed to stay by my side..."
    LA "Juraron permanecer a mi lado..."

# game/scripts/day5.rpy:1800
translate spanish d5f_abrax_questions_28d401b8:

    # LA "For better and for worse..."
    LA "Para bien y para mal..."

# game/scripts/day5.rpy:1803
translate spanish d5f_abrax_questions_7423aace:

    # LA "...till death do us part."
    LA "... hasta que la muerte nos separe."

# game/scripts/day5.rpy:1808
translate spanish d5f_abrax_questions_795206c6:

    # Z "You're killing them."
    Z "Las estás matando."

# game/scripts/day5.rpy:1811
translate spanish d5f_abrax_questions_5c43a833:

    # "{i}You notice one of them looking at you..."
    "{i}Notas que una de ellas te mira..."

# game/scripts/day5.rpy:1812
translate spanish d5f_abrax_questions_29a5b633:

    # Z "They are not decayed."
    Z "Ellas no son decaídas."

# game/scripts/day5.rpy:1813
translate spanish d5f_abrax_questions_e137d07d:

    # Z "These gas masks won't help, in the long run."
    Z "Esas máscaras antigás no servirán de nada a largo plazo."

# game/scripts/day5.rpy:1814
translate spanish d5f_abrax_questions_1765fbe0:

    # Z "They are wasting away and you know it."
    Z "Se están descomponiendo y lo sabes."

# game/scripts/day5.rpy:1817
translate spanish d5f_abrax_questions_9b2dc801:

    # LA "They took the vow."
    LA "Hicieron el voto."

# game/scripts/day5.rpy:1820
translate spanish d5f_abrax_questions_5ab3574d_1:

    # Z "..."
    Z "..."

# game/scripts/day5.rpy:1823
translate spanish d5f_abrax_questions_911eb465:

    # LA "Tell me, [persistent.player_name]..."
    LA "Dime, [persistent.player_name]..."

# game/scripts/day5.rpy:1824
translate spanish d5f_abrax_questions_5b0a4fe2:

    # LA "Are you always there to protect your loved ones..."
    LA "¿Siempre estás ahí para proteger a tus seres queridos...?"

# game/scripts/day5.rpy:1825
translate spanish d5f_abrax_questions_aaf84429:

    # LA "...Or are they merely lucky to live in a safe environment while you are gone?"
    LA "... ¿o simplemente tienen la suerte de vivir en un entorno seguro mientras tú no estás?"

# game/scripts/day5.rpy:1828
translate spanish d5f_abrax_questions_5ab3574d_2:

    # Z "..."
    Z "..."

# game/scripts/day5.rpy:1831
translate spanish d5f_abrax_questions_29b727f4:

    # Z "You never let go of women."
    Z "Nunca dejas ir a las mujeres."

# game/scripts/day5.rpy:1832
translate spanish d5f_abrax_questions_ad1d19e3:

    # Z "Neither back then, nor now."
    Z "Ni antes, ni ahora."

# game/scripts/day5.rpy:1833
translate spanish d5f_abrax_questions_167dd4ca:

    # Z "Your real wife died, and you know that."
    Z "Tu verdadera esposa murió, y lo sabes."

# game/scripts/day5.rpy:1836
translate spanish d5f_abrax_questions_8fac01a4:

    # LA "I laid with countless women, back in the day."
    LA "Me acosté con innumerables mujeres, en su día."

# game/scripts/day5.rpy:1837
translate spanish d5f_abrax_questions_cfe0d94f:

    # LA "Some were weaker, some were even stronger than me."
    LA "Algunas eran más débiles, otras incluso más fuertes que yo."

# game/scripts/day5.rpy:1838
translate spanish d5f_abrax_questions_a8dd50b9:

    # LA "Some could stand up for themselves, and others could not."
    LA "Algunas podían defenderse, y otras no."

# game/scripts/day5.rpy:1841
translate spanish d5f_abrax_questions_2c9a9f57:

    # LA "Can you guess what type of woman sits besides me now...?"
    LA "¿Puedes adivinar qué tipo de mujer se sienta ahora a mi lado...?"

# game/scripts/day5.rpy:1844
translate spanish d5f_abrax_questions_ad63b803:

    # Abrw "..."
    Abrw "..."

# game/scripts/day5.rpy:1850
translate spanish d5f_abrax_questions_d134885a:

    # Z "Is this your version of the Zetan rules?"
    Z "¿Es ésta tu versión de las reglas zetanas?"

# game/scripts/day5.rpy:1851
translate spanish d5f_abrax_questions_d4c892bb:

    # Z "You take what you can and what you can defend is yours..."
    Z "Coges lo que puedes y lo que puedes defender es tuyo..."

# game/scripts/day5.rpy:1852
translate spanish d5f_abrax_questions_06eb1500:

    # Z "...with no consideration for others wellbeing?"
    Z "... sin ninguna consideración por el bienestar de los demás..."

# game/scripts/day5.rpy:1855
translate spanish d5f_abrax_questions_947273aa:

    # LA "What of it? What if it were?"
    LA "¿Y qué? ¿Y si fuera así?"

# game/scripts/day5.rpy:1856
translate spanish d5f_abrax_questions_b7aa44e6:

    # LA "Am I not in keeping with Zetan tradition?"
    LA "¿No estoy en consonancia con la tradición zetánica?"

# game/scripts/day5.rpy:1857
translate spanish d5f_abrax_questions_02e55108:

    # LA "The strong rule the weak. That's what it comes down to, always."
    LA "Los fuertes gobiernan a los débiles. A eso se reduce todo, siempre."

# game/scripts/day5.rpy:1864
translate spanish d5f_abrax_questions_ef6ee5c7:

    # Z "What have you been doing all these years?"
    Z "¿Qué has estado haciendo todos estos años?"

# game/scripts/day5.rpy:1867
translate spanish d5f_abrax_questions_83c4a147:

    # LA "The Long Walk is different for all who take it, and shall not be questioned by anyone but those who take it."
    LA "La Larga Marcha es diferente para todos los que la emprenden, y no será cuestionada por nadie más que por los que la emprenden."

# game/scripts/day5.rpy:1868
translate spanish d5f_abrax_questions_22073c77:

    # LA "You are not ready yet. Perhaps you never will be."
    LA "Todavía no estás preparado. Quizás nunca lo estés."

# game/scripts/day5.rpy:1876
translate spanish d5f_abrax_questions_3edce583:

    # Z "We need to talk about the train station..."
    Z "Necesitamos hablar de la estación de tren..."

# game/scripts/day5.rpy:1879
translate spanish d5f_abrax_questions_67950329:

    # LA "You may ask."
    LA "Puede preguntar."

# game/scripts/day5.rpy:1885
translate spanish d5f_abrax_questions_68b8b875:

    # Z "Why did you bring me here?"
    Z "¿Por qué me has traído aquí?"

# game/scripts/day5.rpy:1888
translate spanish d5f_abrax_questions_9c4fd7d1:

    # LA "You are here because I want to make you an offer."
    LA "Estás aquí porque quiero hacerte una oferta."

# game/scripts/day5.rpy:1889
translate spanish d5f_abrax_questions_ce5e671f:

    # LA "An offer to save those you hold dear."
    LA "Una oferta para salvar a quienes más quieres."

# game/scripts/day5.rpy:1890
translate spanish d5f_abrax_questions_dabda0c4:

    # LA "An offer to give your children a better future..."
    LA "Una oferta para dar a tus hijas un futuro mejor..."

# game/scripts/day5.rpy:1893
translate spanish d5f_abrax_questions_a07538c1:

    # Z "Tell me more."
    Z "Cuéntame más."

# game/scripts/day5.rpy:1896
translate spanish d5f_abrax_questions_e503496c:

    # LA "When they were on a raid, my soldiers found a map..."
    LA "When they were on a raid, my soldiers found a map..."

# game/scripts/day5.rpy:1897
translate spanish d5f_abrax_questions_fe71dc40:

    # LA "My studies lead me to believe that the map leads to a place which holds a key to what plagues us all..."
    LA "Mis estudios me llevan a creer que el mapa conduce a un lugar que contiene la clave de lo que nos atormenta a todos..."

# game/scripts/day5.rpy:1900
translate spanish d5f_abrax_questions_8be2edef:

    # Z "What do you mean by that?"
    Z "¿Qué quieres decir con eso?"

# game/scripts/day5.rpy:1901
translate spanish d5f_abrax_questions_e8e53ced:

    # Z "What plagues us all?"
    Z "¿Qué es lo que nos atormenta a todos?"

# game/scripts/day5.rpy:1904
translate spanish d5f_abrax_questions_6a69a0ee:

    # LA "You know it very well..."
    LA "Lo sabes muy bien..."

# game/scripts/day5.rpy:1905
translate spanish d5f_abrax_questions_edb4381a:

    # LA "...and you also know that as long as it exists, your civilization will never find true peace."
    LA "... y también sabes que mientras exista, vuestra civilización nunca encontrará la verdadera paz."

# game/scripts/day5.rpy:1908
translate spanish d5f_abrax_questions_014e022d:

    # Z "You talk in riddles even more than you used to do."
    Z "Hablas con acertijos incluso más de lo que solías hacerlo."

# game/scripts/day5.rpy:1909
translate spanish d5f_abrax_questions_a71394d7:

    # Z "I need to know what I'm getting myself into."
    Z "Necesito saber en qué me estoy metiendo."

# game/scripts/day5.rpy:1912
translate spanish d5f_abrax_questions_be1b7a20:

    # LA "From what I have heard..."
    LA "Por lo que he oído..."

# game/scripts/day5.rpy:1913
translate spanish d5f_abrax_questions_88c0807b:

    # LA "...it will not be you who takes this on..."
    LA "... no serás tú quien se encargue de esto..."

# game/scripts/day5.rpy:1916
translate spanish d5f_abrax_questions_6e037dd7:

    # Z "...?"
    Z "¿...?"

# game/scripts/day5.rpy:1919
translate spanish d5f_abrax_questions_2c153a15:

    # LA "The map leads to an old building that happens to be in a new zone."
    LA "El mapa conduce a un viejo edificio que resulta estar en una zona nueva."

# game/scripts/day5.rpy:1920
translate spanish d5f_abrax_questions_8edec8c7:

    # LA "It is... unfortunate... that the zone should appear right in that area."
    LA "Es... desafortunado... que la zona aparezca justo en esa zona."

# game/scripts/day5.rpy:1921
translate spanish d5f_abrax_questions_d19b48db:

    # LA "I know you have a [persistent.da] who will soon follow in your footsteps."
    LA "Sé que tienes una [persistent.da] que pronto seguirá tus pasos."

# game/scripts/day5.rpy:1922
translate spanish d5f_abrax_questions_c9062508:

    # LA "When you send her to the Zone, I ask that you give her my map, and tell her to explore the marked building."
    LA "Cuando la envíes a la Zona, te pido que le des mi mapa y le digas que explore el edificio marcado."

# game/scripts/day5.rpy:1923
translate spanish d5f_abrax_questions_ae1a475c:

    # LA "I don't expect you to bring me what she might find."
    LA "No espero que me traigas lo que pueda encontrar."

# game/scripts/day5.rpy:1924
translate spanish d5f_abrax_questions_de48a541:

    # LA "But, should she be successful, I want you to let me know about it, and confirm to me that there was actually something to find."
    LA "Pero, en caso de que tenga éxito, quiero que me lo comuniques y me confirmes que realmente había algo que encontrar."

# game/scripts/day5.rpy:1933
translate spanish d5f_abrax_shani_1a410ca5:

    # Z "How do you know I have a [persistent.da]?"
    Z "¿Cómo sabes que tengo una [persistent.da]?"

# game/scripts/day5.rpy:1936
translate spanish d5f_abrax_shani_b763bc80:

    # LA "When you infiltrated the compound, no doubt under orders of your queen, my people were watching."
    LA "Cuando te infiltraste en el recinto, sin duda bajo las órdenes de tu reina, mi gente estaba observando."

# game/scripts/day5.rpy:1939
translate spanish d5f_abrax_shani_ccca123a:

    # Z "The decayed in that building... they mentioned you."
    Z "Los Decaídos en ese edificio... mencionaron algo sobre ti."

# game/scripts/day5.rpy:1942
translate spanish d5f_abrax_shani_177f15db:

    # LA "They were a nuisance."
    LA " Ellos eran una molestia."

# game/scripts/day5.rpy:1943
translate spanish d5f_abrax_shani_5a469b5d:

    # LA "My men got rid of them right after you left."
    LA "Mis hombres se deshicieron de ellos justo después de que te fuiste."

# game/scripts/day5.rpy:1944
translate spanish d5f_abrax_shani_fbdbd858:

    # LA "Even if there were only a handful left... I had to make sure they stopped the aimless raids... permanently."
    LA "Incluso si quedaban solo unos pocos... Tenía que asegurarme de que dejaran de hacer incursiones sin sentido... permanentemente."

# game/scripts/day5.rpy:1945
translate spanish d5f_abrax_shani_2699829a:

    # LA "I assume you know that the ones you call decayed are not a single group. I am changing that."
    LA "Asumo que sabes que los que llamas descompuestos no son un solo grupo. Estoy cambiando eso."

# game/scripts/day5.rpy:1946
translate spanish d5f_abrax_shani_a944eb4e:

    # LA "However... not everyone accepts change willingly."
    LA "Sin embargo... no todos aceptan el cambio con facilidad."

# game/scripts/day5.rpy:1953
translate spanish d5f_abrax_shani_e8d10881:

    # Z "We don't know exactly where the zone lies."
    Z "No sabemos exactamente dónde está la Zona."

# game/scripts/day5.rpy:1956
translate spanish d5f_abrax_shani_46d8280f:

    # LA "I do."
    LA "Yo si."

# game/scripts/day5.rpy:1957
translate spanish d5f_abrax_shani_50f7bf0e:

    # LA "My soldiers found the place."
    LA "My soldiers found the place."

# game/scripts/day5.rpy:1958
translate spanish d5f_abrax_shani_1722aaf3:

    # LA "But as you well know..."
    LA "Pero como bien sabes..."

# game/scripts/day5.rpy:1959
translate spanish d5f_abrax_shani_d638bf89:

    # LA "...the zone is not a place for mere soldiers."
    LA "...the zone is not a place for mere soldiers."

# game/scripts/day5.rpy:1960
translate spanish d5f_abrax_shani_6d93cecd:

    # LA "Which is why I ask your [persistent.da] to take care of this matter."
    LA "Por eso te pido a tí [persistent.da] que te ocupes de este asunto."

# game/scripts/day5.rpy:1967
translate spanish d5f_abrax_shani_ff792d6a:

    # Z "What exactly are we looking for?"
    Z "¿Qué buscamos exactamente?"

# game/scripts/day5.rpy:1970
translate spanish d5f_abrax_shani_2ab55a3e:

    # LA "Your [persistent.da] will know as soon as she lays her eyes on it..."
    LA "Tu [persistent.da] lo sabrá en cuanto ponga sus ojos en ello..."

# game/scripts/day5.rpy:1976
translate spanish d5f_abrax_shani_945356e2:

    # Zt "Whether or not I can trust him, if [S] truly is about to face a new uncharted zone, having that map could be crucial to her survival."
    Zt "Tanto si puedo confiar en él como si no, si [S] está a punto de enfrentarse a una nueva zona inexplorada, tener ese mapa podría ser crucial para su supervivencia."

# game/scripts/day5.rpy:1977
translate spanish d5f_abrax_shani_1f3eeda0:

    # Z "I will take your map."
    Z "Cogeré tu mapa."

# game/scripts/day5.rpy:1979
translate spanish d5f_abrax_shani_fc95a659:

    # Z "And I will tell [S] to look out for whatever you're trying to find."
    Z "Y le diré a [S] que busque lo que sea que intente encontrar."

# game/scripts/day5.rpy:1982
translate spanish d5f_abrax_shani_e381ba60:

    # LA "Her name is [S]..."
    LA "Se llama [S]..."

# game/scripts/day5.rpy:1983
translate spanish d5f_abrax_shani_3943c2c5:

    # LA "So be it."
    LA "Que así sea."

# game/scripts/day5.rpy:1984
translate spanish d5f_abrax_shani_ca25735e:

    # LA "My guards will escort you and the map back to your car."
    LA "Mis guardias te acompañarán a ti y al mapa de vuelta a tu coche."

# game/scripts/day5.rpy:1985
translate spanish d5f_abrax_shani_e63679da:

    # LA "We will provide you with enough fuel for what lies ahead."
    LA "Te proporcionaremos suficiente combustible para lo que te espera."

# game/scripts/day5.rpy:1988
translate spanish d5f_abrax_shani_5ab3574d:

    # Z "..."
    Z "..."

# game/scripts/day5.rpy:1991
translate spanish d5f_abrax_shani_c0b61923:

    # LA "The end of the plague has begun."
    LA "El fin de la plaga ha comenzado."

# game/scripts/day5.rpy:1992
translate spanish d5f_abrax_shani_1c1a6237:

    # LA "I hope we meet again soon, [persistent.player_name]."
    LA "Espero que nos volvamos a ver pronto, [persistent.player_name]."

# game/scripts/day5.rpy:1993
translate spanish d5f_abrax_shani_c7cde0f0:

    # LA "Guards..."
    LA "Guardias..."

# game/scripts/day5.rpy:1996
translate spanish d5f_abrax_shani_1aaacbb8:

    # "The guards hand you the map and lead you back to the train station."
    "Los guardias te entregan el mapa y te llevan de vuelta a la estación de tren."

# game/scripts/day5.rpy:1997
translate spanish d5f_abrax_shani_1a931542:

    # "Upon looking at it, it seems to be a blueprint of an old industrial complex."
    "Al mirarlo, parece un plano de un antiguo complejo industrial."

# game/scripts/day5.rpy:1998
translate spanish d5f_abrax_shani_65256b76:

    # "A handwritten note marks a room in one of the buildings."
    "Una nota manuscrita marca una habitación de uno de los edificios."

# game/scripts/day5.rpy:1999
translate spanish d5f_abrax_shani_467bd2e2:

    # "You decide to look at it later, together with [S]."
    "Decides mirarlo más tarde, junto con [S]."

# game/scripts/day5.rpy:2001
translate spanish d5f_abrax_shani_fb1e7da8:

    # "You eventually arrive home..."
    "Finalmente llegas a tu casa..."

# game/scripts/day5.rpy:2008
translate spanish d5f_abrax_ethics_d8672f6b:

    # Z "You are slaughtering people like animals."
    Z "Estás masacrando a la gente como si fueran animales."

# game/scripts/day5.rpy:2009
translate spanish d5f_abrax_ethics_f7b3266f:

    # Z "I know that the decayed are cannibals."
    Z "Sé que los decaídos son caníbales."

# game/scripts/day5.rpy:2010
translate spanish d5f_abrax_ethics_9fe41349:

    # Z "But seeing it done on an industrial scale..."
    Z "Pero ver cómo se hace a escala industrial..."

# game/scripts/day5.rpy:2011
translate spanish d5f_abrax_ethics_b3b24d3b:

    # Z "...why?"
    Z "... ¿por qué?"

# game/scripts/day5.rpy:2014
translate spanish d5f_abrax_ethics_e96c1445:

    # LA "My people need to feed."
    LA "Mi pueblo necesita alimentarse."

# game/scripts/day5.rpy:2015
translate spanish d5f_abrax_ethics_9cf3807b:

    # LA "Old Cairo offers no ways to grow or flourish."
    LA "el Viejo Cairo no ofrece formas de crecer o florecer."

# game/scripts/day5.rpy:2016
translate spanish d5f_abrax_ethics_71c35f8a:

    # LA "So we do what humans always did, and still do..."
    LA "Así que hacemos lo que los humanos siempre hicieron, y siguen haciendo..."

# game/scripts/day5.rpy:2017
translate spanish d5f_abrax_ethics_c3668b17:

    # LA "...we survive at all costs."
    LA "... sobrevivimos a toda costa."

# game/scripts/day5.rpy:2020
translate spanish d5f_abrax_ethics_237157c3:

    # Z "Why don't you leave Old Cairo?"
    Z "¿Por qué no dejas el Viejo Cairo?"

# game/scripts/day5.rpy:2021
translate spanish d5f_abrax_ethics_18e00539:

    # Z "Eating people... living in this toxic environment..."
    Z "Comerse a la gente... vivir en este entorno tóxico..."

# game/scripts/day5.rpy:2022
translate spanish d5f_abrax_ethics_265e4b22:

    # Z "You don't have to live like this."
    Z "No tienes que vivir así."

# game/scripts/day5.rpy:2025
translate spanish d5f_abrax_ethics_98d04793:

    # LA "I ask you, [persistent.player_name]..."
    LA "Te pregunto, [persistent.player_name]..."

# game/scripts/day5.rpy:2026
translate spanish d5f_abrax_ethics_5f729ddd:

    # LA "When did humans ever willingly sacrifice infrastructure and progress for sustainability?"
    LA "¿Cuándo los humanos han sacrificado voluntariamente las infraestructuras y el progreso por la sostenibilidad?"

# game/scripts/day5.rpy:2027
translate spanish d5f_abrax_ethics_a691010f:

    # LA "I have seen pictures of the past."
    LA "He visto imágenes del pasado."

# game/scripts/day5.rpy:2028
translate spanish d5f_abrax_ethics_4e8bd07e:

    # LA "Whether it was the air in Beijing, the tainted river in New Delhi or the polluted streets of Berlin and Paris."
    LA "Ya sea el aire de Pekín, el río contaminado de Nueva Delhi o las calles contaminadas de Berlín y París."

# game/scripts/day5.rpy:2029
translate spanish d5f_abrax_ethics_b6c9cf18:

    # LA "The way we live now is not entirely different..."
    LA "La forma en que vivimos ahora no es del todo diferente..."

# game/scripts/day5.rpy:2030
translate spanish d5f_abrax_ethics_d4cc6112:

    # LA "...it is just one step further, in a world of even greater scarcity."
    LA "... es sólo un paso más, en un mundo de escasez aún mayor."

# game/scripts/day5.rpy:2033
translate spanish d5f_abrax_ethics_5ab3574d:

    # Z "..."
    Z "..."

# game/scripts/day5.rpy:2036
translate spanish d5f_abrax_ethics_5e09608d:

    # Z "You have a point."
    Z "Tienes razón."

# game/scripts/day5.rpy:2039
translate spanish d5f_abrax_ethics_6efbf8c9:

    # LA "I know."
    LA "Lo sé."

# game/scripts/day5.rpy:2040
translate spanish d5f_abrax_ethics_b6d7b947:

    # LA "Sadly, I do."
    LA "Lamentablemente, sí."

# game/scripts/day5.rpy:2049
translate spanish d5f_abrax_ethics_71a8600f:

    # Z "You are wrong."
    Z "Te equivocas."

# game/scripts/day5.rpy:2050
translate spanish d5f_abrax_ethics_22ea84e0:

    # Z "They didn't eat people back then and they didn't turn into living mummies either."
    Z "Entonces no se comían a la gente y tampoco se convertían en momias vivientes."

# game/scripts/day5.rpy:2053
translate spanish d5f_abrax_ethics_4543bf44:

    # LA "They did."
    LA "Lo hacían."

# game/scripts/day5.rpy:2054
translate spanish d5f_abrax_ethics_2931cee9:

    # LA "Just not in the way we are."
    LA "Sólo que no en la forma en que estamos ahora"

# game/scripts/day5.rpy:2065
translate spanish d5f_abrax_ethics_62fda746:

    # Z "You have working trains..."
    Z "Tiene trenes en funcionamiento..."

# game/scripts/day5.rpy:2066
translate spanish d5f_abrax_ethics_411e5e5b:

    # Z "Do they lead to the fuel refineries?"
    Z "¿Llegan a las refinerías de combustible?"

# game/scripts/day5.rpy:2069
translate spanish d5f_abrax_ethics_592cc7e3:

    # LA "They do."
    LA "Lo hacen."

# game/scripts/day5.rpy:2070
translate spanish d5f_abrax_ethics_5efa5c5b:

    # LA "We have established the largest faction within the decayed."
    LA "Hemos establecido la mayor facción dentro de los decaídos."

# game/scripts/day5.rpy:2071
translate spanish d5f_abrax_ethics_74cd0a81:

    # LA "All the other groups you see..."
    LA "Todos los otros grupos que ves..."

# game/scripts/day5.rpy:2072
translate spanish d5f_abrax_ethics_ad390fce:

    # LA "...the group you bought fuel from..."
    LA "... el grupo al que compraste combustible..."

# game/scripts/day5.rpy:2073
translate spanish d5f_abrax_ethics_f39955d6:

    # LA "...they are, directly or indirectly, dependent on us."
    LA "... dependen, directa o indirectamente, de nosotros."

# game/scripts/day5.rpy:2084
translate spanish d5c_a962ada6:

    # "{i}You enter the basement..."
    "{i}Entras en el sótano..."

# game/scripts/day5.rpy:2087
translate spanish d5c_0211e33c:

    # Ky "...There you are. Couldn't get enough of me, could you?"
    Ky "... Ahí estás. No pudiste resistirte a mí, ¿verdad?"

# game/scripts/day5.rpy:2090
translate spanish d5c_be26c679:

    # Ky "So... have you made up your mind?!"
    Ky "Y bien... ¿te has quedado con ganas de más o qué?"

# game/scripts/day5.rpy:2095
translate spanish d5c_f038f23c:

    # Z "We will go to Adira."
    Z "Iremos a Adira."

# game/scripts/day5.rpy:2099
translate spanish d5c_887715a7:

    # Ky "Are you sure you want to leave now?"
    Ky "¿Estás seguro de que quieres irte ahora?"

# game/scripts/day5.rpy:2100
translate spanish d5c_7c523277:

    # Ky "Your wife said something about coming down here soon. Ask her yourself."
    Ky "Tu esposa mencionó algo sobre bajar pronto. Pregúntale tú mismo."

# game/scripts/day5.rpy:2103
translate spanish d5c_386b9f3d:

    # Z "She did...?"
    Z "¿Ella lo hizo...?"

# game/scripts/day5.rpy:2106
translate spanish d5c_6bdd1584:

    # Z "I should better check, maybe it's something important."
    Z "Debería comprobarlo, tal vez sea algo importante."

# game/scripts/day5.rpy:2109
translate spanish d5c_81124808:

    # Ky "I'll be here waiting. Obviously..."
    Ky "Estaré aquí esperando. Evidentemente..."

# game/scripts/day5.rpy:2116
translate spanish d5c_18f0fdee:

    # Z "I'm sure that whatever it is, it can wait. Let's go."
    Z "Estoy seguro de que, sea lo que sea, puede esperar. Vamos."

# game/scripts/day5.rpy:2123
translate spanish d5c_306a13a3:

    # "She jumps up..."
    "Salta..."

# game/scripts/day5.rpy:2126
translate spanish d5c_2b351f72:

    # Ky "Haah... finally..."
    Ky "Haah... por fin..."

# game/scripts/day5.rpy:2129
translate spanish d5c_a9dad856:

    # Ky "You need a change of outfit, though. You will not make any friends dressed like that, Zetan."
    Ky "Necesitas un cambio de atuendo, sin embargo. No harás amigos vestido así, Zetan."

# game/scripts/day5.rpy:2130
translate spanish d5c_786cce2b:

    # Ky "Also... please tell me you're going to take this collar off of me..."
    Ky "Además... por favor, dime que vas a quitarme este collar..."

# game/scripts/day5.rpy:2131
translate spanish d5c_bb4d624c:

    # Ky "If I show up with a death necklace around my fucking neck, no one is going to take me seriously..."
    Ky "Si aparezco con un collar de la muerte en el puto cuello, nadie me va a tomar en serio..."

# game/scripts/day5.rpy:2134
translate spanish d5c_5ab3574d:

    # Z "..."
    Z "..."

# game/scripts/day5.rpy:2135
translate spanish d5c_6640a368:

    # Z "One wrong move and you're dead."
    Z "Un mal movimiento y estás muerta."

# game/scripts/day5.rpy:2138
translate spanish d5c_700f8b26:

    # Ky "Whatever you say, tough guy."
    Ky "Lo que digas, tipo duro."

# game/scripts/day5.rpy:2144
translate spanish d5c_9baa6ad5:

    # "{i}You take off her collar. She does not react, and you head outside..."
    "{i}La quitas el collar. Ella no reacciona y salís al exterior..."

# game/scripts/day5.rpy:2147
translate spanish d5c_35a67ac3:

    # Ky "..."
    Ky "..."

# game/scripts/day5.rpy:2150
translate spanish d5c_4a65fb06:

    # Ky "You have got to be fucking kidding me."
    Ky "Tiene que ser una puta broma."

# game/scripts/day5.rpy:2155
translate spanish d5c_e5a38bbf:

    # Ky "The door does not even work properly."
    Ky "La puerta ni siquiera funciona correctamente."

# game/scripts/day5.rpy:2160
translate spanish d5c_c213bd2c:

    # Z "The car got damaged in the storm."
    Z "El coche se dañó en la tormenta."

# game/scripts/day5.rpy:2161
translate spanish d5c_d737f745:

    # Z "It's still working though... now get in or start walking."
    Z "Sin embargo, sigue funcionando... Ahora entra o empieza a caminar."

# game/scripts/day5.rpy:2164
translate spanish d5c_bc831114:

    # Ky "Urgh... fine."
    Ky "Urgh... bien."

# game/scripts/day5.rpy:2169
translate spanish d5c_72ef7268:

    # Z "Just get in."
    Z "Sólo entra."

# game/scripts/day5.rpy:2172
translate spanish d5c_abd625eb:

    # Ky "Pff..."
    Ky "Pff..."

# game/scripts/day5.rpy:2177
translate spanish d5c_903a7d38:

    # Z "It was good enough to save your hide."
    Z "Fue lo suficientemente bueno como para salvar tu pellejo."

# game/scripts/day5.rpy:2178
translate spanish d5c_027b6767:

    # Z "In fact, if I hadn't had your dead weight to carry, we would have been ahead of the storm, instead of taking damage..."
    Z "De hecho, si no llego a tener que cargar con tu peso muerto, habríamos ido por delante de la tormenta, en vez de llevarnos daño..."

# game/scripts/day5.rpy:2179
translate spanish d5c_a63ab5d2:

    # Z "Besides, it's still less dusty than your pussy, so shut your trap and get in, or I'll tie you to the bonnet and slow roast you in the sun."
    Z "Además, eso sigue teniendo menos polvo que tu coño, así que cierra la puta boca y métete, o te ato al capó y te aso a fuego lento al sol."

# game/scripts/day5.rpy:2182
translate spanish d5c_eb247487:

    # Ky "Ouch... you didn't need to go there."
    Ky "Ouch... no hacía falta llegar hasta ahí."

# game/scripts/day5.rpy:2195
translate spanish d5c_38186a91:

    # Z "Yeah, I have made my decision. I don't trust a chick who's supposed sister tried to kill me."
    Z "Sí, ya tomé mi decisión. No me fío de una tía cuya supuesta hermana intentó matarme."

# game/scripts/day5.rpy:2198
translate spanish d5c_124bb6f9:

    # Ky "What the fuck does that have to do with...-"
    Ky "¿Qué coño tiene eso que ver con...?"

# game/scripts/day5.rpy:2201
translate spanish d5c_43eca9ad:

    # "You approach her, the remote in your hand..."
    "Te acercas a ella, el mando en tu mano..."

# game/scripts/day5.rpy:2204
translate spanish d5c_d9769c1f:

    # Z "We'll part ways, but I'm going to get my money's worth out of you first."
    Z "Nos separaremos, pero antes voy a sacarle provecho a mi dinero contigo."

# game/scripts/day5.rpy:2205
translate spanish d5c_cf328d6f:

    # Z "I'm selling you off. You can ask your new owner to take you to your sister; maybe he will be kinder to her than I was."
    Z "Te voy a vender. Puedes pedirle a tu nuevo dueño que te lleve con tu hermana; quizá sea más amable con ella de lo que yo fui."

# game/scripts/day5.rpy:2208
translate spanish d5c_ee8c02ab:

    # Ky "{i}*scoffs*{/i} You bald piece of shit, you really are serious. I should kill you on the spot..."
    Ky "{i}*bufa*{/i} Calvo de mierda, lo dices en serio. Debería matarte aquí mismo..."

# game/scripts/day5.rpy:2209
translate spanish d5c_79010240:

    # Z "Tall words, but... Remember that thing around your neck?"
    Z "Palabras mayores, pero... ¿recuerdas esa cosa que llevas al cuello?"

# game/scripts/day5.rpy:2212
translate spanish d5c_26afd70f:

    # Z "Turn around, I am going to tie you up. They wouldn't let your kind into the city otherwise."
    Z "Date la vuelta, voy a atarte. No dejarían entrar a tu calaña en la ciudad de otra forma."

# game/scripts/day5.rpy:2215
translate spanish d5c_35bb3ca7:

    # "After making sure she won't lash out, you make your way to the local slave market..."
    "Tras asegurarte de que no atacará, te diriges al mercado de esclavos local..."

# game/scripts/day5.rpy:2218
translate spanish d5c_fed22bc6:

    # Ky "Urgh... how the fuck did I get myself in this situation..."
    Ky "Urgh... ¿cómo coño acabé en esta situación...?"

# game/scripts/day5.rpy:2221
translate spanish d5c_487d8483:

    # Ky "All these disgusting, snobby \"citizens\"... They ain't a bit better than the scum in Adira..."
    Ky "Todos estos \"ciudadanos\" asquerosos y estirados... No son mejores que la escoria de Adira..."

# game/scripts/day5.rpy:2224
translate spanish d5c_f4ae665b:

    # Z "Shut up. Customer's coming. Make nice, because if I can't sell you here, there are places where I can sell you for parts."
    Z "Cállate. Viene un cliente. Pon buena cara, porque si no puedo venderte aquí, hay sitios donde te venderé por piezas."

# game/scripts/day5.rpy:2227
translate spanish d5c_d60842e7:

    # Ky "Mh?"
    Ky "¿Mh?"

# game/scripts/day5.rpy:2230
translate spanish d5c_dc57fbd0:

    # Sltr "That's an unusual one. Pale skin, pink hair..."
    Sltr "Esa es una inusual. Piel pálida, pelo rosa..."

# game/scripts/day5.rpy:2233
translate spanish d5c_ec83a955:

    # Sltr "How much?"
    Sltr "¿Cuánto?"

# game/scripts/day5.rpy:2234
translate spanish d5c_cc13042f:

    # Z "Depends on what you want to do with her."
    Z "Depende de lo que quieras hacer con ella."

# game/scripts/day5.rpy:2237
translate spanish d5c_883ec653:

    # Sltr "Let's say I have... friends in more polluted places."
    Sltr "Digamos que tengo... amigos en lugares más contaminados."

# game/scripts/day5.rpy:2240
translate spanish d5c_c058d443:

    # Sltr "They don't pay for her. It would be more of a donation than a real trade..."
    Sltr "Ellos no pagan por ella. Sería más una donación que un trato real..."

# game/scripts/day5.rpy:2241
translate spanish d5c_7480ab31:

    # Sltr "So I'm not getting much out of her."
    Sltr "Así que no saco mucho de ella."

# game/scripts/day5.rpy:2244
translate spanish d5c_97750af1:

    # Sltr "Show her off a little. It will help me decide."
    Sltr "Enséñamela un poco. Me ayudará a decidirme."

# game/scripts/day5.rpy:2245
translate spanish d5c_b7fc4d53:

    # Ky "Show her off?! {i}*sigh*{/i}"
    Ky "¿Enseñarme?! {i}*suspiro*{/i}"

# game/scripts/day5.rpy:2248
translate spanish d5c_e8d41a14:

    # Z "You heard her, get up."
    Z "Ya la oíste, levántate."

# game/scripts/day5.rpy:2251
translate spanish d5c_ce7f3247:

    # "She does so, after a few complaints..."
    "Lo hace, tras algunas quejas..."

# game/scripts/day5.rpy:2254
translate spanish d5c_6a8cb436:

    # Z "There, stand still."
    Z "Ahí, quédate quieta."

# game/scripts/day5.rpy:2255
translate spanish d5c_af3aadfa:

    # Ky "Whatever, asshole..."
    Ky "Lo que sea, capullo..."

# game/scripts/day5.rpy:2258
translate spanish d5c_601afa11:

