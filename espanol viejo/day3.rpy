translate spanish d3b_choice_515f9d08:

    # Z "If she is guilty, she deserves punishment."
    Z "Si ella es culpable, merece un castigo."

# game/scripts/day3.rpy:657
translate spanish d3b_choice_2266234d:

    # Ci "There you are, you monster."
    Ci "Ahí estás, monstruo."

# game/scripts/day3.rpy:658
translate spanish d3b_choice_d6d2c697:

    # Z "I will trust you to square this with the guards, if they show up, and to keep this a simple matter."
    Z "Confiaré en que aclares esto con los guardias, si aparecen, y mantengas esto como un asunto simple."

# game/scripts/day3.rpy:661
translate spanish d3b_choice_55b8740e:

    # Ci "Thank you, Stalker. Your judgement shows you are a true Zetan, like me."
    Ci "Gracias, Acechador. Tu juicio muestra que eres un verdadero Zetan, como yo."

# game/scripts/day3.rpy:662
translate spanish d3b_choice_242c4fc3:

    # Ci "If things go as I intend, you will see first hand how the ways of Zeta will tame this... thing, the next time you see us. A week or two, I expect."
    Ci "Si las cosas van como pretendo, verás de primera mano cómo los caminos de Zeta domesticarán a esta... cosa, la próxima vez que nos veamos. Una o dos semanas, espero."

# game/scripts/day3.rpy:665
translate spanish d3b_choice_61dfd0b7:

    # Z "I trust I will. I might come check on you in a while. Take care of your wounds now, citizen."
    Z "Confío en que lo haré. Tal vez venga a verte en un rato. Cuida tus heridas ahora, ciudadano."

# game/scripts/day3.rpy:668
translate spanish d3b_choice_b22993cf:

    # "You part ways..."
    "Te separas..."

# game/scripts/day3.rpy:671
translate spanish d3b_choice_399e32a4:

    # Zt "I don't trust that she will be treated fairly."
    Zt "No confío en que la traten de manera justa."

# game/scripts/day3.rpy:676
translate spanish d3b_choice_906c9fa2:

    # "You look at her deerlike wide eyes. She too seems to be waiting for your call of judgement..."
    "Miras sus ojos grandes y de ciervo. Ella también parece estar esperando tu juicio..."

# game/scripts/day3.rpy:677
translate spanish d3b_choice_768767e2:

    # Z "Run away, girl."
    Z "Corre, chica."

# game/scripts/day3.rpy:678
translate spanish d3b_choice_98394ef3:

    # Z "And pray I don't discover he was right and I made a mistake, tonight."
    Z "Y reza para que no descubra que tenía razón y cometí un error esta noche."

# game/scripts/day3.rpy:688
translate spanish d3b_choice_bdee522c:

    # "She swiftly runs away; lithe steps fading in the darkness..."
    "Corre rápidamente; pasos ágiles que se desvanecen en la oscuridad..."

# game/scripts/day3.rpy:689
translate spanish d3b_choice_aeb1c6b3:

    # Ci "What are you... Stalker!!"
    Ci "¡¡Qué está tú... Acechador!!"

# game/scripts/day3.rpy:693
translate spanish d3b_choice_0d24993b:

    # Ci "NO!!! YOU LET HER GO!! HOW COULD YOU, DAMNED!!"
    Ci "¡¡¡NO!!! ¡LA DEJASTE IR!! ¿¡CÓMO PUDISTE, MALDITO!?"

# game/scripts/day3.rpy:696
translate spanish d3b_choice_b53d0342:

    # Z "I witnessed no crime today, only a woman trying to escape your grasp."
    Z "No presencié ningún crimen hoy, solo una mujer tratando de escapar de tu control."

# game/scripts/day3.rpy:699
translate spanish d3b_choice_5102675a:

    # Ci "You are mad, Stalker!! I told you what happened!"
    Ci "¡¡Estás loco, Acechador!! ¡Te dije lo que pasó!"

# game/scripts/day3.rpy:701
translate spanish d3b_choice_c31446c5:

    # Ci "SHE IS A VIOLENT THIEF!"
    Ci "¡ELLA ES UNA LADRONA VIOLENTA!"

# game/scripts/day3.rpy:704
translate spanish d3b_choice_5c1a0281:

    # Ci "A Stalker who refuses to impart justice can go to hell!"
    Ci "Un Acechador que se niega a impartir justicia puede ir al infierno."

# game/scripts/day3.rpy:707
translate spanish d3b_choice_dc2b02ea:

    # Z "Do not do this, citizen. You may have lost a finger, but your life is still yours."
    Z "No hagas esto, ciudadano. Puede que hayas perdido un dedo, pero tu vida sigue siendo tuya."

# game/scripts/day3.rpy:710
translate spanish d3b_choice_d6a57493:

    # Ci "Fuck you, Stalker! The title you claim means nothing if you let that filth get away with her actions!"
    Ci "Jódete, Acechador. El título que reclamas no significa nada si dejas que esa escoria se salga con la suya."

# game/scripts/day3.rpy:713
translate spanish d3b_choice_e5ceaab4:

    # Ci "AAaaghh!!"
    Ci "¡¡AAaaghh!!"

# game/scripts/day3.rpy:717
translate spanish d3b_choice_7b1f9023:

    # Ci "Agh-!!"
    Ci "¡¡Agh-!!"

# game/scripts/day3.rpy:718
translate spanish d3b_choice_f4494d7f:

    # Ci "!!"
    Ci "¡¡!!"

# game/scripts/day3.rpy:721
translate spanish d3b_choice_e156dcdd:

    # Z "Ngh-"
    Z "Ngh..."

# game/scripts/day3.rpy:722
translate spanish d3b_choice_dfc86979:

    # Ci "Damn you!!"
    Ci "¡¡Maldita seas!!"

# game/scripts/day3.rpy:725
translate spanish d3b_choice_44e18b32:

    # Ci "You son of a..."
    Ci "¡Hijo de..."

# game/scripts/day3.rpy:728
translate spanish d3b_choice_9381de47:

    # Ci "{i}*gasp*{/i}"
    Ci "{i}*gasp*{/i}"

# game/scripts/day3.rpy:732
translate spanish d3b_choice_52b25bb3:

    # Ci "AAaaahhhhh!!!"
    Ci "¡¡AAaaahhhhh!!"

# game/scripts/day3.rpy:735
translate spanish d3b_choice_743b66a7:

    # Ci "{i}*squirming*{/i} nghhaaa!!!"
    Ci "{i}*Retorciéndose*{/i} ¡¡¡Nghhaaa!!!"

# game/scripts/day3.rpy:739
translate spanish d3b_choice_b8dec8c2:

    # Ci "Arghh... my leg...!!!"
    Ci "¡¡¡Arghh... mi pierna...!!!"

# game/scripts/day3.rpy:740
translate spanish d3b_choice_1492102e:

    # Ci "You fucking..., you chopped my leg off!!"
    Ci "¡¡Joder..., me has cortado la pierna!!"

# game/scripts/day3.rpy:743
translate spanish d3b_choice_dac88428:

    # Ci "Hnnnrghh... I f-forfeit. You win... You win!!"
    Ci "Hnnnrghh... Me rindo. Tú ganas... ¡¡Tú ganas!"

# game/scripts/day3.rpy:746
translate spanish d3b_choice_23616a48:

    # Ci "P-please... I have lost enough!!"
    Ci "P-por favor... ¡¡Ya he perdido bastante!!"

# game/scripts/day3.rpy:751
translate spanish d3b_choice_fe20f5c4:

    # Z "One more word, and you lose your other leg."
    Z "Una palabra más, y perderás la otra pierna."

# game/scripts/day3.rpy:754
translate spanish d3b_choice_14351fd6:

    # Ci "I... I promise. I have no more anger in me... only- ngh... only pain."
    Ci "Yo... yo lo prometo. No tengo más ira en mí... sólo... ngh... sólo dolor."

# game/scripts/day3.rpy:755
translate spanish d3b_choice_35d33546:

    # Ci "Please. Let me go."
    Ci "Por favor. Déjame ir."

# game/scripts/day3.rpy:758
translate spanish d3b_choice_20152baa:

    # Z "Run, and don't turn back. Speak ill of my judgement, and you will regret it."
    Z "Corre, y no mires atrás. Habla mal de mi juicio, y lo lamentarás."

# game/scripts/day3.rpy:762
translate spanish d3b_choice_93f93fc6:

    # Ci "Yes... Stalker. Yes..."
    Ci "Sí... Acechador. Sí..."

# game/scripts/day3.rpy:768
translate spanish d3b_choice_9afc58a3:

    # Z "You challenged a Queen's Stalker to a fight."
    Z "Desafiaste a un Acechador de la Reina a un combate."

# game/scripts/day3.rpy:769
translate spanish d3b_choice_06629c95:

    # Z "Mercy is for the weak, and you weren't acting so weak, against that girl."
    Z "La misericordia es para los débiles, y tú no estabas actuando tan débil contra esa chica."

# game/scripts/day3.rpy:772
translate spanish d3b_choice_5a5fb8bf:

    # Ci "NO!! PLEASE, STALKER!! NOOO!!!"
    Ci "¡NO!! ¡¡POR FAVOR, STALKER!! ¡¡NOOO!!"

# game/scripts/day3.rpy:776
translate spanish d3b_choice_f383f7a0:

    # C "AAghh!!"
    C "¡¡AAghh!!"

# game/scripts/day3.rpy:780
translate spanish d3b_choice_e18559f0:

    # C "ghh..."
    C "ghh..."

# game/scripts/day3.rpy:784
translate spanish d3b_choice_26a803bc:

    # C "..."
    C "..."

# game/scripts/day3.rpy:788
translate spanish d3b_choice_cfb9f776:

    # Ci "Nkgh... {i}*cough*{/i}"
    Ci "Nkgh... {i}*tos*{/i}"

# game/scripts/day3.rpy:791
translate spanish d3b_choice_6f51d99a:

    # Ci "{i}*exhales*{/i}"
    Ci "{i}*exhalando*{/i}"

# game/scripts/day3.rpy:793
translate spanish d3b_choice_7bb5d385:

    # Z "May your heart be weighted more favourably than today's actions deserve."
    Z "Que tu corazón sea juzgado más favorablemente de lo que merecen las acciones de hoy."

# game/scripts/day3.rpy:801
translate spanish d3b_choice_b703ed1a:

    # "Eventually, you leave the market, having not seen a hint of the elf."
    "Finalmente sales del mercado sin haber visto ni rastro de la elfa."

# game/scripts/day3.rpy:803
translate spanish d3b_choice_3f9ffc63:

    # "You wonder if this distraction is what kept her away and if you will have another chance to meet her..."
    "Te preguntas si esta distracción fue lo que la mantuvo alejada y si tendrás otra oportunidad de conocerla..."

# game/scripts/day3.rpy:812
translate spanish d3c_b567f23f:

    # Z "Time to pick up [S] and go."
    Z "Es hora de recoger a [S] e irnos."

# game/scripts/day3.rpy:824
translate spanish d3c_4277bae1:

    # "{i}Hours later..."
    "{i}Horas después..."

# game/scripts/day3.rpy:829
translate spanish d3c_53119f6f:

    # Z "Here we are."
    Z "Aquí estamos."

# game/scripts/day3.rpy:830
translate spanish d3c_f1bf465e:

    # S "Wow..."
    S "Guau..."

# game/scripts/day3.rpy:837
translate spanish d3c_12463840:

    # "You get out..."
    "Sales..."

# game/scripts/day3.rpy:840
translate spanish d3c_7ae6f24b:

    # S "I would have never imagined this..."
    S "Nunca hubiera imaginado esto..."

# game/scripts/day3.rpy:841
translate spanish d3c_fbbe842c:

    # S "...hellfire."
    S "... infierno ardiente."

# game/scripts/day3.rpy:844
translate spanish d3c_946c01f3:

    # Z "I know. But you will get used to it."
    Z "Lo sé. Pero te acostumbrarás."

# game/scripts/day3.rpy:847
translate spanish d3c_0e62de59:

    # Z "Let's get inside. Remember: whatever happens, our goal is to put an end to the raids coming from this area."
    Z "Entremos. Recuerda: pase lo que pase, nuestro objetivo es poner fin a las redadas que provienen de esta zona."

# game/scripts/day3.rpy:848
translate spanish d3c_49359e03:

    # S "Okay... {i}*inhales deeply*{/i}"
    S "Vale... {i}*inhala profundamente*{/i}"

# game/scripts/day3.rpy:849
translate spanish d3c_b5b6f88f:

    # S "{i}*cough*{/i} The air smells burnt."
    S "{i}*tos*{/i} El aire huele a quemado."

# game/scripts/day3.rpy:850
translate spanish d3c_e97c8c11:

    # Z "Don't take deep breaths in Cairo."
    Z "No respires profundamente en El Cairo."

# game/scripts/day3.rpy:851
translate spanish d3c_61a897c4:

    # S "Yeah... either way... let's go."
    S "Sí... de cualquier manera... Vamos."

# game/scripts/day3.rpy:855
translate spanish d3c_05a67a1e:

    # "You walk inside. After heading down into the basement, you find yourself in a long, metallic corridor."
    "Entras. Tras bajar al sótano, te encuentras en un largo corredor metálico."

# game/scripts/day3.rpy:858
translate spanish d3c_3f1993dc:

    # S "I'm going to be sick."
    S "Voy a vomitar."

# game/scripts/day3.rpy:861
translate spanish d3c_4b6b42e2:

    # S "I..."
    S "Yo..."

# game/scripts/day3.rpy:864
translate spanish d3c_f6c49c09:

    # S "{i}*gag*{/i}"
    S "{i}*gag*{/i}"

# game/scripts/day3.rpy:867
translate spanish d3c_b8b2723d:

    # S "Are these... corpses?"
    S "¿Son estos... cadáveres?"

# game/scripts/day3.rpy:870
translate spanish d3c_1cfb7d0c:

    # "The hallway is filled with the remnants of chopped up corpses, decayed and human."
    "El pasillo está lleno de restos de cadáveres desmembrados, humanos y en descomposición."

# game/scripts/day3.rpy:871
translate spanish d3c_9c742dcd:

    # "The air smells of blood and decaying corpses."
    "El aire huele a sangre y cadáveres en descomposición."

# game/scripts/day3.rpy:874
translate spanish d3c_28021bcd:

    # "Puddles of blood cover the floor, as do the bones and skulls of those who fought here."
    "Charcos de sangre cubren el suelo, al igual que los huesos y calaveras de los que lucharon aquí."

# game/scripts/day3.rpy:875
translate spanish d3c_fdf916a9:

    # Z "This is... was... a warzone."
    Z "Esto es... fue... una zona de guerra."

# game/scripts/day3.rpy:878
translate spanish d3c_234fc72b:

    # "You step towards a figure sitting in the dark."
    "Das un paso hacia una figura sentada en la oscuridad."

# game/scripts/day3.rpy:879
translate spanish d3c_d2c9ee02:

    # Decw "Shatter... forgive me..."
    Decw "Rómpelo... perdóname..."

# game/scripts/day3.rpy:881
translate spanish d3c_927ab57f:

    # Decw "Forgive me."
    Decw "Perdóname."

# game/scripts/day3.rpy:884
translate spanish d3c_92e6bfd2:

    # "Looking closer, the decayed muttering these words does not seem to be sound of mind."
    "Mirando de cerca, el desquiciado que murmura estas palabras no parece estar en su sano juicio."

# game/scripts/day3.rpy:885
translate spanish d3c_d9be3d18:

    # "He ignores the pair of you, repeating the same words, over and over."
    "Él ignora a la pareja, repitiendo las mismas palabras, una y otra vez."

# game/scripts/day3.rpy:886
translate spanish d3c_31ad9e1a:

    # Decw "Shatter the skin."
    Decw "Rompe la piel."

# game/scripts/day3.rpy:889
translate spanish d3c_3510031a:

    # S "[persistent.dad!c]... W-what do we do?"
    S "[persistent.dad!c]... ¿Q-qué hacemos?"

# game/scripts/day3.rpy:892
translate spanish d3c_b4e6f9c0:

    # Z "We move on. These here pose no threat to us."
    Z "Seguimos adelante. Estos aquí no representan una amenaza para nosotros."

# game/scripts/day3.rpy:895
translate spanish d3c_8f362e8d:

    # Z "Walk past him, [S]."
    Z "Pasa junto a él, [S]."

# game/scripts/day3.rpy:898
translate spanish d3c_34ab1a0c:

    # Dec "{i}*muttering*{/i}"
    Dec "{i}*murmullos*{/i}"

# game/scripts/day3.rpy:901
translate spanish d3c_e729829b:

    # "You slowly walk past the lost souls."
    "Caminas lentamente entre las almas perdidas."

# game/scripts/day3.rpy:902
translate spanish d3c_f8696993:

    # "Over the years, you have encountered a handful of recently raided villages, or plowed tribes. Some broken beyond the state of posing any threat, despite their previous actions suggesting the opposite."
    "A lo largo de los años, te has encontrado con un puñado de aldeas recientemente saqueadas, o tribus arrasadas. Algunas tan destruidas que no representan ninguna amenaza, a pesar de sus acciones previas que sugerían lo contrario."

# game/scripts/day3.rpy:905
translate spanish d3c_bef0286c:

    # Z "Let's see if we find our answers in here."
    Z "Veamos si encontramos nuestras respuestas aquí."

# game/scripts/day3.rpy:906
translate spanish d3c_63dc0293:

    # S "I'm... not sure I want to."
    S "Estoy... no estoy segura de querer hacerlo."

# game/scripts/day3.rpy:909
translate spanish d3c_9332361c:

    # Z "Stay behind me then."
    Z "Quédate detrás de mí entonces."

# game/scripts/day3.rpy:912
translate spanish d3c_40b0aed4:

    # "Minutes later..."
    "Minutos más tarde..."

# game/scripts/day3.rpy:915
translate spanish d3c_bdcca21f:

    # Dec "Those who enter these halls may never leave them again, Stalker..."
    Dec "Quienes entran en estas salas pueden no volver a salir nunca, Acechador..."

# game/scripts/day3.rpy:916
translate spanish d3c_4847ae67:

    # Z "You will not threaten us."
    Z "No nos amenazarás."

# game/scripts/day3.rpy:917
translate spanish d3c_1b4f0a33:

    # Dec "I... will not, no. We are out of threats. Out of anger... out of lives."
    Dec "Yo... no lo haré, no. Estamos sin amenazas. Sin ira... sin vidas."

# game/scripts/day3.rpy:920
translate spanish d3c_6875edf8:

    # Dec "You have come to a battlefield that is being harvested, my friend."
    Dec "Has venido a un campo de batalla que está siendo cosechado, amigo mío."

# game/scripts/day3.rpy:923
translate spanish d3c_a83c7ea2:

    # Dec "...but have you come to shed even more blood?"
    Dec "... pero, ¿has venido a derramar aún más sangre?"

# game/scripts/day3.rpy:926
translate spanish d3c_68026ddb:

    # S "[persistent.dad!c]... are they slaughtering the bodies?"
    S "[persistent.dad!c]... ¿están destazando los cuerpos?"

# game/scripts/day3.rpy:929
translate spanish d3c_713f263f:

    # Z "All the decayed slaughter. The question is who, and why."
    Z "Toda la masacre de los decaídos. La pregunta es quién y por qué."

# game/scripts/day3.rpy:932
translate spanish d3c_5d84cebf:

    # Dec "We were attacked, Stalker."
    Dec "Fuimos atacados, Acechador."

# game/scripts/day3.rpy:933
translate spanish d3c_bffcdccc:

    # Dec "Attacked by savages. A wild tribe under an even wilder woman."
    Dec "Atacados por salvajes. Una tribu salvaje liderada por una mujer aún más salvaje."

# game/scripts/day3.rpy:936
translate spanish d3c_941fca85:

    # Dec "Many lives they took from us. What you see is all that's left."
    Dec "Muchas vidas nos arrebataron. Lo que ves es todo lo que queda."

# game/scripts/day3.rpy:939
translate spanish d3c_48f1af52:

    # Z "We came to put an end to the attacks on Zetan caravans."
    Z "Vinimos a poner fin a los ataques a las caravanas Zetanas."

# game/scripts/day3.rpy:940
translate spanish d3c_6750f1ec:

    # Z "The raiders do not inhabit these lands. You do, and would have interest in the content of those wagons."
    Z "Los asaltantes no habitan estas tierras. Tú sí, y te interesará el contenido de esos vagones."

# game/scripts/day3.rpy:943
translate spanish d3c_64c9ae12:

    # Dec "And why do you think my people would attack these caravans?!"
    Dec "¿Y por qué crees que mi gente atacaría estas caravanas?"

# game/scripts/day3.rpy:946
translate spanish d3c_cd1c3bef:

    # Dec "Your Queen starved us, refused to trade, decades after your little empire shunned us from the desert lands."
    Dec "Tu reina nos mató de hambre, se negó a comerciar, décadas después de que vuestro pequeño imperio nos desterrara de las tierras del desierto."

# game/scripts/day3.rpy:949
translate spanish d3c_285507ef:

    # Dec "These caravans cross our land, packed with food and treasures, while my people are out here starving!"
    Dec "¡Estas caravanas cruzan nuestras tierras, llenas de comida y tesoros, mientras mi gente está muriendo de hambre!"

# game/scripts/day3.rpy:950
translate spanish d3c_aba1ddf9:

    # Dec "Force a man to eat another long enough, and he will eventually relish in his habit."
    Dec "Fuerza a un hombre a comer a otro durante suficiente tiempo, y eventualmente se deleitará con su hábito."

# game/scripts/day3.rpy:953
translate spanish d3c_023cf5fc:

    # Sw "[persistent.dad!c]... this girl is... alive!"
    Sw "[persistent.dad!c]... ¡Esta chica está... viva!"

# game/scripts/day3.rpy:954
translate spanish d3c_93423d4b:

    # Dec "That harpy over there...? {i}*sigh*{/i}"
    Dec "¿Esa arpía de allá...? {i}*suspiro*{/i}"

# game/scripts/day3.rpy:957
translate spanish d3c_7a4ab5e4:

    # Dec "You are looking at the one responsible for every single drop of blood spilled today."
    Dec "Estás mirando al responsable de cada gota de sangre derramada hoy."

# game/scripts/day3.rpy:958
translate spanish d3c_be67294b:

    # Dec "And now... she shall become our last offer to the boss's table."
    Dec "Y ahora... será nuestra última ofrenda en la mesa del jefe."

# game/scripts/day3.rpy:959
translate spanish d3c_1b51b1a2:

    # Z "The boss...?"
    Z "¿El jefe...?"

# game/scripts/day3.rpy:962
translate spanish d3c_97a736ae:

    # Z "Don't speak in riddles, decayed."
    Z "No hables con acertijos, decaído."

# game/scripts/day3.rpy:963
translate spanish d3c_001fec15:

    # Dec "I see that your knowledge in our ways are staggeringly limited, Stalker."
    Dec "Veo que tu conocimiento sobre nuestras costumbres es sorprendentemente limitado, Acechador."

# game/scripts/day3.rpy:964
translate spanish d3c_8b97a8e9:

    # Dec "We will avenge our fallen brothers, and prepare her for her new role."
    Dec "Vengaremos a nuestros hermanos caídos y la prepararemos para su nuevo rol."

# game/scripts/day3.rpy:967
translate spanish d3c_91fc6807:

    # Dec "The fate that awaits her, you would find it hellish, but for us it's just another day confined to the few places where we thrive."
    Dec "El destino que le espera a ella sería un infierno para ti, pero para nosotros es solo otro día confinados a los pocos lugares donde podemos sobrevivir."

# game/scripts/day3.rpy:968
translate spanish d3c_8d2c6351:

