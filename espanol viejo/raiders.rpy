    # Kit "..."
    Kit "..."

# game/scripts/raiders.rpy:795
translate spanish rsf_1_0fa3bc4c:

    # "His dirty hands caress her flawless skin while he greedily sucks her breast..."
    "Sus manos sucias acarician su piel impecable mientras él chupa ávidamente su pecho..."

# game/scripts/raiders.rpy:796
translate spanish rsf_1_d62fa9c5:

    # SW "Mh... a... dream..."
    SW "Mh... un... sueño..."

# game/scripts/raiders.rpy:799
translate spanish rsf_1_c91ce812:

    # Kyw "{i}*sigh*{/i} Fuck me... this guy is desperate."
    Kyw "{i}*suspiro*{/i} No me jodas... este tío está desesperado."

# game/scripts/raiders.rpy:800
translate spanish rsf_1_27319151:

    # Ky "Hey cockface, that's enough. You'll rip her tit off if you continue like that."
    Ky "Ey, idiota, eso es suficiente. Le arrancarás la teta si sigues así."

# game/scripts/raiders.rpy:803
translate spanish rsf_1_fef04219:

    # SW "I'm... I'm sorry, I don't know what..."
    SW "Lo siento... lo siento, no sé qué..."

# game/scripts/raiders.rpy:804
translate spanish rsf_1_c6005b0a:

    # Z "You had your fun. Now scram!"
    Z "Ya te has divertido. ¡Ahora lárgate!"

# game/scripts/raiders.rpy:805
translate spanish rsf_1_5f85f927:

    # Z "Don't think that what you just did isn't going to cost you, next time."
    Z "No creas que lo que acabas de hacer no te va a costar caro, la próxima vez."

# game/scripts/raiders.rpy:806
translate spanish rsf_1_2cb25fee:

    # SW "Yes... of course. Thank you..."
    SW "Sí... por supuesto. Gracias..."

# game/scripts/raiders.rpy:807
translate spanish rsf_1_7c9d19f3:

    # SW "I would have never... It is worth it, it is!"
    SW "Nunca lo habría hecho... ¡Vale la pena, de verdad!"

# game/scripts/raiders.rpy:813
translate spanish rsf_1_2fd467cc:

    # Z "That's enough. Take your hands off her."
    Z "Ya está bien. Quítale las manos de encima."

# game/scripts/raiders.rpy:814
translate spanish rsf_1_033d117e:

    # SW "I... yes... I apologize."
    SW "Yo... sí... me disculpo."

# game/scripts/raiders.rpy:820
translate spanish rsf4_7480810f:

    # SW "Thank you again, [Kit]. I look forward to seeing you next week."
    SW "Gracias de nuevo, [Kit]. Espero verte la semana que viene."

# game/scripts/raiders.rpy:821
translate spanish rsf4_725e86f3:

    # SW "Until then, goodbye."
    SW "Hasta entonces, adiós."

# game/scripts/raiders.rpy:832
translate spanish rsf4_4ac482be:

    # Z "Hello, someone in there?"
    Z "Hola, ¿hay alguien ahí?"

# game/scripts/raiders.rpy:835
translate spanish rsf4_f6bd4dca:

    # SW "You... oh, hello!"
    SW "Tú... ¡oh, hola!"

# game/scripts/raiders.rpy:836
translate spanish rsf4_4dad1660:

    # SW "I didn't think... you'd want to talk to me, now that you freed [Kit] from the General."
    SW "No pensé... que quisieras hablar conmigo, ahora que liberaste a [Kit] del General."

# game/scripts/raiders.rpy:839
translate spanish rsf4_31daa57e:

    # Z "I wanted to see how you're doing, and if everything went as planned."
    Z "Quería ver cómo estás y si todo salió según lo planeado."

# game/scripts/raiders.rpy:840
translate spanish rsf4_64d118f9:

    # Z "I promised you a slave, didn't I?"
    Z "Te prometí una esclava, ¿verdad?"

# game/scripts/raiders.rpy:843
translate spanish rsf4_71b8030a:

    # SW "..."
    SW "..."

# game/scripts/raiders.rpy:844
translate spanish rsf4_00261fb1:

    # "He smiles..."
    "Él sonríe..."

# game/scripts/raiders.rpy:847
translate spanish rsf4_26da3c8c:

    # SW "You really kept your word! Come here, I'll show you."
    SW "¡Realmente has cumplido tu palabra! Ven aquí, te lo enseñaré."

# game/scripts/raiders.rpy:850
translate spanish rsf4_fc2b4e40:

    # SW "They gave me this one, for contributing so much to the settlement."
    SW "Me dieron a esta, por contribuir tanto al asentamiento."

# game/scripts/raiders.rpy:853
translate spanish rsf4_7bc371e6:

    # Sl "..."
    Sl "..."

# game/scripts/raiders.rpy:854
translate spanish rsf4_f2e1e03f:

    # SW "Isn't she pretty?!"
    SW "¡¿No es bonita?!"

# game/scripts/raiders.rpy:855
translate spanish rsf4_e6fdf491:

    # SW "I will work even harder now, because I have this girl waiting for me when I come home!"
    SW "Trabajaré aún más duro ahora, ¡porque tengo a esta chica esperándome cuando llego a casa!"

# game/scripts/raiders.rpy:856
translate spanish rsf4_cdf96d17:

    # Z "And what about [Kit]?"
    Z "¿Y qué pasa con [Kit]?"

# game/scripts/raiders.rpy:859
translate spanish rsf4_6d624ccd:

    # SW "[Kit], ah... forget her! I finally have my own girl."
    SW "[Kit], ah... ¡olvídala! Finalmente tengo a mi propia chica."

# game/scripts/raiders.rpy:862
translate spanish rsf4_366ac122:

    # SW "She's shy, and has not let me touch her yet... but we will get there, right?"
    SW "Es tímida y aún no me ha dejado tocarla... pero lo conseguiremos, ¿verdad?"

# game/scripts/raiders.rpy:863
translate spanish rsf4_613059d4:

    # SW "She is my slave after all, if you know what I'm saying."
    SW "Después de todo, ella es mi esclava, si sabes a lo que me refiero."

# game/scripts/raiders.rpy:866
translate spanish rsf4_971c0034:

    # Z "she is... well then. I will come back in a few days to see how things are going for you."
    Z "Es... Bueno, entonces. Volveré en unos días para ver cómo te va."

# game/scripts/raiders.rpy:867
translate spanish rsf4_81d4198e:

    # Z "Take care."
    Z "Cuídate."

# game/scripts/raiders.rpy:878
translate spanish rsf_2_48f6d4eb:

    # Z "Let's see how this guy is treating his new slave."
    Z "Veamos cómo trata este tipo a su nueva esclava."

# game/scripts/raiders.rpy:879
translate spanish rsf_2_c6c2a290:

    # Z "He was so confident, last time. A newborn man."
    Z "Estaba tan seguro de sí mismo, la última vez. Un hombre recién nacido."

# game/scripts/raiders.rpy:882
translate spanish rsf_2_98851f82:

    # Z "Hello, it's me again. How are you doing, man?"
    Z "Hola, soy yo otra vez. ¿Qué tal, tío?"

# game/scripts/raiders.rpy:883
translate spanish rsf_2_58131b11:

    # "You hear mumbling coming from the other side..."
    "Oyes murmullos procedentes del otro lado..."

# game/scripts/raiders.rpy:884
translate spanish rsf_2_707fd96d:

    # Z "Hey, you hear me?"
    Z "Oye, ¿me oyes?"

# game/scripts/raiders.rpy:887
translate spanish rsf_2_63b7be8d:

    # Z "What on earth..."
    Z "Qué demonios..."

# game/scripts/raiders.rpy:890
translate spanish rsf_2_1f0d1012:

    # SW "I'm so sorry, I didn't..."
    SW "Lo siento mucho, no..."

# game/scripts/raiders.rpy:891
translate spanish rsf_2_ae50f8f5:

    # C2 "A shift of fourteen hours is all you did? Is this how you thank me?"
    C2 "¿Un turno de catorce horas es todo lo que hiciste? ¿Así me lo agradeces?"

# game/scripts/raiders.rpy:892
translate spanish rsf_2_e91a09c2:

    # SW "Nooo... please. I tried..."
    SW "Nooo... por favor. Lo he intentado..."

# game/scripts/raiders.rpy:895
translate spanish rsf_2_ec8f2757:

    # Sl "Such a pathetic excuse. After all the attention I gave you last night..."
    Sl "Qué excusa tan patética. Después de toda la atención que te presté anoche..."

# game/scripts/raiders.rpy:896
translate spanish rsf_2_f86ed805:

    # Sl "I should start looking for another man after all..."
    Sl "Debería empezar a buscar otro hombre después de todo..."

# game/scripts/raiders.rpy:897
translate spanish rsf_2_7fc73a86:

    # C2 "No... please... anything but that."
    C2 "No... por favor... cualquier cosa menos eso."

# game/scripts/raiders.rpy:900
translate spanish rsf_2_81b9085c:

    # Sl "You said yourself I was too good for this place, and now you refuse to improve my wellbeing."
    Sl "Tú mismo dijiste que yo era demasiado buena para este lugar, y ahora te niegas a mejorar mi bienestar."

# game/scripts/raiders.rpy:901
translate spanish rsf_2_23075990:

    # Sl "I wonder if I can really trust you..."
    Sl "Me pregunto si realmente puedo confiar en ti..."

# game/scripts/raiders.rpy:902
translate spanish rsf_2_6e9ea000:

    # C2 "You can, I... I promise... I will make your life better, much better..."
    C2 "Puedes, yo... Te prometo... Haré que tu vida sea mejor, mucho mejor..."

# game/scripts/raiders.rpy:905
translate spanish rsf_2_dc384165:

    # Sl "You better start delivering on your promises soon."
    Sl "Será mejor que empieces pronto a cumplir tus promesas."

# game/scripts/raiders.rpy:906
translate spanish rsf_2_bcf2ec6d:

    # Sl "...I won't remain in this shithole of a place for long."
    Sl "... no permaneceré en este agujero de mierda por mucho tiempo."

# game/scripts/raiders.rpy:919
translate spanish rsg_1_ff891a23:

    # Z "Hey, you. I am here to check how everything is going."
    Z "Oye, tú. Estoy aquí para comprobar cómo va todo."

# game/scripts/raiders.rpy:922
translate spanish rsg_1_1193edd4:

    # SG "Hey Boss, everything's fine."
    SG "¡Hola, jefe, todo está bien!"

# game/scripts/raiders.rpy:923
translate spanish rsg_1_086351c7:

    # SG "The gate is busy recently, got lots of people wanting to come in... travellers, recruits, traders..."
    SG "La puerta está ocupada últimamente, hay mucha gente que quiere entrar... Viajeros, reclutas, comerciantes..."

# game/scripts/raiders.rpy:926
translate spanish rsg_1_0ab35e96:

    # SG "The word is going around! This settlement is going places."
    SG "¡Se corre la voz! Este asentamiento va a más."

# game/scripts/raiders.rpy:927
translate spanish rsg_1_9d8314d2:

    # SG "Oh, and... can you ask Kyra what we are supposed to do about the caravans?"
    SG "Oh, y... ¿puedes preguntarle a Kyra qué se supone que debemos hacer con las caravanas?"

# game/scripts/raiders.rpy:928
translate spanish rsg_1_3a2fc8c2:

    # SG "I don't want to make her mad at me for doing the wrong thing."
    SG "No quiero que se enfade conmigo por hacer lo incorrecto."

# game/scripts/raiders.rpy:931
translate spanish rsg_1_85845275:

    # Z "Yeah, let's see, I'm busy right now. Should ask her yourself later."
    Z "Sí, veamos, ahora estoy ocupado. Deberías preguntárselo tú mismo más tarde."

# game/scripts/raiders.rpy:938
translate spanish rsg_1_8d2dd89b:

    # Z "Hey, you. How are things at the gate?"
    Z "Oye, tú. ¿Cómo van las cosas en la puerta?"

# game/scripts/raiders.rpy:941
translate spanish rsg_1_6845de3e:

    # SG "...?"
    SG "¿...?"

# game/scripts/raiders.rpy:944
translate spanish rsg_1_17557f6f:

    # SG "Boss, it's you."
    SG "Jefe, eres tú."

# game/scripts/raiders.rpy:945
translate spanish rsg_1_8701159d:

    # SG "Just had another raiding party come back. Things aren't bad. Even brought in some new workers."
    SG "Acabo de tener otro grupo de asaltantes regresar. Las cosas no van mal. Incluso trajeron a algunos trabajadores nuevos."

# game/scripts/raiders.rpy:948
translate spanish rsg_1_3f23f22a:

    # SG "Word is going around not to mess with this place since we arrived. Other gangs stay away from our territory."
    SG "Se corre la voz de no meterse con este lugar desde que llegamos. Otras bandas se mantienen alejadas de nuestro territorio."

# game/scripts/raiders.rpy:949
translate spanish rsg_1_bf57651f:

    # SG "I've got the occasional lost soul coming here, desperate enough, I guess."
    SG "Tengo el ocasional alma perdida que viene aquí, lo suficientemente desesperada, supongo."

# game/scripts/raiders.rpy:952
translate spanish rsg_1_f13c2768:

    # Z "Alright man, keep it up. Else I'll send Zion."
    Z "Muy bien, amigo, sigue así. De lo contrario, enviaré a Zion."

# game/scripts/raiders.rpy:955
translate spanish rsg_1_ec4336b2:

    # SG "Hah, that woman's no joke, boss. You should hear the stories the guys are telling about her."
    SG "Supongo que necesitas que te lo recuerden."

# game/scripts/raiders.rpy:956
translate spanish rsg_1_15a94025:

    # SG "Anyways, see you around."
    SG "En fin, nos vemos."

# game/scripts/raiders.rpy:959
translate spanish rsg_1_fe631a17:

    # Z "Nice decoration. Didn't know you have an artistic side."
    Z "Bonita decoración. No sabía que tuvieras un lado artístico."

# game/scripts/raiders.rpy:962
translate spanish rsg_1_9ff8edb7:

    # SG "Ever carved your own skull trophy, boss?"
    SG "¿Alguna vez has tallado tu propio trofeo de cráneo, jefe?"

# game/scripts/raiders.rpy:963
translate spanish rsg_1_abd8ea80:

    # SG "Thing is, this shit works, people piss their pants at the gate."
    SG "La cosa es que esta mierda funciona, la gente se mea en los pantalones en la puerta."

# game/scripts/raiders.rpy:964
translate spanish rsg_1_15a94025_1:

    # SG "Anyways, see you around."
    SG "En fin, nos vemos."

# game/scripts/raiders.rpy:974
translate spanish rss_1_3034efe5:

    # SW "Hey Boss! Glad to see you back!"
    SW "¡Hola, jefe! ¡Me alegra verte de nuevo!"

# game/scripts/raiders.rpy:975
translate spanish rss_1_cabfa72f:

    # SW "What do you think of my new home?"
    SW "¿Qué piensas de mi nuevo hogar?"

# game/scripts/raiders.rpy:978
translate spanish rss_1_7535b5bd:

    # "The man stands proudly in the doorway of his repaired shack..."
    "El hombre se yergue orgulloso en la puerta de su choza reparada..."

# game/scripts/raiders.rpy:979
translate spanish rss_1_60080890:

    # Z "Not bad. It looks like a better place to come home to after work, for sure."
    Z "No está mal. Parece un lugar mejor para volver a casa después del trabajo, seguro."

# game/scripts/raiders.rpy:982
translate spanish rss_1_f9ac548c:

    # SW "You have not seen the inside yet! You will not believe what I've got!"
    SW "¡Aún no has visto el interior! ¡No te vas a creer lo que tengo!"

# game/scripts/raiders.rpy:985
translate spanish rss_1_6d7dda07:

    # Z "Alright, I'll bite... what have you got?"
    Z "Muy bien, lo escucharé... ¿Qué tienes?"

# game/scripts/raiders.rpy:986
translate spanish rss_1_8b7ca9bf:

    # "As you step closer, you take a peek inside and see..."
    "Al acercarte, echas un vistazo al interior y ves..."

# game/scripts/raiders.rpy:989
translate spanish rss_1_4e8e882a:

    # "...nothing. A bed and... empty space."
    "... nada. Una cama y... espacio vacío."

# game/scripts/raiders.rpy:990
translate spanish rss_1_79897f70:

    # SW "Isn't it great? It's a high quality floor, made just for me!"
    SW "¡Es genial! Es un suelo de alta calidad, hecho especialmente para mí."

# game/scripts/raiders.rpy:991
translate spanish rss_1_cf771b5f:

    # Z "Yeah... um... you're right."
    Z "Sí... um... tienes razón."

# game/scripts/raiders.rpy:992
translate spanish rss_1_a6799ffb:

    # Zt "I don't know if I feel happy or sad for him. I guess that when you have nothing, even as simple as a decent floor is a start."
    Zt "No sé si me siento feliz o triste por él. Supongo que cuando no tienes nada, incluso un suelo decente es un comienzo."

# game/scripts/raiders.rpy:995
translate spanish rss_1_87e3504f:

    # Z "Well, I'm glad for you, buddy. Hope your lucky streak stays strong."
    Z "Me alegro por ti, amigo. Espero que tu racha de suerte siga siendo fuerte."

# game/scripts/raiders.rpy:1002
translate spanish rss_1_64809ab2:

    # Z "How's it going around here?"
    Z "¿Cómo va por aquí?"

# game/scripts/raiders.rpy:1005
translate spanish rss_1_bb11badd:

    # SW "Huh? Oh... hi boss."
    SW "¿Eh? Oh... hola jefe."

# game/scripts/raiders.rpy:1006
translate spanish rss_1_d2375cc0:

    # SW "I... well, my son just joined a mining crew."
    SW "Yo... Bueno, mi hijo se acaba de unir a una tripulación minera."

# game/scripts/raiders.rpy:1009
translate spanish rss_1_d55445ce:

    # SW "He's still young, but he will do great!"
    SW "¡Todavía es joven, pero lo hará genial!"

# game/scripts/raiders.rpy:1010
translate spanish rss_1_48890ea7:

    # SW "We should be able to afford more things, soon even with the raiders in command!"
    SW "Pronto podremos permitirnos más cosas, ¡incluso con los asaltantes al mando!"

# game/scripts/raiders.rpy:1016
translate spanish rss_1_7568168b:

    # SW "...?"
    SW "¿...?"

# game/scripts/raiders.rpy:1017
translate spanish rss_1_aba1d36f:

    # SW "Heh... I... uh... can fix that."
    SW "Je... Yo... eh... puedo arreglarlo."

# game/scripts/raiders.rpy:1018
translate spanish rss_1_780cfe66:

    # SW "Don't worry about me, boss. I'm sure running a settlement is not easy, either!"
    SW "No te preocupes por mí, jefe. Seguro que dirigir un asentamiento tampoco es fácil."

# game/scripts/raiders.rpy:1031
translate spanish rst_1_131f931c:

    # "You hear mumbling from inside as you approach the trailer..."
    "Oyes murmullos procedentes del interior mientras te acercas al remolque..."

# game/scripts/raiders.rpy:1037
translate spanish rst_1_15e6d0f3:

    # Rue "I know it's difficult for you, but you have to stay strong. Your wife surely misses you."
    Rue "Sé que es difícil para ti, pero debes mantener la fortaleza. Tu esposa seguramente te extraña."

# game/scripts/raiders.rpy:1040
translate spanish rst_1_366eea2c:

    # Rue "Oh, hey boss, how can I help?"
    Rue "Oh, ey jefe, ¿cómo puedo ayudarte?"

# game/scripts/raiders.rpy:1043
translate spanish rst_1_635ea865:

    # Z "I am just checking in to see how things are going."
    Z "Solo estoy comprobando cómo van las cosas."

# game/scripts/raiders.rpy:1046
translate spanish rst_1_11684bda:

    # Rue "Gyasi, can we continue this later? Maybe after your shift?"
    Rue "Gyasi, ¿podemos continuar esto más tarde? ¿Tal vez después de tu turno?"

# game/scripts/raiders.rpy:1049
translate spanish rst_1_828fa078:

    # SW "Okay, let us do that."
    SW "De acuerdo, hagámoslo."

# game/scripts/raiders.rpy:1050
translate spanish rst_1_5307d0aa:

    # SW "Thank you, [Rue]."
    SW "Gracias, [Rue]."

# game/scripts/raiders.rpy:1053
translate spanish rst_1_3fca0ec4:

    # Rue "Remember, we all carry our burdens and insecurities. But we do not let them tear us down, agreed?"
    Rue "Recuerda, todos llevamos nuestras cargas e inseguridades. Pero no permitimos que nos destruyan, ¿de acuerdo?"

# game/scripts/raiders.rpy:1056
translate spanish rst_1_832eb9bf:

    # SW "I... you're right. I will come back later... there is something else I want to say."
    SW "Yo... tienes razón. Volveré más tarde... hay algo más que te quiero decir."

# game/scripts/raiders.rpy:1059
translate spanish rst_1_1aa4e663:

    # "The man leaves, and you take his place..."
    "El hombre se va, y tú ocupas su lugar..."

# game/scripts/raiders.rpy:1062
translate spanish rst_1_dc2b5c44:

    # Z "People seem to put their trust in you."
    Z "La gente parece confiar en ti."

# game/scripts/raiders.rpy:1065
translate spanish rst_1_caaeda94:

    # Rue "I guess I've got a thing for talking to people."
    Rue "Supongo que tengo debilidad por hablar con la gente."

# game/scripts/raiders.rpy:1066
translate spanish rst_1_21e0a978:

    # Rue "And that's thanks to you, in a way. You made things happen here, and now I am not just the village whore anymore. People actually value my brains, for a change."
    Rue "Y en cierto sentido, eso es gracias a ti. Hiciste que las cosas sucedieran aquí, y ahora ya no soy solo la puta del pueblo. La gente realmente valora mi inteligencia, para variar."

# game/scripts/raiders.rpy:1067
translate spanish rst_1_cbf9d8c7:

    # Rue "If I can help some of these poor folks get their head straight and help out my son before my sickness gets me, then that's a good thing."
    Rue "Si puedo ayudar a que algunos de estos pobres tipos se aclaren y ayudar a mi hijo antes de que mi enfermedad me alcance, entonces eso es algo bueno."

# game/scripts/raiders.rpy:1074
translate spanish re_rst1a_c95fc621:

    # Rue "Hm..."
    Rue "Hm..."

# game/scripts/raiders.rpy:1077
translate spanish re_rst1a_c79b9eb3:

    # Rue "I don't know about you, but I very strongly remember the first time we met, and the offer I made back then..."
    Rue "No sé qué piensas tú, pero yo recuerdo muy claramente la primera vez que nos encontramos y la oferta que hice en ese momento..."

# game/scripts/raiders.rpy:1078
translate spanish re_rst1a_6d5566c3:

    # Rue "Talking to people is nice, but I do sometimes miss using my mouth for something else..."
    Rue "Hablar con la gente está bien, pero a veces echo de menos usar la boca para otra cosa..."

# game/scripts/raiders.rpy:1079
translate spanish re_rst1a_693b8b59:

    # Rue "If you want, I wouldn't mind giving my hero some gratitude..."
    Rue "Si quieres, no me importaría darle algo de gratitud a mi héroe..."

# game/scripts/raiders.rpy:1086
translate spanish re_rst1a_b4bb73eb:

    # Z "Don't let me stop you. Let me see how."
    Z "No dejes que te lo impida. A ver cómo lo haces."

# game/scripts/raiders.rpy:1089
translate spanish re_rst1a_fc902775:

    # Rue "Oh, darling... I may not have the looks, but I do know what guys like."
    Rue "Oh, cariño... Puede que no sea guapa, pero sé lo que a los chicos les gusta."

# game/scripts/raiders.rpy:1094
translate spanish re_rst1a_fff3dbfa:

    # "She crawls towards you as you unbutton your pants..."
    "Se arrastra hacia ti mientras te desabrochas los pantalones..."

# game/scripts/raiders.rpy:1095
translate spanish re_rst1a_ac5b84c3:

    # Rue "Oh my... what do we have here..."
    Rue "Oh, vaya... ¿qué tenemos aquí...?"

# game/scripts/raiders.rpy:1098
translate spanish re_rst1a_44f3c9d8:

    # Rue "Your wife is a lucky woman..."
    Rue "Tu esposa es una mujer afortunada..."

# game/scripts/raiders.rpy:1101
translate spanish re_rst1a_37912a22:

    # Rue "It's been a long time since I've handled something so... healthy..."
    Rue "Hacía mucho tiempo que no manipulaba algo tan... saludable..."

# game/scripts/raiders.rpy:1104
