    # Kit "..."
    Kit "..."

# game/scripts/raiders.rpy:611
translate spanish rt_send_kitty_back_22bfe304:

    # "She gets up back to her place, as Asha kneels down again before you, resuming her work..."
    "Se levanta y regresa a su lugar, mientras Asha vuelve a arrodillarse ante ti y reanuda su trabajo..."

# game/scripts/raiders.rpy:617
translate spanish rt_send_kitty_back_6fb79fde:

    # "She gets up back to her place. You notice Asha glaring at her for a moment..."
    "Ella se levanta y regresa a su lugar. Notas que Asha la mira con enojo por un momento..."

# game/scripts/raiders.rpy:620
translate spanish rt_send_kitty_back_575e8cc2:

    # Zt "What could be the reason she is the way she is? Trauma? Some sort of mutation? Or was it really just the way she was raised by her brother?"
    Zt "¿Cuál podría ser la razón por la que es como es? ¿Trauma? ¿Algún tipo de mutación? ¿O realmente fue la forma en que la crió su hermano?"

# game/scripts/raiders.rpy:621
translate spanish rt_send_kitty_back_18efbf2e:

    # Zt "Maybe if I ask around the people I know, I will find out more about her."
    Zt "Tal vez si pregunto a las personas que conozco, descubriré más acerca de ella."

# game/scripts/raiders.rpy:622
translate spanish rt_send_kitty_back_90ef3706:

    # Zt "I'm not even sure if the blindfold she's wearing serves any other purpose, so for now, I won't change anything."
    Zt "Ni siquiera estoy seguro de si la venda que lleva le sirve para algún otro propósito, así que por ahora no cambiaré nada."

# game/scripts/raiders.rpy:623
translate spanish rt_send_kitty_back_d0ace27a:

    # Zt "I should have asked her brother more questions before giving him into Zion's hands..."
    Zt "Debería haberle hecho más preguntas a su hermano antes de entregárselo a Zion..."

# game/scripts/raiders.rpy:635
translate spanish rsa_1_a82825ac:

    # Z "How is it going around here?"
    Z "¿Cómo va por aquí?"

# game/scripts/raiders.rpy:638
translate spanish rsa_1_2b7daea0:

    # Wic "Hey... ha, look who's left the general's hut! Our saviour!"
    Wic "Ey... ja, mira quién salió de la choza del general. ¡Nuestro salvador!"

# game/scripts/raiders.rpy:641
translate spanish rsa_1_0ceb11d1:

    # Wic "How's that pink chick treating you, huh? I heard stories, of how you left her alive."
    Wic "¿Cómo está tratándote esa chica rosa, eh? Oí historias de cómo la dejaste viva."

# game/scripts/raiders.rpy:642
translate spanish rsa_1_a02a8d4a:

    # Wic "...right after you got rid of her bastard of a brother, of course."
    Wic "... justo después de deshacerte del maldito hermano de ella, por supuesto."

# game/scripts/raiders.rpy:645
translate spanish rsa_1_3231ee19:

    # Wic "Things have been looking better since your gang decided to decorate the bridge with the General's head."
    Wic "Las cosas han ido mejor desde que tu banda decidió decorar el puente con la cabeza del General."

# game/scripts/raiders.rpy:646
translate spanish rsa_1_cb2ab920:

    # Wic "We're really doing better, especially me, of course! So I've got to thank you."
    Wic "Realmente nos va mejor, sobre todo a mí, ¡por supuesto! Así que tengo que darte las gracias."

# game/scripts/raiders.rpy:649
translate spanish rsa_1_f24af6be:

    # Wic "...I said better though, not good. Life is still a bitch around here."
    Wic "... Aunque he dicho mejor, no bien. La vida sigue siendo una mierda por aquí."

# game/scripts/raiders.rpy:650
translate spanish rsa_1_7820e782:

    # Wic "The workload is still shit, we can barely feed our families out here, and we need more fabric, to make better cloth-"
    Wic "La carga de trabajo sigue siendo una mierda, apenas podemos alimentar a nuestras familias aquí fuera, y necesitamos más tela, para hacer mejores ropas..."

# game/scripts/raiders.rpy:653
translate spanish rsa_1_13e9e226:

    # SW "[Wic]... give it a rest already."
    SW "[Wic]... Déjalo ya."

# game/scripts/raiders.rpy:656
translate spanish rsa_1_dc1f452f:

    # SW "All you do is complain. You know full well that there are a lot of people who would give their leg to work here."
    SW "Todo lo que haces es quejarte. Sabes muy bien que hay mucha gente que daría su pierna por trabajar aquí."

# game/scripts/raiders.rpy:657
translate spanish rsa_1_e8e402a5:

    # SW "If you keep complaining... well, if the General can be replaced, so can you. and you know it."
    SW "Si sigues quejándote... bueno, si el General puede ser reemplazado, tú también puedes. Y lo sabes."

# game/scripts/raiders.rpy:660
translate spanish rsa_1_e7c8084e:

    # Wic "I... that's not the point..."
    Wic "Yo... eso no es lo importante..."

# game/scripts/raiders.rpy:663
translate spanish rsa_1_d5696d7f:

    # SW "Don't mind his attitude, Boss. There's more than enough of us who appreciate the better work conditions."
    SW "No te preocupes por mí, jefe. Estoy segura de que dirigir un asentamiento tampoco es fácil."

# game/scripts/raiders.rpy:664
translate spanish rsa_1_e907682e:

    # SW "There's always things that can be improved. But at least we're not getting most of our shit stolen by those thugs. Thanks again."
    SW "Siempre hay cosas que se pueden mejorar. Pero al menos esos matones no nos roban casi nada. Gracias de nuevo."

# game/scripts/raiders.rpy:674
translate spanish rsa_1_63467694:

    # Wic "I swear to everything, if you won't set me free, people will lay down their fucking pickaxes!"
    Wic "¡Lo juro por todo, si no me liberas, la gente dejará sus putas piquetas!"

# game/scripts/raiders.rpy:675
translate spanish rsa_1_11836d34:

    # Zi "{i}*Sigh...*{/i}"
    Zi "{i}*suspiro*{/i}"

# game/scripts/raiders.rpy:676
translate spanish rsa_1_92131d15:

    # Zi "I should just cut these chains loose..."
    Zi "Debería simplemente cortar estas cadenas..."

# game/scripts/raiders.rpy:677
translate spanish rsa_1_971edda4:

    # Z "Zion."
    Z "Zion."

# game/scripts/raiders.rpy:680
translate spanish rsa_1_5a65c3c7:

    # Zi "[persistent.player_name]... remind me again: why we didn't hang him next to the General?"
    Zi "[persistent.player_name]... Recuérdame, ¿por qué no lo ahorcamos junto al General?"

# game/scripts/raiders.rpy:681
translate spanish rsa_1_714981b2:

    # Z "Let's see about that.."
    Z "Veamos sobre eso..."

# game/scripts/raiders.rpy:684
translate spanish rsa_1_36680673:

    # Z "For now, you've got to endure it. People need to move on from him."
    Z "Por ahora, tienes que soportarlo. La gente necesita seguir adelante."

# game/scripts/raiders.rpy:685
translate spanish rsa_1_d077c6d7:

    # Zi "Those assholes should be happy to get work at all, and what do they produce instead? Cunts like this fuck."
    Zi "Esos gilipollas deberían alegrarse de tener trabajo, ¿y qué producen en su lugar? Cabrones como este cabrón."

# game/scripts/raiders.rpy:688
translate spanish rsa_1_e688b730:

    # Wic "You two... screw yourselves! We deserve more than this!"
    Wic "Vosotros dos... ¡que os den! ¡Nos merecemos más que esto!"

# game/scripts/raiders.rpy:689
translate spanish rsa_1_c355f506:

    # Zi "The only thing you deserve is a tour through my Adira, you little shit! Would teach you what you're really worth."
    Zi "Lo único que te mereces es un recorrido por mi Adira, ¡pequeña mierda! Te enseñaría lo que vales de verdad."

# game/scripts/raiders.rpy:692
translate spanish rsa_1_cf6029e1:

    # Zi "{i}*sigh*{/i}"
    Zi "{i}*suspiro*{/i}"

# game/scripts/raiders.rpy:693
translate spanish rsa_1_338041ae:

    # Zi "You should really consider getting rid of him soon, [persistent.player_name]. I can always find a use for another skull..."
    Zi "Deberías plantearte deshacerte de él pronto, [persistent.player_name]. Siempre puedo encontrar un uso para otro cráneo..."

# game/scripts/raiders.rpy:705
translate spanish rsf_1_010d980f:

    # Ky "Hey, [persistent.player_name], look what the cat dragged in..."
    Ky "Oye, [persistent.player_name], mira quién apareció..."

# game/scripts/raiders.rpy:708
translate spanish rsf_1_87f6c62c:

    # SW "I... I don't want to disturb for long, Miss..."
    SW "No... No quiero molestar mucho tiempo, señorita..."

# game/scripts/raiders.rpy:711
translate spanish rsf_1_ceaef6db:

    # Z "I remember you."
    Z "Te recuerdo."

# game/scripts/raiders.rpy:712
translate spanish rsf_1_747019a5:

    # SW "I am... merely here to see her... to see Kitty, I mean!"
    SW "Solo estoy... aquí para verla... para ver a Kitty, quiero decir."

# game/scripts/raiders.rpy:714
translate spanish rsf_1_abb759f5:

    # Z "She no longer goes by the name Kitty. That was the name the General used, and he was an idiot."
    Z "Ya no se llama Kitty. Ése era el nombre que usaba el General, y era un idiota."

# game/scripts/raiders.rpy:715
translate spanish rsf_1_e8304ddb:

    # Z "Her name is now [Kit]. You will address her by that name, and that name only."
    Z "Ahora se llama [Kit]. Te dirigirás a ella por ese nombre y sólo por ese nombre."

# game/scripts/raiders.rpy:716
translate spanish rsf_1_cbf224c8:

    # SW "Oh... this is... is that so? Then I am happy to finally address her correctly."
    SW "Oh... esto es... ¿es así? Entonces estoy feliz de finalmente dirigirme a ella correctamente."

# game/scripts/raiders.rpy:717
translate spanish rsf_1_b2b6f06a:

    # SW "[Kit]... I always felt like that was wrong. Thank you for giving [Kit] her identity back!"
    SW "[Kit]... Siempre sentí que eso estaba mal. Gracias por devolverle a [Kit] su identidad."

# game/scripts/raiders.rpy:719
translate spanish rsf_1_be9b385c:

    # Z "[Kit] is doing better, now that she is free from the General."
    Z "[Kit] está mejor ahora que está libre del General."

# game/scripts/raiders.rpy:720
translate spanish rsf_1_dc9632eb:

    # Z "We take good care of her."
    Z "Cuidamos bien de ella."

# game/scripts/raiders.rpy:721
translate spanish rsf_1_9b551402:

    # SW "That is... so good to hear! I am happy for her, really!"
    SW "Me alegro mucho de oírlo. ¡Me alegro por ella, de verdad!"

# game/scripts/raiders.rpy:728
translate spanish rsf_1_ae1ca445:

    # SW "I have brought coal, m...much more than last time."
    SW "He traído carbón, m...mucho más que la última vez."

# game/scripts/raiders.rpy:729
translate spanish rsf_1_1b498ad7:

    # SW "I wanted to see how she fares after... the Generals..."
    SW "Quería ver cómo le va después de... el General..."

# game/scripts/raiders.rpy:736
translate spanish rsf_1_1c2815f0:

    # Z "Yeah, we have discussed this."
    Z "Sí, ya lo hemos hablado."

# game/scripts/raiders.rpy:737
translate spanish rsf_1_93bbfd2e:

    # Z "[Kit], it looks like he brought enough tribute. Get up now, and walk to him."
    Z "[Kit], parece que trajo suficiente tributo. Levántate ahora y camina hacia él."

# game/scripts/raiders.rpy:740
translate spanish rsf_1_95a2598e:

    # "She follows your directions almost mechanically, reacting immediately to your orders..."
    "Sigue tus instrucciones casi mecánicamente, reaccionando inmediatamente a tus órdenes..."

# game/scripts/raiders.rpy:743
translate spanish rsf_1_5cb11211:

    # SW "Oh [Kit]... I am... beyond glad that nothing happened to you."
    SW "Oh [Kit].. Estoy más que contento de que no te haya pasado nada."

# game/scripts/raiders.rpy:744
translate spanish rsf_1_0b8ce56e:

    # SW "In fact... you are... as beautiful as ever!"
    SW "De hecho... eres... tan hermosa como siempre."

# game/scripts/raiders.rpy:745
translate spanish rsf_1_302a9836:

    # SW "I, uhm, hope my appearance does not annoy you, princess..."
    SW "Yo, eeh, espero que mi apariencia no te moleste, princesa..."

# game/scripts/raiders.rpy:746
translate spanish rsf_1_abf33785:

    # Z "That was such a nice compliment. [Kit], Give him a smile."
    Z "Qué bonito cumplido. [Kit], dale una sonrisa."

# game/scripts/raiders.rpy:749
translate spanish rsf_1_fddd4425:

    # Kit "...{w=1}{nw}"
    Kit "... {w=1}{nw}"

# game/scripts/raiders.rpy:752
translate spanish rsf_1_07e1c8c7:

    # SW "[Kit]..."
    SW "[Kit]..."

# game/scripts/raiders.rpy:755
translate spanish rsf_1_18548459:

    # SW "To put into words how much this meant to me..."
    SW "Expresar con palabras lo mucho que significaba para mí..."

# game/scripts/raiders.rpy:756
translate spanish rsf_1_fe5716df:

    # SW "I can't... hold it any longer."
    SW "No puedo... contenerlo más."

# game/scripts/raiders.rpy:759
translate spanish rsf_1_07e1c8c7_1:

    # SW "[Kit]..."
    SW "[Kit]..."

# game/scripts/raiders.rpy:760
translate spanish rsf_1_d4aa0439:

    # Kyw "Holy shit, man..."
    Kyw "¡Ostia puta, hombre!"

# game/scripts/raiders.rpy:763
translate spanish rsf_1_dc8811a1:

    # SW "I know that you may not understand, as we see each other only once a week."
    SW "Sé que quizás no lo entiendas, ya que solo nos vemos una vez a la semana."

# game/scripts/raiders.rpy:764
translate spanish rsf_1_85b6ae79:

    # SW "But know that I am working hard every week to be able to see you."
    SW "Pero ten en cuenta que trabajo duro cada semana para poder verte."

# game/scripts/raiders.rpy:765
translate spanish rsf_1_e5d310ca:

    # SW "Whatever it takes, you can be sure to rely on me, even in hard times."
    SW "Sea lo que sea, puedes estar segura de que contarás conmigo, incluso en los momentos difíciles."

# game/scripts/raiders.rpy:768
translate spanish rsf_1_eb0c6107:

    # SW "To have someone so perfect, so flawless, pure and... otherworldly..."
    SW "Tener a alguien tan perfecto, tan impecable, puro y... sin palabras..."

# game/scripts/raiders.rpy:769
translate spanish rsf_1_462a86b7:

    # SW "...stand before a flawed, miserable worker like me..."
    SW "... estar frente a un trabajador imperfecto y miserable como yo..."

# game/scripts/raiders.rpy:772
translate spanish rsf_1_8554a38c:

    # SW "...it is the only reason I keep going. You are the highlight of my existence..."
    SW "... es la única razón por la que sigo adelante. Eres el punto culminante de mi existencia..."

# game/scripts/raiders.rpy:775
translate spanish rsf_1_aeca80d6:

    # SW "And should I never reach your heart enough to love me back..."
    SW "Y si nunca llego a tu corazón lo suficiente como para que me ames de vuelta..."

# game/scripts/raiders.rpy:776
translate spanish rsf_1_5e54b52e:

    # SW "...it is at least a dream... one that makes me escape the reality of this place. Of my struggles."
    SW "...al menos es un sueño... uno que me hace escapar de la realidad de este lugar. De mis luchas."

# game/scripts/raiders.rpy:780
translate spanish rsf_1_4de43a56:

    # SW "If I only could... have a little more of you..."
    SW "Si tan solo pudiera... tener un poco más de ti..."

# game/scripts/raiders.rpy:783
translate spanish rsf_1_07e1c8c7_2:

    # SW "[Kit]..."
    SW "[Kit]..."

# game/scripts/raiders.rpy:786
translate spanish rsf_1_ad57163d:

    # SW "You are so..."
    SW "Eres tan..."

# game/scripts/raiders.rpy:789
translate spanish rsf_1_c71544e8:

    # SW "Mmph..."
    SW "Mmph..."

# game/scripts/raiders.rpy:790
