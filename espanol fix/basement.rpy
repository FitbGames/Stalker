    F "..."

# game/scripts/basement.rpy:2383
translate spanish bf129_ed7c0b12:

    # Z "You look healthy."
    Z "Tienes un aspecto saludable."

# game/scripts/basement.rpy:2384
translate spanish bf129_f3d3e441:

    # Z "Dirty too, but that we can fix."
    Z "También sucia, pero eso lo podemos arreglar."

# game/scripts/basement.rpy:2387
translate spanish bf129_2e54e868:

    # Z "I'm done inspecting you."
    Z "He terminado de inspeccionarte."

# game/scripts/basement.rpy:2388
translate spanish bf129_d11f0889:

    # Z "You can get dressed again."
    Z "Puedes volver a vestirte."

# game/scripts/basement.rpy:2391
translate spanish bf129_1a2455bb:

    # F "Master... can I..."
    F "Amo... ¿puedo...?"

# game/scripts/basement.rpy:2394
translate spanish bf129_d488cd10:

    # Z "No. I said get dressed. That's all for today."
    Z "No. He dicho que te vistas. Eso es todo por hoy."

# game/scripts/basement.rpy:2400
translate spanish bf129_5ab3574d_2:

    # Z "..."
    Z "..."

# game/scripts/basement.rpy:2408
translate spanish bf129_96a99a3d:

    # Z "Your body will do just fine."
    Z "Tu cuerpo servirá perfectamente."

# game/scripts/basement.rpy:2409
translate spanish bf129_1fdcdf05:

