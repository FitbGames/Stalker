    # Z "..."
    Z "..."

# game/scripts/basement.rpy:2362
translate spanish bf129_e689c10d:

    # Zt "That's a cute face. I don't think she's from around here."
    Zt "Tiene una cara bonita. No creo que sea de por aquí."

# game/scripts/basement.rpy:2365
translate spanish bf129_5b83dd17:

    # "You start feeling her up..."
    "Empiezas a palparla..."

# game/scripts/basement.rpy:2368
translate spanish bf129_3a475403:

    # Zt "Yes, definitely toned and firm."
    Zt "Sí, definitivamente tonificada y firme."

# game/scripts/basement.rpy:2369
translate spanish bf129_bc3969d0:

    # Zt "And yet..."
    Zt "Y sin embargo..."

# game/scripts/basement.rpy:2372
translate spanish bf129_b90e3718:

    # Zt "...plump in all the right places."
    Zt "... bien proporcionada en las zonas clave."

# game/scripts/basement.rpy:2378
translate spanish bf129_e7913b4a_1:

