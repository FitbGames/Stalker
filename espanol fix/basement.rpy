    Z "En realidad ya no importa. A partir de ahora me servirás sin reservas."

# game/scripts/basement.rpy:814
translate spanish bf233_f1758576:

    # Z "As long as you do as you're told, you will not lack for food, shelter and essential commodities, this I promise."
    Z "Mientras hagas lo que te digo, no te faltará comida, techo ni productos básicos, te lo prometo."

# game/scripts/basement.rpy:815
translate spanish bf233_e7913b4a_1:

    # F "..."
    F "..."

# game/scripts/basement.rpy:818
translate spanish bf233_2ee5f3b1:

