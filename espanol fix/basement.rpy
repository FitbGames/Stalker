    # F "..."
    F "..."

# game/scripts/basement.rpy:2444
translate spanish fairy_food_3ecb9604:

    # F "Master, this..."
    F "Amo, esto..."

# game/scripts/basement.rpy:2447
translate spanish fairy_food_40425fc7:

    # F "I don't..."
    F "Yo no..."

# game/scripts/basement.rpy:2450
translate spanish fairy_food_9205cb5b:

    # F "Let me serve, Master."
    F "Déjeme servirle, Amo."

# game/scripts/basement.rpy:2451
translate spanish fairy_food_5a9313f7:

    # F "I want mor-"
    F "Quiero más..."

# game/scripts/basement.rpy:2454
translate spanish fairy_food_30ebb0c2:

