    # Z "It's yours."
    Z "Es tuyo."

# game/scripts/basement.rpy:2692
translate spanish fairy_food_floor_e7913b4a:

    # F "..."
    F "..."

# game/scripts/basement.rpy:2693
translate spanish fairy_food_floor_e09d6e8e:

