    Z "Puedes quedarte con el resto, pero tienes que comértelo tú misma."

# game/scripts/basement.rpy:2493
translate spanish fairy_food_fed_herself_79e00f87:

    # Z "You can have it, but I'm not going to feed you."
    Z "Puedes tenerlo, pero yo no te voy a dar de comer."

# game/scripts/basement.rpy:2494
translate spanish fairy_food_fed_herself_e7913b4a:

    # F "..."
    F "..."

