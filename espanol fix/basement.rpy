translate spanish fairy_food_fed_herself_71d7cf38:

    # Z "Here, take it, before it gets cold."
    Z "Toma, cógelo, antes de que se enfríe."

# game/scripts/basement.rpy:2510
translate spanish fairy_food_fed_herself_e7913b4a_1:

    # F "..."
    F "..."

# game/scripts/basement.rpy:2511
