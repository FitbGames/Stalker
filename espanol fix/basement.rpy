    "Se arrastra vacilante hacia ti..."

# game/scripts/basement.rpy:2463
translate spanish fairy_food_e7913b4a_1:

    # F "..."
    F "..."

# game/scripts/basement.rpy:2466
translate spanish fairy_food_9a7cfffd:

    # Z "Are you hungry?"
    Z "¿Tienes hambre?"

# game/scripts/basement.rpy:2467
translate spanish fairy_food_e7913b4a_2:

    # F "..."
    F "..."

# game/scripts/basement.rpy:2470
translate spanish fairy_food_a83ec6d2:

