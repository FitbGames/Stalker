    Z "No me mires así."

# game/scripts/basement.rpy:2498
translate spanish fairy_food_fed_herself_89fed7c2:

    # Z "Stand up, sit down next to me. I won't do anything to you."
    Z "Levántate y siéntate a mi lado. No te haré nada."

