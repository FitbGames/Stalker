# game/scripts/day17.rpy:3
translate spanish d17a_part_1_0e92e9c4:

    # Zt "It looks like Fangs is busy somewhere else..."
    Zt "Parece que Fangs está ocupada en otro lugar..."

# game/scripts/day17.rpy:10
translate spanish d17a_part_1_16033a65:

    # Z "Hey, guys. Has anyone seen Fangs?"
    Z "¡Eh, chicas! ¿Alguna ha visto a Fangs?"

# game/scripts/day17.rpy:17
translate spanish d17a_part_1_c4bd7af6:

    # Mu "Hm..."
    Mu "Hm..."

# game/scripts/day17.rpy:24
translate spanish d17a_part_1_c502f4e2:

    # Mu "Oh yeah, I saw her leaving."
    Mu "¡Oh, sí! La vi salir."

# game/scripts/day17.rpy:31
translate spanish d17a_part_1_e6b1331c:

    # Mu "No idea where she went, though. Why do you need her?"
    Mu "Aunque no tengo ni idea de adónde ha ido. ¿Para qué la necesitas?"

# game/scripts/day17.rpy:38
translate spanish d17a_part_1_734f397e:

    # Z "To ask her what else she is planning."
    Z "Para preguntarle qué más está planeando."

# game/scripts/day17.rpy:42
translate spanish d17a_part_1_0efb8c53:

    # Mant "You could try the gymnasium. She spends her breaks there sometimes."
    Mant "Podrías probar el gimnasio. A veces pasa sus descansos allí."

# game/scripts/day17.rpy:45
translate spanish d17a_part_1_285749e9:

    # Z "Thank you, Mantis. I will try my luck there."
    Z "Gracias, Mantis. Probaré suerte allí."

# game/scripts/day17.rpy:47
translate spanish d17a_part_1_04eae606:

    # Mu "Yeah, she did mention something, but I don't recall the details."
    Mu "Sí, ella mencionó algo, pero no recuerdo los detalles."

# game/scripts/day17.rpy:50
translate spanish d17a_part_1_429492bb:

    # Mu "Just try the gym, that's where she takes her breaks."
    Mu "Prueba el gimnasio, ahí es donde toma sus descansos."

# game/scripts/day17.rpy:53
translate spanish d17a_part_1_9fba6479:

    # Z "Alright, I will take a look."
    Z "Vale, echaré un vistazo."

# game/scripts/day17.rpy:56
translate spanish d17a_part_1_73b9c646:

    # "You move towards the gymnasium..."
    "Te diriges hacia el gimnasio..."

# game/scripts/day17.rpy:59
translate spanish d17a_part_1_d3c264bc:

    # Mu "..."
    Mu "..."

# game/scripts/day17.rpy:67
translate spanish d17a_part_1_d3c264bc_1:

    # Mu "..."
    Mu "..."

# game/scripts/day17.rpy:71
translate spanish d17a_part_1_efa2fecb:

    # Z "{i}*sigh*{/i}"
    Z "{i}*suspiro*{/i}"

# game/scripts/day17.rpy:72
translate spanish d17a_part_1_5f2a6bc3:

    # Zt "No Fangs here either."
    Zt "Tampoco está Fangs por aquí."

# game/scripts/day17.rpy:75
translate spanish d17a_part_1_3b3fd6c8:

    # Zt "Might as well ask her..."
    Zt "Será mejor que le pregunte..."

# game/scripts/day17.rpy:79
translate spanish d17a_part_1_d6df2ce5:

    # "As you step closer, you can see the girl's dark eyes staring into yours..."
    "Al acercarte, puedes ver los oscuros ojos de la chica mirándote fijamente..."

# game/scripts/day17.rpy:80
translate spanish d17a_part_1_f325b2bd:

    # Z "Hey you, have you any idea where I can find Fangs?"
    Z "Ey tú, ¿sabes dónde puedo encontrar a Fangs?"

# game/scripts/day17.rpy:87
translate spanish d17a_part_1_d3c264bc_2:

    # Mu "..."
    Mu "..."

# game/scripts/day17.rpy:90
translate spanish d17a_part_1_f6c1269e:

    # "You hear footsteps approaching from outside..."
    "Oyes pasos acercándose desde fuera..."

# game/scripts/day17.rpy:97
translate spanish d17a_part_1_1e0b25e1:

    # Fa "The shower's free if you want, Krait."
    Fa "La ducha está libre si la quieres, Krait."

# game/scripts/day17.rpy:100
translate spanish d17a_part_1_c58e0196:

    # Fa "Oh, hey [persistent.player_name]. What do you need?"
    Fa "¡Oh, ey, [persistent.player_name]! ¿Qué necesitas?"

# game/scripts/day17.rpy:103
translate spanish d17a_part_1_f1ebb837:

    # Z "I wanted to check if you made some progress in your searches."
    Z "Quería comprobar si hiciste algún progreso en tus búsquedas."

# game/scripts/day17.rpy:106
translate spanish d17a_part_1_41b60a4f:

    # Fa "Well, I didn't..."
    Fa "Bueno, no lo hice..."

# game/scripts/day17.rpy:109
translate spanish d17a_part_1_6c5bc257:

    # Fa "But she did."
    Fa "Pero ella lo hizo."

# game/scripts/day17.rpy:112
translate spanish d17a_part_1_f74fbc20:

    # Fa "Krait and I wanted to go over the things she found, but we aren't done yet."
    Fa "Krait y yo queríamos repasar las cosas que encontró, pero aún no hemos terminado."

# game/scripts/day17.rpy:115
translate spanish d17a_part_1_7396a9c9:

    # Fa "I'll let you know when I've hammered out the details. Meanwhile, you could go see Pepper."
    Fa "Te haré saber cuando haya pulido los detalles. Mientras tanto, podrías ir a ver a Pepper."

# game/scripts/day17.rpy:118
translate spanish d17a_part_1_63d60fd1:

    # Kr "Yeah... we were sidetracked..."
    Kr "Sí... nos distrajimos..."

# game/scripts/day17.rpy:123
translate spanish d17a_part_1_01fa4e64:

    # Z "Do you want to fill me in on the basics, then?"
    Z "¿Quieres ponerme al tanto de lo básico, entonces?"

# game/scripts/day17.rpy:126
translate spanish d17a_part_1_879962eb:

    # Fa "It's best you talk to Pepper herself for that. It concerns her directly after all."
    Fa "Lo mejor es que hables con Pepper directamente para eso. Al fin y al cabo, le concierne a ella."

# game/scripts/day17.rpy:127
translate spanish d17a_part_1_15960c77:

    # Fa "She should be in her lab as usual."
    Fa "Probablemente esté en su laboratorio como de costumbre."

# game/scripts/day17.rpy:130
translate spanish d17a_part_1_1f763c12:

    # Z "Pepper has an issue?"
    Z "¿Pepper tiene algún problema?"

# game/scripts/day17.rpy:133
translate spanish d17a_part_1_879d5fa5:

    # Fa "Yes. Sort of. The village she hails from seems to be having problems."
    Fa "Sí. Más o menos. El pueblo del que proviene parece estar teniendo problemas."

# game/scripts/day17.rpy:136
translate spanish d17a_part_1_7da3455c:

    # Fa "Anyway, I forgot to bring your report, Krait. Be right back."
    Fa "De todos modos, olvidé traer tu informe, Krait. Vuelvo enseguida."

# game/scripts/day17.rpy:139
translate spanish d17a_part_1_fe0cca93:

    # Fa "Let's continue the discussion then."
    Fa "Continuemos la discusión, entonces."

# game/scripts/day17.rpy:142
translate spanish d17a_part_1_fba9da71:

    # Kr "Right... continue the discussion..."
    Kr "Claro... sigamos con la discusión..."

# game/scripts/day17.rpy:148
translate spanish d17a_part_1_9df33ed3:

    # Z "I hadn't seen you here yet."
    Z "Aún no te había visto aquí."

# game/scripts/day17.rpy:154
translate spanish d17a_part_1_62dceb78:

    # "You notice her pose, relaxed, as she's casually draped over the chair, her curvy figure a contrast to the somewhat more butch looks of many of the mutants in this place."
    "Notas su pose, relajada, mientras está casualmente recostada en la silla, su figura curvilínea contrastando con el aspecto algo más rudo de muchas de las mutantes en este lugar."

# game/scripts/day17.rpy:155
translate spanish d17a_part_1_7c328a42:

    # "Her speech is slow but deliberate and measured, her voice enticing and sensual. She stares at you, but you realize you know nothing about her yet."
    "Su discurso es lento, pero deliberado y mesurado, su voz seductora y sensual. Te mira fijamente, pero te das cuenta de que aún no sabes nada sobre ella."

# game/scripts/day17.rpy:156
translate spanish d17a_part_1_cf7284b7:

    # Z "\"Krait\", hm? Did Fangs give you that name?"
    Z "\"Krait\", ¿eh? ¿Fangs te dio ese nombre?"

# game/scripts/day17.rpy:159
translate spanish d17a_part_1_eb0e9a3e:

    # Kr "She did..."
    Kr "Lo hizo..."

# game/scripts/day17.rpy:162
translate spanish d17a_part_1_0bf30455:

    # Z "And why is that?"
    Z "¿Y eso por qué?"

# game/scripts/day17.rpy:165
translate spanish d17a_part_1_9922b583:

    # Kr "I don't know... ask Fangs."
    Kr "No sé... pregunta a Fangs."

# game/scripts/day17.rpy:168
translate spanish d17a_part_1_3eeadadf:

    # Kr "...might have to do with our {i}discussions{/i}..."
    Kr "... podría tener que ver con nuestras {i}discusiones{/i}..."

# game/scripts/day17.rpy:174
translate spanish d17a_part_1_6a66bd28:

    # Kr "..."
    Kr "..."

# game/scripts/day17.rpy:175
translate spanish d17a_part_1_8a68ba01:

    # Zt "Blessed be..."
    Zt "Bendito sea..."

# game/scripts/day17.rpy:178
translate spanish d17a_part_1_b18acb9b:

    # Kr "I heard Pepper needs you in her laboratory, doesn't she?"
    Kr "Escuché que Pepper te necesita en su laboratorio, ¿no es así?"

# game/scripts/day17.rpy:181
translate spanish d17a_part_1_5ab3574d:

    # Z "..."
    Z "..."

# game/scripts/day17.rpy:182
translate spanish d17a_part_1_47d4ccbe:

    # Z "She does, yes."
    Z "Sí, lo hace."

# game/scripts/day17.rpy:185
translate spanish d17a_part_1_9c85f583:

    # "You stand and stare for a moment longer, replaying her provocation in your mind..."
    "Te quedas ahí y observas un momento más, repasando su provocación en tu mente..."

# game/scripts/day17.rpy:188
translate spanish d17a_part_1_7f0b9a29:

    # Z "I will see you around."
    Z "Nos veremos."

# game/scripts/day17.rpy:189
translate spanish d17a_part_1_6a66bd28_1:

    # Kr "..."
    Kr "..."

# game/scripts/day17.rpy:194
translate spanish d17a_part_1_262d31ac:

    # Pe "{i}*mumbling*{/i}"
    Pe "{i}*murmurando*{/i}"

# game/scripts/day17.rpy:195
translate spanish d17a_part_1_198412dd:

    # Pe "This goes in there..."
    Pe "Esto va ahí..."

# game/scripts/day17.rpy:198
translate spanish d17a_part_1_3e1d1aae:

    # Pe "You better not fail on me. I only have the two of you..."
    Pe "Será mejor que no me falles. Solo tengo a vosotros dos..."

# game/scripts/day17.rpy:205
translate spanish d17a_part_1_2e3987c0:

    # Pe "..."
    Pe "..."

# game/scripts/day17.rpy:206
translate spanish d17a_part_1_81b12872:

    # Z "Pepper, Fang's told me tha...-"
    Z "Pepper, Fangs me dijo que...-"

# game/scripts/day17.rpy:209
translate spanish d17a_part_1_5ab3574d_1:

    # Z "..."
    Z "..."

# game/scripts/day17.rpy:210
translate spanish d17a_part_1_f6b541a2:

    # Z "Hey..."
    Z "Ey..."

# game/scripts/day17.rpy:213
translate spanish d17a_part_1_40527276:

    # Pe "Yes, [persistent.player_name]? The laboratory is shut down today."
    Pe "¿Sí, [persistent.player_name]? El laboratorio hoy está cerrado."

# game/scripts/day17.rpy:215
translate spanish d17a_part_1_c733071e:

    # Pe "You may donate your samples another time."
    Pe "Puedes donar tus muestras en otro momento."

# game/scripts/day17.rpy:220
translate spanish d17a_part_1_15e9aaf7:

    # Z "I am not here for that. Fangs sent me to you for some information about whatever her scout discovered."
    Z "No estoy aquí por eso. Fangs me envió contigo por información sobre lo que descubrió su exploradora."

# game/scripts/day17.rpy:227
translate spanish d17a_part_1_5fbce2ec:

    # "You take your time admiring her, for once not wearing her usual labcoat."
    "Te tomas tu tiempo admirándola, por una vez sin llevar su habitual bata de laboratorio."

# game/scripts/day17.rpy:230
translate spanish d17a_part_1_7d7d662c:

    # "Her long legs and feet attract your gaze first, the remainder of her body barely covered by a revealing bodysuit..."
    "Sus largas piernas y pies atraen tu mirada primero, el resto de su cuerpo apenas cubierto por un traje ceñido y revelador..."

# game/scripts/day17.rpy:231
translate spanish d17a_part_1_e9cdc85e:

    # Pe "[persistent.player_name]...?"
    Pe "¿[persistent.player_name]...?"

# game/scripts/day17.rpy:234
translate spanish d17a_part_1_c386cd87:

    # Z "What happened to the lab coat?"
    Z "¿Qué pasó con la bata de laboratorio?"

# game/scripts/day17.rpy:235
translate spanish d17a_part_1_b8de1d94:

    # Pe "Oh... of course..."
    Pe "¡Oh... por supuesto!"

# game/scripts/day17.rpy:238
translate spanish d17a_part_1_67b7b824:

    # Pe "{i}*sigh*{/i} I should have known."
    Pe "{i}*suspiro*{/i} Debería haberlo sabido."

# game/scripts/day17.rpy:241
translate spanish d17a_part_1_316b58dd:

    # Pe "The coat is being washed, [persistent.player_name]."
    Pe "La bata está siendo lavada, [persistent.player_name]."

# game/scripts/day17.rpy:242
translate spanish d17a_part_1_37787138:

    # Pe "And since I am just inspecting the machines today, I am just dressed for comfort. My comfort."
    Pe "Y como hoy solo estoy inspeccionando las máquinas, estoy vestida para estar cómoda. Mi comodidad."

# game/scripts/day17.rpy:245
translate spanish d17a_part_1_b7fbe7df:

    # Z "Yeah... I can see that."
    Z "Sí... ya lo veo."

# game/scripts/day17.rpy:248
translate spanish d17a_part_1_c67f6581:

    # Pe "Now, if you're done staring, can we go back to the reason for your presence?"
    Pe "Ahora, si has terminado de mirar, ¿podemos volver a la razón de tu presencia?"

# game/scripts/day17.rpy:251
translate spanish d17a_part_1_e36665af:

    # Z "Fine. Fangs tells me you have information about her scout's latest finds..."
    Z "Vale. Fangs me dice que tienes información sobre los últimos hallazgos de su exploradora..."

# game/scripts/day17.rpy:255
translate spanish d17a58_e7ed1d89:

    # Z "Krait, I believe? Something about your village."
    Z "Krait, ¿verdad? Algo sobre tu pueblo."

# game/scripts/day17.rpy:258
translate spanish d17a58_50b21665:

    # Pe "Village, huh..."
    Pe "¿Pueblo, eh...?"

# game/scripts/day17.rpy:261
translate spanish d17a58_1e54d114:

    # Pe "...if you can even call it that. They call themselves a tribe..."
    Pe "... si es que puedes llamarlo así. Se hacen llamar una tribu..."

# game/scripts/day17.rpy:264
translate spanish d17a58_cf0a3806:

    # Pe "And yes, they try to keep to themselves.."
    Pe "Y sí, intentan mantenerse por su cuenta..."

# game/scripts/day17.rpy:265
translate spanish d17a58_a01e51ad:

    # Pe "Krait had been keeping an eye on them, because of some movements in the region. I don't really have many details other than this."
    Pe "Krait los había estado vigilando debido a algunos movimientos en la región. Realmente no tengo muchos detalles aparte de esto."

# game/scripts/day17.rpy:268
translate spanish d17a58_1b3b6ba2:

    # Pe "Not sure what Fangs wants me to tell you, other than Krait suspecting an attack against the village has happened. We intend to intervene."
    Pe "No estoy segura de qué quiere que te diga Fangs, aparte de que Krait sospecha que ha ocurrido un ataque contra la aldea. Tenemos la intención de intervenir."

# game/scripts/day17.rpy:274
translate spanish d17a_pepper_questions_d1e7d653:

    # Z "I didn't know the bunker has other outside connections."
    Z "No sabía que el búnker tenía otras conexiones externas."

# game/scripts/day17.rpy:277
translate spanish d17a_pepper_questions_b323109a:

    # Pe "That's because... we don't. But we do all come from somewhere else. Either way, we are simply looking out for them. It's a long story."
    Pe "Eso es porque... no lo hacemos. Pero todos venimos de algún otro lugar. De cualquier forma, solo buscamos protegerlos. Es una larga historia."

# game/scripts/day17.rpy:284
translate spanish d17a_pepper_questions_48c4062c:

    # Z "You are far too educated to have grown up in some random wasteland tribe."
    Z "Eres muy educada para haber crecido en una tribu cualquiera de un páramo."

# game/scripts/day17.rpy:287
translate spanish d17a_pepper_questions_d620dbea:

    # Pe "While I appreciate the compliment, you should know that tribe is just the name they have chosen for themselves."
    Pe "Aunque aprecio el cumplido, deberías saber que tribu es solo el nombre que eligieron para sí mismos."

# game/scripts/day17.rpy:288
translate spanish d17a_pepper_questions_3d9f8e91:

    # Pe "It doesn't imply an inferior level of education just because other tribes don't value education the same way."
    Pe "No implica un nivel inferior de educación solo porque otras tribus no valoren la educación de la misma manera."

# game/scripts/day17.rpy:291
translate spanish d17a_pepper_questions_5bb47675:

    # Pe "Just as you are more educated than many of your people in Zeta, some tribes are less ignorant than others."
    Pe "Así como tú estás más educado que muchos de tu gente en Zeta, algunas tribus son menos ignorantes que otras."

# game/scripts/day17.rpy:295
translate spanish d17a_pepper_questions_985d9a81:

    # Pe "Although, I have my doubts now, about you. If all it takes is showing a little skin to short circuit you..."
    Pe "Aunque, ahora tengo mis dudas sobre ti. Si todo lo que se necesita es mostrar un poco de piel para cortocircuitarte..."

# game/scripts/day17.rpy:298
translate spanish d17a_pepper_questions_a4766dea:

    # Z "Very funny. But I assume you don't read old scriptures about machines just for fun, do you?"
    Z "Muy graciosa. Pero supongo que no lees viejos textos sobre máquinas solo por diversión, ¿verdad?"

# game/scripts/day17.rpy:301
translate spanish d17a_pepper_questions_ffd030eb:

    # Pe "We do not, indeed. There is a reason for everything."
    Pe "No, no lo hacemos. Todo tiene su razón de ser."

# game/scripts/day17.rpy:304
translate spanish d17a_pepper_questions_64757330:

    # Pe "But that's for another time. We both have better things to do now."
    Pe "Pero eso es para otro momento. Ahora tenemos cosas mejores que hacer."

# game/scripts/day17.rpy:310
translate spanish d17a_pepper_questions_5b97d8db:

    # Z "So... I assume your people don't read old scriptures about machines just for fun, do they?"
    Z "Supongo que tu gente no lee escrituras antiguas sobre máquinas solo por diversión, ¿verdad?"

# game/scripts/day17.rpy:313
translate spanish d17a_pepper_questions_ffd030eb_1:

    # Pe "We do not, indeed. There is a reason for everything."
    Pe "No, no lo hacemos. Todo tiene su razón de ser."

# game/scripts/day17.rpy:316
translate spanish d17a_pepper_questions_64757330_1:

    # Pe "But that's for another time. We both have better things to do now."
    Pe "Pero eso es para otro momento. Ahora tenemos cosas mejores que hacer."

# game/scripts/day17.rpy:326
translate spanish d17a_pepper_questions_end_3f1f770c:

    # Z "So what do you need me for?"
    Z "¿Entonces para qué me necesitas?"

# game/scripts/day17.rpy:329
translate spanish d17a_pepper_questions_end_515e2037:

    # Pe "I appreciate you going straight to the point."
    Pe "Agradezco que vayas directo al grano."

# game/scripts/day17.rpy:332
translate spanish d17a_pepper_questions_end_3876183f:

    # Pe "Look, I know you have questions, but this is neither the place nor time for my personal story."
    Pe "Mira, sé que tienes preguntas, pero este no es ni el lugar ni el momento para mi historia personal."

# game/scripts/day17.rpy:335
translate spanish d17a_pepper_questions_end_d2d2de66:

    # Pe "And as you may have noticed, I am in the middle of something, here."
    Pe "Y como te habrás dado cuenta, estoy en medio de algo aquí."

# game/scripts/day17.rpy:338
translate spanish d17a_pepper_questions_end_d933a9a2:

    # Pe "So please, do me a great favor and go to the lower maintenance section."
    Pe "Por favor, hazme un gran favor y ve a la sección de mantenimiento inferior."

# game/scripts/day17.rpy:339
translate spanish d17a_pepper_questions_end_89b37c12:

    # Pe "My sister is there, ask whether she has completed the gear checkup, and her... personal project."
    Pe "Mi hermana está allí, pregúntale si ha completado la revisión del equipo y su... proyecto personal."

# game/scripts/day17.rpy:342
translate spanish d17a_pepper_questions_end_6ab19b2d:

    # Z "You never mentioned you had a sister."
    Z "Nunca mencionaste que tenías una hermana."

# game/scripts/day17.rpy:345
translate spanish d17a_pepper_questions_end_b57adf91:

    # Pe "You don't know the first thing about me, [persistent.player_name]. We hardly talk. Why would I mention her to you?"
    Pe "No sabes lo más mínimo sobre mí, [persistent.player_name]. Casi no hablamos. ¿Por qué iba a mencionártela?"

# game/scripts/day17.rpy:348
translate spanish d17a_pepper_questions_end_2301ee02:

    # Pe "But yes, I try to avoid letting her inside the laboratory or involving her in missions."
    Pe "Pero sí, trato de evitar que entre al laboratorio o que se involucre en misiones."

# game/scripts/day17.rpy:349
translate spanish d17a_pepper_questions_end_c78ac0ae:

    # Pe "She is extremely naive, and her unfocused nature makes it impossible for me to work with her."
    Pe "Es extremadamente ingenua, y su naturaleza dispersa hace imposible trabajar con ella."

# game/scripts/day17.rpy:352
translate spanish d17a_pepper_questions_end_a78ef5e1:

    # Pe "But... it seems that I cannot convince Fangs to leave her behind this time around, so she will unfortunately accompany us."
    Pe "Pero... parece que no puedo convencer a Fangs de dejarla atrás esta vez, así que lamentablemente nos acompañará."

# game/scripts/day17.rpy:355
translate spanish d17a_pepper_questions_end_2a17c843:

    # Pe " As I said, the maintenance rooms. She's short, a couple years younger than me. You'll recognise her, I'm sure."
    Pe "Como dije, las salas de mantenimiento. Es bajita, un par de años más joven que yo. La reconocerás, estoy segura."

# game/scripts/day17.rpy:356
translate spanish d17a_pepper_questions_end_c9787515:

    # Pe "I apologize for the noise in advance. Unlike me, she does not like to work in silence."
    Pe "Disculpa el ruido de antemano. A diferencia de mí, a ella no le gusta trabajar en silencio."

# game/scripts/day17.rpy:359
translate spanish d17a_pepper_questions_end_2e625203:

    # Z "Okay... although I am getting tired of being shuffled around, all over this place."
    Z "Vale... aunque me estoy cansando de que me lleven de un lado a otro por este lugar."

# game/scripts/day17.rpy:363
translate spanish d17a_pepper_questions_end_33a46fdf:

    # "Some time later..."
    "Pasado un tiempo..."

# game/scripts/day17.rpy:377
translate spanish d17a_pepper_questions_end_7aae589c:

    # C "Hm, hm, hm...!"
    C "Hm, hm, hm... ¡!"

# game/scripts/day17.rpy:378
translate spanish d17a_pepper_questions_end_86a8e2ad:

    # C "Doo doo..."
    C "Doo doo..."

# game/scripts/day17.rpy:379
translate spanish d17a_pepper_questions_end_bd834230:

    # C "Screw in this, screw in that...!"
    C "¡Atornilla esto, atornilla aquello...!"

# game/scripts/day17.rpy:380
translate spanish d17a_pepper_questions_end_1bac1aac:

    # Z "Hello!"
    Z "¡Hola!"

# game/scripts/day17.rpy:381
translate spanish d17a_pepper_questions_end_913e2240:

    # C "Tat tat tat... Hm hmm..."
    C "Tat tat tat... Hm hmm..."

# game/scripts/day17.rpy:382
translate spanish d17a_pepper_questions_end_90a2cec7:

    # Z "Can you hear me?!"
    Z "¿Puedes oírme?"

# game/scripts/day17.rpy:385
translate spanish d17a_pepper_questions_end_2459756e:

    # C "{i}*humming*{/i}"
    C "{i}*tarareando*{/i}"

# game/scripts/day17.rpy:386
translate spanish d17a_pepper_questions_end_efa2fecb:

    # Z "{i}*sigh*{/i}"
    Z "{i}*suspiro*{/i}"

# game/scripts/day17.rpy:388
translate spanish d17a_pepper_questions_end_08b6f201:

    # Z "HEY! I'M BEHIND YOU!"
    Z "¡Ey! ¡ESTOY DETRÁS DE TI!"

# game/scripts/day17.rpy:391
translate spanish d17a_pepper_questions_end_4250ce34:

    # C "Huh..."
    C "Eh..."

# game/scripts/day17.rpy:394
translate spanish d17a_pepper_questions_end_31cfe388:

    # C "Oh..."
    C "Oh..."

# game/scripts/day17.rpy:397
translate spanish d17a_pepper_questions_end_6338a33a:

    # C "Hi!! Haven't seen you before! But I think I know who you are!"
    C "¡Hola! No te había visto antes. ¡Pero creo que sé quién eres!"

# game/scripts/day17.rpy:402
translate spanish d17a_pepper_questions_end_a29c4e8a:

    # Z "You like it loud!"
    Z "¡Te gusta que sea ruidoso!"

# game/scripts/day17.rpy:405
translate spanish d17a_pepper_questions_end_7ae04369:

    # C "Totally! What's the point if you can ignore it?!"
    C "¡Totalmente! ¡¿Cuál es el punto si puedes ignorarlo?!"

# game/scripts/day17.rpy:408
translate spanish d17a_pepper_questions_end_7d1fdeee:

    # Z "What is this noise?!"
    Z "¡¿Qué es ese ruido?!"

# game/scripts/day17.rpy:411
translate spanish d17a_pepper_questions_end_5503798f:

    # C "Oh, you don't like it? Did you know they used to dance to this?"
    C "Oh, ¿no te gusta? ¿Sabías que solían bailar con esto?"

# game/scripts/day17.rpy:416
translate spanish d17a72_3e94c204:

    # Z "Yeah... so... your sister sent me? You {i}are{/i} Pepper's sister, right?!"
    Z "Sí... entonces... ¿tu hermana me envió? ¡¿Tú {i}eres{/i} la hermana de Pepper, verdad?!"

# game/scripts/day17.rpy:419
translate spanish d17a72_ca1f28fb:

    # Chi "Yep! That's me! I'm Chili! Nice to meet you!"
    Chi "¡Sí! ¡Esa soy yo! ¡Soy Chili! ¡Encantada de conocerte!"

# game/scripts/day17.rpy:420
translate spanish d17a72_1d04ecc8:

    # Chi "You must be the new guy?"
    Chi "¿Tú debes de ser el nuevo?"

# game/scripts/day17.rpy:423
translate spanish d17a72_5360583b:

    # Z "New, I guess you could say that. Anyways, she wanted me to check how the preparations are going. And mentioned something about your personal project."
    Z "Nuevo, supongo que podrías decir eso. De todos modos, quería que revisara cómo van los preparativos. Y mencionó algo sobre tu proyecto personal."

# game/scripts/day17.rpy:426
translate spanish d17a72_8a31fa50:

    # Chi "Personal project..."
    Chi "Proyecto personal..."

# game/scripts/day17.rpy:429
translate spanish d17a72_d2d8a7d6:

    # Chi "Oh, of course!"
    Chi "¡Oh, por supuesto!"

# game/scripts/day17.rpy:432
translate spanish d17a72_1c0c5a14:

    # Chi "Let's see, where did I put them...!"
    Chi "Veamos, ¿dónde los puse...?"

# game/scripts/day17.rpy:435
translate spanish d17a72_7182a8a9:

    # Chi "Ah, hmm...! Must be here."
    Chi "Ah, hmm... ¡Debe de estar por aquí!"

# game/scripts/day17.rpy:436
translate spanish d17a72_ae2170c6:

    # Chi "...I even sorted them! Or did I?!"
    Chi "...¡Incluso los ordené! ¡¿O no lo hice?!"

# game/scripts/day17.rpy:439
translate spanish d17a72_37e3fc4a:

    # Chi "So, has Pepper told you anything about it?"
    Chi "Entonces, ¿te ha contado Pepper algo sobre eso?"

# game/scripts/day17.rpy:440
translate spanish d17a72_a333a01a:

    # Z "She didnt mention any specifics. Just said it was a personal thing."
    Z "No mencionó detalles específicos. Solo dijo que era algo personal."

# game/scripts/day17.rpy:443
translate spanish d17a72_0c8b1dc7:

    # Chi "Aw... Anyway... where's my... hm..."
    Chi "Ay... De todos modos... ¿dónde está mi... hm..."

# game/scripts/day17.rpy:446
translate spanish d17a72_1dbef7fc:

    # Chi "Eh, whatever. Let's take this one!"
    Chi "Bah, da igual. ¡Vamos con este!"

# game/scripts/day17.rpy:452
translate spanish d17a72_7f543d75:

    # Chi "So, as you may have heard, my family has kind of disappeared from their settlement! We need to find out what happened!"
    Chi "Entonces, como quizás hayas oído, ¡mi familia ha desaparecido de su asentamiento! ¡Necesitamos averiguar qué pasó!"

# game/scripts/day17.rpy:455
translate spanish d17a72_08392ef7:

    # Chi "And since we are approaching at night, I was thinking this could be {i}*the*{/i} opportunity to try these out!"
    Chi "Y dado que estamos llegando de noche, estaba pensando que esta podría ser *la* oportunidad para probar esto."

# game/scripts/day17.rpy:458
translate spanish d17a72_494970dc:

    # Chi "Qara! This thing will light the night!"
    Chi "¡Qara! ¡Esto iluminará la noche!"

# game/scripts/day17.rpy:461
translate spanish d17a72_dc593a48:

    # Z "What is this?"
    Z "¿Qué es eso?"

# game/scripts/day17.rpy:464
translate spanish d17a72_a2905ae0:

    # Chi "I have been working on it for weeks! It's what they called a flare gun!"
    Chi "He estado trabajando en esto durante semanas. ¡Es lo que llamaban una pistola de bengalas!"

# game/scripts/day17.rpy:465
translate spanish d17a72_57071150:

    # Chi "Unfortunately the powder inside the ammunition for this thing has gone quite weak, but I was able to replace it and then some!"
    Chi "Desafortunadamente, la pólvora dentro de la munición para esta cosa se ha debilitado mucho, pero pude reemplazarla y algo más."

# game/scripts/day17.rpy:466
translate spanish d17a72_bdf1116e:

    # Chi "The only problem is that..."
    Chi "El único problema es que..."

# game/scripts/day17.rpy:469
translate spanish d17a72_d99e5bab:

    # Chi "...I have not been able to test it yet."
    Chi "... no he podido probarla aún."

# game/scripts/day17.rpy:472
translate spanish d17a72_7f8c638b:

    # Chi "Hm!"
    Chi "¡Hm!"

# game/scripts/day17.rpy:475
translate spanish d17a72_4fd0ccdc:

    # Z "I don't get it. Start again. What does it do?"
    Z "No me queda claro. Vuelve a empezar. ¿Qué hace?"

# game/scripts/day17.rpy:478
translate spanish d17a72_7c64ca4a:

    # Chi "Sorry! Let me explain!"
    Chi "¡Perdón! ¡Déjame explicártelo!"

# game/scripts/day17.rpy:481
translate spanish d17a72_bd798d9d:

    # Z "They stored bows, crossbows and armor in here. And now hand cannons?"
    Z "Aquí guardaban arcos, ballestas y armaduras. ¿Y ahora cañones de mano?"

# game/scripts/day17.rpy:484
translate spanish d17a72_fc6a230f:

    # Chi "Well... it would be great if it were an actual cannon! Let me show you!"
    Chi "Bueno... sería genial si fuera un cañón real. ¡Déjame mostrártelo!"

# game/scripts/day17.rpy:489
translate spanish d17a91_2df97b51:

    # "She steps closer..."
    "Ella da un paso más cerca..."

# game/scripts/day17.rpy:492
translate spanish d17a91_7446003c:

    # Chi "Wow, okay, heh. You are tall. Just like Fangs!"
    Chi "Guau, bueno, je. Eres alto. ¡Igual que Fangs!"

# game/scripts/day17.rpy:493
translate spanish d17a91_4b85d468:

    # Chi "You guys are lucky, I was born a midget. {i}*Sigh*{/i}"
    Chi "Tenéis suerte, yo nací enana. {i}*Suspiros*{/i}"

# game/scripts/day17.rpy:494
translate spanish d17a91_0a616aa6:

    # Chi "Sadly, not the only thing that's short about me. Anyway..."
    Chi "Lamentablemente, no es lo único que tengo corto. De todos modos..."

# game/scripts/day17.rpy:497
translate spanish d17a91_9e8633e3:

    # Chi "It's best for me to show you how it is used, and then you can see for yourself what it does!"
    Chi "Es mejor que te muestre cómo se usa, y luego podrás ver por ti mismo lo que hace."

# game/scripts/day17.rpy:500
translate spanish d17a91_2feda373:

    # Chi "That is... later, whenever we need some light out there. In here, it would cause quite the mayhem..."
    Chi "Eso es... más tarde, cuando necesitemos algo de luz allá afuera. Aquí dentro, causaría un gran caos..."

# game/scripts/day17.rpy:503
translate spanish d17a91_ef1b5ae5:

    # Chi "Okay, so the reason why you can't compare it to classic guns, or \"handcannons\", as you would like to say, is that you can only shoot once before having to replace the cartridge!"
    Chi "Vale, así que la razón por la que no puedes compararlo con armas clásicas, o \"cañones de mano\", como te gusta decir, es que solo puedes disparar una vez antes de tener que reemplazar el cartucho."

# game/scripts/day17.rpy:504
translate spanish d17a91_5e57353d:

    # Chi "So, after flipping it open..."
    Chi "Entonces, después de abrirlo..."

# game/scripts/day17.rpy:507
translate spanish d17a91_8f9c7961:

    # Chi "You take this! That's the ammunition, just like they used to make them!"
    Chi "¡Tomas esto! Esa es la munición, ¡justo como solían fabricarlas!"

# game/scripts/day17.rpy:510
translate spanish d17a91_f928ab3a:

    # Chi "These are filled with powder. Treat them like gasoline tanks."
    Chi "Estos están llenos de pólvora. Trátalos como si fueran tanques de gasolina."

# game/scripts/day17.rpy:511
translate spanish d17a91_2b30f234:

    # Z "Got it."
    Z "Entendido."

# game/scripts/day17.rpy:514
translate spanish d17a91_8f739db6:

    # Chi "Now, in with that..."
    Chi "Ahora, con esto..."

# game/scripts/day17.rpy:517
translate spanish d17a91_fdf27f58:

    # Chi "Bleb!"
    Chi "¡Bleb!"

# game/scripts/day17.rpy:520
translate spanish d17a91_ec19afb2:

    # Chi "Ping! Shut close! And now...!"
    Chi "¡Ping! ¡Cierra rápido! Y ahora... ¡"

# game/scripts/day17.rpy:523
translate spanish d17a91_ade00a0b:

    # Chi "Aim at the enemy, and... du!!"
    Chi "¡Apunta al enemigo y... du!"

# game/scripts/day17.rpy:526
translate spanish d17a91_98a47aa3:

    # Chi "Du!"
    Chi "¡Du!"

# game/scripts/day17.rpy:529
translate spanish d17a91_3eb34611:

    # Chi "Bam!"
    Chi "¡Bam!"

# game/scripts/day17.rpy:532
translate spanish d17a91_77fd1a0f:

    # Chi "..."
    Chi "..."

# game/scripts/day17.rpy:533
translate spanish d17a91_5ab3574d:

    # Z "..."
    Z "..."

# game/scripts/day17.rpy:536
translate spanish d17a91_77fd1a0f_1:

    # Chi "..."
    Chi "..."

# game/scripts/day17.rpy:539
translate spanish d17a91_6b55b5af:

    # Chi "As I said! Can't shoot here! But if everything goes right, we will have no issue with the light!"
    Chi "¡Como dije! ¡No se puede disparar aquí! Pero si todo va bien, no tendremos problemas con la luz."

# game/scripts/day17.rpy:540
translate spanish d17a91_6bb71be4:

    # Chi "Oh, and always point these things not at the enemy, but the sky!"
    Chi "¡Oh, y siempre apunta estas cosas al cielo, no al enemigo!"

# game/scripts/day17.rpy:543
translate spanish d17a91_49c06b14:

    # Chi "Again, NOT at the enemy! You might blind the poor guy, and then he won't even see when you hit him!"
    Chi "¡Otra vez, NO al enemigo! Podrías cegar al pobre tipo, ¡y entonces ni siquiera verá cuando lo golpees!"

# game/scripts/day17.rpy:546
translate spanish d17a91_72b31200:

    # Z "Alright. So how many do you have, do we shoot one at a time or..."
    Z "Vale. Entonces, ¿cuántos tienes? ¿Disparamos uno a la vez o...?"

# game/scripts/day17.rpy:549
translate spanish d17a91_28e8b65d:

    # Chi "Nope! Everyone gets one! One won't be strong enough!"
    Chi "¡Nope! ¡Todos tienen uno! ¡Uno no será suficiente!"

# game/scripts/day17.rpy:552
translate spanish d17a91_452133b7:

    # Chi "That reminds me, I did make an experimental one with a stronger effect..."
    Chi "Eso me recuerda, hice uno experimental con un efecto más fuerte..."

# game/scripts/day17.rpy:555
translate spanish d17a91_e1b386a8:

    # Chi "Buuut I may have overdone it with the charge. It could go bad, and you'd lose your hand, so I'll keep it for emergencies!"
    Chi "Pero... puede que me haya pasado con la carga. Podría salir mal y perderías la mano, ¡así que lo guardaré para emergencias!"

# game/scripts/day17.rpy:558
translate spanish d17a91_81327d3a:

    # Z "So... you're saying I should tell Pepper that you're ready?"
    Z "¿Estás diciendo que debería decirle a Pepper que estás lista?"

# game/scripts/day17.rpy:561
translate spanish d17a91_8ed8995a:

    # Chi "Eh, I'd say you tell Fangs. She's the boss after all."
    Chi "Eh, diría que se lo cuentes a Fangs. Ella es la jefa, después de todo."

# game/scripts/day17.rpy:564
translate spanish d17a91_439d13bd:

    # Z "I see. Well.. See you around then."
    Z "Entendido. Bueno... Nos vemos entonces."

# game/scripts/day17.rpy:567
translate spanish d17a91_95cc7753:

    # Chi "Cool! I will see you when we hit the road!"
    Chi "¡Genial! Nos vemos cuando estemos en camino."

# game/scripts/day17.rpy:570
translate spanish d17a91_c126258d:

    # Chi "Oh, I never asked. What's your name?"
    Chi "¡Oh, nunca te lo pregunté! ¿Cómo te llamas?"

# game/scripts/day17.rpy:573
translate spanish d17a91_060fb7db:

    # Z "Call me [persistent.player_name]."
    Z "Llámame [persistent.player_name]."

# game/scripts/day17.rpy:576
translate spanish d17a91_c00b006e:

    # Chi "Alright, [persistent.player_name]! Bye for now!"
    Chi "¡Está bien, [persistent.player_name]! ¡Adiós por ahora!"

# game/scripts/day17.rpy:582
translate spanish d17a91_dae3aa16:

    # "You leave the short woman, lost in her tinkering, the walls to her room trembling at the beat of loud music."
    "Dejas a la pequeña mujer, perdida en sus experimentos, mientras las paredes de su habitación tiemblan al ritmo de la música fuerte."

# game/scripts/day17.rpy:584
translate spanish d17a91_fea21be4:

    # Zt "Pepper and Chili... Fangs please."
    Zt "Pepper y Chili... Fangs, por favor."

# game/scripts/day17.rpy:592
translate spanish d17a_part_2_9669528e:

    # "Later..."
    "Más tarde..."

# game/scripts/day17.rpy:596
translate spanish d17a_part_2_c7680d96:

    # Mu "How's everything, Red?"
    Mu "¿Cómo va todo, Red?"

# game/scripts/day17.rpy:597
translate spanish d17a_part_2_82402c48:

    # Re "As far as I can tell, we are ready to go!"
    Re "Por lo que puedo decir, ¡estamos listos para partir!"

# game/scripts/day17.rpy:600
translate spanish d17a_part_2_0cddab12:

    # Mu "What about rations? Do we have enough?"
    Mu "¿Y las raciones? ¿Tenemos suficientes?"

# game/scripts/day17.rpy:603
translate spanish d17a_part_2_608b808d:

    # Re "Enough for two nights."
    Re "Suficiente para dos noches."

# game/scripts/day17.rpy:606
translate spanish d17a_part_2_7311aa27:

    # Mu "That's...a lot, but I guess it's good to be overprepared? You never know."
    Mu "Es... mucho, pero supongo que es bueno estar demasiado preparado. Nunca se sabe."

# game/scripts/day17.rpy:607
translate spanish d17a_part_2_0a78cf68:

    # Mu "What about Ivy and the others?"
    Mu "¿Y qué pasa con Ivy y los demás?"

# game/scripts/day17.rpy:610
translate spanish d17a_part_2_aa8a2d00:

    # Re "Scarp, girl, you know where I've been in the last few hours... why are you asking me?"
    Re "Scarp, chica, ya sabes dónde he estado en las últimas horas... ¿por qué me lo preguntas?"

# game/scripts/day17.rpy:613
translate spanish d17a_part_2_df20ec0d:

    # Sc "All right, all right, was just a question."
    Sc "Está bien, está bien, solo era una pregunta."

# game/scripts/day17.rpy:617
translate spanish d17a_part_2_0cd66271:

    # Mant "Ivy is getting ready. We saw her earlier."
    Mant "Ivy se está preparando. La vimos antes."

# game/scripts/day17.rpy:620
translate spanish d17a_part_2_79fe0d7a:

    # Mant "I... saw her earlier. She was taking a bath."
    Mant "Yo... la vi antes. Ella se estaba bañando."

# game/scripts/day17.rpy:624
translate spanish d17a_part_2_66c160bc:

    # Pe "So if you follow the path I laid out, we should approach the area from the side."
    Pe "Si sigues el camino que tracé, deberíamos acercarnos al área desde un costado."

# game/scripts/day17.rpy:625
translate spanish d17a_part_2_c66cc277:

    # Pe "There is a small complex of ruins nearby, we will set up camp there. If we approach carefully, they won't notice us."
    Pe "Hay un pequeño complejo de ruinas cerca, instalaremos un campamento allí. Si nos acercamos con cuidado, no nos notarán."

# game/scripts/day17.rpy:629
translate spanish d17a_part_2_e38ad2bf:

    # Pe "The important part is that you let me know as soon as you can."
    Pe "Lo importante es que me lo digas tan pronto como puedas."

# game/scripts/day17.rpy:630
translate spanish d17a_part_2_a9d72f99:

    # Pe "There will be quite the distance between you and the rest of the group."
    Pe "Habrá bastante distancia entre tú y el resto del grupo."

# game/scripts/day17.rpy:633
translate spanish d17a_part_2_23bab0fd:

    # Pe "We still don't know what to expect in detail, so I suggest not to spread ourselves too far apart."
    Pe "Aún no sabemos qué esperar con detalle, así que sugiero no separarnos demasiado."

# game/scripts/day17.rpy:636
translate spanish d17a_part_2_6efa8127:

    # Fa "Don't worry, Pepper, we know what we're doing."
    Fa "No te preocupes, Pepper, sabemos lo que hacemos."

# game/scripts/day17.rpy:639
translate spanish d17a_part_2_74412beb:

    # Chi "Are we all set?"
    Chi "¿Estamos listos?"

# game/scripts/day17.rpy:642
translate spanish d17a_part_2_effdb8af:

    # Chi "I could stand to see some natural daylight."
    Chi "Podría soportar ver algo de luz natural."

# game/scripts/day17.rpy:645
translate spanish d17a_part_2_cc87c7fd:

    # Pe "I just have a few last things to check off my list, sister."
    Pe "Solo tengo algunas cosas más que tachar de mi lista, hermana."

# game/scripts/day17.rpy:648
translate spanish d17a_part_2_987c132f:

    # Z "This feels... pretty sturdy, I'll admit. Still, I think I prefer to be able to move more freely."
    Z "Esto se siente... bastante resistente, lo admitiré. Aun así, creo que prefiero moverme con más libertad."

# game/scripts/day17.rpy:651
translate spanish d17a_part_2_482fa272:

    # Pe "We have extra body armour. It would be dumb to not use it, when it is available."
    Pe "Tenemos armaduras extra. Sería una estupidez no usarlas cuando están disponibles."

# game/scripts/day17.rpy:654
translate spanish d17a_part_2_6da6f215:

    # Z "I've gotten by just fine for a long time, Pepper."
    Z "Me las he arreglado bastante bien durante mucho tiempo, Pepper."

# game/scripts/day17.rpy:657
translate spanish d17a_part_2_1f9b9920:

    # Pe "Good for you. Now you will be even better protected."
    Pe "Bien por ti. Ahora estarás aún mejor protegido."

# game/scripts/day17.rpy:660
translate spanish d17a_part_2_2cc6ff3e:

    # Chi "Don't protest! She wants to keep you safe. It's cute!"
    Chi "¡No protestes! Ella quiere mantenerte a salvo. ¡Es adorable!"

# game/scripts/day17.rpy:663
translate spanish d17a_part_2_d18de692:

    # Chi "Why don't I get body armor? Don't I deserve to be protected?"
    Chi "¿Por qué yo no tengo armadura? ¿Es que no merezco estar protegida?"

# game/scripts/day17.rpy:666
translate spanish d17a_part_2_73839ba8:

    # Pe "If it was up to me, you wouldn't even be joining this...excursion."
    Pe "Si fuera por mí, ni siquiera estarías participando en esta... excursión."

# game/scripts/day17.rpy:669
translate spanish d17a_part_2_89c9f722:

    # Pe "...and we both know what happened to your last piece of body armour."
    Pe "... y ambas sabemos lo que le pasó a tu última pieza de armadura corporal."

# game/scripts/day17.rpy:670
translate spanish d17a_part_2_0deb8fe8:

    # Chi "You're no fun, {i}\"Pepper\"{/i}..."
    Chi "No eres divertida, {i}\"Pepper\"{/i}..."

# game/scripts/day17.rpy:673
translate spanish d17a_part_2_89bb14bb:

    # Fa "Have you looked at the map? Do you know the area?"
    Fa "¿Has mirado el mapa? ¿Conoces la zona?"

# game/scripts/day17.rpy:674
translate spanish d17a_part_2_b524c5b3:

    # Z "Yes and yes, which is why I am surprised that I haven't encountered..."
    Z "Sí y sí, por eso me sorprende que no me haya encontrado con..."

# game/scripts/day17.rpy:677
translate spanish d17a_part_2_e6198cb3:

    # Kr "Guys... are we moving out or what? I am tired of waiting."
    Kr "Chicos... ¿vamos a movernos o qué? Estoy cansada de esperar."

# game/scripts/day17.rpy:680
translate spanish d17a_part_2_0d70974f:

    # Fa "Not quite yet..."
    Fa "Todavía no..."

# game/scripts/day17.rpy:683
translate spanish d17a_part_2_86171ef6:

    # Fa "Ivy's not here yet, and I want her with us on this one. Anyway, you lot, leave us alone for a second."
    Fa "Ivy no ha llegado todavía, y la quiero con nosotros para esto. En fin, vosotros, dejadnos solos un momento."

# game/scripts/day17.rpy:684
translate spanish d17a_part_2_5fa169c6:

    # Fa "I need to exchange some words with [persistent.player_name]."
    Fa "Necesito intercambiar unas palabras con [persistent.player_name]."

# game/scripts/day17.rpy:689
translate spanish d17a_part_2_1cc203bd:

    # "The other women leave you and Fangs alone, giving you some privacy in this otherwise crowded vehicle bay."
    "Las otras mujeres te dejan a ti y a Fangs solos, dándote algo de privacidad en este abarrotado hangar de vehículos."

# game/scripts/day17.rpy:692
translate spanish d17a_part_2_20452550:

    # Fa "{i}*sigh*{/i} This whole ordeal is nothing new for us. Essentially we're going to lean on some Raiders, and try to put them in their place."
    Fa "{i}*suspiro*{/i} Todo este asunto no es nuevo para nosotros. Básicamente vamos a apoyarnos en algunos asaltantes e intentar ponerlos en su lugar."

# game/scripts/day17.rpy:693
translate spanish d17a_part_2_cd8b3603:

    # Fa "But after the last situation I don't want to run into any surprises, and there are additional considerations, this time... "
    Fa "Pero después de la última situación, no quiero encontrarme con sorpresas, y hay consideraciones adicionales esta vez..."

# game/scripts/day17.rpy:696
translate spanish d17a_part_2_af5ffb77:

    # Fa "Anyway, you've talked to the girls... I figure you have questions."
    Fa "De todos modos, ya hablaste con las chicas... Me imagino que tienes preguntas."

# game/scripts/day17.rpy:697
translate spanish d17a_part_2_2bd0548e:

    # Fa "So, shoot."
    Fa "Dispara."

# game/scripts/day17.rpy:703
translate spanish d17a_fangs_questions_773cacfd:

    # Z "Let's start at the beginning. Tell me about Pepper, and her tribe."
    Z "Empecemos por el principio. Háblame de Pepper y su tribu."

# game/scripts/day17.rpy:704
translate spanish d17a_fangs_questions_5bc34a4b:

    # Z "What is the deal exactly?"
    Z "¿Cuál es exactamente el trato?"

# game/scripts/day17.rpy:707
translate spanish d17a_fangs_questions_566bb43f:

    # Fa "There's not much to say, really."
    Fa "No hay mucho que decir, realmente."

# game/scripts/day17.rpy:708
translate spanish d17a_fangs_questions_e2e4dc83:

    # Fa "We were a smaller group, back then. Still trying to grow our numbers, when we came across this... complex of ruins in the middle of nowhere."
    Fa "Éramos un grupo más pequeño, entonces. Todavía tratando de aumentar nuestros números, cuando nos encontramos con este... complejo de ruinas en medio de la nada."

# game/scripts/day17.rpy:709
translate spanish d17a_fangs_questions_bfb2c2ce:

    # Fa "Tall skeletons of buildings, and then this metal looking wheel at the center."
    Fa "Altos esqueletos de edificios, y luego esta rueda metálica en el centro."

# game/scripts/day17.rpy:712
translate spanish d17a_fangs_questions_7c18167b:

    # Fa "They were peaceful. Not at all phased, even when they saw Krait's eyes and noticed my... well, fangs. Simple, welcoming folk."
    Fa "Eran pacíficas. No se inmutaron en absoluto, ni siquiera cuando vieron los ojos de Krait o notaron mis... bueno, colmillos. Mujeres sencillas y acogedoras."

# game/scripts/day17.rpy:713
translate spanish d17a_fangs_questions_0d4136d2:

    # Fa "There was one woman, had this frustrated, stoic look on her face, who was especially interested in us."
    Fa "Había una mujer, con esa mirada frustrada y estoica en su rostro, que estaba especialmente interesada en nosotras."

# game/scripts/day17.rpy:716
translate spanish d17a_fangs_questions_27166b0d:

    # Z "That sounds like Pepper."
    Z "Eso suena como algo que diría Pepper."

# game/scripts/day17.rpy:719
translate spanish d17a_fangs_questions_4a050b6f:

    # Fa "That wasn't her name back then, but yes."
    Fa "Ese no era su nombre en ese entonces, pero sí."

# game/scripts/day17.rpy:722
translate spanish d17a_fangs_questions_2cd188b7:

    # Z "So why did she join you?"
    Z "¿Por qué se unió a ti?"

# game/scripts/day17.rpy:725
translate spanish d17a_fangs_questions_2a227d5f:

    # Fa "Well, put simply, we let our guard down and told her a few things about the bunker. When she found out that there was a lot of equipment that we didn't know the purpose or the workings of, she was adamant.."
    Fa "Bueno, en pocas palabras, bajamos la guardia y le contamos algunas cosas sobre el búnker. Cuando descubrió que había mucho equipo cuyo propósito o funcionamiento desconocíamos, fue insistente..."

# game/scripts/day17.rpy:726
translate spanish d17a_fangs_questions_2ee5a308:

    # Fa "She would not be dissuaded from coming along and promised to help us shed some light on the many things we did not know about the bunker."
    Fa "Ella no se dejaría disuadir de acompañarnos y prometió ayudarnos a arrojar algo de luz sobre las muchas cosas que no sabíamos acerca del búnker."

# game/scripts/day17.rpy:729
translate spanish d17a_fangs_questions_a4f26855:

    # Fa "From what I gather, the tribe possessed several texts that mentioned some of the machines in the lab, and other pieces of equipment."
    Fa "Por lo que entiendo, la tribu poseía varios textos que mencionaban algunas de las máquinas en el laboratorio y otros equipos."

# game/scripts/day17.rpy:730
translate spanish d17a_fangs_questions_38db6999:

    # Fa "They were pretty knowledgeable about them, but only on paper, in theory. They had learned by heart the old texts, but had never actually seen examples of what those texts were about."
    Fa "Eran bastante conocedores sobre ellos, pero solo en teoría. Habían aprendido de memoria los viejos textos, pero nunca habían visto ejemplos reales de lo que trataban esos textos."

# game/scripts/day17.rpy:731
translate spanish d17a_fangs_questions_93443def:

    # Fa "Even so, especially the two girls, two sisters, their breadth of knowledge, however limited by the lack of exposure, was too important to not try to learn from it."
    Fa "Aun así, especialmente las dos chicas, dos hermanas, su conocimiento, aunque limitado por la falta de exposición, era demasiado importante como para no intentar aprender de ellas."

# game/scripts/day17.rpy:732
translate spanish d17a_fangs_questions_6f0ca9e7:

    # Fa "So we struck a deal. They would get the opportunity to test their knowledge and theories, and we would reap the benefit of their experience."
    Fa "Hicimos un trato. Tendrían la oportunidad de probar su conocimiento y teorías, y nosotras cosecharíamos el beneficio de su experiencia. Chili resultó ser una mecánico talentosa, y Pepper tiene un entendimiento casi instintivo de equipos complejos."

# game/scripts/day17.rpy:733
translate spanish d17a_fangs_questions_53d7ccef:

    # Fa "They were definitely the two brightest jewels in that tribe, and their presence has helped us immensely."
    Fa "Eran definitivamente las dos joyas más brillantes de esa tribu, y su presencia nos ha ayudado inmensamente."

# game/scripts/day17.rpy:736
translate spanish d17a_fangs_questions_32913b31:

    # Z "A tribe that possesses and hoards ancient knowledge. What else do you know about them?"
    Z "Una tribu que posee y atesora conocimientos antiguos. ¿Qué más sabes de ellos?"

# game/scripts/day17.rpy:739
translate spanish d17a_fangs_questions_d508b3a9:

    # Z "I don't understand... Why bother with memorising knowledge that they can't do anything with?"
    Z "No entiendo... ¿Por qué memorizar conocimientos si no pueden usarlos para nada?"

# game/scripts/day17.rpy:742
translate spanish d17a_fangs_questions_05284165:

    # Fa "When I asked that, Pepper just said something about the necessity of knowledge, the value of it for its own sake. I don't get it either, but then..."
    Fa "Cuando le pregunté eso, Pepper solo dijo algo sobre la necesidad del conocimiento, el valor de este por sí mismo. Yo tampoco lo entiendo, pero entonces..."

# game/scripts/day17.rpy:743
translate spanish d17a_fangs_questions_efe0a3d1:

    # Fa "Time proved them right, as we have been able to put that knowledge to the test and to good use."
    Fa "El tiempo les dio la razón, ya que hemos podido poner ese conocimiento a prueba y darle buen uso."

# game/scripts/day17.rpy:746
translate spanish d17a_fangs_questions_478733d5:

    # Fa "Anyway, to join us, Pepper struck a bargain. We would not ask about the village and, when needed, we would protect it."
    Fa "De todos modos, para unirse a nosotras, Pepper hizo un trato. No preguntaríamos sobre el pueblo y, cuando fuera necesario, lo protegeríamos."

# game/scripts/day17.rpy:749
translate spanish d17a_fangs_questions_5ab3574d:

    # Z "..."
    Z "..."

# game/scripts/day17.rpy:750
translate spanish d17a_fangs_questions_d9c44c4e:

    # Z "So... you know nothing about her. Neither her tribe, nor why she is fascinated by the technology."
    Z "Así que... no sabes nada sobre ella. Ni de su tribu, ni por qué le fascina la tecnología."

# game/scripts/day17.rpy:751
translate spanish d17a_fangs_questions_42a1a200:

    # Fa "She is a mystery, in many ways, but I have learned to use her talents and her inclinations.."
    Fa "Ella es un misterio, en muchos sentidos, pero he aprendido a usar sus talentos y sus inclinaciones..."

# game/scripts/day17.rpy:754
translate spanish d17a_fangs_questions_68dc56cb:

    # Fa "At least there is some common ground. I assume you have seen her at work today...?"
    Fa "Al menos hay algo en común. Supongo que la has visto trabajar hoy... ¿no?"

# game/scripts/day17.rpy:757
translate spanish d17a_fangs_questions_1648e88e:

    # Fa "In some things, she is far more predictable than you might think..."
    Fa "En algunas cosas, ella es mucho más predecible de lo que podrías pensar..."

# game/scripts/day17.rpy:765
translate spanish d17a_fangs_questions_0eb697fd:

    # Z "Tell me about Chili. She reminds me a little of my [persistent.da]."
    Z "Háblame de Chili. Me recuerda un poco a mi [persistent.da]."

# game/scripts/day17.rpy:767
translate spanish d17a_fangs_questions_3ac2c9b4:

    # Z "Tell me about Chili."
    Z "Háblame de Chili."

# game/scripts/day17.rpy:771
translate spanish d17a_fangs_questions_174b672b:

    # Fa "If your [persistent.da] is all over the place like her, then I'm truly sorry."
    Fa "Si tu [persistent.da] está por todos lados como ella, entonces lo siento de verdad."

# game/scripts/day17.rpy:772
translate spanish d17a_fangs_questions_2d81282e:

    # Fa "She's a bright young woman, truly dedicated to repairing things. She will dismantle and reassemble anything she can get her hands on."
    Fa "Es una joven brillante, verdaderamente dedicada a reparar cosas. Desmontará y volverá a ensamblar cualquier cosa que pueda conseguir."

# game/scripts/day17.rpy:773
translate spanish d17a_fangs_questions_87caf6ce:

    # Fa "Which makes her an invaluable asset."
    Fa "Lo que la hace un activo invaluable."

# game/scripts/day17.rpy:776
translate spanish d17a_fangs_questions_0155943e:

    # Z "You didn't take her to the hive last time around."
    Z "No la llevaste a la colmena la última vez."

# game/scripts/day17.rpy:779
translate spanish d17a_fangs_questions_df6b31af:

    # Fa "Both her and Pepper are irreplaceable. I never allow both of them out the bunker at the same time."
    Fa "Tanto ella como Pepper son insustituibles. Nunca permito que ambas salgan del búnker al mismo tiempo."

# game/scripts/day17.rpy:785
translate spanish d17a_fangs_questions_2f2997bb:

    # Fa "After what happened to Keen... I don't regret that decision."
    Fa "Después de lo que le pasó a Keen... no me arrepiento de esa decisión."

# game/scripts/day17.rpy:788
translate spanish d17a_fangs_questions_e1837691:

    # Fa "This being about their family however, I am forced to make an exception."
    Fa "Siendo esto sobre su familia, sin embargo, me veo obligada a hacer una excepción."

# game/scripts/day17.rpy:795
translate spanish d17a_fangs_questions_72240c82:

    # Z "What about Krait? What's her deal?"
    Z "¿Qué pasa con Krait? ¿Cuál es su trato?"

# game/scripts/day17.rpy:798
translate spanish d17a_fangs_questions_833351ec:

    # Fa "She and I go a long way back."
    Fa "Ella y yo tenemos una larga historia juntas."

# game/scripts/day17.rpy:801
translate spanish d17a_fangs_questions_9b09adfb:

    # Fa "Over the years, I have brought in a bunch of people."
    Fa "A lo largo de los años, he traído a un montón de personas."

# game/scripts/day17.rpy:802
translate spanish d17a_fangs_questions_7c25bda8:

    # Fa "Each with their own story and characters."
    Fa "Cada una con su propia historia y personajes."

# game/scripts/day17.rpy:805
translate spanish d17a_fangs_questions_357009f3:

    # Fa "Occasionally it has taken a while, but eventually they all learned who was calling the shots around here."
    Fa "A veces ha tomado un tiempo, pero eventualmente todas aprendieron quién estaba al mando aquí."

# game/scripts/day17.rpy:808
translate spanish d17a_fangs_questions_a1ee7050:

    # Fa "But Krait... she's a fighter. Spent a lot of time in the wasteland."
    Fa "Pero Krait... es una luchadora. Pasó mucho tiempo en el páramo."

# game/scripts/day17.rpy:809
translate spanish d17a_fangs_questions_227c828d:

    # Fa "Getting her to do as she's told is a challenge at the best of times. She follows her own desires."
    Fa "Lograr que haga lo que se le dice es un desafío incluso en los mejores momentos. Sigue sus propios deseos."

# game/scripts/day17.rpy:812
translate spanish d17a_fangs_questions_815ebfa7:

    # Fa "Fortunately, her heart is mostly in the right place, and so most of the damage she does is... well, a few broken hearts, a few overinflated egos and some fond memories."
    Fa "Afortunadamente, su corazón está mayormente en el lugar correcto, así que la mayoría del daño que hace es... bueno, unos cuantos corazones rotos, unos cuantos egos inflados y algunos buenos recuerdos."

# game/scripts/day17.rpy:815
translate spanish d17a_fangs_questions_ea85c75a:

    # Fa "You've seen her though, haven't you? There's something about her that just entices and attracts... anybody, really."
    Fa "Pero la has visto, ¿verdad? Hay algo en ella que simplemente seduce y atrae... a cualquiera, en realidad."

# game/scripts/day17.rpy:816
translate spanish d17a_fangs_questions_ec82c05c:

    # Fa "If given a chance, she will spin the head of even the most hostile men... and women."
    Fa "Si se le da la oportunidad, hará girar la cabeza incluso de los hombres... y mujeres más hostiles."

# game/scripts/day17.rpy:821
translate spanish d17a_fangs_questions_58291735:

    # Z "She definitely looks enticing."
    Z "Definitivamente parece atractiva."

# game/scripts/day17.rpy:824
translate spanish d17a_fangs_questions_ff3bedd8:

    # Fa "Stick around for long enough.. you'll see there is more to it than that..."
    Fa "Quédate el tiempo suficiente... verás que hay más en ello de lo que parece."

# game/scripts/day17.rpy:827
translate spanish d17a_fangs_questions_cce88b5d:

    # Fa "Anyway, I wasn't expecting you just yet."
    Fa "De todos modos, no te esperaba aún."

# game/scripts/day17.rpy:828
translate spanish d17a_fangs_questions_621a2401:

    # Fa "I'm glad I didn't take too long of a... private time."
    Fa "Me alegra no haber tardado demasiado en... mi tiempo privado."

# game/scripts/day17.rpy:834
translate spanish d17a_fangs_questions_a5483681:

    # Z "You're more my type."
    Z "Tú eres más mi tipo."

# game/scripts/day17.rpy:837
translate spanish d17a_fangs_questions_7a7d82ff:

    # Fa "Am I...? And how is that?"
    Fa "¿Lo soy...? ¿Y cómo es eso?"

# game/scripts/day17.rpy:842
translate spanish d17a_fangs_questions_13a7d611:

    # Z "You are a strong woman, with the body of an athlete."
    Z "Eres una mujer fuerte, con el cuerpo de una atleta."

# game/scripts/day17.rpy:845
translate spanish d17a_fangs_questions_45948b49:

    # Fa "Maybe we should train together one of these days."
    Fa "Tal vez deberíamos entrenar juntos uno de estos días."

# game/scripts/day17.rpy:848
translate spanish d17a_fangs_questions_d0e8272f:

    # Z "...and see how that goes."
    Z "... y veamos cómo va eso."

# game/scripts/day17.rpy:852
translate spanish d17a_fangs_questions_6810939c:

    # Z "Dark skin, clear eyes... blond hair and, well, even your... special features."
    Z "Piel oscura, ojos claros... cabello rubio y, bueno, incluso tus... características especiales."

# game/scripts/day17.rpy:853
translate spanish d17a_fangs_questions_02359397:

    # Z "It's a unique look, for sure."
    Z "Tienes un aspecto único, sin duda."

# game/scripts/day17.rpy:856
translate spanish d17a_fangs_questions_b361eb1d:

    # Fa "So you're saying I am exotic and rare..."
    Fa "Entonces dices que soy exótica y rara..."

# game/scripts/day17.rpy:857
translate spanish d17a_fangs_questions_dd3f2054:

    # Fa "Is that what you say to all the women you chase?"
    Fa "¿Eso es lo que les dices a todas las mujeres que persigues?"

# game/scripts/day17.rpy:863
translate spanish d17a_fangs_questions_0e0bc97e:

    # Z "Your attitude. That's it."
    Z "Tu actitud. Eso es todo."

# game/scripts/day17.rpy:866
translate spanish d17a_fangs_questions_21247301:

    # Fa "I've been told I have an attitude, yes."
    Fa "Me han dicho que tengo actitud, sí."

# game/scripts/day17.rpy:869
translate spanish d17a_fangs_questions_d4d3e7c6:

    # Fa "But what do {i}you{/i} mean by it, exactly?"
    Fa "Pero, ¿qué quieres decir {i}tú{/i}, exactamente?"

# game/scripts/day17.rpy:874
translate spanish d17a_fangs_questions_3b1c8d9f:

    # Z "Because you are a challenge to defeat."
    Z "Porque eres un desafío a vencer."

# game/scripts/day17.rpy:877
translate spanish d17a_fangs_questions_fb3518d1:

    # Fa "Mh... that's how you see me? Something to conquer, to prove yourself against...?"
    Fa "Mh... ¿así es como me ves? ¿Algo que conquistar, para probarte a ti mismo?..."

# game/scripts/day17.rpy:878
translate spanish d17a_fangs_questions_1bbb354c:

    # Fa "Is everything a contest, a battle, to you?"
    Fa "¿Todo es un concurso, una batalla, para ti?"

# game/scripts/day17.rpy:884
translate spanish d17a_fangs_questions_6cc1694e:

    # Z "Because you stand up to me."
    Z "Porque te enfrentas a mí."

# game/scripts/day17.rpy:885
translate spanish d17a_fangs_questions_a728b158:

    # Z "I've had my share of slaves and servile women. You however don't back down easily. That's a lot less common.."
    Z "He tenido mi ración de esclavas y mujeres serviles. Sin embargo, tú no te rindes fácilmente. Eso es mucho menos común..."

# game/scripts/day17.rpy:888
translate spanish d17a_fangs_questions_4720f975:

    # Fa "All I want is for you to remember that this is not your domain. Regular humans have no place here, not really."
    Fa "Todo lo que quiero es que recuerdes que este no es tu dominio. Los humanos comunes no tienen cabida aquí, no realmente."

# game/scripts/day17.rpy:889
translate spanish d17a_fangs_questions_ab467366:

    # Fa "As long as you do, we will get along just fine."
    Fa "Mientras lo hagas, nos llevaremos bien."

# game/scripts/day17.rpy:895
translate spanish d17a_fangs_questions_02abec8c:

    # Z "I might pass."
    Z "Puede que pase."

# game/scripts/day17.rpy:898
translate spanish d17a_fangs_questions_3189317b:

    # Fa "It amuses me, that you think that you can control that, or her..."
    Fa "Me divierte que creas que puedes controlar eso, o a ella..."

# game/scripts/day17.rpy:905
translate spanish d17a_fangs_questions_64b71857:

    # Z "Want to let off some steam?"
    Z "¿Quieres descargar algo de tensión?"

# game/scripts/day17.rpy:908
translate spanish d17a_fangs_questions_cb8cbf59:

    # Fa "..."
    Fa "..."

# game/scripts/day17.rpy:911
translate spanish d17a_fangs_questions_75a98b6e:

    # Fa "Maybe, but not now. We have a mission coming up, and I want to stay focused."
    Fa "Tal vez, pero no ahora. Tenemos una misión en camino, y quiero mantenerme enfocada."

# game/scripts/day17.rpy:912
translate spanish d17a_fangs_questions_4b53192f:

    # Fa "Screwing this one up is not an option."
    Fa "No hay margen para equivocarse en esto."

# game/scripts/day17.rpy:916
translate spanish d17a_fangs_questions_33f24fca:

    # Z "No more questions. I'm ready to go."
    Z "Sin más preguntas. Estoy listo para irme."

# game/scripts/day17.rpy:920
translate spanish d17a_fangs_questions_a343cde1:

    # Fa "I will get the girls moving."
    Fa "Pondré a las chicas en movimiento."

# game/scripts/day17.rpy:932
translate spanish d17a136_240a010b:

    # Chi "FULL THROTTLE!"
    Chi "¡A FONDO!"

# game/scripts/day17.rpy:933
translate spanish d17a136_7113cc4d:

    # Chi "WE..."
    Chi "¡NOSOTROS..."

# game/scripts/day17.rpy:934
translate spanish d17a136_ca7852ab:

    # Chi "ARE..."
    Chi "ESTAMOS..."

# game/scripts/day17.rpy:935
translate spanish d17a136_0bb4c3c8:

    # Chi "ALMOST THERE!"
    Chi "¡CASI LLEGANDO!"

# game/scripts/day17.rpy:936
translate spanish d17a136_624b6a97:

    # Pe "{i}*sigh*{/i} And they wonder why I don't want to work with you. Will you pipe down?"
    Pe "{i}*suspiro*{/i} Y se preguntan por qué no quiero trabajar contigo. ¿Puedes callarte?"

# game/scripts/day17.rpy:937
translate spanish d17a136_b8bc4e95:

    # Kr "How mean..."
    Kr "Qué cruel..."

# game/scripts/day17.rpy:938
translate spanish d17a136_daba977e:

    # Pe "I heard that."
    Pe "Lo oí."

# game/scripts/day17.rpy:944
translate spanish d17a136_5018f220:

    # I "..."
    I "..."

# game/scripts/day17.rpy:947
translate spanish d17a136_2b2ecef3:

    # Fa "It has been a long time since we took this route."
    Fa "Ha pasado mucho tiempo desde que tomamos esta ruta."

# game/scripts/day17.rpy:948
translate spanish d17a136_8556cb4e:

    # Chi "I bet. There's not much of any value around here."
    Chi "Apostaría a que sí. No hay nada de mucho de valor por aquí."

# game/scripts/day17.rpy:949
translate spanish d17a136_9c7001f1:

    # Z "It's this barren even around the village?"
    Z "¿Esto está tan desolado incluso alrededor del pueblo?"

# game/scripts/day17.rpy:950
translate spanish d17a136_c4f646d1:

    # Chi "Yep!"
    Chi "¡Sip!"

# game/scripts/day17.rpy:953
translate spanish d17a136_843231f3:

    # Fa "Are we still on the right track, Pepper?"
    Fa "¿Seguimos en el camino correcto, Pepper?"

# game/scripts/day17.rpy:954
translate spanish d17a136_b1b08774:

    # Pe "Yes. I'm sure of it."
    Pe "Sí. Estoy segura de ello."

# game/scripts/day17.rpy:957
translate spanish d17a136_282126b9:

    # Pe "Once we reach those rocks ahead, turn forty degrees to the left."
    Pe "Una vez que alcancemos esas rocas adelante, gira cuarenta grados a la izquierda."

# game/scripts/day17.rpy:958
translate spanish d17a136_e0a9c6de:

    # Fa "You do miss your people, don't you?"
    Fa "Echas de menos a tu gente, ¿verdad?"

# game/scripts/day17.rpy:959
translate spanish d17a136_3aee2001:

    # Pe "What do you mean?"
    Pe "¿Qué quieres decir?"

# game/scripts/day17.rpy:962
translate spanish d17a136_d162dcbd:

    # Fa "Don't pretend, Pepper. You're fidgeting. You never fidget."
    Fa "No finjas, Pepper. Estás inquieta. Nunca estás inquieta."

# game/scripts/day17.rpy:963
translate spanish d17a136_2e3987c0:

    # Pe "..."
    Pe "..."

# game/scripts/day17.rpy:966
translate spanish d17a136_3b9fa18b:

    # Chi "So... what's your story, [persistent.player_name]? Fangs only said that you're helping us, but not why."
    Chi "Entonces... ¿Cuál es tu historia, [persistent.player_name]? Fangs solo dijo que estás ayudándonos, pero no por qué."

# game/scripts/day17.rpy:967
translate spanish d17a136_186c1755:

    # Chi "Oh, and that you're from the big city, right?"
    Chi "¡Oh, y que eres de la gran ciudad, ¿verdad?"

# game/scripts/day17.rpy:968
translate spanish d17a136_616f7df4:

    # Z "Correct."
    Z "Correcto."

# game/scripts/day17.rpy:969
translate spanish d17a136_fc850120:

    # Chi "Okay, uhm... so? Tell me about the city."
    Chi "Vale, ehm... ¿y? Háblame de la ciudad."

# game/scripts/day17.rpy:970
translate spanish d17a136_b926390a:

    # Chi "Like, I know about it, but not much. How are the people?"
    Chi "Sé algo sobre eso, pero no demasiado. ¿Cómo es la gente?"

# game/scripts/day17.rpy:971
translate spanish d17a136_b28722e0:

    # Chi "Are they kind? Stubborn? Are they... good people?"
    Chi "¿Son amables? ¿Testarudos? ¿Son... buena gente?"

# game/scripts/day17.rpy:974
translate spanish d17a136_ee1fae37:

    # Z "They are pretty normal people. They work, they care about their friends and families. They can be harsh, unforgiving even, but they don't always have to."
    Z "Son personas bastante normales. Trabajan, se preocupan por sus amigos y familias. Pueden ser duros, incluso implacables, pero no siempre tiene que ser así."

# game/scripts/day17.rpy:975
translate spanish d17a136_2c6f4210:

    # Chi "Oh... that sounds... normal indeed."
    Chi "¡Oh... eso suena... bastante normal, de hecho!"

# game/scripts/day17.rpy:978
translate spanish d17a136_84a90f0b:

    # Z "They are open minded, in many ways."
    Z "Son de mente abierta, en muchos sentidos."

# game/scripts/day17.rpy:979
translate spanish d17a136_0158d21b:

    # Z "With enough money or power, anything is possible."
    Z "Con suficiente dinero o poder, cualquier cosa es posible."

# game/scripts/day17.rpy:980
translate spanish d17a136_dd68f0e6:

    # Chi "Sounds fun! If you are on top of course!"
    Chi "¡Suena divertido! ¡Si tú estás encima, claro!"

# game/scripts/day17.rpy:981
translate spanish d17a136_cd6c1dcf:

    # Z "Unless you like to serve others, you are right."
    Z "A menos que te guste servir a los demás, tienes razón."

# game/scripts/day17.rpy:984
translate spanish d17a136_3c39b891:

    # Z "They are dutiful and traditionalist. Even when several of them are aware of the fact that outside of the city there is a world with tools and technology beyond their means, they accept living without them."
    Z "Son diligentes y tradicionalistas. Incluso cuando varios de ellos son conscientes del hecho de que fuera de la ciudad hay un mundo con herramientas y tecnología más allá de sus medios, aceptan vivir sin ellas."

# game/scripts/day17.rpy:985
translate spanish d17a136_b93a59f2:

    # Z "And the city government makes sure that they won't get their hands on it, which makes the indoctrination that much easier."
    Z "Y el gobierno de la ciudad se asegura de que no puedan ponerle las manos encima, lo que hace que la indoctrinación sea mucho más fácil."

# game/scripts/day17.rpy:986
translate spanish d17a136_c7875c8c:

    # Chi "How sad. They're missing out!"
    Chi "Qué triste. ¡Se lo están perdiendo!"

# game/scripts/day17.rpy:990
translate spanish d17a136_9557dce7:

    # Chi "But what about the beeping noises? Do they start panicking if they hear a machine?"
    Chi "¿Pero qué pasa con los ruidos de los pitidos? ¿Se ponen a entrar en pánico si oyen una máquina?"

# game/scripts/day17.rpy:991
translate spanish d17a136_07489c8a:

    # Z "I don't know. I guess the zealots would. You could see for yourself, try it."
    Z "No lo sé. Supongo que los fanáticos lo harían. Podrías comprobarlo tú misma, inténtalo."

# game/scripts/day17.rpy:992
translate spanish d17a136_ae801ec7:

    # Chi "Me?"
    Chi "¿Yo?"

# game/scripts/day17.rpy:993
translate spanish d17a136_87aefcce:

    # Z "Why not? We would have to adjust your wardrobe, and that's it. You would blend in."
    Z "¿Por qué no? Solo tendríamos que ajustar tu vestuario, y ya está. Encajarías perfectamente."

# game/scripts/day17.rpy:994
translate spanish d17a136_3647e9c6:

    # Chi "Only if Krait and Fangs can come, too. And don't forget Ivy!"
    Chi "Solo si Krait y Fangs pueden venir también. ¡Y no olvides a Ivy!"

# game/scripts/day17.rpy:995
translate spanish d17a136_677f9406:

    # Z "That would be difficult..."
    Z "Eso sería difícil..."

# game/scripts/day17.rpy:996
translate spanish d17a136_3caf9828:

    # Chi "For now. If Fangs gets her way, they will open the doors for us sooner or later."
    Chi "Por ahora. Si Fangs consigue lo que quiere, nos abrirán las puertas tarde o temprano."

# game/scripts/day17.rpy:997
translate spanish d17a136_e9ed796e:

    # Chi "Sooner is better than later for me at least!"
    Chi "Más pronto que tarde, al menos para mí."

# game/scripts/day17.rpy:998
translate spanish d17a136_126e2dd3:

    # Fa "What do you mean by that?"
    Fa "¿Qué quieres decir con eso?"

# game/scripts/day17.rpy:999
translate spanish d17a136_5bc1120e:

    # Pe "Chili, that's enough, what are you rambling about..."
    Pe "Chili, ya basta, ¿de qué estás divagando...?"

# game/scripts/day17.rpy:1000
translate spanish d17a136_accb0cfb:

    # Chi "Sorry..."
    Chi "Lo siento..."

# game/scripts/day17.rpy:1003
translate spanish d17a136_d61eef0e:

    # Chi "Whoaaa... I need a haircut... it keeps smacking me in the face..."
    Chi "¡Guauuu... necesito un corte de pelo... sigue dándome en la cara!"

# game/scripts/day17.rpy:1006
translate spanish d17a136_32baea73:

    # Chi "Hm..."
    Chi "Hm..."

# game/scripts/day17.rpy:1009
translate spanish d17a136_a01e49c1:

    # Z "How long has it been since you left the village?"
    Z "¿Cuánto tiempo ha pasado desde que dejaste el pueblo?"

# game/scripts/day17.rpy:1012
translate spanish d17a136_7e67f5fc:

    # Chi "I don't know. A year? I haven't really kept track of time much. In the bunker days tend to blend together."
    Chi "No lo sé. ¿Un año? Realmente no he llevado la cuenta del tiempo. En el búnker los días tienden a mezclarse."

# game/scripts/day17.rpy:1013
translate spanish d17a136_78e698e8:

    # Pe "Now... you see this canyon?"
    Pe "Ahora... ¿ves ese cañón?"

# game/scripts/day17.rpy:1014
translate spanish d17a136_2356a9f4:

    # Fa "I do."
    Fa "Lo hago."

# game/scripts/day17.rpy:1017
translate spanish d17a136_eb22d205:

    # Pe "Go around it."
    Pe "Rodea eso."

# game/scripts/day17.rpy:1018
translate spanish d17a136_46b0d3dd:

    # Fa "As you wish."
    Fa "Como desees."

# game/scripts/day17.rpy:1021
translate spanish d17a136_6dd09b82:

    # Chi "By the way, Krait? Did you forget your swords?"
    Chi "Por cierto, Krait, ¿olvidaste tus espadas?"

# game/scripts/day17.rpy:1022
translate spanish d17a136_959d1301:

    # Chi "Or are they..."
    Chi "¿O es que...?"

# game/scripts/day17.rpy:1029
translate spanish d17a136_6a66bd28:

    # Kr "..."
    Kr "..."

# game/scripts/day17.rpy:1030
translate spanish d17a136_fc835d4f:

    # Chi "Krait?"
    Chi "¿Krait?"

# game/scripts/day17.rpy:1034
translate spanish d17a136_be284316:

    # Chi "Your... swords...?"
    Chi "Tus... ¿espadas...?"

# game/scripts/day17.rpy:1040
translate spanish d17a136_4c914ded:

    # Kr "Chili... they are in the other rover."
    Kr "Chili... están en el otro rover."

# game/scripts/day17.rpy:1043
translate spanish d17a136_bac5180a:

    # Chi "Oh, okay... Sorry!"
    Chi "Oh, vale... ¡Perdón!"

# game/scripts/day17.rpy:1046
translate spanish d17a136_c2360b68:

    # Fa "There we go, that looks familiar!"
    Fa "¡Ahí vamos, eso parece familiar!"

# game/scripts/day17.rpy:1049
translate spanish d17a136_649b08c5:

    # Chi "Wait, what?!"
    Chi "¡¿Espera, qué?!"

# game/scripts/day17.rpy:1052
translate spanish d17a136_3077f945:

    # Chi "Let me see!"
    Chi "¡Déjame ver!"

# game/scripts/day17.rpy:1055
translate spanish d17a136_5b23cebe:

    # Chi "Where is it?"
    Chi "¿Dónde está?"

# game/scripts/day17.rpy:1058
translate spanish d17a136_a7cd1724:

    # Chi "Whoa!"
    Chi "¡Guau!"

# game/scripts/day17.rpy:1061
translate spanish d17a136_454e5a58:

    # Chi "Almost there now!"
    Chi "¡Ya casi estamos!"

# game/scripts/day17.rpy:1067
translate spanish d17a136_0a6d27f4:

    # Chi "Wha-!"
    Chi "¡Qué-!"

# game/scripts/day17.rpy:1073
translate spanish d17a136_6a66bd28_1:

    # Kr "..."
    Kr "..."

# game/scripts/day17.rpy:1074
translate spanish d17a136_a95df7a5:

    # Chi "Krait! Oh... Phew..."
    Chi "¡Krait! Oh... Uf..."

# game/scripts/day17.rpy:1077
translate spanish d17a136_4f933570:

    # Z "Close one."
    Z "Por poco."

# game/scripts/day17.rpy:1080
translate spanish d17a136_5d8dd186:

    # Chi "I... uh... didn't think...."
    Chi "Yo... eh... no pensé..."

# game/scripts/day17.rpy:1083
translate spanish d17a136_abdaca7f:

    # Chi "Sorry again..."
    Chi "Perdón de nuevo..."

# game/scripts/day17.rpy:1088
translate spanish d17a136_77fd1a0f:

    # Chi "..."
    Chi "..."

# game/scripts/day17.rpy:1091
translate spanish d17a136_15e4ffea:

    # Chi "I missed you, guys...!"
    Chi "¡Os echaba de menos, chicos!"

# game/scripts/day17.rpy:1094
translate spanish d17a136_e810b7e0:

    # Chi "Whatever happened..."
    Chi "Lo que sea que haya pasado..."

# game/scripts/day17.rpy:1097
translate spanish d17a136_113954f9:

    # Chi "...we're coming to help you!"
    Chi "... ¡venimos a ayudaros!"

# game/scripts/day17.rpy:1100
translate spanish d17a136_051998de:

    # Fa "That building on the left... that's the one, right?"
    Fa "El edificio de la izquierda... ese es, ¿verdad?"

# game/scripts/day17.rpy:1101
translate spanish d17a136_4da5a90c:

    # Pe "Yes."
    Pe "Sí."

# game/scripts/day17.rpy:1104
translate spanish d17a136_86eaa1dd:

    # Pe "We are still far, but let's hurry and take cover, before they see us approaching."
    Pe "Aún estamos lejos, pero apresurémonos y busquemos cobertura antes de que nos vean acercarnos."

# game/scripts/day17.rpy:1107
translate spanish d17a136_a91cb169:

    # Fa "Alright... everyone, follow me."
    Fa "Vale... todos, seguidme."

# game/scripts/day17.rpy:1110
translate spanish d17a136_13014d3d:

    # Sc "What do you say, Fangs? Perfect opportunity for everyone to press the horns?"
    Sc "¿Qué dices, Fangs? ¿Una oportunidad perfecta para que todos toquen el claxon?"

# game/scripts/day17.rpy:1111
translate spanish d17a136_5efc30f3:

    # Sc "Let whoever is in there know we're coming!"
    Sc "¡Que sepa quien esté ahí que vamos a entrar!"

# game/scripts/day17.rpy:1113
translate spanish d17a136_3f6c9ddf:

    # Re "How about we take her back to the hive? She would fit right right in with our new friends!"
    Re "¿Qué tal si la llevamos de vuelta a la colmena? ¡Encajaría perfectamente con nuestros nuevos amigos!"

# game/scripts/day17.rpy:1114
translate spanish d17a136_500aa43b:

    # Sc "Fuck you, Red."
    Sc "Jódete, Red."

# game/scripts/day17.rpy:1115
translate spanish d17a136_efef0d85:

    # Re "Aww... no need to get all romantic."
    Re "Ohhh... no hace falta ponerse románticos."

# game/scripts/day17.rpy:1117
translate spanish d17a136_6170958e:

    # Re "What if we send Scarp in by herself? She could try negotiating?"
    Re "¿Y si enviamos a Scarp sola? Podría intentar negociar."

# game/scripts/day17.rpy:1118
translate spanish d17a136_0a0959c2:

    # Sc "The only negotiating these guys will get is my fist up their asses."
    Sc "El único trato que tendrán estos tipos será mi puño en sus culos."

# game/scripts/day17.rpy:1119
translate spanish d17a136_aebd31bb:

    # Re "Just what I thought."
    Re "Justo lo que pensaba."

# game/scripts/day17.rpy:1120
translate spanish d17a136_390476ce:

    # Fa "Cut the crap, guys. We're almost there."
    Fa "Dejad las gilipolleces, chicos. Estamos casi allí."

# game/scripts/day17.rpy:1127
translate spanish d17a136_8e69c6b4:

    # Pe "And now... we wait."
    Pe "Y ahora... esperamos."

# game/scripts/day17.rpy:1128
translate spanish d17a136_45fadbe4:

    # Pe "We're about 3 hours away from sunset."
    Pe "Estamos a unas 3 horas de la puesta de sol."

# game/scripts/day17.rpy:1129
translate spanish d17a136_6e8345f6:

    # Fa "There is still enough light to find our way."
    Fa "Aún hay suficiente luz para encontrar nuestro camino."

# game/scripts/day17.rpy:1132
translate spanish d17a136_23b45a6f:

    # Z "Let's go over the plan, again."
    Z "Repasemos el plan, una vez más."

# game/scripts/day17.rpy:1133
translate spanish d17a136_77961ccc:

    # Fa "Right..."
    Fa "Bien..."

# game/scripts/day17.rpy:1136
translate spanish d17a136_f6531112:

    # Fa "At night, a small group will walk over to the left side of the settlement."
    Fa "Por la noche, un pequeño grupo caminará hacia el lado izquierdo del asentamiento."

# game/scripts/day17.rpy:1137
translate spanish d17a136_9fbd5d3d:

    # Fa "There seems to be no activity whatsoever in that place, so we should not have any trouble getting closer."
    Fa "No parece haber actividad alguna en ese lugar, así que no deberíamos tener problemas para acercarnos."

# game/scripts/day17.rpy:1140
translate spanish d17a136_21c7542a:

    # Fa "Krait will sneak around the back and see if she can find anything looking into the building, and you, me, and the rest of the squad will stay put until we know what's going on."
    Fa "Krait rodeará por la parte trasera para ver si encuentra algo mirando hacia el edificio, y tú, yo y el resto del escuadrón nos quedaremos quietos hasta que sepamos qué está pasando."

# game/scripts/day17.rpy:1141
translate spanish d17a136_101017e5:

    # Fa "Pepper will stay here and communicate with us through the radio, waiting for our signal."
    Fa "Pepper se quedará aquí y se comunicará con nosotros a través de la radio, esperando nuestra señal."

# game/scripts/day17.rpy:1144
translate spanish d17a136_a7537532:

    # Pe "I have lowered the output volume. Don't forget, the vehicles need about three minutes to cover the distance."
    Pe "He bajado el volumen de salida. No lo olvides, los vehículos necesitan unos tres minutos para cubrir la distancia."

# game/scripts/day17.rpy:1147
translate spanish d17a136_06d974b2:

    # Fa "If things go wrong, that's a three minutes window in which we will have to tough it out."
    Fa "Si las cosas salen mal, hay una ventana de tres minutos en la que tendremos que aguantar."

# game/scripts/day17.rpy:1150
translate spanish d17a136_3107cc38:

    # Fa "[persistent.player_name], your number one task is to stay with Chili."
    Fa "[persistent.player_name], tu tarea número uno es quedarte con Chili."

# game/scripts/day17.rpy:1151
translate spanish d17a136_e204a856:

    # Fa "Whatever happens in there, don't let her out of your sight and listen to the signal, in case we need to light the place up."
    Fa "Lo que sea que pase ahí dentro, no la pierdas de vista y escucha la señal, por si tenemos que iluminar el lugar."

# game/scripts/day17.rpy:1154
translate spanish d17a136_86e312c1:

    # Z "Your sister is in good hands, Pepper."
    Z "Tu hermana está en buenas manos, Pepper."

# game/scripts/day17.rpy:1157
translate spanish d17a136_cc9a007b:

    # Fa "Alright. I need Pepper for a few minutes, and Krait. Everybody else can take a breather."
    Fa "Vale. Necesito a Pepper por unos minutos, y a Krait. Los demás pueden tomarse un respiro."

# game/scripts/day17.rpy:1158
translate spanish d17a136_430878b4:

    # Fa "Send them to me."
    Fa "Envíamelas."

# game/scripts/day17.rpy:1163
translate spanish d17a136_00ec046a:

    # Z "I have some time to kill..."
    Z "Tengo algo de tiempo para matar..."

# game/scripts/day17.rpy:1175
translate spanish d17a_preparation_overview_1c4dffa3:

    # Zt "Always looking for the high ground..."
    Zt "Siempre buscando el terreno alto..."

# game/scripts/day17.rpy:1178
translate spanish d17a_preparation_overview_5018f220:

    # I "..."
    I "..."

# game/scripts/day17.rpy:1182
translate spanish d17a_preparation_overview_f6b541a2:

    # Z "Hey..."
    Z "Ey..."

# game/scripts/day17.rpy:1188
translate spanish d17a_preparation_overview_7fc321bc:

    # "You lean on the rusted rail next to her..."
    "Te apoyas en la barandilla oxidada junto a ella..."

# game/scripts/day17.rpy:1192
translate spanish d17a_preparation_overview_5e718303:

    # Z "It's hard to imagine this being more than yet another ruin."
    Z "Es difícil imaginar que esto sea más que otra ruina."

# game/scripts/day17.rpy:1193
translate spanish d17a_preparation_overview_6b751b3b:

    # Z "Have you been here before?"
    Z "¿Has estado aquí antes?"

# game/scripts/day17.rpy:1195
translate spanish d17a_preparation_overview_8e641bfa:

    # I "This is my first time, too."
    I "Esta también es mi primera vez."

# game/scripts/day17.rpy:1198
translate spanish d17a_preparation_overview_9a99137d:

    # I "But there is more than meets the eye. The signs are there..."
    I "Pero hay más de lo que parece. Las señales están ahí..."

# game/scripts/day17.rpy:1199
translate spanish d17a_preparation_overview_6f5b39f9:

    # I "There are no bodies, no real signs of anything other than the passage of time."
    I "No hay cuerpos, ni señales reales de nada más que el paso del tiempo."

# game/scripts/day17.rpy:1200
translate spanish d17a_preparation_overview_2ba898cc:

    # I "These structures seem solid enough that over the decades someone would have taken an interest, but there's nothing."
    I "Estas estructuras parecen lo suficientemente sólidas como para que, con los años, alguien se hubiera interesado, pero no hay nada."

# game/scripts/day17.rpy:1203
translate spanish d17a_preparation_overview_0bb27599:

    # I "Whoever is residing here, must be hiding inside those ruins, out of sight."
    I "Quienquiera que resida aquí, debe estar escondido dentro de esas ruinas, fuera de la vista."

# game/scripts/day17.rpy:1206
translate spanish d17a_preparation_overview_ffe43285:

    # Z "Do you see anything that stands out?"
    Z "¿Ves algo que llame la atención?"

# game/scripts/day17.rpy:1209
translate spanish d17a_preparation_overview_2142c6fb:

    # I "Yes, actually. Just one thing... a structure... no... symbol. Right at the center."
    I "Sí, en realidad. Sólo una cosa... una estructura... no... un símbolo. Justo en el centro."

# game/scripts/day17.rpy:1212
translate spanish d17a_preparation_overview_c4e62efd:

    # I "I can't shake the feeling that there is more. I mean, we know it rationally, because Pepper led us here, but something..."
    I "No puedo quitarme la sensación de que hay más. Quiero decir, lo sabemos racionalmente, porque Pepper nos llevó aquí, pero algo..."

# game/scripts/day17.rpy:1213
translate spanish d17a_preparation_overview_048ee287:

    # "Her voice trails off."
    "Su voz se desvanece."

# game/scripts/day17.rpy:1218
translate spanish d17a_preparation_overview_c574e84b:

    # Z "I will keep that in mind. Stay safe out here, [I]."
    Z "Lo tendré en cuenta. Mantente a salvo ahí fuera, [I]."

# game/scripts/day17.rpy:1226
translate spanish d17a_preparation_overview_40de150c:

    # Re "You see this? We have a lot of replacement parts for this one."
    Re "¿Ves esto? Tenemos muchas piezas de repuesto para esta."

# game/scripts/day17.rpy:1227
translate spanish d17a_preparation_overview_0f853a3f:

    # Chi "We do, I saw..."
    Chi "Lo hacemos, lo vi..."

# game/scripts/day17.rpy:1228
translate spanish d17a_preparation_overview_b84ef6fa:

    # Re "But this one... is rare. It isn't a simple material either. It just never seems to deteriorate..."
    Re "Pero esta... es rara. Tampoco es un simple material. Simplemente nunca parece deteriorarse..."

# game/scripts/day17.rpy:1231
translate spanish d17a_preparation_overview_75b9ba84:

    # Chi "Will you be coming with us? Tonight, I mean..."
    Chi "¿Te unirás a nosotras? Esta noche, quiero decir..."

# game/scripts/day17.rpy:1232
translate spanish d17a_preparation_overview_ea6decd7:

    # Z "{i}*clears throat*{/i}"
    Z "{i}aclarándose la garganta{/i}"

# game/scripts/day17.rpy:1237
translate spanish d17a_preparation_overview_a22a000b:

    # Chi "Oh, hey [persistent.player_name]. Anything you need?"
    Chi "¡Oh, ey, [persistent.player_name]! ¿Hay algo que necesites?"

# game/scripts/day17.rpy:1240
translate spanish d17a_preparation_overview_b007096d:

    # Z "No, but Fangs asked for you."
    Z "No, pero Fangs preguntó por ti."

# game/scripts/day17.rpy:1241
translate spanish d17a_preparation_overview_896b6308:

    # Z "She wants to go over some things."
    Z "Quiere repasar algunas cosas."

# game/scripts/day17.rpy:1244
translate spanish d17a_preparation_overview_3b16d9f1:

    # Chi "Ah, Fangs and her plans. Okay, I will go right away."
    Chi "Ah, Fangs y sus planes. Está bien, iré de inmediato."

# game/scripts/day17.rpy:1249
translate spanish d17a_preparation_overview_cac48aed:

    # "She walks off..."
    "Ella se aleja..."

# game/scripts/day17.rpy:1252
translate spanish d17a_preparation_overview_b6b64205:

    # Re "So... I know we don't know each other, but... be honest."
    Re "Entonces... sé que no nos conocemos, pero... sé sincero."

# game/scripts/day17.rpy:1253
translate spanish d17a_preparation_overview_c9b61e6e:

    # Re "Why are you helping us? One Zetan patrol catching you... and you're done, aren't you?"
    Re "¿Por qué nos ayudas? Si una patrulla Zetana te atrapa... estás acabado, ¿no?"

# game/scripts/day17.rpy:1256
translate spanish d17a_preparation_overview_7c2abd97:

    # Z "Not really. I have enough pull to probably be able to explain things away, but it would be problematic, that much is true."
    Z "No realmente. Tengo suficiente influencia para probablemente explicar las cosas, pero sería problemático, eso es cierto."

# game/scripts/day17.rpy:1259
translate spanish d17a_preparation_overview_853d717a:

    # Re "Still... you don't just help out Fangs because she asked you to. Everyone knows she's not the likeable sort."
    Re "Aun así... no ayudas a Fangs solo porque te lo pidió. Todos saben que no es precisamente querida."

# game/scripts/day17.rpy:1260
translate spanish d17a_preparation_overview_3b5033cf:

    # Re "So, what gives?"
    Re "¿Qué pasa?"

# game/scripts/day17.rpy:1265
translate spanish d17a_preparation_overview_c049bc75:

    # Z "I do quite like her, in fact. And that's as good a reason as any."
    Z "De hecho, me gusta bastante. Y eso ya es suficiente razón."

# game/scripts/day17.rpy:1268
translate spanish d17a_preparation_overview_cb391f07:

    # Re "Oh my... Don't let her hear that."
    Re "¡Oh, Dios mío... no dejes que lo escuche!"

# game/scripts/day17.rpy:1269
translate spanish d17a_preparation_overview_5040c440:

    # Re "I doubt she realises the situation, and if she did..."
    Re "Dudo que se dé cuenta de la situación, y si lo hiciera..."

# game/scripts/day17.rpy:1272
translate spanish d17a_preparation_overview_5671181e:

    # Re "She just doesn't do emotions very well."
    Re "... simplemente no se le dan muy bien las emociones."

# game/scripts/day17.rpy:1275
translate spanish d17a_preparation_overview_8f58bd2d:

    # Z "Ivy led me to you guys. I guess it's because of her."
    Z "Ivy me llevó hasta vosotras. Supongo que es gracias a ella."

# game/scripts/day17.rpy:1278
translate spanish d17a_preparation_overview_8f724a8e:

    # Re "Ah, sweet Ivy."
    Re "Ah, la dulce Ivy."

# game/scripts/day17.rpy:1279
translate spanish d17a_preparation_overview_0db43f56:

    # Re "I heard she just... popped into Fangs' life one day, and gave Fangs heaven on earth."
    Re "Escuché que simplemente... apareció en la vida de Fangs un día, y le dio el cielo en la tierra."

# game/scripts/day17.rpy:1282
translate spanish d17a_preparation_overview_75f9ecca:

    # Re "I can't imagine a life without the bunker anymore. Clean, if rationed, water... no more wandering through the desert..."
    Re "No puedo imaginar una vida sin el búnker ya. Agua limpia, aunque racionada... nada de más vagar por el desierto..."

# game/scripts/day17.rpy:1285
translate spanish d17a_preparation_overview_9c95001b:

    # Re "So I guess we all have to thank her... and if she likes you too, then that's even better."
    Re "Supongo que todos tenemos que agradecerle... y si también le gustas, eso es aún mejor."

# game/scripts/day17.rpy:1288
translate spanish d17a_preparation_overview_08524391:

    # Re "I can't figure her out, really... and not just because she doesn't talk."
    Re "No puedo entenderla, realmente... y no solo porque no hable."

# game/scripts/day17.rpy:1291
translate spanish d17a_preparation_overview_72f6937a:

    # Z "Pepper needs my samples. I have been visiting her lab more frequently."
    Z "Pepper necesita mis muestras. He estado visitando su laboratorio con más frecuencia."

# game/scripts/day17.rpy:1294
translate spanish d17a_preparation_overview_0febb6ed:

    # Re "Um... I have been visiting her as well. But are syringes the reason why you are sticking with us?"
    Re "Eh... También he estado visitándola. Pero, ¿las jeringuillas son la razón por la que sigues con nosotros?"

# game/scripts/day17.rpy:1297
translate spanish d17a_preparation_overview_c4e9b7ec:

    # Z "I believe in your mission. My city would be better off if they could benefit from tech and knowledge the way you do."
    Z "Creo en vuestra misión. Mi ciudad estaría mejor si pudieran beneficiarse de la tecnología y el conocimiento como lo haces tú."

# game/scripts/day17.rpy:1300
translate spanish d17a_preparation_overview_0522b54e:

    # Re "A noble goal, trying to change the minds of a whole culture."
    Re "Un objetivo noble, intentar cambiar las mentes de toda una cultura."

# game/scripts/day17.rpy:1303
translate spanish d17a_preparation_overview_c4eb82a3:

    # Re "Let's see how this will all turn out... I don't have high hopes."
    Re "Veamos cómo resulta todo esto... No tengo muchas esperanzas."

# game/scripts/day17.rpy:1306
translate spanish d17a_preparation_overview_37254ba9:

    # Z "I like the adventure. And as long as I can take something home to feed my family, you can count me in."
    Z "Me gusta la aventura. Y mientras pueda llevarme algo a casa para alimentar a mi familia, puedes contar conmigo."

# game/scripts/day17.rpy:1309
translate spanish d17a_preparation_overview_98f160ca:

    # Re "Everyone has to survive... Having the luxury of the bunker's resources does not mean it's not true for us also."
    Re "Todos tienen que sobrevivir... Tener el lujo de los recursos del búnker no significa que no sea cierto también para nosotros."

# game/scripts/day17.rpy:1310
translate spanish d17a_preparation_overview_13625a7e:

    # Re "All this ancient, or rather advanced, technology needs a purpose."
    Re "Toda esta tecnología antigua, o mejor dicho, avanzada, necesita un propósito."

# game/scripts/day17.rpy:1313
translate spanish d17a_preparation_overview_5cb578c7:

    # Re "And when you give it one, but don't really have an instruction manual, occasionally you break things."
    Re "¿Y cuando le das uno, pero no tienes realmente un manual de instrucciones, de vez en cuando rompes cosas?"

# game/scripts/day17.rpy:1316
translate spanish d17a_preparation_overview_a56e368f:

    # Re "Making things to last forever only works if you use them properly, after all."
    Re "Hacer cosas para que duren para siempre solo funciona si las usas adecuadamente, después de todo."

# game/scripts/day17.rpy:1321
translate spanish d17a_preparation_overview_ee3e2173:

    # Re "Anyway... I've got things to do. See you later, alright?"
    Re "De todos modos... tengo cosas que hacer. Nos vemos más tarde, ¿vale?"

# game/scripts/day17.rpy:1324
translate spanish d17a_preparation_overview_e28997a2:

    # Z "Will you be coming with us tonight?"
    Z "¿Te unirás a nosotros esta noche?"

# game/scripts/day17.rpy:1327
translate spanish d17a_preparation_overview_8ab5faf1:

    # Re "Nope, I'm not a fighter. I take care of the vehicles, and that's about it!"
    Re "Nope, no soy una luchadora. Me encargo de los vehículos, ¡y eso es todo!"

# game/scripts/day17.rpy:1339
translate spanish d17a_preparation_overview_6a66bd28:

    # Kr "..."
    Kr "..."

# game/scripts/day17.rpy:1340
translate spanish d17a_preparation_overview_392141c5:

    # Z "Krait..."
    Z "Krait..."

# game/scripts/day17.rpy:1343
translate spanish d17a_preparation_overview_5099af71:

    # Z "Fangs wants to speak to you."
    Z "Fangs quiere hablar contigo."

# game/scripts/day17.rpy:1347
translate spanish d17a_preparation_overview_6a66bd28_1:

    # Kr "..."
    Kr "..."

# game/scripts/day17.rpy:1353
translate spanish d17a_preparation_overview_6a66bd28_2:

    # Kr "..."
    Kr "..."

# game/scripts/day17.rpy:1359
translate spanish d17a_preparation_overview_199dc2c0:

    # Kr "I'll be going, then..."
    Kr "Me iré entonces..."

# game/scripts/day17.rpy:1367
translate spanish d17a_preparation_overview_20d076d2:

    # Kr "I am curious to see you fight."
    Kr "Tengo curiosidad por verte luchar."

# game/scripts/day17.rpy:1378
translate spanish d17a_preparation_overview_26eb0152:

    # Sc "If it isn't the new guy."
    Sc "Si no es el chico nuevo."

# game/scripts/day17.rpy:1381
translate spanish d17a_preparation_overview_5dd79b6a:

    # Z "I fought with Fangs in the hive, remember?"
    Z "Luché con Fangs en la colmena, ¿lo recuerdas?"

# game/scripts/day17.rpy:1384
translate spanish d17a_preparation_overview_645e720d:

    # Sc "You fought one battle with us, so?"
    Sc "¿Luchaste una batalla con nosotros, y qué?"

# game/scripts/day17.rpy:1389
translate spanish d17a_preparation_overview_4b9ac059:

    # Z "One battle with you, a thousand more without you."
    Z "Una batalla contigo, mil más sin ti."

# game/scripts/day17.rpy:1390
translate spanish d17a_preparation_overview_0ed4b9c1:

    # Z "Maybe you should've been there with us last time."
    Z "Tal vez deberías haber estado allí con nosotros la última vez."

# game/scripts/day17.rpy:1393
translate spanish d17a_preparation_overview_d87dad31:

    # Sc "I. Had. Other. Obligations!"
    Sc "Yo. tenía. otras. obligaciones."

# game/scripts/day17.rpy:1396
translate spanish d17a_preparation_overview_794a0b52:

    # Sc "Don't think I would not have been there. These scars? I wasn't born with them."
    Sc "No pienses que no habría estado allí. ¿Estas cicatrices? No nací con ellas."

# game/scripts/day17.rpy:1397
translate spanish d17a_preparation_overview_2ae5febb:

    # Sc "You may have gotten Fangs all mushy, but not me."
    Sc "Puede que hayas ablandado a Fangs, pero a mí no."

# game/scripts/day17.rpy:1401
translate spanish d17a_preparation_overview_b470a7d6:

    # Z "So I don't care for your tone."
    Z "No me importa tu tono."

# game/scripts/day17.rpy:1402
translate spanish d17a_preparation_overview_b25a9a29:

    # Z "You don't get to my age in my line of work without proving yourself repeatedly."
    Z "No llegas a mi edad en mi línea de trabajo sin demostrar tu valía una y otra vez."

# game/scripts/day17.rpy:1403
translate spanish d17a_preparation_overview_de77ff72:

    # Z "So you can drop the attitude."
    Z "Puedes ahorrarte la actitud."

# game/scripts/day17.rpy:1406
translate spanish d17a_preparation_overview_43294590:

    # Sc "You piece of..."
    Sc "Pedazo de..."

# game/scripts/day17.rpy:1407
translate spanish d17a_preparation_overview_56a50067:

    # Sc "You think I am a rookie?!"
    Sc "¡¿Crees que soy una novata?!"

# game/scripts/day17.rpy:1410
translate spanish d17a_preparation_overview_58032499:

    # Sc "Thank you for the compliment, asshole, but if you couldn't tell, I am not the youngest one either."
    Sc "Gracias por el cumplido, idiota, pero si no lo notaste, tampoco soy la más joven."

# game/scripts/day17.rpy:1412
translate spanish d17a_preparation_overview_ffe58c69:

    # Sc "You and Fangs may be fucking, but that doesn't mean I need to bend over and accept you as one of our own when you clearly aren't."
    Sc "Tú y Fangs podréis estar follando, pero eso no significa que tenga que agachar la cabeza y aceptarte como uno de los nuestros cuando claramente no lo eres."

# game/scripts/day17.rpy:1414
translate spanish d17a_preparation_overview_52805af4:

    # Sc "Fangs may have her reasons for you to stay, but that doesn't mean I need to bend over and accept you as one of our own when you clearly aren't. "
    Sc "Fangs puede tener sus razones para que te quedes, pero eso no significa que yo deba inclinarme y aceptarte como uno de los nuestros cuando claramente no lo eres."

# game/scripts/day17.rpy:1417
translate spanish d17a_preparation_overview_3a50f1ca:

    # Sc "We'll see tonight if there's more to you than big words."
    Sc "Lo veremos esta noche si hay algo más en ti que palabras grandes."

# game/scripts/day17.rpy:1423
translate spanish d17a_preparation_overview_28657375:

    # Z "Good. I like a challenge."
    Z "Bien. Me gustan los desafíos."

# game/scripts/day17.rpy:1425
translate spanish d17a_preparation_overview_91a3564a:

    # Sc "Hm."
    Sc "Umm."

# game/scripts/day17.rpy:1428
translate spanish d17a_preparation_overview_0b4c0e34:

    # Sc "Fine then."
    Sc "Vale entonces."

# game/scripts/day17.rpy:1431
translate spanish d17a_preparation_overview_d87616d0:

    # Z "Words are not the only big things about me, but I don't know if I like you enough for you to find out."
    Z "Las palabras no son lo único grande en mí, pero no sé si me gustas lo suficiente para que lo descubras."

# game/scripts/day17.rpy:1434
translate spanish d17a_preparation_overview_da19b0ef:

    # Sc "Really? Childish humour?"
    Sc "¿En serio? ¿Humor infantil?"

# game/scripts/day17.rpy:1437
translate spanish d17a_preparation_overview_f3e5f9b6:

    # Z "Well, stop being a brat then, if that's not what you're into."
    Z "Bueno, deja de ser una mocosa entonces, si no es lo que te gusta."

# game/scripts/day17.rpy:1438
translate spanish d17a_preparation_overview_d0ef8948:

    # Z "You will see, in time. I am not that bad to have around."
    Z "Lo verás con el tiempo. No soy tan malo para tener cerca."

# game/scripts/day17.rpy:1441
translate spanish d17a_preparation_overview_22e8e026:

    # Z "I have better things to do than to try and impress you, but sure, stay back and watch."
    Z "Tengo mejores cosas que hacer que intentar impresionarte, pero claro, quédate atrás y observa."

# game/scripts/day17.rpy:1442
translate spanish d17a_preparation_overview_98b1b2a3:

    # Z "Maybe you'll learn something."
    Z "Tal vez aprendas algo."

# game/scripts/day17.rpy:1445
translate spanish d17a_preparation_overview_495e3ef3:

    # Sc "I like people who let their actions speak for them."
    Sc "Me gustan las personas que dejan que sus acciones hablen por ellas."

# game/scripts/day17.rpy:1449
translate spanish d17a_preparation_overview_3701d2c2:

    # Sc "You won't mind if I keep an eye on the only man in this squad today, will you?"
    Sc "¿Te importa si mantengo un ojo en el único hombre de este escuadrón hoy?"

# game/scripts/day17.rpy:1452
translate spanish d17a_preparation_overview_f8dd1791:

    # Sc "Hm?"
    Sc "¿Um?"

# game/scripts/day17.rpy:1457
translate spanish d17a_preparation_overview_b9121a23:

    # Sc "I mean to keep my girls safe."
    Sc "Quiero mantener a mis chicas a salvo."

# game/scripts/day17.rpy:1476
translate spanish d17a236_414940c9:

    # Chi "Man..."
    Chi "Tío..."

# game/scripts/day17.rpy:1478
translate spanish d17a236_2b613ace:

    # Chi "I never before realised how lonely it all looks from here..."
    Chi "Nunca me había dado cuenta de lo solitario que todo se ve desde aquí..."

# game/scripts/day17.rpy:1481
translate spanish d17a236_0a36c4df:

    # Chi "...what have they done to my lights?"
    Chi "... ¿qué le han hecho a mis luces?"

# game/scripts/day17.rpy:1482
translate spanish d17a236_de5a6694:

    # Z "It was never this silent, was it?"
    Z "¿No estaba nunca tan silencioso, verdad?"

# game/scripts/day17.rpy:1485
translate spanish d17a236_ac62060a:

    # Chi "Never, no... But that is not the worst part."
    Chi "Nunca, no... Pero esa no es la peor parte."

# game/scripts/day17.rpy:1489
translate spanish d17a236_e72e96cb:

    # Pe "Fangs, do you see or hear anything from your viewpoint?"
    Pe "Fangs, ¿ves o escuchas algo desde tu punto de vista?"

# game/scripts/day17.rpy:1491
translate spanish d17a236_5afd53b9:

    # Fa "Nothing but dead air, and darkness."
    Fa "Nada más que aire muerto y oscuridad."

# game/scripts/day17.rpy:1492
translate spanish d17a236_92aeeda9:

    # Fa "If there's anyone sneaking around, we wouldn't notice from here."
    Fa "Si hay alguien merodeando, no lo notaríamos desde aquí."

# game/scripts/day17.rpy:1496
translate spanish d17a236_d97dc7f8:

    # Pe "Let me know when you approach the buildings, then."
    Pe "Avísame cuando te acerques a los edificios, entonces."

# game/scripts/day17.rpy:1500
translate spanish d17a236_d5ede02a:

    # Fa "Let's take our time. The sun is barely under."
    Fa "Tomémonos nuestro tiempo. El sol apenas se ha ocultado."

# game/scripts/day17.rpy:1504
translate spanish d17a236_a67a4c56:

    # Pe "You're the boss... we are ready, and waiting."
    Pe "Tú eres la jefa... estamos listas y esperando."

# game/scripts/day17.rpy:1507
translate spanish d17a236_82a04d55:

    # Pe "We should not overuse our communication devices. They only last so long before needing to recharge."
    Pe "No deberíamos abusar de nuestros dispositivos de comunicación. Solo duran cierto tiempo antes de necesitar recargarse."

# game/scripts/day17.rpy:1510
translate spanish d17a236_7a15abe1:

    # Fa "Understood."
    Fa "Entendido."

# game/scripts/day17.rpy:1513
translate spanish d17a236_07b5d6c7:

    # Fa "Probably best if you stop messing around with them then."
    Fa "Probablemente sea mejor que dejes de jugar con ellos entonces."

# game/scripts/day17.rpy:1517
translate spanish d17a236_e986f3b2:

    # Kr "{i}*sigh*{/i}"
    Kr "{i}*suspiro*{/i}"

# game/scripts/day17.rpy:1520
translate spanish d17a236_70500e88:

    # Kr "What a beautiful moment..."
    Kr "Qué momento tan hermoso..."

# game/scripts/day17.rpy:1523
translate spanish d17a236_030d43d3:

    # Kr "Staring at silent ruins, drowned in depressing darkness, the cold wind blowing in your face..."
    Kr "Observando ruinas silenciosas, sumidas en una oscuridad deprimente, el viento frío soplando en tu cara..."

# game/scripts/day17.rpy:1524
translate spanish d17a236_7b76ea5d:

    # Kr "...all the while, laying on cold steel, waiting for a signal from your boss."
    Kr "... ¡todo el tiempo, acostada en acero frío, esperando una señal de tu jefa!"

# game/scripts/day17.rpy:1525
translate spanish d17a236_df5f1799:

    # Kr "The tension before imminent, or at least possible battle... do you sense it too?"
    Kr "La tensión antes de una batalla inminente, o al menos posible... ¿Tú también la sientes?"

# game/scripts/day17.rpy:1526
translate spanish d17a236_e730bc87:

    # Kr "Does it bring back older memories for you as well?"
    Kr "¿También te trae recuerdos antiguos?"

# game/scripts/day17.rpy:1527
translate spanish d17a236_1f100ba2:

    # Kr "The caves you were hiding in... the murders you had to commit to survive... the misery of a life on the run."
    Kr "Las cuevas en las que te escondías... los asesinatos que tuviste que cometer para sobrevivir... la miseria de una vida huyendo."

# game/scripts/day17.rpy:1530
translate spanish d17a236_04e0b53d:

    # "The warmth emanating from the woman's reveries, however bleak and reminiscent of a dark past, somehow feels like a cozy blanket, until the words sink in and you shake your head."
    "El calor que emana de las ensoñaciones de la mujer, aunque sombrías y reminiscentes de un oscuro pasado, de alguna manera se siente como una manta acogedora, hasta que las palabras calan y sacudes la cabeza."

# game/scripts/day17.rpy:1531
translate spanish d17a236_32e829af:

    # "What is it, with this woman?"
    "¿Qué pasa con esta mujer?"

# game/scripts/day17.rpy:1533
translate spanish d17a236_6019a086:

    # Fa "Pepper...? I think it's time."
    Fa "¿Pepper...? Creo que es la hora."

# game/scripts/day17.rpy:1537
translate spanish d17a236_cdbf6cd7:

    # Pe "Off you go then. Let's find out what happened."
    Pe "¡Vamos allá! Averigüemos qué pasó."

# game/scripts/day17.rpy:1538
translate spanish d17a236_4ecc9241:

    # Fa "Everyone, get up."
    Fa "Todos, arriba."

# game/scripts/day17.rpy:1541
translate spanish d17a236_d74b19e8:

    # Mu "Understood."
    Mu "Entendido."

# game/scripts/day17.rpy:1546
translate spanish d17a236_bd4c6f34:

    # "Your group silently approaches the ruins. You try to listen to any suspicious noises coming from where you're told the settlement is, but you hear nothing."
    "Tu grupo se acerca silenciosamente a las ruinas. Intentas escuchar cualquier ruido sospechoso proveniente del asentamiento, pero no escuchas nada."

# game/scripts/day17.rpy:1549
translate spanish d17a236_8a4df6c2:

    # Faw "Those stairs over there..."
    Faw "Esas escaleras de allí..."

# game/scripts/day17.rpy:1552
translate spanish d17a236_0c91aa30:

    # Faw "Ivy, do you see them?"
    Faw "Ivy, ¿las ves?"

# game/scripts/day17.rpy:1555
translate spanish d17a236_3469c129:

    # Faw "Can you get there, quietly?"
    Faw "¿Puedes llegar allí, en silencio?"

# game/scripts/day17.rpy:1558
translate spanish d17a236_3c5c10f0:

    # Faw "Keep a lookout while we approach. Check the windows for hostiles."
    Faw "Vigila mientras nos acercamos. Revisa las ventanas buscando hostiles."

# game/scripts/day17.rpy:1565
translate spanish d17a236_9e98b042:

    # "You silently split up in smaller groups, approaching from different angles."
    "Te divides en pequeños grupos, acercándote desde diferentes ángulos."

# game/scripts/day17.rpy:1566
translate spanish d17a236_cf49e3da:

    # "As you stick with Chili, leading the way, Krait has already vanished into the darkness."
    "Al quedarte con Chili, liderando el camino, Krait ya ha desaparecido en la oscuridad."

# game/scripts/day17.rpy:1569
translate spanish d17a236_e5595436:

    # Chiw "Hey, [persistent.player_name]. Can you cover me?"
    Chiw "Ey, [persistent.player_name]. ¿Puedes cubrirme?"

# game/scripts/day17.rpy:1572
translate spanish d17a236_81db7539:

    # Chiw "I never liked this room..."
    Chiw "Nunca me gustó esta habitación..."

# game/scripts/day17.rpy:1575
translate spanish d17a236_5e970731:

    # Zw "I got you."
    Zw "Estoy contigo."

# game/scripts/day17.rpy:1578
translate spanish d17a236_226ba37c:

    # Zw "I see something..."
    Zw "Veo algo..."

# game/scripts/day17.rpy:1579
translate spanish d17a236_0bfda4cf:

    # Chiw "Yes, follow the light."
    Chiw "Sí, sigue la luz."

# game/scripts/day17.rpy:1582
translate spanish d17a236_811d01d7:

    # Chiw "There is... no movement..."
    Chiw "No hay... movimiento..."

# game/scripts/day17.rpy:1585
translate spanish d17a236_9ed2839b:

    # Zw "No one's there?"
    Zw "¿Nadie está ahí?"

# game/scripts/day17.rpy:1588
translate spanish d17a236_cbbd6360:

    # Chiw "Yes..."
    Chiw "Sí..."

# game/scripts/day17.rpy:1591
translate spanish d17a236_4a75ba0c:

    # Chiw "What do we do now..."
    Chiw "¿Qué hacemos ahora...?"

# game/scripts/day17.rpy:1592
translate spanish d17a236_f7b18626:

    # Zw "We wait for Fangs."
    Zw "Esperamos a Fangs."

# game/scripts/day17.rpy:1596
translate spanish d17a236_505d2e70:

    # Faw "Is everyone in position? Report, if you're not!"
    Faw "¿Está todo el mundo en su posición? ¡Reportar, si no lo estáis!"

# game/scripts/day17.rpy:1598
translate spanish d17a236_6c3bdf62:

    # Faw "Good."
    Faw "Bien."

# game/scripts/day17.rpy:1601
translate spanish d17a236_069b2fbe:

    # Faw "[persistent.player_name], look up to your right."
    Faw "[persistent.player_name], mira hacia arriba, a tu derecha."

# game/scripts/day17.rpy:1605
translate spanish d17a236_c11fa5c0:

    # Zw "What should I see?"
    Zw "¿Qué debería ver?"

# game/scripts/day17.rpy:1607
translate spanish d17a236_87aa6cd8:

    # Faw "Higher up."
    Faw "Más arriba."

# game/scripts/day17.rpy:1611
translate spanish d17a236_0a132fbd:

    # Zw "Got it."
    Zw "La tengo."

# game/scripts/day17.rpy:1613
translate spanish d17a236_97f1091f:

    # Faw "She will watch over us."
    Faw "Ella velará por nosotros."

# game/scripts/day17.rpy:1616
translate spanish d17a236_9c14621d:

    # Faw "Ivy, hold back. But should we get spotted, fire at will."
    Faw "Ivy, mantente atrás. Pero si nos descubren, dispara a discreción."

# game/scripts/day17.rpy:1619
translate spanish d17a236_d21851bf:

    # Faw "Now... Krait? Do you hear me?"
    Faw "Ahora... ¿Krait? ¿Me oyes?"

# game/scripts/day17.rpy:1622
translate spanish d17a236_87bf7c30:

    # Faw "Krait, where are you right now?"
    Faw "Krait, ¿dónde estás ahora mismo?"

# game/scripts/day17.rpy:1626
translate spanish d17a236_287b99af:

    # Krw "Dancing with the rodents. What do you think...?"
    Krw "Bailando con los roedores. ¿Qué opinas?..."

# game/scripts/day17.rpy:1628
translate spanish d17a236_5d5f4aca:

    # Faw "{i}*sigh*{/i} Krait..."
    Faw "{i}*suspiro*{/i} Krait..."

# game/scripts/day17.rpy:1632
translate spanish d17a236_412c3f51:

    # Kr "I am in position..."
    Kr "Estoy en posición..."

# game/scripts/day17.rpy:1634
translate spanish d17a236_6c3bdf62_1:

    # Faw "Good."
    Faw "Bien."

# game/scripts/day17.rpy:1637
translate spanish d17a236_38901378:

    # Faw "Remember, if you get rushed, double back to us. We are near the entrance, to the right, behind the containers."
    Faw "Recuerda, si te atacan, regresa a nosotros. Estamos cerca de la entrada, a la derecha, detrás de los contenedores."

# game/scripts/day17.rpy:1640
translate spanish d17a236_42956205:

    # Faw "Now do your thing; but do it silently and carefully."
    Faw "Ahora haz lo tuyo; pero hazlo en silencio y con cuidado."

# game/scripts/day17.rpy:1643
translate spanish d17a236_207027c0:

    # "The chatter falls silent, and the group starts to take in the surroundings."
    "El bullicio se detiene, y el grupo empieza a asimilar el entorno."

# game/scripts/day17.rpy:1644
translate spanish d17a236_9d286222:

    # "You look to your left and see a ramshackle building, most likely put together from parts over many years."
    "Miras a tu izquierda y ves un edificio destartalado, probablemente ensamblado con piezas a lo largo de los años."

# game/scripts/day17.rpy:1645
translate spanish d17a236_ddf29106:

    # "Containers, scrap and junk lay between the rubble. Everything looks neglected."
    "Contenedores, chatarra y basura se extienden entre los escombros. Todo parece descuidado."

# game/scripts/day17.rpy:1648
translate spanish d17a236_a90916cd:

    # "On top and beside the tall concrete walls, from which the jagged steel beams emerge, you see makeshift housing."
    "En la parte superior y al lado de las altas paredes de concreto, de las cuales emergen vigas de acero dentadas, ves viviendas improvisadas."

# game/scripts/day17.rpy:1649
translate spanish d17a236_2b4d8942:

    # "People live here in the open, like in so many other settlements around the region. But you spot no movement, and no sound."
    "La gente vive aquí al aire libre, como en tantos otros asentamientos de la región. Pero no ves movimiento, ni escuchas sonido alguno."

# game/scripts/day17.rpy:1652
translate spanish d17a236_7d2de91e:

    # "Around the shacks ahead, you spot vegetation. Outside a Zone, there are precious few places where vegetation occurs naturally. Is this cultivated ground?"
    "Alrededor de las chabolas más adelante, ves vegetación. Fuera de una Zona, hay pocos lugares donde la vegetación ocurre de forma natural. ¿Es tierra cultivada?"

# game/scripts/day17.rpy:1655
translate spanish d17a236_42723e89:

    # "Wherever you look, you can't help but think that this place looks too rough to be inhabited."
    "Dondequiera que mires, no puedes evitar pensar que este lugar se ve demasiado áspero para ser habitable."

# game/scripts/day17.rpy:1656
translate spanish d17a236_1a49e943:

    # Zw "You told us this is where you used to live, Chili. But it looks rundown and abandoned."
    Zw "Nos dijiste que aquí es donde solías vivir, Chili. Pero parece deteriorado y abandonado."

# game/scripts/day17.rpy:1657
translate spanish d17a236_c81224e3:

    # Chiw "It didn't look like this last time I was here... something must have changed."
    Chiw "No se veía así la última vez que estuve aquí... algo debe haber cambiado."

# game/scripts/day17.rpy:1658
translate spanish d17a236_9cc11396:

    # Chiw "Some of us always took their work very lightly... but what you see is only the surface."
    Chiw "Algunos siempre se tomaron su trabajo a la ligera... pero lo que ves es solo la superficie."

# game/scripts/day17.rpy:1661
translate spanish d17a236_7a0e93f5:

    # Chiw "Once, my people used to roam around, but that was a long time ago."
    Chiw "Una vez, mi gente solía vagar, pero eso fue hace mucho tiempo."

# game/scripts/day17.rpy:1662
translate spanish d17a236_6731baab:

    # Chiw "The last few generations, we spent our time learning, growing... things, caring for this place, in our own way."
    Chiw "Las últimas generaciones hemos dedicado nuestro tiempo a aprender, crecer... cuidar este lugar a nuestra manera."

# game/scripts/day17.rpy:1663
translate spanish d17a236_251f57aa:

    # Z "You were nomads?"
    Z "¿Eran nómadas?"

# game/scripts/day17.rpy:1664
translate spanish d17a236_0f2b0190:

    # Chiw "Pepper doesn't like me to talk about these things, but yes..."
    Chiw "A Pepper no le gusta que hable de estas cosas, pero sí..."

# game/scripts/day17.rpy:1665
translate spanish d17a236_9c99351a:

    # Chiw "The region of Egypt was but a stop on our quest. Our \"Sapa\", as we call it."
    Chiw "La región de Egipto fue solo una parada en nuestra búsqueda. Nuestro \"Sapa\", como lo llamamos."

# game/scripts/day17.rpy:1666
translate spanish d17a236_74e4665d:

    # Zw "What quest is that?"
    Zw "¿Qué misión es esa?"

# game/scripts/day17.rpy:1667
translate spanish d17a236_c0af7355:

    # Chiw "Well, I..."
    Chiw "Bueno, yo..."

# game/scripts/day17.rpy:1669
translate spanish d17a236_9e790efa:

    # Faw "Everyone... we have movement. Look out!"
    Faw "Todos... tenemos movimiento. ¡Atentos!"

# game/scripts/day17.rpy:1672
translate spanish d17a236_2977651d:

    # C "Nh..."
    C "Nh..."

# game/scripts/day17.rpy:1675
translate spanish d17a236_0bbbeb65:

    # "A lone woman hurries outside, stumbling, clearly agitated..."
    "Una mujer solitaria sale apresurada, tropezando, claramente agitada..."

# game/scripts/day17.rpy:1677
translate spanish d17a236_e1339288:

    # Faw "Chili... do you know her?"
    Faw "Chili... ¿la conoces?"

# game/scripts/day17.rpy:1679
translate spanish d17a236_8d60883d:

    # Chiw "Yes... it's my cousin!"
    Chiw "Sí... ¡es mi prima!"

# game/scripts/day17.rpy:1682
translate spanish d17a236_a3c16ad0:

    # C "Just..."
    C "Solo..."

# game/scripts/day17.rpy:1683
translate spanish d17a236_fc8c9a1e:

    # C "...for once..."
    C "... por una vez..."

# game/scripts/day17.rpy:1687
translate spanish d17a236_4f252a4e:

    # "She falls down on her knees in front of the big steely wheel..."
    "Cae de rodillas frente a la gran rueda de acero..."

# game/scripts/day17.rpy:1688
translate spanish d17a236_706fcbbc:

    # C "I shouldn't..."
    C "No debería..."

# game/scripts/day17.rpy:1691
translate spanish d17a236_29cf07e8:

    # C "...I shouldn't be alone tonight..."
    C "... no debería estar sola esta noche..."

# game/scripts/day17.rpy:1695
translate spanish d17a236_32b3e98d:

    # C2 "Trying to run away, I see?"
    C2 "¿Intentando escapar, veo?"

# game/scripts/day17.rpy:1698
translate spanish d17a236_2a0cf28d:

    # C2 "...and running out into the cold nevertheless."
    C2 "... y corriendo hacia el frío de todos modos."

# game/scripts/day17.rpy:1699
translate spanish d17a236_cc34184a:

    # C2 "You are out of your mind."
    C2 "Estás fuera de tus cabales."

# game/scripts/day17.rpy:1702
translate spanish d17a236_17952d87:

    # C2 "Your fears are delusional, woman."
    C2 "Tus miedos son delirantes, mujer."

# game/scripts/day17.rpy:1705
translate spanish d17a236_191522b7:

    # Tre "...as for your life, it is not in danger."
    Tre "... en cuanto a tu vida, no está en peligro."

# game/scripts/day17.rpy:1707
translate spanish d17a236_7a8a3723:

    # Pew "Guys... what's happening? I see three figures."
    Pew "Chicos... ¿qué está pasando? Veo tres figuras."

# game/scripts/day17.rpy:1709
translate spanish d17a236_71755e6e:

    # Chiw "Tribals, sister. They're surrounding Dinara!"
    Chiw "Tribus, hermana. ¡Están rodeando a Dinara!"

# game/scripts/day17.rpy:1711
translate spanish d17a236_9baa6823:

    # Pew "These must be the occupiers. Assume they are hostile."
    Pew "Deben ser los ocupantes. Asume que son hostiles."

# game/scripts/day17.rpy:1714
translate spanish d17a236_df7c4edb:

    # Tre "Come back, and resume your role. For the sake of your future."
    Tre "Vuelve y retoma tu papel. Por el bien de tu futuro."

# game/scripts/day17.rpy:1717
translate spanish d17a236_4a1d2372:

    # Di "I... can't."
    Di "Yo... no puedo."

# game/scripts/day17.rpy:1720
translate spanish d17a236_aa38e1f3:

    # Di "I... told you before... there is no future for me."
    Di "Yo... te dije antes... no hay futuro para mí."

# game/scripts/day17.rpy:1723
translate spanish d17a236_f49cefeb:

    # Tre "Your future is to hold true to our agreement! The confusion that is stopping you is all in your mind."
    Tre "¡Tu futuro es cumplir con nuestro acuerdo! La confusión que te detiene está solo en tu mente."

# game/scripts/day17.rpy:1726
translate spanish d17a236_99ab2246:

    # Tre "You agreed to become my woman, for the sake of your people. And yet, you disrespect me after your pledge."
    Tre "Acordaste convertirte en mi mujer, por el bien de tu gente. Y, sin embargo, me faltas al respeto tras tu promesa."

# game/scripts/day17.rpy:1729
translate spanish d17a236_59385aa8:

    # Di "I..."
    Di "Yo..."

# game/scripts/day17.rpy:1732
translate spanish d17a236_3428e7e4:

    # Di "I gave you my life, but I cannot give you another."
    Di "Te di mi vida, pero no puedo darte otra."

# game/scripts/day17.rpy:1735
translate spanish d17a236_5cec7a1b:

    # Di "I told you so, and you wouldn't listen."
    Di "Te lo dije, y no escuchaste."

# game/scripts/day17.rpy:1738
translate spanish d17a236_bdf9c532:

    # Tre "Your fixation on your religion has driven you mad, woman!"
    Tre "¡Tu obsesión con tu religión te ha vuelto loca, mujer!"

# game/scripts/day17.rpy:1740
translate spanish d17a236_504dea4a:

    # Faw "Did she just..."
    Faw "¿Ella acaba de...?"

# game/scripts/day17.rpy:1742
translate spanish d17a236_832ead50:

    # Chiw "Dinara is... carrying?!"
    Chiw "¡¿Dinara está... embarazada?!"

# game/scripts/day17.rpy:1746
translate spanish d17a236_3778c14d:

    # Faw "People are coming out of the shacks."
    Faw "La gente está saliendo de las chozas."

# game/scripts/day17.rpy:1749
translate spanish d17a236_c386b480:

    # Faw "It looks like they were here all along, hiding."
    Faw "Parece que siempre estuvieron aquí, escondidos."

# game/scripts/day17.rpy:1753
translate spanish d17a236_7a97d5d1:

    # Zw "Everyone is looking..."
    Zw "Todo el mundo está mirando..."

# game/scripts/day17.rpy:1755
translate spanish d17a236_1b99aa6b:

    # Faw "Don't let them see you yet."
    Faw "No dejes que te vean todavía."

# game/scripts/day17.rpy:1758
translate spanish d17a236_ca74816b:

    # Krw "Hostile spotted..."
    Krw "¡Hostil avistado!"

# game/scripts/day17.rpy:1761
translate spanish d17a236_d50ac4f5:

    # Trw "What is happening... Is father scolding them again?"
    Trw "¿Qué está pasando... Está mi padre regañándolas otra vez?"

# game/scripts/day17.rpy:1764
translate spanish d17a236_bf44151f:

    # Krw "..."
    Krw "..."

# game/scripts/day17.rpy:1767
translate spanish d17a236_b72fa137:

    # Trw "{i}*sigh*{/i}... always the same. Paranoid folk..."
    Trw "{i}*suspiro*{/i}... Siempre lo mismo. Gente paranoica..."

# game/scripts/day17.rpy:1770
translate spanish d17a236_1fb658fd:

    # Tre "Come inside by yourself. Don't make me drag you."
    Tre "Entra tú misma. No me hagas arrastrarte."

# game/scripts/day17.rpy:1771
translate spanish d17a236_f5e039d7:

    # Di "I... don't want to..."
    Di "Yo... no quiero..."

# game/scripts/day17.rpy:1774
translate spanish d17a236_237aa90f:

    # Di "...please, leave me be for a moment."
    Di "... por favor, dame estos momentos a solas."

# game/scripts/day17.rpy:1777
translate spanish d17a236_68901548:

    # Tre "I cannot allow it. You are risking the child's health!"
    Tre "No puedo permitirlo. ¡Estás poniendo en riesgo la salud del niño!"

# game/scripts/day17.rpy:1778
translate spanish d17a236_c45ee047:

    # Trw "..."
    Trw "..."

# game/scripts/day17.rpy:1781
translate spanish d17a236_f8044826:

    # Trw "Aghh...!"
    Trw "¡Aghh...!"

# game/scripts/day17.rpy:1784
translate spanish d17a236_63cca1b3:

    # Trw "Kgh-"
    Trw "Kgh-"

# game/scripts/day17.rpy:1787
translate spanish d17a236_c092ac32:

    # Trw "{i}*muffled moaning*{/i}"
    Trw "{i}gemidos apagados{/i}"

# game/scripts/day17.rpy:1790
translate spanish d17a236_ae5f1cac:

    # Trw "{i}*cough*{/i}"
    Trw "{i}*tos*{/i}"

# game/scripts/day17.rpy:1793
translate spanish d17a236_6a66bd28:

    # Kr "..."
    Kr "..."

# game/scripts/day17.rpy:1797
translate spanish d17a236_89c65fcb:

    # Faw "Krait... did something happen?"
    Faw "Krait... ¿pasó algo?"

# game/scripts/day17.rpy:1800
translate spanish d17a236_3839c6e3:

    # Trw "Ngh-..."
    Trw "Ngh-..."

# game/scripts/day17.rpy:1801
translate spanish d17a236_33010f22:

    # Krw "Rest now... you are dying..."
    Krw "Descansa ahora... te estás muriendo..."

# game/scripts/day17.rpy:1804
translate spanish d17a236_6bc4a52d:

    # Trw "{i}*muffled coughing*{/i}"
    Trw "{i}*tos amortiguada*{/i}"

# game/scripts/day17.rpy:1805
translate spanish d17a236_7b85f010:

    # Krw "Dying only once... but for such... a long... time."
    Krw "Morir solo una vez... pero durante tanto... tiempo."

# game/scripts/day17.rpy:1808
translate spanish d17a236_a5a4da14:

    # Trw "Mgh..."
    Trw "Mgh..."

# game/scripts/day17.rpy:1811
translate spanish d17a236_83dcd7b7:

    # Kr "Mh..."
    Kr "Mh..."

# game/scripts/day17.rpy:1812
translate spanish d17a236_50cdd14f:

    # Trw "...ngh..."
    Trw "... ngh..."

# game/scripts/day17.rpy:1815
translate spanish d17a236_6a66bd28_1:

    # Kr "..."
    Kr "..."

# game/scripts/day17.rpy:1819
translate spanish d17a236_6ee7abd1:

    # Tre "You have mentioned this day since I chose you. And yet, you are still here."
    Tre "Has mencionado este día desde que te elegí. Y aun así, aquí estás."

# game/scripts/day17.rpy:1820
translate spanish d17a236_7c4b36f9:

    # Tre "Forfeit your belief in this... unholy religion. Don't make me send my son."
    Tre "Renuncia a tu creencia en esta... religión impía. No me hagas enviar a mi hijo."

# game/scripts/day17.rpy:1823
translate spanish d17a236_99c1ddf2:

    # Di "It is no religion... I'm sure that... tonight is the night."
    Di "No es una religión... Estoy segura de que... esta noche es la noche."

# game/scripts/day17.rpy:1826
translate spanish d17a236_b33212ae:

    # Di "I wish things were different... but they are not."
    Di "Desearía que las cosas fueran diferentes... pero no lo son."

# game/scripts/day17.rpy:1829
translate spanish d17a236_218ab0e8:

    # Di "My... poor... poor child..."
    Di "Mi... pobre... pobre niña..."

# game/scripts/day17.rpy:1832
translate spanish d17a236_196879d4:

    # Tre "Son... she has gone mad. Take her in."
    Tre "Hijo... se ha vuelto loca. Llévala contigo."

# game/scripts/day17.rpy:1838
translate spanish d17a236_1b3915db:

    # Tr "..."
    Tr "..."

# game/scripts/day17.rpy:1841
translate spanish d17a236_762bfb1e:

    # Tr "Father has spoken. You come now. Don't make me hurt a mother."
    Tr "Padre ha hablado. Vienes ahora. No me hagas lastimar a una madre."

# game/scripts/day17.rpy:1844
translate spanish d17a236_8e0f35a1:

    # Tre "Daughter... guide me inside. I want to bed you tonight."
    Tre "Hija... guíame dentro. Quiero acostarme contigo esta noche."

# game/scripts/day17.rpy:1847
translate spanish d17a236_f669dbf2:

    # Tr "Woman. Now."
    Tr "Mujer. Ahora."

# game/scripts/day17.rpy:1850
translate spanish d17a236_40cfa6eb:

    # Di "Please... it doesn't have to be like this..."
    Di "Por favor... no tiene que ser así..."

# game/scripts/day17.rpy:1854
translate spanish d17a236_87114b6b:

    # Di "All I want is..."
    Di "Todo lo que quiero es..."

# game/scripts/day17.rpy:1855
translate spanish d17a236_1b3915db_1:

    # Tr "..."
    Tr "..."

# game/scripts/day17.rpy:1859
translate spanish d17a236_239ab9c0:

    # Tr "F-father... You need to... look!"
    Tr "P-padre... Tienes que... ¡mira!"

# game/scripts/day17.rpy:1863
translate spanish d17a236_cf0c1acd:

    # Di "Wh... what?"
    Di "¿Q... qué?"

# game/scripts/day17.rpy:1866
translate spanish d17a236_200f4042:

    # Di "No..."
    Di "No..."

# game/scripts/day17.rpy:1867
translate spanish d17a236_5c564dd5:

    # C2 "Dinara!!"
    C2 "¡¡Dinara!!"

# game/scripts/day17.rpy:1870
translate spanish d17a236_4063523a:

    # Di "..."
    Di "..."

# game/scripts/day17.rpy:1873
translate spanish d17a236_e9d5ace9:

    # C2 "Dinara... Baqyt Sapa."
    C2 "Dinara... Baqyt Sapa."

# game/scripts/day17.rpy:1874
translate spanish d17a236_278f388a:

    # C2 "We love you, and always will."
    C2 "Te amamos, y siempre lo haremos."

# game/scripts/day17.rpy:1877
translate spanish d17a236_485230f0:

    # Di "Ngh... no..."
    Di "Ngh... no..."

# game/scripts/day17.rpy:1878
translate spanish d17a236_67a0d474:

    # Di "It's happening..."
    Di "Está sucediendo..."

# game/scripts/day17.rpy:1881
translate spanish d17a236_22f693bd:

    # Di "It's happening to me..."
    Di "Me está pasando..."

# game/scripts/day17.rpy:1884
translate spanish d17a236_f8ae075d:

    # Di "I was right..."
    Di "Yo tenía razón..."

# game/scripts/day17.rpy:1887
translate spanish d17a236_a9dc87d3:

    # Di "I was..."
    Di "Yo estaba..."

# game/scripts/day17.rpy:1890
translate spanish d17a236_68899999:

    # Di "...right."
    Di "... bien."

# game/scripts/day17.rpy:1893
translate spanish d17a236_bf64832d:

    # Di "...!"
    Di "¡...!"

# game/scripts/day17.rpy:1902
translate spanish d17a236_4063523a_1:

    # Di "..."
    Di "..."

# game/scripts/day17.rpy:1903
translate spanish d17a236_3146240b:

    # Kr "By the scorched sands..."
    Kr "Por las arenas chamuscadas..."

# game/scripts/day17.rpy:1904
translate spanish d17a236_6bc4a52d_1:

    # Trw "{i}*muffled coughing*{/i}"
    Trw "{i}*tos amortiguada*{/i}"

# game/scripts/day17.rpy:1905
translate spanish d17a236_59a6b90d:

    # Faw "Wh... what just happened?"
