# game/scripts/day20.rpy:2765
translate spanish d20a_shani_released_0bfe4577:

    # Ban2 "This way!"
    Ban2 "¡Por aquí!"

# game/scripts/day20.rpy:2766
translate spanish d20a_shani_released_8b5bb967:

    # Ban3 "Which exit?!"
    Ban3 "¡¿Por qué salida?!"

# game/scripts/day20.rpy:2769
translate spanish d20a_shani_released_179d5db7:

    # S "Oh no..."
    S "Oh, no..."

# game/scripts/day20.rpy:2775
translate spanish d20a_shani_released_3713c802:

    # Ban "They're here!"
    Ban "¡Están aquí!"

# game/scripts/day20.rpy:2778
translate spanish d20a_shani_released_7c368494:

    # Ban "GET THEM, BOYS!"
    Ban "¡¡COGEDLOS, CHICOS!!"

# game/scripts/day20.rpy:2787
translate spanish d20a_shani_released_731e804c:

    # Z "{i}*grunt*{/i}"
    Z "{i}*gruñido*{/i}"

# game/scripts/day20.rpy:2788
translate spanish d20a_shani_released_031c927c:

    # Ban "AAAAAGGGHHH-"
    Ban "¡¡AAAAAGGGHHH-!!"

# game/scripts/day20.rpy:2789
translate spanish d20a_shani_released_92ff627b:

    # Ban2 "OPEN THE DOOR!"
    Ban2 "¡¡ABRID LA PUERTA!!"

# game/scripts/day20.rpy:2792
translate spanish d20a_shani_released_9737d14e:

    # Z "[S]! The door is blocked. I can't hold them out forever! Find us another way out!"
    Z "¡[S]! La puerta está bloqueada. ¡No puedo mantenerlos alejados para siempre! ¡Encuéntranos otra salida!"

# game/scripts/day20.rpy:2794
translate spanish d20a_shani_released_ae1f4450:

    # Z "NOW!"
    Z "¡¡AHORA!!"

# game/scripts/day20.rpy:2797
translate spanish d20a_shani_released_16c5790b:

    # St "Shit... What do I do?!"
    St "Mierda... ¡¿Qué hago?!"

# game/scripts/day20.rpy:2803
translate spanish d20a381_menu_02229d5f:

    # St "W-windows... what about them?!"
    St "V-ventanas... ¡¿qué pasa con ellas?!"

# game/scripts/day20.rpy:2806
translate spanish d20a381_menu_9d9e1f2e:

    # St "Chain-link fences... and those planks... not enough time."
    St "Vallas metálicas... y esos tablones... no hay tiempo suficiente."

# game/scripts/day20.rpy:2807
translate spanish d20a381_menu_92503abd:

    # S "The... the windows are barred!"
    S "¡Las... las ventanas tienen rejas!"

# game/scripts/day20.rpy:2817
translate spanish d20a381_menu_45977097:

    # St "We are so close, yet [persistent.dad] didn't manage to open them..."
    St "Estamos tan cerca, y aun así [persistent.dad] no consiguió abrirlas..."

# game/scripts/day20.rpy:2818
translate spanish d20a381_menu_2a74ce5d:

    # St "...and I don't see any other exits either!"
    St "¡...y yo tampoco veo ninguna otra salida!"

# game/scripts/day20.rpy:2819
translate spanish d20a381_menu_97f62986:

    # S "M-maybe I'll try pushing the door again?!"
    S "¡¿Y-y si intento empujar la puerta otra vez?!"

# game/scripts/day20.rpy:2820
translate spanish d20a381_menu_33cedd2b:

    # Z "There is no time... ngh... for that, I already tried!!"
    Z "¡¡No hay tiempo... ngh... para eso, ya lo he intentado!!"

# game/scripts/day20.rpy:2828
translate spanish d20a381_menu_51c2d723:

    # St "Maybe... it's the only way out...!"
    St "Quizás... ¡sea la única salida...!"

# game/scripts/day20.rpy:2831
translate spanish d20a381_menu_794d4ebf:

    # S "[persistent.dad!c], let's fight our way out!"
    S "¡[persistent.dad!c], abrámonos paso luchando!"

# game/scripts/day20.rpy:2834
translate spanish d20a381_menu_1545a907:

    # Z "Only one weapon between us. They're too many."
    Z "Solo tenemos un arma entre los dos. Son demasiados."

# game/scripts/day20.rpy:2837
translate spanish d20a381_menu_5dae60fd:

    # Ban "Hhhrggh... PUSH HARDER BOYS!!"
    Ban "¡¡Hhhrggh... EMPUJAD CON MÁS FUERZA, CHICOS!!"

# game/scripts/day20.rpy:2838
translate spanish d20a381_menu_f074aae0:

    # Z "Look again, before we risk the fight!!"
    Z "¡¡Mira otra vez, antes de arriesgarnos a pelear!!"

# game/scripts/day20.rpy:2854
translate spanish d20a_first_push_4ce900b3:

    # Z "Come on, [S]!"
    Z "¡Vamos, [S]!"

# game/scripts/day20.rpy:2857
translate spanish d20a_first_push_031e0ac9:

    # Z "Ngh... there needs to be some way out!!"
    Z "¡¡Ngh... tiene que haber alguna salida!!"

# game/scripts/day20.rpy:2858
translate spanish d20a_first_push_1cabbbc1:

    # Z "We can't take them on!!"
    Z "¡¡No podemos con ellos!!"

# game/scripts/day20.rpy:2866
translate spanish d20a_second_push_5fd658a5:

    # S "I... I don't know what to do, [persistent.dad]..."
    S "Yo... no sé qué hacer, [persistent.dad]..."

# game/scripts/day20.rpy:2870
translate spanish d20a_second_push_50adc86c:

    # Ban2 "PUUUUUUUSH..."
    Ban2 "¡¡EMPUUUUUJAD...!!"

# game/scripts/day20.rpy:2871
translate spanish d20a_second_push_f0ef4426:

    # Ban "YOU'RE GONNA DIEEEEEE!! HAHAHAAA!"
    Ban "¡¡VAAAAAIS A MORIIIIIR!! ¡¡JAJAJAAA!!"

# game/scripts/day20.rpy:2872
translate spanish d20a_second_push_b2005094:

    # St "They're about to break in... is this it?!"
    St "Están a punto de entrar... ¿se acabó?!"

# game/scripts/day20.rpy:2873
translate spanish d20a_second_push_790e4fc6:

    # Z "Ngghhh... I can't hold much longer..."
    Z "Ngghhh... No puedo aguantar mucho más..."

# game/scripts/day20.rpy:2876
translate spanish d20a_second_push_d4dcaa86:

    # C "Ngh..."
    C "Ngh..."

# game/scripts/day20.rpy:2877
translate spanish d20a_second_push_2a2827df:

    # St "Someone's at the door?!"
    St "¡¿Hay alguien en la puerta?!"

# game/scripts/day20.rpy:2880
translate spanish d20a_second_push_bd18d843:

    # S "H-hey, [persistent.dad]... I think they're coming from the other door."
    S "O-oye, [persistent.dad]... Creo que vienen por la otra puerta."

# game/scripts/day20.rpy:2881
translate spanish d20a_second_push_fc74aa50:

    # Z "What?! Ngh..."
    Z "¡¿Qué?! Ngh..."

# game/scripts/day20.rpy:2882
translate spanish d20a_second_push_54968693:

    # Z "Damn it! Then we should open this door first. The tunnel is easier to defend, maybe we can fight through there."
    Z "¡Joder! Entonces deberíamos abrir esta puerta primero. El túnel es más fácil de defender, quizás podamos abrirnos paso luchando por ahí."

# game/scripts/day20.rpy:2885
translate spanish d20a_second_push_e3db39fb:

    # S "Maybe..."
    S "Quizás..."

# game/scripts/day20.rpy:2886
translate spanish d20a_second_push_04de6293:

    # S "...maybe that's not necessary..."
    S "... quizás no sea necesario..."

# game/scripts/day20.rpy:2891
translate spanish d20a_second_push_964980e4:

    # S "Neith?! I thought... you abandoned us!"
    S "¡¿Neith?! ¡Pensaba... que nos habías abandonado!"

# game/scripts/day20.rpy:2894
translate spanish d20a_second_push_8ba76fd9:

    # Ne "I'm the Queen of Zeta. I would never abandon my people..."
    Ne "Soy la Reina de Zeta. Nunca abandonaría a mi gente..."

# game/scripts/day20.rpy:2897
translate spanish d20a_second_push_5ed8e87a:

    # Ne "...unless they deserve it."
    Ne "... a menos que se lo merezcan."

# game/scripts/day20.rpy:2902
translate spanish d20a_second_push_e8fc5518:

    # Ne "[persistent.player_name!u]! LET THEM COME!"
    Ne "¡[persistent.player_name!u]! ¡DEJA QUE ENTREN!"

# game/scripts/day20.rpy:2905
translate spanish d20a_second_push_d1806ce6:

    # Z "What... is..."
    Z "Qué... está..."

# game/scripts/day20.rpy:2910
translate spanish d20a_second_push_4968934b:

    # Z "Ngh... They will..."
    Z "Ngh... Ellos van a..."

# game/scripts/day20.rpy:2913
translate spanish d20a_second_push_4fff3fc2:

    # Ne "I SAID LET THEM COME! OPEN THE GATE!"
    Ne "¡HE DICHO QUE DEJES QUE ENTREN! ¡ABRE LA PUERTA!"

# game/scripts/day20.rpy:2917
translate spanish d20a_second_push_63e42dc8:

    # Ne "NOW, STALKER!"
    Ne "¡AHORA, ACECHADOR!"

# game/scripts/day20.rpy:2922
translate spanish d20a_second_push_bc7cd5a6:

    # Ban2 "...!{w=1}{nw}"
    Ban2 "¡...!{w=1}{nw}"

# game/scripts/day20.rpy:2924
translate spanish d20a_second_push_b1baea40:

    # Ban "AAAAAAAAAAAAAAAAGGGGGHHHHHHHHHH!!!!{w=3}{nw}"
    Ban "¡¡¡AAAAAAAAAAAAAAAAGGGGGHHHHHHHHHH!!!!{w=3}{nw}"

# game/scripts/day20.rpy:2925
translate spanish d20a_second_push_00694ff5:

    # Ban2 "{i}*painful screeching*{/i}{w=3}{nw}"
    Ban2 "{i}*chillido de dolor*{/i}{w=3}{nw}"

# game/scripts/day20.rpy:2927
translate spanish d20a_second_push_89f09223:

    # Q "KNEEL BEFORE YOUR QUEEN, HERETICS!!!{w=3.5}{nw}"
    Q "¡¡¡ARRODILLAOS ANTE VUESTRA REINA, HEREJES!!!{w=3.5}{nw}"

# game/scripts/day20.rpy:2928
translate spanish d20a_second_push_ae8e8f92:

    # Q "RESPECT MY AUTHORIAAH!!!{w=3.5}{nw}"
    Q "¡¡¡RESPETAD MI AUTORIDAAAAD!!!{w=3.5}{nw}"

# game/scripts/day20.rpy:2930
translate spanish d20a_second_push_e911e93f:

    # S "NEITH! WE NEED TO LEAVE!!{w=3}{nw}"
    S "¡¡NEITH! ¡¡TENEMOS QUE IRNOS!!{w=3}{nw}"

# game/scripts/day20.rpy:2942
translate spanish d20b_ba39306b:

    # Ne "I'm almost done..."
    Ne "Ya casi he terminado..."

# game/scripts/day20.rpy:2946
translate spanish d20b_480cd3a7:

    # Ne "There is still enough water left."
    Ne "Todavía queda suficiente agua."

# game/scripts/day20.rpy:2948
translate spanish d20b_8d6479a4:

    # Ne "There..."
    Ne "Ahí..."

# game/scripts/day20.rpy:2951
translate spanish d20b_d2ae7066:

    # Ne "...that should at least prevent an infection."
    Ne "... eso debería al menos evitar una infección."

# game/scripts/day20.rpy:2954
translate spanish d20b_cc42a49b:

    # Ne "They really worked you over. Are you in a lot of pain?"
    Ne "De verdad que te dieron una paliza. ¿Te duele mucho?"

# game/scripts/day20.rpy:2957
translate spanish d20b_0e701cdf:

    # Z "It could've been worse. But I'm good now, thank you."
    Z "Podría haber sido peor. Pero ya estoy bien, gracias."

# game/scripts/day20.rpy:2958
translate spanish d20b_d91a9150:

    # Z "Say... How did you know about the exit, and where they took [S] anyway?"
    Z "Oye... ¿Cómo sabías lo de la salida y adónde se llevaron a [S]?"

# game/scripts/day20.rpy:2961
translate spanish d20b_17877cb3:

    # Ne "Oh, back there?"
    Ne "¿Ah, eso?"

# game/scripts/day20.rpy:2964
translate spanish d20b_34fadf70:

    # Ne "It wasn't that difficult."
    Ne "No fue tan difícil."

# game/scripts/day20.rpy:2965
translate spanish d20b_6abef0a7:

    # Ne "They beat you two unconscious, but not me. I looked out a window as they moved us around."
    Ne "Os dejaron inconscientes a vosotros dos, pero a mí no. Miré por una ventana cuando nos trasladaban."

# game/scripts/day20.rpy:2966
translate spanish d20b_ae38febd:

    # Ne "I'm used to navigating around endless palace corridors. You learn to understand the layout of places like this."
    Ne "Estoy acostumbrada a orientarme por pasillos interminables de palacios. Aprendes a entender la disposición de sitios como este."

# game/scripts/day20.rpy:2970
translate spanish d20b_00c69d36:

    # "You look at her for a moment..."
    "La miras durante un momento..."

# game/scripts/day20.rpy:2974
translate spanish d20b_e8aef5cd:

    # Z "I didn't think I'd ever see this side of you."
    Z "No pensé que llegaría a ver este lado tuyo."

# game/scripts/day20.rpy:2977
translate spanish d20b_81b6cf56:

    # Ne "I... didn't know I had it in me either..."
    Ne "Yo... tampoco sabía que lo tenía dentro..."

# game/scripts/day20.rpy:2983
translate spanish d20b_105e4c2d:

    # Ne "Oh, that reminds me. I almost forgot something..."
    Ne "Oh, eso me recuerda. Casi se me olvida algo..."

# game/scripts/day20.rpy:2986
translate spanish d20b_771d48a4:

    # Z "What is it?"
    Z "¿El qué?"

# game/scripts/day20.rpy:2991
translate spanish d20b_b4a1c64b:

    # Ne "A small reward, for saving your Queen."
    Ne "Una pequeña recompensa, por salvar a vuestra Reina."

# game/scripts/day20.rpy:2994
translate spanish d20b_492e0491:

    # Z "Just one?"
    Z "¿Solo una?"

# game/scripts/day20.rpy:2997
translate spanish d20b_abe4230e:

    # Ne "For now..."
    Ne "Por ahora..."

# game/scripts/day20.rpy:3001
translate spanish d20b_6484af8e:

    # S "Guys..."
    S "Chicos..."

# game/scripts/day20.rpy:3004
translate spanish d20b_356d940f:

    # S "...I found something!"
    S "¡... he encontrado algo!"

# game/scripts/day20.rpy:3007
translate spanish d20b_21092a95:

    # S "It took me a while, but it turns out our Elder wasn't kidding about his hideout."
    S "Me llevó un rato, pero resulta que nuestro Anciano no bromeaba sobre su escondite."

# game/scripts/day20.rpy:3008
translate spanish d20b_357f9778:

    # S "I can understand why it's easy to overlook though. It's a bit of a maze."
    S "Aunque puedo entender por qué es fácil pasarlo por alto. Es un poco un laberinto."

# game/scripts/day20.rpy:3011
translate spanish d20b_8003050f:

    # Z "Look at you, perhaps I'll just send you out on your own next time."
    Z "Mírate, quizás la próxima vez te envíe a ti sola."

# game/scripts/day20.rpy:3014
translate spanish d20b_3ad239e8:

    # S "Say... are you really okay? Those marks above your eye..."
    S "Oye... ¿de verdad estás bien? Esas marcas sobre tu ojo..."

# game/scripts/day20.rpy:3017
translate spanish d20b_81e9eb7d:

    # Z "Don't worry about it. [Ne] patched me up just fine."
    Z "No te preocupes. [Ne] me ha curado bien."

# game/scripts/day20.rpy:3020
translate spanish d20b_c19ac202:

    # "She smiles..."
    "Sonríe..."

# game/scripts/day20.rpy:3023
translate spanish d20b_b6d4a7cd:

    # S "Are you ready to learn more about your ancestors, my Queen?"
    S "¿Estás lista para aprender más sobre tus ancestros, mi Reina?"

# game/scripts/day20.rpy:3024
translate spanish d20b_f05727b6:

    # S "I'm afraid you won't get to see mummies today, though. This place looks older than them."
    S "Me temo que hoy no vas a poder ver momias, eso sí. Este sitio parece más antiguo que ellas."

# game/scripts/day20.rpy:3027
translate spanish d20b_06807f10:

    # Ne "That's... fine by me. I don't need any more scares."
    Ne "Eso... por mí bien. No necesito más sustos."

# game/scripts/day20.rpy:3030
translate spanish d20b_eab79661:

    # Ne "As for what we find inside... I think I'm just about done following clues. I could use some answers."
    Ne "En cuanto a lo que encontremos dentro... creo que ya estoy harta de seguir pistas. Me vendrían bien algunas respuestas."

# game/scripts/day20.rpy:3033
translate spanish d20b_ded05f6c:

    # Z "Then let's waste no more time. After you, girls."
    Z "Entonces no perdamos más tiempo. Después de vosotras, chicas."

# game/scripts/day20.rpy:3038
translate spanish d20b_9669528e:

    # "Later..."
    "Más tarde..."

# game/scripts/day20.rpy:3043
translate spanish d20b_05957039:

    # S "Here we are. The Elder's hideout."
    S "Ya estamos. El escondite del Anciano."

# game/scripts/day20.rpy:3046
translate spanish d20b_82a3e939:

    # Ne "I... I take it back. I wasn't ready..."
    Ne "Yo... me retracto. No estaba preparada..."

# game/scripts/day20.rpy:3049
translate spanish d20b_93b51dbf:

    # S "This place... feels different..."
    S "Este sitio... se siente diferente..."

# game/scripts/day20.rpy:3052
translate spanish d20b_d0001052:

    # S "The air is cold and heavy..."
    S "El aire es frío y pesado..."

# game/scripts/day20.rpy:3053
translate spanish d20b_c64957fe:

    # S "....and the smell... earthy."
    S "... y el olor... a tierra."

# game/scripts/day20.rpy:3056
translate spanish d20b_152f3369:

    # S "This must be the Elder's writings..."
    S "Estas deben ser las escrituras del Anciano..."

# game/scripts/day20.rpy:3059
translate spanish d20b_7605fb98:

    # Ne "Do... do you guys also feel this slight pressure in your ears?"
    Ne "¿Vosotros... vosotros también notáis esta ligera presión en los oídos?"

# game/scripts/day20.rpy:3062
translate spanish d20b_b625cf24:

    # "The halls are grand, and ancient."
    "Los pasillos son grandiosos y ancestrales."

# game/scripts/day20.rpy:3063
translate spanish d20b_13f914bf:

    # "As you pass the threshold, you note the similarities with other tombs you have explored."
    "Al cruzar el umbral, notas las similitudes con otras tumbas que has explorado."

# game/scripts/day20.rpy:3066
translate spanish d20b_f7af7eb7:

    # "As [Ne] noticed, there's a marked change of pressure in the room, as if opening the entrance unsealed it for the first time in ages, like uncorking an old bottle."
    "Como [Ne] notó, hay un cambio notable de presión en la habitación, como si al abrir la entrada se hubiera destapado por primera vez en mucho tiempo, como al descorchar una botella vieja."

# game/scripts/day20.rpy:3067
translate spanish d20b_57b9fec0:

    # Z "He must have lived here periodically... to write his memoirs."
    Z "Debió de vivir aquí periódicamente... para escribir sus memorias."

# game/scripts/day20.rpy:3070
translate spanish d20b_7bef33b8:

    # S "I... I think I found our Elder."
    S "Yo... yo creo que he encontrado a nuestro Anciano."

# game/scripts/day20.rpy:3071
translate spanish d20b_ed71a4e3:

    # Z "He did imply that his secrets would die with him..."
    Z "Él sí dio a entender que sus secretos morirían con él..."

# game/scripts/day20.rpy:3074
translate spanish d20b_f7aa6359:

    # Ne "And... whoever this is."
    Ne "Y... quienquiera que sea este."

# game/scripts/day20.rpy:3075
translate spanish d20b_bf0b3ada:

    # S "I wonder what he or she thought in their last moments?"
    S "Me pregunto qué pensaría él o ella en sus últimos momentos."

# game/scripts/day20.rpy:3078
translate spanish d20b_5f831d3c:

    # Z "Be careful what you touch. Time has a way of catching up on things, once you expose them to fresh air."
    Z "Cuidado con lo que toquéis. El tiempo tiene una forma de alcanzar las cosas una vez que las expones al aire fresco."

# game/scripts/day20.rpy:3081
translate spanish d20b_3b77f946:

    # S "But... why did he leave those pages open? Wouldn't they decay faster?"
    S "Pero... ¿por qué dejó esas páginas abiertas? ¿No se deteriorarían más rápido?"

# game/scripts/day20.rpy:3084
translate spanish d20b_4b082999:

    # "You bow over the open book, placed on a single stone in the center of the hall..."
    "Te inclinas sobre el libro abierto, colocado en una simple piedra en el centro de la sala..."

# game/scripts/day20.rpy:3087
translate spanish d20b_a9327aff:

    # Ne "[S]... look at what I found..."
    Ne "[S]... mira lo que he encontrado..."

# game/scripts/day20.rpy:3090
translate spanish d20b_5cfa2609:

    # S "Wait, I'm coming..."
    S "Espera, ahora voy..."

# game/scripts/day20.rpy:3093
translate spanish d20b_d944b34e:

    # Ne "These are... flowers..."
    Ne "Estas son... flores..."

# game/scripts/day20.rpy:3094
translate spanish d20b_561e8e81:

    # Ne "But they don't smell... Is this some kind of anomaly? I have never seen one before..."
    Ne "Pero no huelen... ¿Es algún tipo de anomalía? Nunca había visto una antes..."

# game/scripts/day20.rpy:3097
translate spanish d20b_b69b2743:

    # S "No anomaly here. They're made of plastic. Entirely artificial."
    S "Aquí no hay anomalía. Están hechas de plástico. Totalmente artificiales."

# game/scripts/day20.rpy:3100
translate spanish d20b_87feaaf6:

    # Ne "{i}Plastic{/i}... it looks so vibrant..."
    Ne "{i}Plástico{/i}... tiene un aspecto tan vibrante..."

# game/scripts/day20.rpy:3102
translate spanish d20b_44c34741:

    # Z "[S], you asked why this book is lying out in the open?"
    Z "[S], ¿preguntaste por qué este libro está expuesto al aire?"

# game/scripts/day20.rpy:3105
translate spanish d20b_be6f2c57:

    # S "Yes, did you find something?"
    S "Sí, ¿encontraste algo?"

# game/scripts/day20.rpy:3106
translate spanish d20b_e78e5f0c:

    # Z "...it's because he wanted us to read this."
    Z "... es porque quería que leyéramos esto."

# game/scripts/day20.rpy:3107
translate spanish d20b_e6a4b6ad:

    # Ne "R-really? Can you read what it says?"
    Ne "¿E-en serio? ¿Puedes leer lo que dice?"

# game/scripts/day20.rpy:3110
translate spanish d20b_02449da9:

    # "You try to make out the faded words."
    "Intentas descifrar las palabras descoloridas."

# game/scripts/day20.rpy:3112
translate spanish d20b_f2da6e31:

    # EPN "Dear stranger, you found my hideout, and with it, my final rest."
    EPN "Querido desconocido, has encontrado mi escondite, y con él, mi descanso final."

# game/scripts/day20.rpy:3113
translate spanish d20b_0b6cfb99:

    # EPN "I took many precautions to ensure the secrecy of this place, so I assume that some time must have gone by since my own passing."
    EPN "Tomé muchas precauciones para garantizar el secreto de este lugar, así que supongo que debe haber pasado cierto tiempo desde mi fallecimiento."

# game/scripts/day20.rpy:3114
translate spanish d20b_b5e09dff:

    # EPN "I expect my body will long have lost its integrity, and so that of my loyal assistant."
    EPN "Supongo que mi cuerpo habrá perdido hace tiempo su integridad, y también el de mi leal asistente."

# game/scripts/day20.rpy:3115
translate spanish d20b_b66a710e:

    # EPN "Do not think me foolish or reckless. I chose to die in this place to preserve memories of the past - truths of the past. Truths that must not die with me."
    EPN "No me creas tonto ni imprudente. Elegí morir en este lugar para preservar los recuerdos del pasado, verdades del pasado. Verdades que no deben morir conmigo."

# game/scripts/day20.rpy:3116
translate spanish d20b_1917dc8f:

    # EPN "If you are reading this, I can only hope that the time is right for these truths to be remembered, rekindled, and that you did not find them by accident."
    EPN "Si estás leyendo esto, solo puedo esperar que sea el momento adecuado para que estas verdades sean recordadas, reavivadas, y que no las hayas encontrado por accidente."

# game/scripts/day20.rpy:3117
translate spanish d20b_eb28cdaa:

    # EPN "I pray that you got here by following the echoes of the past that I and others left behind... Perhaps it was my letter, or other ways that I cannot foresee."
    EPN "Ruego que hayas llegado aquí siguiendo los ecos del pasado que yo y otros dejamos atrás... Quizás fue mi carta, u otros medios que no puedo prever."

# game/scripts/day20.rpy:3118
translate spanish d20b_44467174:

    # EPN "... and that you followed, researched and explored like we once did, us students of the ancient worlds."
    EPN "... y que hayas seguido, investigado y explorado como lo hicimos nosotros una vez, nosotros, los estudiantes de los mundos antiguos."

# game/scripts/day20.rpy:3120
translate spanish d20b_7200b780:

    # EPN "If that is the case, I salute and congratulate you. What knowledge I have to share is yours now, so let me educate you about the ending of a world and the birth of a new one."
    EPN "Si ese es el caso, te saludo y te felicito. El conocimiento que tengo para compartir es tuyo ahora, así que permíteme instruirte sobre el fin de un mundo y el nacimiento de uno nuevo."

# game/scripts/day20.rpy:3121
translate spanish d20b_cf8c107a:

    # EPN "A new world which decided to forget, dissimulate the reason it came to exist. Let me take you from my time as an archaeologist, to my role as a ruler under the divinely chosen Queen of the city."
    EPN "Un nuevo mundo que decidió olvidar, disimular la razón por la que llegó a existir. Permíteme llevarte desde mi época como arqueólogo, hasta mi papel como gobernante bajo la Reina elegida por la divinidad de la ciudad."

# game/scripts/day20.rpy:3123
translate spanish d20b_c039ec3f:

    # EPN "...but not all the echoes and memories inside my halls are for you to read."
    EPN "... pero no todos los ecos y recuerdos dentro de mis salas son para que los leas."

# game/scripts/day20.rpy:3124
translate spanish d20b_00f6666c:

    # EPN "When I started my journals, I wrote down in great detail about the many dark steps that led the world to its implosion."
    EPN "Cuando empecé mis diarios, escribí con gran detalle los muchos pasos oscuros que llevaron al mundo a su implosión."

# game/scripts/day20.rpy:3125
translate spanish d20b_8966aaa8:

    # EPN "I feel that those notions are not going to be of much use to you. The wisdom of my waning days tells me I should keep what I have to say simple and direct."
    EPN "Siento que esas nociones no van a serte de mucha utilidad. La sabiduría de mis días menguantes me dice que debo mantener lo que tengo que decir simple y directo."

# game/scripts/day20.rpy:3126
translate spanish d20b_7ed64050:

    # EPN "It is best to lay bare the truth of our mistakes than to lay bare the path that might push you into repeating them."
    EPN "Es mejor exponer la verdad de nuestros errores que exponer el camino que podría empujaros a repetirlos."

# game/scripts/day20.rpy:3127
translate spanish d20b_88ed9e0a:

    # EPN "Even so, I cannot bring myself to destroy my own writings, so I will let time do it in my stead."
    EPN "Aun así, no puedo obligarme a destruir mis propios escritos, así que dejaré que el tiempo lo haga en mi lugar."

# game/scripts/day20.rpy:3128
translate spanish d20b_244e9b97:

    # EPN "What I will endeavour to protect are the things I do care for you to read.."
    EPN "Lo que me esforzaré por proteger son las cosas que sí me importa que leas..."

# game/scripts/day20.rpy:3129
translate spanish d20b_a1bd1eb9:

    # EPN "I will assume that if you are here, you have found my letter, and thus Zeta, the city of gods, has endured."
    EPN "Daré por sentado que si estás aquí, has encontrado mi carta, y por tanto Zeta, la ciudad de los dioses, ha perdurado."

# game/scripts/day20.rpy:3130
translate spanish d20b_6c6f26c1:

    # EPN "Don't be surprised to find my pupil's body in this place. He understands the need for secrecy. His devotion is, was, greater than I have words to convey."
    EPN "No te sorprendas de encontrar el cuerpo de mi discípulo en este lugar. Él entiende la necesidad de secreto. Su devoción es, fue, mayor de lo que tengo palabras para expresar."

# game/scripts/day20.rpy:3131
translate spanish d20b_102f30e7:

    # EPN "My name is Elder Paris. This is my word."
    EPN "Mi nombre es Anciano París. Esta es mi palabra."

# game/scripts/day20.rpy:3134
translate spanish d20b_be078e45:

    # "The fabric of the book starts crumbling as you try to turn a page..."
    "El material del libro empieza a desmoronarse cuando intentas pasar una página..."

# game/scripts/day20.rpy:3135
translate spanish d20b_fb161a1a:

    # Z "The Elder was right. This is all he wanted us to read."
    Z "El Anciano tenía razón. Esto es todo lo que quería que leyéramos."

# game/scripts/day20.rpy:3138
translate spanish d20b_c7cd0678:

    # Ne "Then these scrolls may not be any different. Do you think it's worth an attempt?"
    Ne "Entonces estos pergaminos pueden no ser diferentes. ¿Crees que vale la pena intentarlo?"

# game/scripts/day20.rpy:3141
translate spanish d20b_247972ac:

    # Z "We can try to get the fragile scrolls back home. Let's worry about it later."
    Z "Podemos intentar llevarnos los pergaminos frágiles a casa. Ya nos preocuparemos de eso más tarde."

# game/scripts/day20.rpy:3144
translate spanish d20b_7900f3e7:

    # Ne "Then perhaps some of these books still hold worth, or perhaps..."
    Ne "Entonces quizás algunos de estos libros aún tengan valor, o quizás..."

# game/scripts/day20.rpy:3147
translate spanish d20b_c328ec1b:

    # Ne "...a chest."
    Ne "... un cofre."

# game/scripts/day20.rpy:3150
translate spanish d20b_03b709de:

    # S "I will look around for more of them."
    S "Echaré un vistazo a ver si encuentro más."

# game/scripts/day20.rpy:3156
translate spanish d20b_4d9a574e:

    # Ne "This looks promising..."
    Ne "Esto parece prometedor..."

# game/scripts/day20.rpy:3159
translate spanish d20b_614a2a3c:

    # Ne "..."
    Ne "..."

# game/scripts/day20.rpy:3160
translate spanish d20b_29950838:

    # Z "What does it say?"
    Z "¿Qué dice?"

# game/scripts/day20.rpy:3163
translate spanish d20b_90e75ab1:

    # Ne "It's like a diary... of just an ordinary day, it seems, but it contains very specific descriptions."
    Ne "Es como un diario... de un día cualquiera, parece, pero contiene descripciones muy específicas."

# game/scripts/day20.rpy:3164
translate spanish d20b_31148842:

    # Ne "There... is no mention in this of an Elder, or any Queen. Maybe this is from before... everything?"
    Ne "En él... no se menciona a ningún Anciano ni a ninguna Reina. Quizás esto sea de antes... de todo."

# game/scripts/day20.rpy:3167
translate spanish d20b_a23c299b:

    # Z "Read it."
    Z "Léelo."

# game/scripts/day20.rpy:3171
translate spanish d20b_756a00b7:

    # Ne "Okay... I will take it from the start."
    Ne "Vale... lo empezaré desde el principio."

# game/scripts/day20.rpy:3183
translate spanish d20b_46620863:

    # EPN "\"Truth is the daughter of time, not of authority.\""
    EPN "\"La verdad es hija del tiempo, no de la autoridad.\""

# game/scripts/day20.rpy:3184
translate spanish d20b_f51f2c20:

    # EPN "...but what if those who are supposed to seek it are hired by the former?"
    EPN "... pero ¿y si los que se supone que deben buscarla están contratados por la primera?"

# game/scripts/day20.rpy:3187
translate spanish d20b_c1e01d1a:

    # EPN "The weeks are passing, as we reside in these long forgotten halls."
    EPN "Las semanas pasan, mientras residimos en estos pasillos largamente olvidados."

# game/scripts/day20.rpy:3190
translate spanish d20b_dc6155a4:

    # EPN "My name was Paris Sivara."
    EPN "Mi nombre es París Sivara."

# game/scripts/day20.rpy:3191
translate spanish d20b_c986e6c8:

    # EPN "Professor Azari and I were leading an international group of scientists and historians, tasked to excavate and analyse these ruins that have surfaced from the dunes of the Sahara."
    EPN "La profesora Azari y yo dirigíamos un grupo internacional de científicos e historiadores, encargados de excavar y analizar estas ruinas que han surgido de las dunas del Sáhara."

# game/scripts/day20.rpy:3192
translate spanish d20b_259bf218:

    # EPN "This had been our home for some weeks now, and our time in this place was slowly coming to an end."
    EPN "Este había sido nuestro hogar durante algunas semanas, y nuestro tiempo en este lugar llegaba lentamente a su fin."

# game/scripts/day20.rpy:3195
translate spanish d20b_743b4f22:

    # Val "Professor?"
    Val "¿Profesor?"

# game/scripts/day20.rpy:3199
translate spanish d20b_7a28f877:

    # PS "...yes. Are they here?"
    PS "... sí. ¿Ya están aquí?"

# game/scripts/day20.rpy:3202
translate spanish d20b_b89ffb7b:

    # Val "I'm afraid not. But Dr. Kaito wants to speak with you before the meeting."
    Val "Me temo que no. Pero el Dr. Kaito quiere hablar con usted antes de la reunión."

# game/scripts/day20.rpy:3205
translate spanish d20b_6b02a671:

    # PS "Mh... fine. What is it about?"
    PS "Mh... bien. ¿Sobre qué es?"

# game/scripts/day20.rpy:3208
translate spanish d20b_ba3eafa7:

    # Val "He is talking about sensational discoveries, at least those were his words."
    Val "Habla de descubrimientos sensacionales, al menos esas fueron sus palabras."

# game/scripts/day20.rpy:3211
translate spanish d20b_f3977b94:

    # Val "I think you should not let him wait, if you ask me. I believe he found the outline of what must once have been yet another building."
    Val "Creo que no debería hacerle esperar, si me pregunta. Creo que encontró el contorno de lo que una vez debió ser otro edificio."

# game/scripts/day20.rpy:3214
translate spanish d20b_5ec06d47:

    # EPN "Miss Vale was neither the most brilliant nor the most knowledgeable assistant I could have picked from the university staff."
    EPN "La señorita Vale no era ni la más brillante ni la más informada de las asistentes que podría haber elegido del personal de la universidad."

# game/scripts/day20.rpy:3215
translate spanish d20b_f2429f4f:

    # EPN "What she lacked in competence however she made up for in spades with enthusiasm, a certain libertine attitude towards coworkers, and diligence..."
    EPN "Sin embargo, lo que le faltaba en competencia lo compensaba con creces con entusiasmo, una cierta actitud libertina hacia los compañeros de trabajo y diligencia..."

# game/scripts/day20.rpy:3221
translate spanish d20b_b228d6eb:

    # PS "Dr. Kaito, you wanted to speak to me?"
    PS "Dr. Kaito, ¿quería hablar conmigo?"

# game/scripts/day20.rpy:3222
translate spanish d20b_55c6e559:

    # Kai "Yes, Professor. You see..."
    Kai "Sí, profesor. Verá..."

# game/scripts/day20.rpy:3225
translate spanish d20b_79dae4a3:

    # Kai "As far as the excavation site goes, we are breaking new ground."
    Kai "En lo que respecta al sitio de excavación, estamos abriendo nuevos caminos."

# game/scripts/day20.rpy:3226
translate spanish d20b_33d7fb2c:

    # Kai "To the side of dig site 1 and 4, I believe we may have hit upon another wall, this time of some sort of public structure."
    Kai "Al lado de los sitios de excavación 1 y 4, creo que podemos haber dado con otro muro, esta vez de algún tipo de estructura pública."

# game/scripts/day20.rpy:3227
translate spanish d20b_391988c2:

    # Kai "Before I announce it to the committee however, I could use a second opinion on my findings."
    Kai "Sin embargo, antes de anunciarlo al comité, me vendría bien una segunda opinión sobre mis hallazgos."

# game/scripts/day20.rpy:3228
translate spanish d20b_046eb564:

    # Kai "If I am right, we may have to extend our presence here for a few more weeks at least."
    Kai "Si tengo razón, es posible que tengamos que prolongar nuestra presencia aquí al menos unas semanas más."

# game/scripts/day20.rpy:3229
translate spanish d20b_8dad465b:

    # Kai "I know that our Lidar and GPR equipment have been already pulled from the site but if we can show there's still more to be found, maybe the funding can be stretched."
    Kai "Sé que nuestro equipo Lidar y GPR ya ha sido retirado del sitio, pero si podemos demostrar que todavía hay más por encontrar, quizás se pueda estirar la financiación."

# game/scripts/day20.rpy:3232
translate spanish d20b_e0214b8a:

    # PS "I appreciate your thoughts, Dr. Kaito. However, as you know, this is not just a finding expedition but also a teaching opportunity.."
    PS "Agradezco sus pensamientos, Dr. Kaito. Sin embargo, como sabe, esta no es solo una expedición de hallazgo, sino también una oportunidad de enseñanza..."

# game/scripts/day20.rpy:3233
translate spanish d20b_5254cd75:

    # PS "Professor Azari shares my thought, that the younger students should first learn the hard way, with a brush, a rake and a shovel, before they can play with the expensive toys."
    PS "La profesora Azari comparte mi pensamiento, que los estudiantes más jóvenes primero deben aprender por las malas, con un pincel, un rastrillo y una pala, antes de poder jugar con los juguetes caros."

# game/scripts/day20.rpy:3234
translate spanish d20b_529ae8c0:

    # PS "If you ask me, there is value in letting our younger members engage directly with the site. Touch some dirt, so to speak."
    PS "Si me pregunta, hay valor en dejar que nuestros miembros más jóvenes se involucren directamente con el sitio. Tocar un poco de tierra, por así decirlo."

# game/scripts/day20.rpy:3235
translate spanish d20b_14c214a9:

    # PS "Tactile experience teaches them to interpret subtle artifact clues, and the context that no algorithm can fully convey."
    PS "La experiencia táctil les enseña a interpretar pistas sutiles de artefactos y el contexto que ningún algoritmo puede transmitir por completo."

# game/scripts/day20.rpy:3236
translate spanish d20b_da9ca930:

    # PS "So, for now, mark down and contour where you think the new site should be. We can tackle it with the new season."
    PS "Así que, por ahora, marca y traza el contorno donde crees que debería estar el nuevo sitio. Podemos abordarlo con la nueva temporada."

# game/scripts/day20.rpy:3238
translate spanish d20b_4749c225:

    # Kai "Hm."
    Kai "Hm."

# game/scripts/day20.rpy:3242
translate spanish d20b_ac16056c:

    # Kai "I knew I liked your ways the day I submitted my name for the project, Professor. I will let them-"
    Kai "Supe que me gustaban sus formas el día que presenté mi nombre para el proyecto, profesor. Les diré que-"

# game/scripts/day20.rpy:3248
translate spanish d20b_4f32ef99:

    # Kai "..."
    Kai "..."

# game/scripts/day20.rpy:3249
translate spanish d20b_c8690a12:

    # PS "{i}*sigh*{/i}"
    PS "{i}*suspiro*{/i}"

# game/scripts/day20.rpy:3253
translate spanish d20b_0af31691:

    # Kai "With all due respect, what possessed you to bring your [persistent.da] here?"
    Kai "Con todos mis respetos, ¿qué le poseyó para traer a su [persistent.da] aquí?"

# game/scripts/day20.rpy:3255
translate spanish d20b_72cac550:

    # Kai "With all due respect, what possessed you to bring that young girl here?"
    Kai "Con todos mis respetos, ¿qué le poseyó para traer a esa joven aquí?"

# game/scripts/day20.rpy:3258
translate spanish d20b_0e6a29fa:

    # PS "Her mother, Doctor. Or rather, the absence of said mother. And she was done with her... studies."
    PS "Su madre, doctor. O más bien, la ausencia de dicha madre. Y ella había terminado con sus... estudios."

# game/scripts/day20.rpy:3259
translate spanish d20b_adfb9c15:

    # PS "I will return for the meeting."
    PS "Volveré para la reunión."

# game/scripts/day20.rpy:3262
translate spanish d20b_61843423:

    # EPN "Filling an empty hall with life feels good…. until you hear the echo."
    EPN "Llenar de vida un salón vacío se siente bien… hasta que escuchas el eco."

# game/scripts/day20.rpy:3265
translate spanish d20b_6196aa86:

    # EPN "Sometimes I wondered if that music of hers was call for attention, more than anything."
    EPN "A veces me preguntaba si esa música suya era más que nada una llamada de atención."

# game/scripts/day20.rpy:3268
translate spanish d20b_0c56f669:

    # EPN "Either way, she was a product of the city, and she carried its marks..."
    EPN "En cualquier caso, ella era un producto de la ciudad y llevaba sus marcas..."

# game/scripts/day20.rpy:3271
translate spanish d20b_2a5531e2:

    # EPN "...but what started out as a mistake for the sake of disciplinatory measures, ended up saving her life."
    EPN "... pero lo que comenzó como un error por medidas disciplinarias, terminó salvándole la vida."

# game/scripts/day20.rpy:3273
translate spanish d20b_04ea86b4:

    # Sky "{i}*sigh*{/i} Scrap this... no connection whatsoever..."
    Sky "{i}*suspiro*{/i} A la mierda... no hay conexión alguna..."

# game/scripts/day20.rpy:3277
translate spanish d20b_441f0f8a:

    # PS "Skye..."
    PS "Skye..."

# game/scripts/day20.rpy:3278
translate spanish d20b_2c2d6e84:

    # PS "I told you you could turn it up during surface hours. How much more freedom do you need?!"
    PS "Te dije que podías subir el volumen durante las horas de superficie. ¡¿Cuánta más libertad necesitas?!"

# game/scripts/day20.rpy:3281
translate spanish d20b_8b5b9aff:

    # Sky "..."
    Sky "..."

# game/scripts/day20.rpy:3284
translate spanish d20b_0aa0d682:

    # PS "We have a meeting coming up. Turn it off, before I bury this thing for the next expedition to find."
    PS "Tenemos una reunión próximamente. Apágalo, antes de que entierre esta cosa para que la encuentre la próxima expedición."

# game/scripts/day20.rpy:3288
translate spanish d20b_6c50db91:

    # Sky "God, why do you have to be so stiff, [persistent.dad]. It's just a few tracks."
    Sky "Dios, por qué tienes que ser tan rígido, [persistent.dad]. Son solo unas cuantas canciones."

# game/scripts/day20.rpy:3290
translate spanish d20b_8ad185ea:

    # Sky "God, why do you have to be so stiff? It's just a few tracks."
    Sky "Dios, por qué tienes que ser tan rígido. Son solo unas cuantas canciones."

# game/scripts/day20.rpy:3291
translate spanish d20b_02f0ca36:

    # Sky "What else can I do in here anyway? There's no fucking net whatsoever."
    Sky "¿Qué más puedo hacer aquí dentro de todos modos? No hay una puta red de ningún tipo."

# game/scripts/day20.rpy:3294
translate spanish d20b_647d022b:

    # PS "Yes... you've told me this for weeks."
    PS "Sí... me lo has dicho durante semanas."

# game/scripts/day20.rpy:3295
translate spanish d20b_4d2e52ae:

    # PS "But this is where we are. One of us has to earn a living out here, to feed your potty mouth."
    PS "Pero aquí es donde estamos. Uno de nosotros tiene que ganarse la vida aquí, para alimentar tu bocaza."

# game/scripts/day20.rpy:3298
translate spanish d20b_399781c1:

    # Sky "{i}*scoffs*{/i} I {i}was{/i} earning my living."
    Sky "{i}*resopla*{/i} {i}Sí{/i} me ganaba la vida."

# game/scripts/day20.rpy:3299
translate spanish d20b_2cba2229:

    # Sky "In fact, I was getting quite the mouthful in the process."
    Sky "De hecho, me llevaba bastante en el proceso."

# game/scripts/day20.rpy:3302
translate spanish d20b_acae625a:

    # PS "Yes, and I regret the day your mother took you to that decadent city. Look what it turned you into."
    PS "Sí, y lamento el día que tu madre te llevó a esa ciudad decadente. Mira en qué te ha convertido."

# game/scripts/day20.rpy:3306
translate spanish d20b_4da4f520:

    # Sky "Too bad, [persistent.dad]. Should've raised me better, I guess."
    Sky "Lástima, [persistent.dad]. Deberías haberme criado mejor, supongo."

# game/scripts/day20.rpy:3308
translate spanish d20b_eab8163b:

    # Sky "Too bad, \"[persistent.dad]\". Should've raised me better, I guess."
    Sky "Lástima, \"[persistent.dad]\". Deberías haberme criado mejor, supongo."

# game/scripts/day20.rpy:3311
translate spanish d20b_56e414bd:

    # Sky "And stop acting like you didn't watch my porn. Everyone did. Puh-lease!"
    Sky "Y deja de actuar como si no hubieras visto mi porno. Todo el mundo lo hizo. ¡Por favor!"

# game/scripts/day20.rpy:3312
translate spanish d20b_3700e70b:

    # Sky "Point is... I was making good money before you dragged me to this shithole."
    Sky "El caso es que... estaba ganando buen dinero antes de que me arrastraras a este agujero de mierda."

# game/scripts/day20.rpy:3315
translate spanish d20b_e6204d75:

    # PS "You will regret even suggesting I would do that..."
    PS "Te arrepentirás incluso de sugerir que yo haría eso..."

# game/scripts/day20.rpy:3318
translate spanish d20b_7e53cb52:

    # Sky "{i}*sigh*{/i} Don't get all defensive, I wouldn't blame you."
    Sky "{i}*suspiro*{/i} No te pongas a la defensiva, no te culparía."

# game/scripts/day20.rpy:3321
translate spanish d20b_a27f1ccb:

    # Sky "Maybe catch up with the times, these aren't even real ruins anyway and you know it."
    Sky "Quizás ponte al día con los tiempos, esto ni siquiera son ruinas reales y lo sabes."

# game/scripts/day20.rpy:3322
translate spanish d20b_e8113b82:

    # Sky "I've read it's just some old ass government site from a hundred years ago, where they want you to cover up their shady shit."
    Sky "He leído que es solo un viejo sitio del gobierno de hace cien años, donde quieren que encubras sus mierdas turbias."

# game/scripts/day20.rpy:3325
translate spanish d20b_cabd6df4:

    # PS "I can't hear my own thoughts...!"
    PS "¡No puedo oír mis propios pensamientos...!"

# game/scripts/day20.rpy:3335
translate spanish d20b_669f883d:

    # PS "Instead of believing some lunatics off the ether, how about you listen to your own father, who actually studied these subjects since before you were alive."
    PS "En lugar de creer a unos lunáticos de internet, ¿qué tal si escuchas a tu propio padre, que de hecho ha estudiado estas materias desde antes de que estuvieras viva?"

# game/scripts/day20.rpy:3336
translate spanish d20b_019df35c:

    # PS "Anyway, The meeting is about to start and I expect you to attend it as well."
    PS "En cualquier caso, la reunión está a punto de comenzar y espero que también asistas."

# game/scripts/day20.rpy:3339
translate spanish d20b_d4e4b0ac:

    # Sky "Hey, [persistent.dad]..."
    Sky "Oye, [persistent.dad]..."

# game/scripts/day20.rpy:3342
translate spanish d20b_17ff78bb:

    # Sky "I heard your slut of a secretary choking on your cock yesterday."
    Sky "Ayer oí a tu puta de secretaria atragantándose con tu polla."

# game/scripts/day20.rpy:3343
translate spanish d20b_3a2fe35f:

    # Sky "Stop acting all high and mighty in front of me, will you?"
    Sky "Deja de actuar tan superior y engreído delante de mí, ¿quieres?"

# game/scripts/day20.rpy:3346
translate spanish d20b_915565f2:

    # PS "{i}*scoffs*{/i}"
    PS "{i}*resoplido*{/i}"

# game/scripts/day20.rpy:3350
translate spanish d20b_916b3cf0:

    # EPN "The following meeting was nothing out of the ordinary."
    EPN "La siguiente reunión no tuvo nada de extraordinario."

# game/scripts/day20.rpy:3353
translate spanish d20b_5c566f86:

    # EPN "Skye was not entirely wrong about the background of our expedition."
    EPN "Skye no estaba del todo equivocada sobre los antecedentes de nuestra expedición."

# game/scripts/day20.rpy:3354
translate spanish d20b_cd60ad45:

    # EPN "Yes, we were experts, coming together from universities around the world to research the past."
    EPN "Sí, éramos expertos, reunidos de universidades de todo el mundo para investigar el pasado."

# game/scripts/day20.rpy:3355
translate spanish d20b_74361c5e:

    # EPN "And yes, all of us lived and worked by the unilateral agreement to find the facts buried in this place."
    EPN "Y sí, todos vivíamos y trabajábamos bajo el acuerdo unilateral de encontrar los hechos enterrados en este lugar."

# game/scripts/day20.rpy:3358
translate spanish d20b_f678e2dc:

    # EPN "...but Professor Azari was a smart woman. The most intelligent woman I had ever the pleasure to work with, in fact."
    EPN "... pero la profesora Azari era una mujer inteligente. De hecho, la mujer más inteligente con la que he tenido el placer de trabajar."

# game/scripts/day20.rpy:3361
translate spanish d20b_71c802a0:

    # Aza "...the stratigraphy is consistent with earlier surveys, but if you look at these curved trajectories,..."
    Aza "... la estratigrafía coincide con estudios anteriores, pero si observas estas trayectorias curvas,..."

# game/scripts/day20.rpy:3362
translate spanish d20b_d818cddb:

    # Aza "...it suggests localized disruptions in the sediment that are worth taking a closer look at."
    Aza "... sugiere perturbaciones localizadas en el sedimento que merecen un vistazo más de cerca."

# game/scripts/day20.rpy:3365
translate spanish d20b_a51c30ea:

    # EPN "...but even she knew that in our world, simple curiosity does not give you the authorization, nor the funds. Politics are not new to the game, but things have changed even further."
    EPN "... pero incluso ella sabía que en nuestro mundo, la simple curiosidad no te da la autorización, ni los fondos. La política no es nueva en el juego, pero las cosas han cambiado aún más."

# game/scripts/day20.rpy:3368
translate spanish d20b_8d3c6785:

    # EPN "Our profession was commercialized. Corporations and governments alike were hiring us to dig up past sins or achievements."
    EPN "Nuestra profesión se comercializó. Tanto corporaciones como gobiernos nos contrataban para desenterrar pecados o logros del pasado."

# game/scripts/day20.rpy:3371
translate spanish d20b_abb2c54a:

    # EPN "...and this job was no different."
    EPN "... y este trabajo no fue diferente."

# game/scripts/day20.rpy:3374
translate spanish d20b_fcf60154:

    # EPN "Xena, for example, was neither a scientist, nor one of our students. She was sent by the sponsoring corporation to provide survival necessities."
    EPN "Xena, por ejemplo, no era ni científica ni una de nuestras estudiantes. Fue enviada por la corporación patrocinadora para proporcionar necesidades de supervivencia."

# game/scripts/day20.rpy:3375
translate spanish d20b_df654bad:

    # EPN "The devices given to us would seem unimaginable to you, dear reader. But they were a reality nobody could refuse."
    EPN "Los dispositivos que nos dieron te parecerían inimaginables, querido lector. Pero eran una realidad que nadie podía rechazar."

# game/scripts/day20.rpy:3376
translate spanish d20b_83a164f3:

    # EPN "Dr. Daoz on the other hand was part of a collaboration effort between independently partnered universities. The few who still existed."
    EPN "La Dra. Daoz, por otro lado, era parte de un esfuerzo de colaboración entre universidades asociadas de forma independiente. Las pocas que aún existían."

# game/scripts/day20.rpy:3379
translate spanish d20b_20b76046:

    # EPN "[Cal] - I have partly introduced her before."
    EPN "[Cal] - Ya la he presentado en parte antes."

# game/scripts/day20.rpy:3380
translate spanish d20b_62dfc433:

    # EPN "Like most people participating in this excavation, she did not carry visible signs of excessive genetic manipulation, or other... alterations."
    EPN "Como la mayoría de los participantes en esta excavación, no mostraba signos visibles de manipulación genética excesiva, ni de otras... alteraciones."

# game/scripts/day20.rpy:3381
translate spanish d20b_f36ddaf9:

    # EPN "The story, albeit untrue, was that many of our modern alterations would interfere with the more advanced pieces of equipment."
    EPN "La historia, aunque falsa, era que muchas de nuestras modificaciones modernas interferían con los equipos más avanzados."

# game/scripts/day20.rpy:3382
translate spanish d20b_9395373f:

    # EPN "The truth is that society was becoming more and more polarised between those who embraced all kinds of enhancements, technological, virtual or otherwise, and those who refused them outright."
    EPN "La verdad es que la sociedad se polarizaba cada vez más entre aquellos que abrazaban todo tipo de mejoras, tecnológicas, virtuales o de otro tipo, y aquellos que las rechazaban de plano."

# game/scripts/day20.rpy:3383
translate spanish d20b_aa9ec6ca:

    # EPN "In general, in the world of academia, a certain degree of snobbery made it so that most of the places of education would hold on to the traditional image of what a regular human should be."
    EPN "En general, en el mundo académico, cierto grado de esnobismo hacía que la mayoría de las instituciones educativas se aferraran a la imagen tradicional de lo que debería ser un ser humano normal."

# game/scripts/day20.rpy:3386
translate spanish d20b_52dba5a3:

    # EPN "Of course, there was always a degree of hypocrisy in this; more than many others, we knew what the ravages of malnutrition, illness, inbreeding and poor hygiene had done through the ages..."
    EPN "Por supuesto, siempre había cierto grado de hipocresía en esto; más que muchos otros, sabíamos lo que los estragos de la desnutrición, la enfermedad, la endogamia y la falta de higiene habían causado a lo largo de los siglos..."

# game/scripts/day20.rpy:3387
translate spanish d20b_e9eb541d:

    # EPN "...just as we knew that truly unaltered humans belonged firmly to the past. Alas, it was nothing compared to the abominations one would find in the cities."
    EPN "... del mismo modo que sabíamos que los humanos verdaderamente no alterados pertenecían firmemente al pasado. Por desgracia, no era nada comparado con las abominaciones que uno podía encontrar en las ciudades."

# game/scripts/day20.rpy:3388
translate spanish d20b_3563101d:

    # EPN "I guess we took it further than most. Professor Azari's ideals were always considered conservative..."
    EPN "Supongo que lo llevamos más lejos que la mayoría. Los ideales de la profesora Azari siempre fueron considerados conservadores..."

# game/scripts/day20.rpy:3389
translate spanish d20b_efc50412:

    # extend "ancient..."
    extend "antiguos..."

# game/scripts/day20.rpy:3390
translate spanish d20b_b770821b:

    # extend "...backwards."
    extend "... retrógrados."

# game/scripts/day20.rpy:3391
translate spanish d20b_1b7666f4:

    # EPN "...to speak fairly, I agreed with most of it."
    EPN "... para ser justo, estaba de acuerdo con la mayor parte."

# game/scripts/day20.rpy:3394
translate spanish d20b_9acbb24f:

    # EPN "But like many things, ideas that once seemed unthinkable can become reality."
    EPN "Pero como muchas cosas, las ideas que una vez parecieron impensables pueden convertirse en realidad."

# game/scripts/day20.rpy:3395
translate spanish d20b_91912cc1:

    # EPN "Given a chance, a once marginally appealing concept can become the new norm."
    EPN "Dada la oportunidad, un concepto que una vez fue marginalmente atractivo puede convertirse en la nueva norma."

# game/scripts/day20.rpy:3398
translate spanish d20b_d49157f5:

    # EPN "The small window we were seeing the world through eventually became manifest truth across the lands."
    EPN "La pequeña ventana a través de la cual veíamos el mundo finalmente se convirtió en una verdad manifiesta en todas las tierras."

# game/scripts/day20.rpy:3399
translate spanish d20b_7ec6ab8a:

    # EPN "But before everything was artificially shaped towards what you know to be the reality you live in, dear reader..."
    EPN "Pero antes de que todo se moldeara artificialmente hacia lo que tú conoces como la realidad en la que vives, querido lector..."

# game/scripts/day20.rpy:3402
translate spanish d20b_e6b5c488:

    # EPN "...before that, the mind that led us down that path had itself been shaped by experience, much as mine had been."
    EPN "... antes de eso, la mente que nos llevó por ese camino había sido moldeada por la experiencia, al igual que la mía."

# game/scripts/day20.rpy:3403
translate spanish d20b_859c395f:

    # EPN "Our shared disgust for the world we lived in didn't come to us in a dream, but was rooted in the order of things we could not escape..."
    EPN "Nuestro disgusto compartido por el mundo en el que vivíamos no nos vino en un sueño, sino que estaba arraigado en el orden de las cosas del que no podíamos escapar..."

# game/scripts/day20.rpy:3404
translate spanish d20b_743e7357:

    # EPN "...and it grew only bolder once the events of the final days unfolded."
    EPN "... y solo se volvió más audaz una vez que se desarrollaron los acontecimientos de los últimos días."

# game/scripts/day20.rpy:3413
translate spanish d20b_bc9e592b:

    # EPN "The surface hours were bright and inviting. Leaving the dark caves behind us, we looked at the vibrant image of a city in the distance."
    EPN "Las horas en la superficie eran brillantes y acogedoras. Dejando atrás las oscuras cuevas, contemplábamos la vibrante imagen de una ciudad a lo lejos."

# game/scripts/day20.rpy:3414
translate spanish d20b_a58e0510:

    # EPN "From a distance, there was a certain appeal in the skyline, the profiles of illuminated buildings shimmering on the horizon, framed by dunes and dusty skies."
    EPN "Desde la distancia, había un cierto atractivo en el horizonte, los perfiles de edificios iluminados brillando en el horizonte, enmarcados por dunas y cielos polvorientos."

# game/scripts/day20.rpy:3415
translate spanish d20b_2d847627:

    # EPN "One could almost forget the distaste that a closer view inspired in many of us."
    EPN "Uno casi podía olvidar el desagrado que una visión más cercana inspiraba en muchos de nosotros."

# game/scripts/day20.rpy:3421
translate spanish d20b_0a17cdf1:

    # EPN "The excavations proceeded in the following days. The atmosphere was relaxing at the time. A calm before the storm, perhaps."
    EPN "Las excavaciones procedieron en los días siguientes. La atmósfera era relajada en ese momento. Una calma antes de la tormenta, quizás."

# game/scripts/day20.rpy:3424
translate spanish d20b_797c2f43:

    # EPN "Dr. Kaito was a thoughtful man. He understood the situation more than I did, back in the day."
    EPN "El Dr. Kaito era un hombre reflexivo. Él entendía la situación mejor que yo en aquel entonces."

# game/scripts/day20.rpy:3425
translate spanish d20b_91ffce24:

    # EPN "A product, maybe, of his past experiences working with the military and the corporations."
    EPN "Un producto, tal vez, de sus experiencias pasadas trabajando con los militares y las corporaciones."

# game/scripts/day20.rpy:3428
translate spanish d20b_6d45001a:

    # EPN "Often I would see him stare into the horizon, clearly mulling something over. Did he know what was to come? If so, why not share his concerns?"
    EPN "A menudo lo veía mirar al horizonte, claramente reflexionando sobre algo. ¿Sabía él lo que iba a suceder? Si era así, ¿por qué no compartir sus preocupaciones?"

# game/scripts/day20.rpy:3431
translate spanish d20b_e19dd864:

    # "As the last of the post-graduate students and hired men left the camp, the days rolled by slowly, in the blistering heat."
    "Cuando los últimos estudiantes de posgrado y los hombres contratados abandonaron el campamento, los días transcurrían lentamente, bajo un calor abrasador."

# game/scripts/day20.rpy:3434
translate spanish d20b_f2e2d485:

    # "The physical labour was exhausting but satisfying. Arguments dragged on, but with less intensity. It was peaceful and mostly quiet."
    "El trabajo físico era agotador pero satisfactorio. Las discusiones se prolongaban, pero con menos intensidad. Era tranquilo y en su mayor parte silencioso."

# game/scripts/day20.rpy:3437
translate spanish d20b_eab83916:

    # "Miss Vale and Skye seemed to have reached some kind of understanding, or at least a truce."
    "Parecía que la señorita Vale y Skye habían llegado a algún tipo de entendimiento, o al menos a una tregua."

# game/scripts/day20.rpy:3440
translate spanish d20b_7a12a67d:

    # EPN "The nights eventually grew cold, and my discussions with Professor Azari alternated between the troubles beyond the site and the task of recording its findings."
    EPN "Las noches finalmente se volvieron frías, y mis debates con la profesora Azari oscilaban entre los problemas más allá del yacimiento y la tarea de registrar sus hallazgos."

# game/scripts/day20.rpy:3443
translate spanish d20b_dfc44c73:

    # EPN "A kindred spirit, she revealed herself even more of an inspiration. One of the foremost Egyptologists, her interests and knowledge expanding far beyond that already complex subject."
    EPN "Un alma gemela, ella se reveló como una inspiración aún mayor. Una de las egiptólogas más destacadas, con intereses y conocimientos que se expandían mucho más allá de esa ya de por sí compleja materia."

# game/scripts/day20.rpy:3446
translate spanish d20b_2c366320:

    # EPN "The common thread of our more esoteric conversations was one of nostalgia for times long past before either of us was born."
    EPN "El hilo conductor de nuestras conversaciones más esotéricas era una nostalgia por tiempos pasados mucho antes de que ninguno de los dos naciéramos."

# game/scripts/day20.rpy:3447
translate spanish d20b_f5a1e9e8:

    # EPN "How to explain such a feeling, this longing, to someone like Skye?"
    EPN "¿Cómo explicar ese sentimiento, esa añoranza, a alguien como Skye?"

# game/scripts/day20.rpy:3450
translate spanish d20b_d2397c53:

    # EPN "The outskirts of the encampment were mostly shuttered now, the remaining scientists, crew and respective family members in visit being huddled around the center of the encampment."
    EPN "Las afueras del campamento estaban ahora casi desiertas, y los científicos, el personal y los familiares visitantes que quedaban se agrupaban en el centro del campamento."

# game/scripts/day20.rpy:3453
translate spanish d20b_707064de:

    # EPN "It was not lost on me that, during the nights, many people were not in their assigned sleeping quarters, but..."
    EPN "No pasó desapercibido para mí que, durante las noches, muchas personas no estaban en sus alojamientos asignados, pero..."

# game/scripts/day20.rpy:3456
translate spanish d20b_3f8510b4:

    # EPN "I guess I could not really point a finger at anyone without facing similar criticism."
    EPN "Supongo que no podía señalar a nadie sin enfrentarme a críticas similares."

# game/scripts/day20.rpy:3459
translate spanish d20b_70f7e563:

    # EPN "In the end, it mattered little to me as long as during the day, the work continued."
    EPN "Al final, me importaba poco, siempre que durante el día el trabajo continuara."

# game/scripts/day20.rpy:3466
translate spanish d20b_cf0fe34a:

    # Ne "In the next part..."
    Ne "En la siguiente parte..."

# game/scripts/day20.rpy:3469
translate spanish d20b_e35d811e:

    # Ne "The writing is more chaotic. Almost hectic."
    Ne "La escritura es más caótica. Casi frenética."

# game/scripts/day20.rpy:3470
translate spanish d20b_e6227816:

    # Ne "It seems that he had a hard time writing... or even processing the next part."
    Ne "Parece que le costó mucho escribir... o incluso procesar la parte siguiente."

# game/scripts/day20.rpy:3473
translate spanish d20b_5bb35b30:

    # S "What do you see?"
    S "¿Qué ves?"

# game/scripts/day20.rpy:3476
translate spanish d20b_3b885d6b:

    # Ne "Scribbled drawings, many of them. Circular patterns, spirals... a dying... sun?"
    Ne "Dibujos garabateados, muchos de ellos. Patrones circulares, espirales... ¿un sol... moribundo?"

# game/scripts/day20.rpy:3477
translate spanish d20b_60907da2:

    # Ne "Loose ramblings for a few pages. But he kept them nonetheless. I wonder why?"
    Ne "Divagaciones sueltas durante varias páginas. Pero aun así las conservó. ¿Me pregunto por qué?"

# game/scripts/day20.rpy:3480
translate spanish d20b_5bb855f7:

    # Ne "\"How do you describe the end of everything you know?\", he asks."
    Ne "\"¿Cómo describes el fin de todo lo que conoces?\", pregunta."

# game/scripts/day20.rpy:3483
translate spanish d20b_bd54abbd:

    # Ne "\"...I am going to show you what I saw...\""
    Ne "\"... Voy a mostraros lo que vi...\""

# game/scripts/day20.rpy:3488
translate spanish d20b_afcf6135:

    # Ne "\"...but I can not show you what it felt like.\""
    Ne "\"... pero no puedo mostraros cómo se sintió.\""

# game/scripts/day20.rpy:3493
translate spanish d20b_8b5b9aff_1:

    # Sky "..."
    Sky "..."

# game/scripts/day20.rpy:3495
translate spanish d20b_1163185d:

    # EPN "Centuries of promises and hopes for a better tomorrow in people's minds, driving the evolution of our species..."
    EPN "Siglos de promesas y esperanzas de un mañana mejor en la mente de la gente, impulsando la evolución de nuestra especie..."

# game/scripts/day20.rpy:3497
translate spanish d20b_f3fd6f51:

    # EPN "...the end of all of this, was supposed to start that one night."
    EPN "... el fin de todo esto, se suponía que comenzaría aquella noche."

# game/scripts/day20.rpy:3500
translate spanish d20b_227a8b5c:

    # EPN "The future did not arrive as promised... It flew in on the wings of destruction, and left things in its wake, most of them dead, some of them changed."
    EPN "El futuro no llegó como se prometió... Llegó volando sobre las alas de la destrucción, y dejó cosas a su paso, la mayoría muertas, algunas cambiadas."

# game/scripts/day20.rpy:3501
translate spanish d20b_e75cf2aa:

    # EPN "Cairo burned right before our eyes. A fire so bright that it lit up the sky, in one hellish deluge of the worst and most destructive powers shaped by mankind."
    EPN "El Cairo ardió ante nuestros ojos. Un fuego tan brillante que iluminó el cielo, en un diluvio infernal de los peores y más destructivos poderes forjados por la humanidad."

# game/scripts/day20.rpy:3502
translate spanish d20b_6b27babe:

    # EPN "It was one of the first cities to fall. What we did not know at the time, is just how many others would follow."
    EPN "Fue una de las primeras ciudades en caer. Lo que no sabíamos entonces era cuántas más la seguirían."

# game/scripts/day20.rpy:3503
translate spanish d20b_2c0d975d:

    # EPN "The reasons for this insane chain of events could be divined by anyone with an eye on the cycles of History, yet they went completely unheeded, as one might expect."
    EPN "Las razones de esta loca cadena de acontecimientos podían ser adivinadas por cualquiera que observara los ciclos de la Historia, pero pasaron completamente desapercibidas, como era de esperar."

# game/scripts/day20.rpy:3506
translate spanish d20b_237ba116:

    # EPN "It was the first time since her childhood, that I saw my [persistent.da] in tears."
    EPN "Fue la primera vez desde su infancia que vi a mi [persistent.da] llorar."

# game/scripts/day20.rpy:3507
translate spanish d20b_fe7f2232:

    # EPN "But they were not the tears of a young woman whose dreams had been shattered, or whose mother was still in that city."
    EPN "Pero no eran las lágrimas de una joven cuyos sueños se habían hecho añicos, o cuya madre seguía en esa ciudad."

# game/scripts/day20.rpy:3508
translate spanish d20b_5d9f8809:

    # EPN "It was... shock, wonderment, a sense of incredulity... Who could possibly contemplate destruction on such a large scale, hitting all you hold dear?"
    EPN "Era...  conmoción, asombro, una sensación de incredulidad... ¿Quién podría contemplar una destrucción a tan gran escala, que golpea todo lo que te es querido?"

# game/scripts/day20.rpy:3511
translate spanish d20b_e6de191d:

    # EPN "Xena, like many others, was scared that night. A collective and reasonable reaction quickly compounded by sorrow for those we knew lost, and worry for those we could not reach."
    EPN "Xena, como muchos otros, tenía miedo esa noche. Una reacción colectiva y razonable a la que se sumó rápidamente el dolor por los que sabíamos perdidos y la preocupación por los que no podíamos contactar."

# game/scripts/day20.rpy:3512
translate spanish d20b_d68d7dda:

    # EPN "How does one react when the only thing you would like to do is to reach out to the world, but the world has fallen into silence?"
    EPN "¿Cómo reacciona uno cuando lo único que desea es tender la mano al mundo, pero el mundo ha caído en silencio?"

# game/scripts/day20.rpy:3513
translate spanish d20b_b520087c:

    # EPN "To my regret, I didn't see this happening to her, too preoccupied with everybody to concern myself with a single, beloved, person. I didn't see it until later, much later, when she left."
    EPN "Para mi pesar, no vi que esto le estaba pasando a ella, demasiado ocupada con todos como para preocuparme por una sola persona, amada. No lo vi hasta después, mucho después, cuando se fue."

# game/scripts/day20.rpy:3516
translate spanish d20b_41f22ea2:

    # EPN "In stark contrast, professor Serafina Azari never blinked."
    EPN "En marcado contraste, la profesora Serafina Azari no parpadeó."

# game/scripts/day20.rpy:3517
translate spanish d20b_20f0f6d5:

    # EPN "I could see the immediate acceptance in her eyes, almost as if she cast a stubborn, disheartened look of grim vindication toward the city."
    EPN "Podía ver la aceptación inmediata en sus ojos, casi como si lanzara una mirada obstinada y descorazonadora de sombría vindicación hacia la ciudad."

# game/scripts/day20.rpy:3520
translate spanish d20b_330d8bc2:

    # EPN "Despite the suspicions and intuitions he later revealed to harbour, Elren Kaito was, initially, possibly the one who took what happened the hardest."
    EPN "A pesar de las sospechas e intuiciones que luego reveló albergar, Elren Kaito fue, inicialmente, posiblemente quien tomó lo sucedido con más dureza."

# game/scripts/day20.rpy:3521
translate spanish d20b_b233c685:

    # EPN "It makes sense, given that most of his immediate family was in Cairo."
    EPN "Tiene sentido, dado que la mayor parte de su familia directa estaba en El Cairo."

# game/scripts/day20.rpy:3524
translate spanish d20b_0af6de3f:

    # EPN "But, much like Calista, when the initial shock wore off, he quickly accepted the new reality."
    EPN "Pero, al igual que Calista, cuando el shock inicial pasó, aceptó rápidamente la nueva realidad."

# game/scripts/day20.rpy:3525
translate spanish d20b_e2b63013:

    # EPN "Unlike him, she even found a sense of beauty amidst the inferno. I suppose it's easier to detach oneself, when you have no personal connection to what's burning."
    EPN "A diferencia de él, ella incluso encontró un sentido de belleza en medio del infierno. Supongo que es más fácil desvincularse cuando no tienes una conexión personal con lo que está ardiendo."

# game/scripts/day20.rpy:3528
translate spanish d20b_20a7f50d:

    # EPN "As for myself..."
    EPN "En cuanto a mí mismo..."

# game/scripts/day20.rpy:3529
translate spanish d20b_2626a028:

    # EPN "The disorganized notes, these half finished doodles, were not done shortly after it happened."
    EPN "Las notas desorganizadas, estos garabatos a medio terminar, no se hicieron poco después de lo sucedido."

# game/scripts/day20.rpy:3530
translate spanish d20b_b997f761:

    # EPN "I would lie if I claimed I ever really, truly processed what happened..."
    EPN "Mentiría si dijera que alguna vez realmente, de verdad, procesé lo que pasó..."

# game/scripts/day20.rpy:3531
translate spanish d20b_ab36da52:

    # EPN "...the end of all things never felt real to me. Maybe that is why I had an easier time conceptualising how a new reality could be put together, brick by brick?"
    EPN "... el fin de todas las cosas nunca me pareció real. ¿Tal vez por eso me resultó más fácil conceptualizar cómo se podría construir una nueva realidad, ladrillo a ladrillo?"

# game/scripts/day20.rpy:3534
translate spanish d20b_fdd48f82:

    # EPN "Dear reader, let me close this chapter of my life with one simple question to you."
    EPN "Querido lector, permíteme cerrar este capítulo de mi vida con una simple pregunta."

# game/scripts/day20.rpy:3536
translate spanish d20b_58f20ace:

    # EPN "Is the sky still burning to this day?"
    EPN "¿Sigue ardiendo el cielo hasta el día de hoy?"

# game/scripts/day20.rpy:3549
translate spanish d20b_aed182c1:

    # Aza "Feeling nostalgic, Professor?"
    Aza "¿Nostálgico, profesor?"

# game/scripts/day20.rpy:3552
translate spanish d20b_2d801059:

    # PS "What do you want..."
    PS "¿Qué quieres...?"

# game/scripts/day20.rpy:3555
translate spanish d20b_f55ca498:

    # Aza "I want you to answer my question."
    Aza "Quiero que respondas a mi pregunta."

# game/scripts/day20.rpy:3558
translate spanish d20b_6428880c:

    # PS "{i}*scoffs*{/i} You're asking about nostalgia?"
    PS "{i}*resopla*{/i} ¿Me estás preguntando por la nostalgia?"

# game/scripts/day20.rpy:3561
translate spanish d20b_a811daa0:

    # PS "You can't feel nostalgic for places which changed long before we were born."
    PS "No se puede sentir nostalgia por lugares que cambiaron mucho antes de que naciéramos."

# game/scripts/day20.rpy:3564
translate spanish d20b_10cd2dbc:

    # Aza "We are romantics at heart, Paris..."
    Aza "Somos románticos en el fondo, Paris..."

# game/scripts/day20.rpy:3565
translate spanish d20b_391f102a:

    # Aza "That is why we grew up reading books, why we love History to the point of making it our career."
    Aza "Por eso crecimos leyendo libros, por eso amamos la Historia hasta el punto de hacerla nuestra carrera."

# game/scripts/day20.rpy:3566
translate spanish d20b_9049730c:

    # Aza "You are allowed a bit of irrational nostalgia, especially so in these days."
    Aza "Se te permite un poco de nostalgia irracional, especialmente en estos días."

# game/scripts/day20.rpy:3567
translate spanish d20b_10a65825:

    # Aza "The question is, whether you will let yourself be consumed by it..."
    Aza "La pregunta es si te dejarás consumir por ella..."

# game/scripts/day20.rpy:3570
translate spanish d20b_bb4b9045:

    # PS "Listen... it's been a few weeks since the last communication came through, and you've heard it, what did come through did not make sense."
    PS "Escucha... han pasado unas semanas desde la última comunicación, y tú la oíste, lo que llegó no tenía sentido."

# game/scripts/day20.rpy:3571
translate spanish d20b_5cbf5e5a:

    # PS "Everybody needs time to process the loss. It's best if you-"
    PS "Todo el mundo necesita tiempo para procesar la pérdida. Será mejor que-"

# game/scripts/day20.rpy:3574
translate spanish d20b_5e262757:

    # Aza "It has been months, Professor... You are depressed and lethargic."
    Aza "Han pasado meses, Profesor... Está deprimido y aletargado."

# game/scripts/day20.rpy:3575
translate spanish d20b_2f9c14d8:

    # Aza "The mist is regressing to Cairo. How long do you want to wait underground?"
    Aza "La niebla retrocede hacia El Cairo. ¿Cuánto tiempo quieres esperar bajo tierra?"

# game/scripts/day20.rpy:3578
translate spanish d20b_79d7588d:

    # Aza "Will you wait until our last rations are depleted?"
    Aza "¿Vas a esperar hasta que se agoten nuestras últimas raciones?"

# game/scripts/day20.rpy:3581
translate spanish d20b_2f488d45:

    # PS "I can't think of much that could be of use, really. If our communications are down and our rations depleting... What can we do?"
    PS "No se me ocurre gran cosa que pueda ser útil, la verdad. Si las comunicaciones están caídas y las raciones se agotan... ¿Qué podemos hacer?"

# game/scripts/day20.rpy:3584
translate spanish d20b_794e876d:

    # Aza "My friend, I don't know what happened to the rest of the world. Maybe in a few months we will be sitting in our respective countries, mourning our losses."
    Aza "Amigo mío, no sé qué le ha pasado al resto del mundo. Quizá dentro de unos meses estemos sentados en nuestros respectivos países, lamentando nuestras pérdidas."

# game/scripts/day20.rpy:3585
translate spanish d20b_822fa81c:

    # Aza "Maybe we will be rescued by a military convoy or some corporation probe."
    Aza "Tal vez nos rescate un convoy militar o alguna sonda corporativa."

# game/scripts/day20.rpy:3588
translate spanish d20b_318c63d4:

    # Aza "Maybe everybody else is dead and we are all alone."
    Aza "Quizá todos los demás están muertos y estamos completamente solos."

# game/scripts/day20.rpy:3593
translate spanish d20b_29a99c2b:

    # Aza "What I do know is that the couple of drones we had for the aerial surveys have been flying as far as we dared send them and saw nothing but naked desert, destruction, and death."
    Aza "Lo que sí sé es que los pocos drones que teníamos para los reconocimientos aéreos han volado hasta donde nos hemos atrevido a enviarlos y no han visto más que desierto desnudo, destrucción y muerte."

# game/scripts/day20.rpy:3594
translate spanish d20b_1187e62a:

    # Aza "I don't know when our technology will start failing to breaking point and how many of our crew will be able to do something about it, but I do know something else."
    Aza "No sé cuándo nuestra tecnología empezará a fallar hasta el punto de ruptura ni cuántos de nuestro equipo podrán hacer algo al respecto, pero sí sé otra cosa."

# game/scripts/day20.rpy:3596
translate spanish d20b_b464e237:

    # PS "I am listening."
    PS "Te escucho."

# game/scripts/day20.rpy:3597
translate spanish d20b_ef7132fb:

    # Aza "Eventually, if we truly are alone, our technology will fail us. But we are a collective of people of science, and knowledge."
    Aza "Con el tiempo, si de verdad estamos solos, nuestra tecnología nos fallará. Pero somos un colectivo de gente de ciencia y conocimiento."

# game/scripts/day20.rpy:3598
translate spanish d20b_02bbc1df:

    # Aza "Kaito is an expert in industrial archaeology and the science of things. We have botanists and biologists in our midst."
    Aza "Kaito es experto en arqueología industrial y la ciencia de las cosas. Tenemos botánicos y biólogos entre nosotros."

# game/scripts/day20.rpy:3601
translate spanish d20b_84b2238c:

    # Aza "But...I need your help. If we are to survive, we must all work together, and I am losing grip on the workers."
    Aza "Pero... necesito tu ayuda. Si queremos sobrevivir, tenemos que trabajar todos juntos, y estoy perdiendo el control sobre los trabajadores."

# game/scripts/day20.rpy:3604
translate spanish d20b_07d6edd2:

    # Aza "The young ones are fretting and want to flee the relative safety to go find their loved ones, people are starting to fight over the food we have left."
    Aza "Los más jóvenes están inquietos y quieren huir de la seguridad relativa para ir a buscar a sus seres queridos, la gente empieza a pelearse por la comida que nos queda."

# game/scripts/day20.rpy:3607
translate spanish d20b_2f812dce:

    # Aza "Today one of the truckers stabbed someone over one of the last beers."
    Aza "Hoy uno de los camioneros apuñaló a alguien por una de las últimas cervezas."

# game/scripts/day20.rpy:3610
translate spanish d20b_7bef086b:

    # Aza "In order to survive we have to maintain a united front. You have always had your way with the workers. They listen to you."
    Aza "Para sobrevivir tenemos que mantener un frente unido. Siempre has sabido manejar a los trabajadores. Te escuchan."

# game/scripts/day20.rpy:3613
translate spanish d20b_d2402026:

    # Aza "Help me help them. Make them see that we can't afford to squander our strengths fighting each other. It is time to rebuild."
    Aza "Ayúdame a ayudarles. Hazles ver que no podemos permitirnos malgastar nuestras fuerzas peleando entre nosotros. Es hora de reconstruir."

# game/scripts/day20.rpy:3616
translate spanish d20b_0be9e849:

    # PS "Rebuild, you say? Here? This cave might have been good for a temporary shelter, but we'll be doomed soon enough if we stay here. Resources are getting low."
    PS "¿Reconstruir, dices? ¿Aquí? Esta cueva podría haber servido como refugio temporal, pero estamos condenados si nos quedamos aquí. Los recursos se están agotando."

# game/scripts/day20.rpy:3619
translate spanish d20b_ffd9da6f:

    # Aza "Do you have a better idea?"
    Aza "¿Tienes una idea mejor?"

# game/scripts/day20.rpy:3622
translate spanish d20b_3f3936e4:

    # PS "Scout the area, perhaps. Find a place out there more suitable, further away from the city to avoid the mist, and then build on that."
    PS "Explorar la zona, quizá. Encontrar un lugar más adecuado, más lejos de la ciudad para evitar la niebla, y luego construir sobre eso."

# game/scripts/day20.rpy:3625
translate spanish d20b_49a6c2cf:

    # PS "Those drones must have located {i}something{/i}..."
    PS "Esos drones deben haber localizado {i}algo{/i}..."

# game/scripts/day20.rpy:3628
translate spanish d20b_51fc94e7:

    # Aza "...we can start there, yes."
    Aza "... podemos empezar por ahí, sí."

# game/scripts/day20.rpy:3631
translate spanish d20b_a4a3b102:

    # PS "Leave the workers to me, I will organize scavenging runs. You talk to the students and our colleagues..."
    PS "Deja a los trabajadores en mis manos, organizaré expediciones de búsqueda. Tú habla con los estudiantes y nuestros colegas..."

# game/scripts/day20.rpy:3635
translate spanish d20b_77f2648b:

    # "Months after the world's end, we were already picking through its remains."
    "Meses después del fin del mundo, ya estábamos hurgando entre sus restos."

# game/scripts/day20.rpy:3652
translate spanish d20b_6502818d:

    # EPN "There we were, on the outskirts of what once was Cairo, trying to scavenge what we could."
    EPN "Allí estábamos, en las afueras de lo que una vez fue El Cairo, tratando de recoger lo que podíamos."

# game/scripts/day20.rpy:3653
translate spanish d20b_67bffe69:

    # EPN "It wasn't the first time either. On a previous occasion, Professor Kaito once said something that stuck with me."
    EPN "Tampoco era la primera vez. En una ocasión anterior, el profesor Kaito dijo algo que se me quedó grabado."

# game/scripts/day20.rpy:3654
translate spanish d20b_4721862b:

    # EPN "\"Once we dug through the remnants of the old world, seeking what was lost to time. Now, we walk upon the ruins of our own world and still we do the same.\""
    EPN "\"Antes excavábamos entre los restos del mundo antiguo, buscando lo perdido en el tiempo. Ahora caminamos sobre las ruinas de nuestro propio mundo y aún hacemos lo mismo.\""

# game/scripts/day20.rpy:3655
translate spanish d20b_d544c6fb:

    # EPN "\"Strange signs and subtle phenomena occur where the earth was broken and its harmony lost, as if the soul of the world - its kami - awakened to teach us.\""
    EPN "\"Donde la tierra se quebró y perdió su armonía, ocurren signos extraños y fenómenos sutiles, como si el alma del mundo -su kami- se hubiera despertado para enseñarnos.\""

# game/scripts/day20.rpy:3656
translate spanish d20b_c41c0b59:

    # EPN "\"In their presence, we are now forced to honor the earth and tread lightly upon it.\""
    EPN "\"En su presencia, ahora nos vemos obligados a honrar la tierra y pisarla con suavidad.\""

# game/scripts/day20.rpy:3659
translate spanish d20b_4ce3e8f7:

    # EPN "I think about those words now and then, and wonder if we did right."
    EPN "Pienso en esas palabras de vez en cuando, y me pregunto si hicimos bien."

# game/scripts/day20.rpy:3662
translate spanish d20b_e6c03c6b:

    # EPN "We refined the concept of that first notion of how we wanted the future to be shaped during many late night conversations."
    EPN "Refinamos el concepto de esa primera idea de cómo queríamos que fuera el futuro durante muchas conversaciones nocturnas."

# game/scripts/day20.rpy:3665
translate spanish d20b_7b322f19:

    # EPN "But first we had to, as Azari put it, lay the groundwork, build something that could last, be practical."
    EPN "Pero primero teníamos que, como decía Azari, sentar las bases, construir algo que pudiera durar, que fuera práctico."

# game/scripts/day20.rpy:3668
translate spanish d20b_325e5ced:

    # EPN "As we were doing this, a modicum of comfort became available even on the surface."
    EPN "Mientras hacíamos esto, un mínimo de comodidad se hizo disponible incluso en la superficie."

# game/scripts/day20.rpy:3669
translate spanish d20b_e286cfb2:

    # EPN "We used what we had left of our technological means to find water first."
    EPN "Utilizamos lo que nos quedaba de nuestros medios tecnológicos para encontrar agua primero."

# game/scripts/day20.rpy:3672
translate spanish d20b_2e5881f2:

    # "Over time, we restored some of the ruins and even started building smaller accomodations."
    "Con el tiempo, restauramos algunas de las ruinas e incluso empezamos a construir alojamientos más pequeños."

# game/scripts/day20.rpy:3675
translate spanish d20b_ef01a4e5:

    # EPN "There weren't many of us. And in the first years only a couple of stragglers, mostly wanderers from the nearby regions joined us. They had no news of other settlements."
    EPN "No éramos muchos. Y en los primeros años solo se nos unieron un par de rezagados, principalmente vagabundos de las regiones cercanas. No tenían noticias de otros asentamientos."

# game/scripts/day20.rpy:3678
translate spanish d20b_cb62cb0f:

    # EPN "So they searched for a place to provide a chance of survival and, maybe, stability."
    EPN "Así que buscaban un lugar que ofreciera una posibilidad de supervivencia y, tal vez, estabilidad."

# game/scripts/day20.rpy:3681
translate spanish d20b_0432b923:

    # EPN "I used to like to think that my greatest contribution had been to help Professor Azari solidify her role as leader of our small community."
    EPN "Me gustaba pensar que mi mayor contribución había sido ayudar a la profesora Azari a solidificar su papel como líder de nuestra pequeña comunidad."

# game/scripts/day20.rpy:3684
translate spanish d20b_064414b3:

    # EPN "Truth is, it would have happened anyway. She rose to the occasion and managed to organize our little group of survivors."
    EPN "La verdad es que habría sucedido de todos modos. Ella supo estar a la altura y consiguió organizar a nuestro pequeño grupo de supervivientes."

# game/scripts/day20.rpy:3685
translate spanish d20b_61304c3b:

    # EPN "Many of them didn't share her distaste for the society we are abandoning and the stranglehold technology had come to have on every facet of our civilisation."
    EPN "Muchos de ellos no compartían su disgusto por la sociedad que abandonábamos y el control asfixiante que la tecnología había llegado a tener sobre cada faceta de nuestra civilización."

# game/scripts/day20.rpy:3688
translate spanish d20b_b64471df:

    # EPN "This was changing, however. As she talked to them, often in private, sometimes holding speeches, she was changing the narrative of how we got where we got."
    EPN "Sin embargo, eso estaba cambiando. Mientras hablaba con ellos, a menudo en privado, a veces dando discursos, estaba transformando la narrativa de cómo habíamos llegado hasta donde estábamos."

# game/scripts/day20.rpy:3691
translate spanish d20b_18467b29:

    # EPN "Building a new society, a simpler one based on personal worth and pride in one's merits and inclusion in Zeta, was no longer a survival strategy born out of disaster."
    EPN "Construir una nueva sociedad, una más simple basada en el valor personal y el orgullo por los propios méritos y la inclusión en Zeta, ya no era una estrategia de supervivencia nacida de la catástrofe."

# game/scripts/day20.rpy:3692
translate spanish d20b_416c85af:

    # EPN "Yes, that was the catalyst, but she was spreading the word that this immense catastrophe might have been a chance for all of us to move towards a better life."
    EPN "Sí, ese fue el catalizador, pero ella estaba difundiendo la idea de que esta inmensa catástrofe podría haber sido una oportunidad para que todos avanzáramos hacia una vida mejor."

# game/scripts/day20.rpy:3693
translate spanish d20b_91cafd03:

    # EPN "She didn't have to convince me of course, I was already on board."
    EPN "No tuvo que convencerme a mí, claro, yo ya estaba a bordo."

# game/scripts/day20.rpy:3696
translate spanish d20b_0f50f783:

    # EPN "For sure, when we were kids, most of us older archaelogists were playing, pretending to be noble knights or princes in ancient civilisations; discoverers of great treasures like we saw in the vintage movies of centuries ago."
    EPN "Seguro, cuando éramos niños, la mayoría de los arqueólogos más veteranos jugábamos a ser nobles caballeros o príncipes de civilizaciones antiguas; descubridores de grandes tesoros como los que veíamos en las películas antiguas de hacía siglos."

# game/scripts/day20.rpy:3699
translate spanish d20b_8c330ad6:

    # EPN "She however has made it possible even for those of us who were in this project just to make a living, to start dreaming about a society both new and old."
    EPN "Sin embargo, ella ha hecho posible que incluso aquellos de nosotros que estábamos en este proyecto solo para ganarnos la vida, empecemos a soñar con una sociedad a la vez nueva y antigua."

# game/scripts/day20.rpy:3702
translate spanish d20b_08aa701b:

    # EPN "And yet, some remained...unconvinced about our ways..."
    EPN "Y sin embargo, algunos permanecieron... reacios a aceptar nuestros métodos..."

# game/scripts/day20.rpy:3708
translate spanish d20b_83d9de4b:

    # S "I... found another text."
    S "Yo... he encontrado otro texto."

# game/scripts/day20.rpy:3711
translate spanish d20b_49a8edf4:

    # Z "What is it about?"
    Z "¿De qué trata?"

# game/scripts/day20.rpy:3712
translate spanish d20b_890e65b1:

    # S "The dates he uses... same count as ours."
    S "Las fechas que utiliza... la misma cuenta que la nuestra."

# game/scripts/day20.rpy:3715
translate spanish d20b_e580ccef:

    # S "This... has been written many years later, it seems."
    S "Esto... parece haber sido escrito muchos años después."

# game/scripts/day20.rpy:3718
translate spanish d20b_96eb947a:

    # Z "Let us hear it, [S]."
    Z "Déjanos oírlo, [S]."

# game/scripts/day20.rpy:3722
translate spanish d20b_85373308:

    # S "\"There are some things you cannot come back from.\""
    S "\"Hay cosas de las que no se puede volver.\""

# game/scripts/day20.rpy:3726
translate spanish d20b_7742d704:

    # PS "You wanted to speak to me?"
    PS "¿Querías hablar conmigo?"

# game/scripts/day20.rpy:3729
translate spanish d20b_dad9548c:

    # Sera "Yes, indeed, I do."
    Sera "Sí, de hecho, así es."

# game/scripts/day20.rpy:3732
translate spanish d20b_908917e0:

    # Sera "What do you think of this dress, Professor?"
    Sera "¿Qué le parece este vestido, profesor?"

# game/scripts/day20.rpy:3735
translate spanish d20b_d51cd596:

    # PS "Where did your men scavenge it?"
    PS "¿Dónde lo encontraron sus hombres?"

# game/scripts/day20.rpy:3738
translate spanish d20b_2eaba305:

    # Sera "Does it matter? I asked you whether you like it."
    Sera "¿Importa? Le he preguntado si le gusta."

# game/scripts/day20.rpy:3741
translate spanish d20b_44dec9e0:

    # Aza "Take a look. It looks the part, doesn't it?"
    Aza "Échale un vistazo. Tiene el aspecto adecuado, ¿no?"

# game/scripts/day20.rpy:3744
translate spanish d20b_744f3627:

    # PS "It suits you well... if that is what you're asking."
    PS "Le queda bien... si eso es lo que pregunta."

# game/scripts/day20.rpy:3747
translate spanish d20b_20046939:

    # Sera "We have come quite far in our quest, have we not? After all these years spent trying to shape this new world..."
    Sera "Hemos avanzado bastante en nuestra búsqueda, ¿no es así? Después de todos estos años dedicados a intentar dar forma a este nuevo mundo..."

# game/scripts/day20.rpy:3748
translate spanish d20b_87fdb61a:

    # Sera "But there are some things we have not yet undertaken, Professor."
    Sera "Pero hay algunas cosas que aún no hemos emprendido, profesor."

# game/scripts/day20.rpy:3751
translate spanish d20b_de52b016:

    # PS "What are you getting at..."
    PS "¿A qué viene esto...?"

# game/scripts/day20.rpy:3754
translate spanish d20b_0ff42aa1:

    # Sera "You see, we've built an aesthetic reminder of old Egypt, and introduced some of their simpler ways of life."
    Sera "Verá, hemos construido un recordatorio estético del antiguo Egipto, e introducido algunas de sus formas de vida más sencillas."

# game/scripts/day20.rpy:3755
translate spanish d20b_92cd8fbb:

    # Sera "But even now, despite my best efforts, many are still staring at the dunes, waiting for something to restore their old lives; a miracle if you ask me."
    Sera "Pero incluso ahora, a pesar de mis mejores esfuerzos, muchos siguen mirando fijamente las dunas, esperando que algo les devuelva sus antiguas vidas; un milagro, si me preguntas."

# game/scripts/day20.rpy:3758
translate spanish d20b_2b9d1405:

    # Sera "We need something to strive for beyond survival, a notion of manifest destiny, of strong cultural identity and belonging based on rules and guidelines."
    Sera "Necesitamos algo por lo que luchar más allá de la supervivencia, una noción de destino manifiesto, de identidad cultural fuerte y pertenencia basada en normas y directrices."

# game/scripts/day20.rpy:3759
translate spanish d20b_770c8c33:

    # Sera "And yet, rules fade away along with the ones enforcing them, but stories? They live on..."
    Sera "Y sin embargo, las normas se desvanecen junto con quienes las hacen cumplir, pero ¿las historias? Ellas perduran..."

# game/scripts/day20.rpy:3760
translate spanish d20b_1de7104a:

    # Sera "If we are to move on, I believe we should truly create a new... order. We should educate our people in those myths, those legends, the origins of the rules we try to establish."
    Sera "Si queremos seguir adelante, creo que deberíamos crear realmente un nuevo... orden. Deberíamos educar a nuestra gente en esos mitos, esas leyendas, los orígenes de las normas que tratamos de establecer."

# game/scripts/day20.rpy:3761
translate spanish d20b_95e289e1:

    # Sera "...and make them a way of thinking, solidify them in everybody's eyes for generations to come."
    Sera "... y convertirlas en una forma de pensar, solidificarlas a los ojos de todos para las generaciones venideras."

# game/scripts/day20.rpy:3762
translate spanish d20b_7b73886a:

    # Sera "The people are yearning for an ideal, Paris Sivara. Help me enforce it."
    Sera "La gente anhela un ideal, Paris Sivara. Ayúdeme a imponerlo."

# game/scripts/day20.rpy:3765
translate spanish d20b_c7abfa46:

    # PS "...what do you seek?"
    PS "... ¿qué busca?"

# game/scripts/day20.rpy:3768
translate spanish d20b_b7d2f7d0:

    # Sera "Offspring, Paris."
    Sera "Descendencia, Paris."

# game/scripts/day20.rpy:3769
translate spanish d20b_a7bbbb8d:

    # Sera "The women need to bear children for us to survive."
    Sera "Las mujeres deben parir hijos para que nosotros podamos sobrevivir."

# game/scripts/day20.rpy:3770
translate spanish d20b_346202c9:

    # Sera "Take your [persistent.da] for example, Paris. Despite her... liberal tendencies, she has avoided the responsibility of ensuring our survival for years."
    Sera "Tome a su [persistent.da], por ejemplo, Paris. A pesar de sus... tendencias liberales, ha evitado durante años la responsabilidad de asegurar nuestra supervivencia."

# game/scripts/day20.rpy:3773
translate spanish d20b_68addbfd:

    # Sera "...and should I not lead by example?"
    Sera "... ¿y no debería dar ejemplo?"

# game/scripts/day20.rpy:3776
translate spanish d20b_5fed8cd4:

    # Sera "Become my Elder, Paris. Serve under me, guide over this young city..."
    Sera "Conviértase en mi Anciano, París. Sírvame bajo mis órdenes, guíe a esta joven ciudad..."

# game/scripts/day20.rpy:3779
translate spanish d20b_352465ad:

    # Sera "...and give me the first child of this new world."
    Sera "... y déme el primer hijo de este nuevo mundo."

# game/scripts/day20.rpy:3782
translate spanish d20b_bf04a847:

    # Sera "With your support, the others will quickly follow."
    Sera "Con su apoyo, los demás seguirán rápidamente."

# game/scripts/day20.rpy:3783
translate spanish d20b_0e46b4a3:

    # Sera "And I promise you will have a say in shaping more than the rebirth of our society. I promise you power and standing in it."
    Sera "Y le prometo que tendrá voz en la formación de algo más que el renacimiento de nuestra sociedad. Le prometo poder y posición en ella."

# game/scripts/day20.rpy:3784
translate spanish d20b_42c323e0:

    # Sera "Let us make history... instead of writing about it."
    Sera "Hagamos historia... en lugar de escribir sobre ella."

# game/scripts/day20.rpy:3786
translate spanish d20b_0ca039cc:

    # QS "...help me become the first Queen of Zeta."
    QS "... ayúdeme a convertirme en la primera Reina de Zeta."

# game/scripts/day20.rpy:3794
translate spanish d20b_b8367e7b:

    # EPN "You know what followed, dear reader.{w=6}{nw}"
    EPN "Sabe lo que siguió, querido lector.{w=6}{nw}"

# game/scripts/day20.rpy:3796
translate spanish d20b_37fc7cee:

    # EPN "You were raised in the shadow of my decision.{w=6}{nw}"
    EPN "Fue criado a la sombra de mi decisión.{w=6}{nw}"

# game/scripts/day20.rpy:3806
translate spanish d20b_6d7cfbb2:

    # EPN "And so history was written."
    EPN "Y así se escribió la historia."

# game/scripts/day20.rpy:3807
translate spanish d20b_d7e52207:

    # EPN "With my child growing inside her, she advanced her desire to forge a culture that would last for generations to come."
    EPN "Con mi hijo creciendo dentro de ella, impulsó su deseo de forjar una cultura que durara para las generaciones venideras."

# game/scripts/day20.rpy:3810
translate spanish d20b_5dacdbea:

    # EPN "We got to work in more ways than one, and a few months later she was officially hailed as the sovereign of Zeta."
    EPN "Nos pusimos a trabajar en más de un sentido, y unos meses después fue aclamada oficialmente como soberana de Zeta."

# game/scripts/day20.rpy:3813
translate spanish d20b_1d0726e8:

    # EPN "We started claiming that those irregularities who appeared in the skies were a godly sign."
    EPN "Empezamos a afirmar que esas irregularidades que aparecían en el cielo eran una señal divina."

# game/scripts/day20.rpy:3814
translate spanish d20b_1363db96:

    # EPN "People have an affinity for the divine, the inexplicable. But somehow we were protected by them. Maybe we were blessed, chosen if you will."
    EPN "La gente tiene afinidad por lo divino, lo inexplicable. Pero de algún modo estábamos protegidos por ellos. Quizá estábamos bendecidos, elegidos si se quiere."

# game/scripts/day20.rpy:3817
translate spanish d20b_bdb5cab9:

    # EPN "Eventually, we started to treat outsiders differently, not as fellow refugees from destruction, but as resources."
    EPN "Con el tiempo, empezamos a tratar a los forasteros de otra manera, no como compañeros refugiados de la destrucción, sino como recursos."

# game/scripts/day20.rpy:3820
translate spanish d20b_dfacdc12:

    # EPN "As people who could not be fully trusted and, in time, as something less than us."
    EPN "Como personas en las que no se podía confiar plenamente y, con el tiempo, como algo menos que nosotros."

# game/scripts/day20.rpy:3823
translate spanish d20b_5450c4a9:

    # EPN "Survival and safety came at a cost, after all. And, we reasoned, it ultimately was their choice to approach us, we had things they needed and they could offer nothing but themselves."
    EPN "La supervivencia y la seguridad tenían un precio, después de todo. Y, razonamos, al final era su elección acercarse a nosotros, nosotros teníamos cosas que ellos necesitaban y ellos no podían ofrecer nada más que a sí mismos."

# game/scripts/day20.rpy:3826
translate spanish d20b_b1f8ba8f:

    # EPN "As [QS] commanded, foreigners were to be a potential liability to our ways, and had to become assimilated, forcefully, if necessary."
    EPN "Como [QS] ordenó, los extranjeros debían ser un riesgo potencial para nuestras costumbres, y tenían que ser asimilados, por la fuerza si era necesario."

# game/scripts/day20.rpy:3829
translate spanish d20b_ea4de06b:

    # EPN "Over the years, it was agreed on that they'd be allocated to community members, and pay their debt of survival with labour."
    EPN "Con los años, se acordó que serían asignados a miembros de la comunidad y pagarían su deuda de supervivencia con trabajo."

# game/scripts/day20.rpy:3832
translate spanish d20b_585e404f:

    # EPN "But not everyone was happy with the status quo."
    EPN "Pero no todo el mundo estaba contento con el statu quo."

# game/scripts/day20.rpy:3833
translate spanish d20b_179f39f1:

    # EPN "Some old friends said they no longer recognized us."
    EPN "Algunos viejos amigos dijeron que ya no nos reconocían."

# game/scripts/day20.rpy:3836
translate spanish d20b_ea64fb48:

    # EPN "Some defied the nascent structure of our city, the philosophy behind our new existence."
    EPN "Algunos desafiaron la incipiente estructura de nuestra ciudad, la filosofía detrás de nuestra nueva existencia."

# game/scripts/day20.rpy:3837
translate spanish d20b_d9085472:

    # EPN "Others refused to live in a world where technology was shunned, even after it almost destroyed the world, convinced as they were that precious resources were being wasted."
    EPN "Otros se negaron a vivir en un mundo donde la tecnología era rechazada, incluso después de que casi destruyera el mundo, convencidos de que se estaban desperdiciando recursos valiosos."

# game/scripts/day20.rpy:3840
translate spanish d20b_f396739b:

    # EPN "So they departed trying to find their own luck outside these walls."
    EPN "Así que partieron buscando su propia suerte fuera de estos muros."

# game/scripts/day20.rpy:3841
translate spanish d20b_e6ee54c6:

    # EPN "We never heard from them again... did they find peace in those dunes?"
    EPN "Nunca volvimos a saber de ellos... ¿encontraron la paz en esas dunas?"

# game/scripts/day20.rpy:3847
translate spanish d20b_9f236b52:

    # EPN "Being free to shape a new society, we indulged in our wants as we saw fit."
    EPN "Al ser libres para dar forma a una nueva sociedad, nos entregamos a nuestros deseos como mejor nos pareció."

# game/scripts/day20.rpy:3850
translate spanish d20b_5f2c357a:

    # EPN "Now, that I had participated in the laws that lead to this moment, the moment had come to choose a man for Skye."
    EPN "Ahora que yo había participado en las leyes que llevaron a este momento, había llegado la hora de elegir un hombre para Skye."

# game/scripts/day20.rpy:3853
translate spanish d20b_2a8276ab:

    # EPN "She stood in front of me, accepting her new fate. The traces of the past on her face were gone."
    EPN "Ella se plantó ante mí, aceptando su nuevo destino. Los rastros del pasado en su rostro habían desaparecido."

# game/scripts/day20.rpy:3856
translate spanish d20b_fc20046f:

    # EPN "So when the moment came, to decide which man deserved her, and the offspring she'd bless our new city with..."
    EPN "Así que cuando llegó el momento, de decidir qué hombre la merecía, y la descendencia con la que bendeciría nuestra nueva ciudad..."

# game/scripts/day20.rpy:3857
translate spanish d20b_e169f631:

    # EPN "...that's when I chose the only right man for her."
    EPN "... fue entonces cuando elegí al único hombre adecuado para ella."

# game/scripts/day20.rpy:3860
translate spanish d20b_f9846fbf:

    # EPN "Myself."
    EPN "A mí mismo."

# game/scripts/day20.rpy:3863
translate spanish d20b_aaead68f:

    # EPN "While she lost everything that was dear to her from the old world..."
    EPN "Mientras ella perdía todo lo que le era querido del viejo mundo..."

# game/scripts/day20.rpy:3864
translate spanish d20b_ed4b1e52:

    # EPN "...this fragment of a degraded culture endured. The libertine ways of the old world had remained embedded in our consciousness."
    EPN "... este fragmento de una cultura degradada perduró. Las costumbres libertinas del viejo mundo habían quedado incrustadas en nuestra conciencia."

# game/scripts/day20.rpy:3867
translate spanish d20b_5f99cd1f:

    # EPN "And for the first time, despite my convictions, I was about to relish in it."
    EPN "Y por primera vez, a pesar de mis convicciones, estaba a punto de deleitarme en ellas."

# game/scripts/day20.rpy:3870
translate spanish d20b_d625e748:

    # EPN "...and so she knelt before me, conscious of her new responsibility."
    EPN "... y así se arrodilló ante mí, consciente de su nueva responsabilidad."

# game/scripts/day20.rpy:3873
translate spanish d20b_4a675ec4:

    # EPN "In the age before the fall, she urged me to adapt to her future. After the ruin, it was she who was told to endure mine."
    EPN "En la era anterior a la caída, ella me instó a adaptarme a su futuro. Tras la ruina, fue ella quien tuvo que soportar el mío."

# game/scripts/day20.rpy:3874
translate spanish d20b_65ae8928:

    # EPN "Now, she was finally ready to do what was expected of her."
    EPN "Ahora, por fin estaba lista para hacer lo que se esperaba de ella."

# game/scripts/day20.rpy:3878
translate spanish d20b_956cfb11:

    # EPN "But, with my sunset years also came regret. Regret for my misdeeds, for my words, for the perils of absolute power. Regret for the society I helped create."
    EPN "Pero, con mis años crepusculares también llegó el arrepentimiento. Arrepentimiento por mis fechorías, por mis palabras, por los peligros del poder absoluto. Arrepentimiento por la sociedad que ayudé a crear."

# game/scripts/day20.rpy:3879
translate spanish d20b_88b35e7d:

    # EPN "Let this, dear reader, be my atonement and my written warning to you, and all the people in Zeta."
    EPN "Que esto, querido lector, sea mi expiación y mi advertencia escrita para ti, y para toda la gente de Zeta."

# game/scripts/day20.rpy:3882
translate spanish d20b_8e8dca33:

    # EPN "I, Paris Sivara, authored the fairytale that became your reality."
    EPN "Yo, Paris Sivara, autoricé el cuento de hadas que se convirtió en vuestra realidad."

# game/scripts/day20.rpy:3883
translate spanish d20b_6c4f38c1:

    # EPN "Like all such stories, it has grown larger than its maker and now demands worship instead of belief."
    EPN "Como todas esas historias, ha crecido más que su creador y ahora exige culto en lugar de creencia."

# game/scripts/day20.rpy:3884
translate spanish d20b_f40f7af3:

    # EPN "There was no divine hand in the Queen's rise, and Zeta was never sanctified by anything but our schemes and ambitions, however well intended they may have been."
    EPN "No hubo mano divina en el ascenso de la Reina, y Zeta nunca fue santificada por nada más que por nuestros planes y ambiciones, por bienintencionados que pudieran haber sido."

# game/scripts/day20.rpy:3892
translate spanish d20b_80239f19:

    # Z "There are a few smaller parchments around here."
    Z "Hay algunos pergaminos más pequeños por aquí."

# game/scripts/day20.rpy:3893
translate spanish d20b_e4ffcf0c:

    # Z "But that is for another time. I think we have read enough."
    Z "Pero eso será para otro momento. Creo que ya hemos leído suficiente."

# game/scripts/day20.rpy:3896
translate spanish d20b_06a591f0:

    # S "So... now we know for sure. All those tales we were told... a lie crafted by people desperate to survive and cling to the power they were gaining."
    S "Así que... ahora lo sabemos con certeza. Todos esos cuentos que nos contaron... una mentira fabricada por gente desesperada por sobrevivir y aferrarse al poder que estaban ganando."

# game/scripts/day20.rpy:3899
translate spanish d20b_9ab09b11:

    # Z "They were..."
    Z "Eran..."

# game/scripts/day20.rpy:3901
translate spanish d20b_a1685880:

    # Z "I... Now is not the time. We should load what we can save to the car, and read more, or read this again, and think about the implications later."
    Z "Yo... Ahora no es el momento. Deberíamos cargar todo lo que podamos salvar en el coche, y leer más, o releer esto, y pensar en las implicaciones más tarde."

# game/scripts/day20.rpy:3902
translate spanish d20b_fde49c7f:

    # Z "Can you help me, [S]?"
    Z "¿Puedes ayudarme, [S]?"

# game/scripts/day20.rpy:3905
translate spanish d20b_28a1633e:

    # S "I will try my best."
    S "Haré lo que pueda."

# game/scripts/day20.rpy:3908
translate spanish d20b_7b47b6e2:

    # Z "Then let's get moving."
    Z "Entonces pongámonos en marcha."

# game/scripts/day20.rpy:3911
translate spanish d20b_73007046:

    # Z "Is everything okay, Neith?"
    Z "¿Va todo bien, Neith?"

# game/scripts/day20.rpy:3914
translate spanish d20b_c9400a8a:

    # Ne "I... guess. As far as the first Queen goes..."
    Ne "Supongo... En lo que respecta a la primera Reina..."

# game/scripts/day20.rpy:3915
translate spanish d20b_ae0ce148:

    # Ne "...perhaps I was hoping for her to be... I don't know... more?"
    Ne "... quizá esperaba que fuera... no sé... ¿algo más?"

# game/scripts/day20.rpy:3916
translate spanish d20b_a94eadf9:

    # Ne "More importantly. I am considering whether I should not seal this tomb and burn every scrap of paper. The City is not ready for this discovery."
    Ne "Más importante aún. Estoy considerando si no debería sellar esta tumba y quemar cada pedazo de papel. La Ciudad no está preparada para este descubrimiento."

# game/scripts/day20.rpy:3919
translate spanish d20b_83cb8833:

    # Z "She may not have been what you or me thought she was..."
    Z "Ella puede que no fuera lo que tú o yo pensábamos que era..."

# game/scripts/day20.rpy:3922
translate spanish d20b_28fc7b95:

    # Z "...but that does not mean she was any less crucial to the survival of her people and the founding of your realm."
    Z "... pero eso no significa que fuera menos crucial para la supervivencia de su gente y la fundación de tu reino."

# game/scripts/day20.rpy:3923
translate spanish d20b_bfae7565:

    # Z "To your point, I understand your reasoning, but maybe it's too soon to make that decision. Let's get out of here to someplace safe, lick our wounds, and then decide."
    Z "En cuanto a tu punto, entiendo tu razonamiento, pero quizá es demasiado pronto para tomar esa decisión. Salgamos de aquí a algún lugar seguro, lamamos nuestras heridas, y entonces..."

# game/scripts/day20.rpy:3924
translate spanish d20b_0e2a5d7b:

    # Z "There's always time to burn these papers, as long as we keep them safe."
    Z "Siempre hay tiempo para quemar esos papeles, siempre que los mantengamos a salvo."

# game/scripts/day20.rpy:3929
translate spanish d20b_f624f172:

    # Ne "You are asking me to trust the endurance of my reign to your word that you will keep it secret. Maybe I should bury you both here, to be sure."
    Ne "Me estás pidiendo que confíe la perdurabilidad de mi reinado a tu palabra de que lo mantendrás en secreto. Quizá debería enterraros aquí a los dos, para asegurarme."

# game/scripts/day20.rpy:3930
translate spanish d20b_10fc30f5:

    # Z "Or I could kill you here and now and destroy everything Zeta stands for. We have bled together and we have proven ourselves to you. Let me keep the papers safe until you decide. I promise we will abide by your decision."
    Z "O podría matarte aquí y ahora y destruir todo lo que Zeta representa. Hemos sangrado juntos y te hemos demostrado nuestra valía. Déjame guardar los papeles a salvo hasta que decidas. Prometo que acataremos tu decisión."

# game/scripts/day20.rpy:3931
translate spanish d20b_5c866370:

    # Ne "So be it. Gods protect us all. Speak not a word of this to anyone!"
    Ne "Así sea. Que los dioses nos protejan a todos. ¡No le digas ni una palabra de esto a nadie!"

# game/scripts/day20.rpy:3936
translate spanish d20b_4ef0ede7:

    # Ne "I am trusting you to keep these papers secret from anyone, until I decide what to do with them, Stalker."
    Ne "Confío en que mantendrás estos papeles en secreto para todos, hasta que decida qué hacer con ellos, Acechador."

# game/scripts/day20.rpy:3937
translate spanish d20b_6987116e:

    # Z "Trust me, I understand their importance and will make sure they don't fall in the wrong hands."
    Z "Confía en mí, entiendo su importancia y me aseguraré de que no caigan en manos equivocadas."

# game/scripts/day20.rpy:3944
translate spanish d20b_e7aec6ea:

    # Ne "...but don't think this little adventure relieves you from your palace duties, Stalker. This must not be spoken about with anyone, until further notice, and we must keep up appearances for the world."
    Ne "... pero no creas que esta pequeña aventura te exime de tus obligaciones en el palacio, Acechador. No se debe hablar de esto con nadie, hasta nuevo aviso, y debemos mantener las apariencias ante el mundo."

# game/scripts/day20.rpy:3947
translate spanish d20b_32059c18:

    # Z "Of course I won't forget that."
    Z "Por supuesto que no lo olvidaré."

# game/scripts/day20.rpy:3952
translate spanish d20b_65555694:

    # "Hours later..."
    "Horas después..."

# game/scripts/day20.rpy:3962
translate spanish d20b_dbfa5b79:

    # S "Finally, home! [persistent.mom!c]! We're back!"
    S "¡Por fin, casa! ¡[persistent.mom!c]! ¡Hemos vuelto!"

# game/scripts/day20.rpy:3963
translate spanish d20b_aca1f894:

    # W "Blessed be Mer-... I am so relieved, [S]!"
    W "Bendita sea Mer-... ¡Estoy tan aliviada, [S]!"

# game/scripts/day20.rpy:3966
translate spanish d20b_188367e3:

    # Z "Here we are. Are you certain to go back alone?"
    Z "Aquí estamos. ¿Estás segura de volver sola?"

# game/scripts/day20.rpy:3967
translate spanish d20b_24e645ae:

    # Q "I have to. And I don't need you to risk your life again."
    Q "Tengo que hacerlo. Y no necesito que arriesgues tu vida otra vez."

# game/scripts/day20.rpy:3970
translate spanish d20b_fa2c1f40:

    # Q "Are you sure I can trust you to keep the papers?"
    Q "¿Estás seguro de que puedo confiar en que guardarás los papeles?"

# game/scripts/day20.rpy:3971
translate spanish d20b_089d060d:

    # Q "If what we found ever reaches the wrong hands, you will..."
    Q "Si lo que encontramos llega a caer en malas manos, tú..."

# game/scripts/day20.rpy:3973
translate spanish d20b_6d5ffe84:

    # Z "We need to study them, and then decide what to do with them. I think our house is the best place to do that safe from prying eyes."
    Z "Necesitamos estudiarlos, y luego decidir qué hacer con ellos. Creo que nuestra casa es el mejor lugar para hacerlo a salvo de miradas indiscretas."

# game/scripts/day20.rpy:3976
translate spanish d20b_be37314e:

    # Q "\"Study them...\" Especially that last part, huh?"
    Q "\"Estudiarlos...\" Sobre todo esa última parte, ¿eh?"

# game/scripts/day20.rpy:3977
translate spanish d20b_8d8909bf:

    # Z "That's not what..."
    Z "No es eso lo que..."

# game/scripts/day20.rpy:3980
translate spanish d20b_753f6ebe:

    # Q "I'm just messing with you."
    Q "Solo te estoy tomando el pelo."

# game/scripts/day20.rpy:3983
translate spanish d20b_2309c02e:

    # Q "Thank you for everything, [persistent.player_name]. I should apologise. My mere presence put you and [S] in mortal danger."
    Q "Gracias por todo, [persistent.player_name]. Debería disculparme. Mi mera presencia os puso a ti y a [S] en peligro de muerte."

# game/scripts/day20.rpy:3984
translate spanish d20b_a7e5c9a0:

    # Q "I will not forget this."
    Q "No olvidaré esto."

# game/scripts/day20.rpy:3985
translate spanish d20b_c214ac1f:

    # Z "In the end we're safe and sound. That is what matters. We will see about the rest with a rested mind. Have a safe walk home, Neith."
    Z "Al final estamos sanos y salvos. Eso es lo que importa. Ya veremos el resto con la mente descansada. Que tengas un camino seguro a casa, Neith."

# game/scripts/day20.rpy:3991
translate spanish d20b_29a2de66:

    # "She leaves..."
    "Se marcha..."

# game/scripts/day20.rpy:3994
translate spanish d20b_8f65f127:

    # W "I am so glad you're not hurt this time, [S]."
    W "Me alegro mucho de que no te hayas hecho daño esta vez, [S]."

# game/scripts/day20.rpy:3997
translate spanish d20b_6a1018b4:

    # S "I'm just fine, [persistent.mom], don't worry about me!"
    S "Estoy bien, [persistent.mom], ¡no te preocupes por mí!"

# game/scripts/day20.rpy:3998
translate spanish d20b_0f71d6df:

    # S "But..."
    S "Pero..."

# game/scripts/day20.rpy:4001
translate spanish d20b_71795571:

    # W "{i}*gasp*{/i} Love!"
    W "{i}*jadeo*{/i} ¡Amor!"

# game/scripts/day20.rpy:4004
translate spanish d20b_70dac837:

    # Z "Hey, love..."
    Z "Hola, amor..."

# game/scripts/day20.rpy:4007
translate spanish d20b_834df94e:

    # W "Old man, tell me at once what happened, and who did this to you, so I can deal with them personally!"
    W "Querido, dime de inmediato qué pasó y quién te hizo esto, ¡para que me encargue de él personalmente!"

# game/scripts/day20.rpy:4010
translate spanish d20b_f98565e0:

    # Z "They're already dead, [W]. We just ran into some problems. It's part of the job, you know this."
    Z "Ya están muertos, [W]. Solo tuvimos algunos problemas. Es parte del trabajo, ya lo sabes."

# game/scripts/day20.rpy:4013
translate spanish d20b_e1a9600b:

    # Z "We're bruised but mostly unharmed, and I am glad to see your pretty face again."
    Z "Estamos magullados pero casi ilesos, y me alegra volver a ver tu bonita cara."

# game/scripts/day20.rpy:4016
translate spanish d20b_e4c3e70a:

    # W "Well then... let me do {i}my{/i} job and take care of my husband."
    W "Bueno entonces... déjame hacer {i}mi{/i} trabajo y cuidar de mi esposo."

# game/scripts/day20.rpy:4021
translate spanish d20b_011b294b:

    # Zt "It is time to lean back, and enjoy some well deserved rest."
    Zt "Es hora de recostarse y disfrutar de un merecido descanso."

# game/scripts/day20.rpy:4026
translate spanish d20b_56b32da7:

    # W "Husband..."
    W "Marido..."

# game/scripts/day20.rpy:4033
translate spanish d20b_9667796d:

    # Z "Mmh...?"
    Z "¿Mmm...?"

# game/scripts/day20.rpy:4036
translate spanish d20b_29bcc727:

    # Z "Oh, hello..."
    Z "Oh, hola..."

# game/scripts/day20.rpy:4037
translate spanish d20b_30e2a1b4:

    # W "Up here, old man."
    W "Aquí arriba, amor."

# game/scripts/day20.rpy:4040
translate spanish d20b_91e0b411:

    # W "I'm glad to see you getting better."
    W "Me alegro de verte mejorar."

# game/scripts/day20.rpy:4043
translate spanish d20b_6d5b881f:

    # Z "How long have I slept..."
    Z "¿Cuánto tiempo he dormido...?"

# game/scripts/day20.rpy:4047
translate spanish d20b_d378facf:

    # W "For about nine hours. I told the girls to not disturb you."
    W "Unas nueve horas. Les dije a las chicas que no te molestaran."

# game/scripts/day20.rpy:4049
translate spanish d20b_d5356846:

    # W "For about nine hours. I told [A] not to disturb you."
    W "Unas nueve horas. Le dije a [A] que no te molestara."

# game/scripts/day20.rpy:4053
translate spanish d20b_225ad964:

    # Z "I hope they're not too concerned."
    Z "Espero que no estén demasiado preocupados."

# game/scripts/day20.rpy:4055
translate spanish d20b_467f52a6:

    # Z "I know my girl. She must be concerned."
    Z "Conozco a mi chica. Debe de estar preocupada."

# game/scripts/day20.rpy:4058
translate spanish d20b_c19ac202_1:

    # "She smiles..."
    "Sonríe..."

# game/scripts/day20.rpy:4062
translate spanish d20b_3f93eb65:

    # W "Of course they are. They have been waiting to see you."
    W "Claro que lo están. Llevan tiempo esperando verte."

# game/scripts/day20.rpy:4064
translate spanish d20b_60ef2e6c:

    # W "More than you can imagine. She's dying to see you."
    W "Más de lo que imaginas. Se muere por verte."

# game/scripts/day20.rpy:4067
translate spanish d20b_66dfae1d:

    # W "...but first, I want a moment with my husband alone."
    W "... pero primero, quiero un momento a solas con mi esposo."

# game/scripts/day20.rpy:4070
translate spanish d20b_d712798b:

    # "She kisses you passionately, gentle, but demanding."
    "Te besa apasionadamente, suave, pero exigente."

# game/scripts/day20.rpy:4073
translate spanish d20b_794e07ca:

    # W "...mh."
    W "... mh."

# game/scripts/day20.rpy:4076
translate spanish d20b_4ce6947f:

    # "You kiss for a while, and for the first time since your return, you soak in the familiar feelings of safety, home, comfort."
    "Os besáis un rato, y por primera vez desde tu regreso, te empapas de esas sensaciones familiares de seguridad, hogar, confort."

# game/scripts/day20.rpy:4077
translate spanish d20b_5ec2517d:

    # Zt "What's a rough encounter once in a while, if I can come home to this...?"
    Zt "¿Qué es un mal encuentro de vez en cuando, si puedo volver a casa a esto...?"

# game/scripts/day20.rpy:4081
translate spanish d20b_1b3000f7:

    # Zt "Right... it's nothing."
    Zt "Cierto... no es nada."

# game/scripts/day20.rpy:4087
translate spanish d20b_5fc59991:

    # W "I missed you, husband."
    W "Te eché de menos, marido."

# game/scripts/day20.rpy:4089
translate spanish d20b_07241ce9:

    # W "We all did."
    W "Todos te echamos de menos."

# game/scripts/day20.rpy:4091
translate spanish d20b_eca5f1fd:

    # W "And so did [A]."
    W "Y [A] también."

# game/scripts/day20.rpy:4094
translate spanish d20b_6738b0fa:

    # W "Speaking of..."
    W "Hablando de eso..."

# game/scripts/day20.rpy:4096
translate spanish d20b_9336ff93:

    # W "...I think they will want to see you soon."
    W "... creo que querrán verte pronto."

# game/scripts/day20.rpy:4098
translate spanish d20b_3b938517:

    # W "...I think she will very much want to see you soon."
    W "... creo que querrá verte mucho muy pronto."

# game/scripts/day20.rpy:4102
translate spanish d20b_89e445c4:

    # W "In fact, they each wanted a moment alone time with you. I am sure I don't know what that is all about ."
    W "De hecho, cada una quería un momento a solas contigo. Seguro que no tengo ni idea de qué va todo eso."

# game/scripts/day20.rpy:4104
translate spanish d20b_c107d441:

    # W "In fact, she wanted a moment alone with you. Isn't that sweet?"
    W "De hecho, ella quería un momento a solas contigo. ¿No es dulce?"

# game/scripts/day20.rpy:4108
translate spanish d20b_fa57596f:

    # Z "I somehow think you know exactly what they want."
    Z "De algún modo creo que sabes exactamente lo que quieren."

# game/scripts/day20.rpy:4110
translate spanish d20b_595436a7:

    # Z "It is."
    Z "Lo es."

# game/scripts/day20.rpy:4113
translate spanish d20b_cfb7bf13:

    # W "Well then, I will come to bed later. For now, enjoy the rest of the night, my warrior."
    W "Bueno, entonces, yo me acostaré más tarde. Por ahora, disfruta del resto de la noche, mi guerrero."

# game/scripts/day20.rpy:4116
translate spanish d20b_c1edff07:

    # Z "Good night, my Queen."
    Z "Buenas noches, mi Reina."

# game/scripts/day20.rpy:4119
translate spanish d20b_c538c60c:

    # A "Um... [persistent.dad]...?"
    A "Em... ¿[persistent.dad]...?"

# game/scripts/day20.rpy:4122
translate spanish d20b_bec6e073:

    # Z "Mh... what is..."
    Z "Mmm... ¿qué es...?"

# game/scripts/day20.rpy:4125
translate spanish d20b_8bb0d922:

    # A "Ahh!"
    A "¡Ah!"

# game/scripts/day20.rpy:4128
translate spanish d20b_7c979a14:

    # Z "[A]...?"
    Z "¿[A]...?"

# game/scripts/day20.rpy:4131
translate spanish d20b_c06a16b7:

    # A "S-sorry... you jumped up so suddenly..."
    A "P-perdón... te has levantado tan de repente..."

# game/scripts/day20.rpy:4134
translate spanish d20b_e87c5236:

    # Z "I... guess I was still out there, for a moment."
    Z "Supongo... que por un momento todavía estaba allí fuera."

# game/scripts/day20.rpy:4137
translate spanish d20b_e4cab320:

    # A "I didn't want to interrupt your sleep..."
    A "No quería interrumpir tu sueño..."

# game/scripts/day20.rpy:4138
translate spanish d20b_29d53953:

    # A "But when [S] mentioned that you were wounded, I got concerned..."
    A "Pero cuando [S] mencionó que estabas herido, me preocupé..."

# game/scripts/day20.rpy:4141
translate spanish d20b_4f2a1542:

    # A "But... I'm happy to see you are safe."
    A "Pero... me alegra verte sano y salvo."

# game/scripts/day20.rpy:4143
translate spanish d20b_285a8fa2:

    # A "Thank you for fighting for us out there, [persistent.dad]."
    A "Gracias por luchar por nosotras allí fuera, [persistent.dad]."

# game/scripts/day20.rpy:4145
translate spanish d20b_1539c824:

    # A "Thank you for fighting for us out there."
    A "Gracias por luchar por nosotras allí fuera."

# game/scripts/day20.rpy:4148
translate spanish d20b_7479d256:

    # Z "And thank you for caring. I appreciate it, [A]."
    Z "Y gracias por preocuparte. Te lo agradezco, [A]."

# game/scripts/day20.rpy:4151
translate spanish d20b_c19ac202_2:

    # "She smiles..."
    "Sonríe..."

# game/scripts/day20.rpy:4155
translate spanish d20b_937d4fa6:

    # A "I... need to go now. There is someone else who wants to see you."
    A "Yo... tengo que irme ya. Hay alguien más que quiere verte."

# game/scripts/day20.rpy:4157
translate spanish d20b_b704a331:

    # A "I... think I will wait until you are fully recovered. [persistent.mom!c] wants me to help out a bit."
    A "Yo... creo que esperaré hasta que te recuperes del todo. [persistent.mom!c] quiere que eche una mano por aquí."

# game/scripts/day20.rpy:4158
translate spanish d20b_b71a5592:

    # A "See you tomorrow, [persistent.dad]?"
    A "¿Hasta mañana, [persistent.dad]?"

# game/scripts/day20.rpy:4161
translate spanish d20b_ff0feb37:

    # Z "Alright then. See you tomorrow, [A]."
    Z "De acuerdo entonces. Hasta mañana, [A]."

# game/scripts/day20.rpy:4166
translate spanish d20b_d65276f3:

    # "You fall asleep quickly, and sleep until the next morning."
    "Te duermes rápidamente y duermes hasta la mañana siguiente."

# game/scripts/day20.rpy:4172
translate spanish d20b_157fcc04:

    # E "Master?"
    E "¿Amo?"

# game/scripts/day20.rpy:4175
translate spanish d20b_27f9a0aa:

    # Z "Emilia?"
    Z "¿Emilia?"

# game/scripts/day20.rpy:4178
translate spanish d20b_7ab45ee5:

    # E "Welcome home, Master."
    E "Bienvenido a casa, Amo."

# game/scripts/day20.rpy:4181
translate spanish d20b_4ebb0e05:

    # Z "Your dress..."
    Z "Tu vestido..."

# game/scripts/day20.rpy:4184
translate spanish d20b_ab654fe7:

    # Z "...it looks very nice on you."
    Z "... te queda muy bien."

# game/scripts/day20.rpy:4187
translate spanish d20b_d78e9a6e:

    # E "Thank you very much, the Mistress, she..."
    E "Muchas gracias, Ama, ella..."

# game/scripts/day20.rpy:4188
translate spanish d20b_05a7dc6e:

    # E "...she wanted me to wear it today, for you."
    E "... ella quería que lo llevara puesto hoy, para ti."

# game/scripts/day20.rpy:4191
translate spanish d20b_1b7a5a5d:

    # Z "She has good taste, yes."
    Z "Tiene buen gusto, sí."

# game/scripts/day20.rpy:4195
translate spanish d20b_f29024c6:

    # E "Master, I know that I am merely your servant, but..."
    E "Amo, sé que solo soy su sirvienta, pero..."

# game/scripts/day20.rpy:4198
translate spanish d20b_5070210a:

    # E "...please be careful, out there? I can not think of what would happen, should you one day not return home."
    E "... por favor, ¿tenga cuidado ahí fuera? No puedo imaginar qué pasaría, si un día usted no volviera a casa."

# game/scripts/day20.rpy:4201
translate spanish d20b_edf951b8:

    # Z "I will try my best, Emilia. I appreciate your concern."
    Z "Haré todo lo que pueda, Emilia. Agradezco tu preocupación."

# game/scripts/day20.rpy:4204
translate spanish d20b_a9f5a4b6:

    # E "Thank you for hearing me out, Master. I have grown to care for this family, and would not want to be sold to some other master."
    E "Gracias por escucharme, Amo. He llegado a encariñarme con esta familia, y no me gustaría ser vendida a otro amo."

# game/scripts/day20.rpy:4207
translate spanish d20b_4e6abe9f:

    # E "And if you desire a bath... you know that all you have to do..."
    E "Y si desea un baño... ya sabe que solo tiene que levantar la mano."

# game/scripts/day20.rpy:4210
translate spanish d20b_97d058e0:

    # E "...Is raise your hand."
    E "... ya sabe que solo tiene que levantar la mano."

# game/scripts/day20.rpy:4211
translate spanish d20b_5b222207:

    # E "Until then, rest well, Master."
    E "Hasta entonces, descanse bien, Amo."

# game/scripts/day20.rpy:4214
translate spanish d20b_448027c5:

    # Z "You're a good maid, Emilia. See you tomorrow."
    Z "Eres una buena criada, Emilia. Hasta mañana."

# game/scripts/day20.rpy:4216
translate spanish d20b_e81e22f8:

    # E "Master, perhaps it is not my place to ask you, but..."
    E "Amo, quizá no me corresponde preguntarle, pero..."

# game/scripts/day20.rpy:4219
translate spanish d20b_21d13f36:

    # E "...please be more careful, out there?"
    E "... ¿por favor tenga más cuidado, allí fuera?"

# game/scripts/day20.rpy:4220
translate spanish d20b_02f3d929:

    # E "You have given me a new life, and I don't want to spend it without you."
    E "Usted me ha dado una nueva vida, y no quiero pasarla sin usted."

# game/scripts/day20.rpy:4223
translate spanish d20b_1c3885c1:

    # Z "I will try my best, Emilia. But out there, you encounter the unpredictable."
    Z "Haré lo posible, Emilia. Pero allí fuera, uno se encuentra con lo impredecible."

# game/scripts/day20.rpy:4226
translate spanish d20b_9e39b169:

    # E "If it helps... when you are out there, know that the Mistress and I are always thinking about you."
    E "Si sirve de algo... cuando estés ahí fuera, sabe que la Ama y yo siempre estamos pensando en ti."

# game/scripts/day20.rpy:4229
translate spanish d20b_bc3e1b72:

    # Z "I will. Thank you."
    Z "Lo tendré en cuenta. Gracias."

# game/scripts/day20.rpy:4232
translate spanish d20b_9855e3ff:

    # E "And if you desire a bath..."
    E "Y si deseas un baño..."

# game/scripts/day20.rpy:4235
translate spanish d20b_97d058e0_1:

    # E "...Is raise your hand."
    E "... ya sabe que solo tiene que levantar la mano."

# game/scripts/day20.rpy:4236
translate spanish d20b_5b222207_1:

    # E "Until then, rest well, Master."
    E "Hasta entonces, descanse bien, Amo."

# game/scripts/day20.rpy:4240
translate spanish d20b_448027c5_1:

    # Z "You're a good maid, Emilia. See you tomorrow."
    Z "Eres una buena criada, Emilia. Hasta mañana."

# game/scripts/day20.rpy:4242
translate spanish d20b_1b8c5e00:

    # Z "Have a good night, Emilia."
    Z "Que pases buena noche, Emilia."

# game/scripts/day20.rpy:4249
translate spanish d20b_1f16d93b:

    # "You feel delicate hands touching your chest..."
    "Sientes unas manos delicadas tocando tu pecho..."

# game/scripts/day20.rpy:4252
translate spanish d20b_a83e9fd0:

    # Z "Mh... I fell asleep again..."
    Z "Mh... Me he vuelto a dormir..."

# game/scripts/day20.rpy:4255
translate spanish d20b_0eefb305:

    # Z "I recognize that red hair... but that dress... and the collar."
    Z "Reconozco ese pelo rojo... pero ese vestido... y el collar."

# game/scripts/day20.rpy:4256
translate spanish d20b_c306872e:

    # F "The Mistress allowed me to wear this. Do you like it, Master?"
    F "El Ama me permitió ponerme esto. ¿Te gusta, Amo?"

# game/scripts/day20.rpy:4257
translate spanish d20b_41b49433:

    # Z "I do..."
    Z "Me gusta..."

# game/scripts/day20.rpy:4260
translate spanish d20b_c1fe7ef4:

    # F "I can ask the Mistress to wear it again, next time you will have me..."
    F "Puedo pedirle al Ama que lo vuelva a llevar, la próxima vez que me tengas..."

# game/scripts/day20.rpy:4263
translate spanish d20b_fb663ad6:

    # "The way she hints at it makes your mind drift. Your eyes wander to her plump lips, her sultry smile, and then back to her green eyes..."
    "La forma en que lo insinúa hace que tu mente divague. Tus ojos recorren sus labios carnosos, su sonrisa sensual, y luego vuelven a sus ojos verdes..."

# game/scripts/day20.rpy:4266
translate spanish d20b_16968637:

    # F "Sadly, Mistress has told me to let you rest..."
    F "Por desgracia, la ama me ha dicho que le deje descansar..."

# game/scripts/day20.rpy:4270
translate spanish d20b_1cdfbe9f:

    # F "...but I am still always yours."
    F "... pero sigo siendo siempre suya."

# game/scripts/day20.rpy:4272
translate spanish d20b_a7260378:

    # F "...but I will ready, if you say the word."
    F "... pero sigo lista, si tú dices la palabra."

# game/scripts/day20.rpy:4275
translate spanish d20b_6fcc77c5:

    # F "Thank you for coming back, Master."
    F "Gracias por volver, Amo."

# game/scripts/day20.rpy:4279
translate spanish d20b_612f026c:

    # Z "I will, [F]. I appreciate it."
    Z "Lo haré, [F]. Te lo agradezco."

# game/scripts/day20.rpy:4281
translate spanish d20b_322c32a1:

    # Z "You're a good slave, [F]. I will call on you, once I have rested."
    Z "Eres una buena esclava, [F]. Te llamaré, cuando haya descansado."

# game/scripts/day20.rpy:4287
translate spanish d20b_f00dd0a1:

    # Ka "Um... [persistent.player_name]?"
    Ka "Em... ¿[persistent.player_name]?"

# game/scripts/day20.rpy:4290
translate spanish d20b_cd827270:

    # Z "Mh...? Hey, Kateryna..."
    Z "¿Mmm...? Oye, Kateryna..."

# game/scripts/day20.rpy:4293
translate spanish d20b_09f0e294:

    # Ka "A-are you hurting? I heard that you fought bad men..."
    Ka "¿T-te duele algo? Oí que luchaste contra hombres malos..."

# game/scripts/day20.rpy:4296
translate spanish d20b_3fcc7f70:

    # Z "I am not hurting, don't worry."
    Z "No me duele nada, no te preocupes."

# game/scripts/day20.rpy:4297
translate spanish d20b_2f0e4c11:

    # Z "How did you fare, while I was gone?"
    Z "¿Cómo te fue mientras estuve fuera?"

# game/scripts/day20.rpy:4300
translate spanish d20b_ad46672d:

    # Ka "Me? I... helped [W] out, and..."
    Ka "¿Yo? Yo... ayudé a [W], y..."

# game/scripts/day20.rpy:4303
translate spanish d20b_cf7d423a:

    # "She looks at you, nervously..."
    "Te mira, nerviosa..."

# game/scripts/day20.rpy:4304
translate spanish d20b_baa9c817:

    # Z "What are you thinking?"
    Z "¿En qué estás pensando?"

# game/scripts/day20.rpy:4308
translate spanish d20b_d4f5fc8d:

    # Ka "I... miss making babies, [persistent.player_name]."
    Ka "Yo... echo de menos hacer bebés, [persistent.player_name]."

# game/scripts/day20.rpy:4310
translate spanish d20b_59ec2a7a:

    # Ka "I... missed you, [persistent.player_name]."
    Ka "Yo... te eché de menos, [persistent.player_name]."

# game/scripts/day20.rpy:4311
translate spanish d20b_e0daea13:

    # Ka "When you are healed, can I..."
    Ka "Cuando te hayas curado, ¿podremos...?"

# game/scripts/day20.rpy:4314
translate spanish d20b_f6e338b1:

    # Z "{i}*chuckles*{/i} Yes, we can."
    Z "{i}*risilla*{/i} Sí, podremos."

# game/scripts/day20.rpy:4317
translate spanish d20b_d83b52dc:

    # Ka "Hm...!"
    Ka "¡Mm...!"

# game/scripts/day20.rpy:4318
translate spanish d20b_61ca9e3b:

    # Z "But I need the night to rest, alright?"
    Z "Pero necesito la noche para descansar, de acuerdo."

# game/scripts/day20.rpy:4321
translate spanish d20b_1769fa96:

    # Ka "O-of course, [persistent.player_name]!"
    Ka "¡P-por supuesto, [persistent.player_name]!"

# game/scripts/day20.rpy:4322
translate spanish d20b_efdd0aac:

    # Ka "I will leave you sleep, so you are rested soon! Goodnight!"
    Ka "Te dejo dormir, ¡para que descanses pronto! ¡Buenas noches!"

# game/scripts/day20.rpy:4327
translate spanish d20b_cc3a30e0:

    # "Excited, reassured, she rushes out..."
    "Emocionada, tranquila, ella sale corriendo..."

# game/scripts/day20.rpy:4331
translate spanish d20b_146535a2:

    # "Having seen all the girls, you fall asleep quickly, and sleep until the next morning."
    "Habiendo visto a todas las chicas, te duermes rápidamente y duermes hasta la mañana siguiente."

# game/scripts/day20.rpy:4340
translate spanish d20c_de78e495:

    # "Do you want to enable [S]'s perspective for this replay?"
    "¿Quieres activar la perspectiva de [S] para esta repetición?"

# game/scripts/day20.rpy:4352
translate spanish d20c_7e634183:

    # S "...so one thing led to another, and then we woke him up together."
    S "... y una cosa llevó a la otra, y entonces lo despertamos juntas."

# game/scripts/day20.rpy:4353
translate spanish d20c_2159381a:

    # A "Together, as in...?"
    A "¿Juntas, como...?"

# game/scripts/day20.rpy:4356
translate spanish d20c_be2bc42b:

    # S "How you always wake him up, you dummy... {i}*giggles*{/i}"
    S "Como tú siempre le despiertas, tonta... {i}*risilla*{/i}"

# game/scripts/day20.rpy:4357
translate spanish d20c_310c9d67:

    # A "Oh...! The Queen really did that...?"
    A "¡Oh...! ¿La Reina realmente hizo eso...?"

# game/scripts/day20.rpy:4358
translate spanish d20c_3984f72d:

    # S "...and much more, yes."
    S "... y mucho más, sí."

# game/scripts/day20.rpy:4362
translate spanish d20c_d383d53e:

    # S "...and then I went to sleep. That was before we got attacked..."
    S "... y luego me fui a dormir. Eso fue antes de que nos atacaran..."

# game/scripts/day20.rpy:4363
translate spanish d20c_2783da1c:

    # A "So... nothing happened, this time?"
    A "Así que... ¿no pasó nada, esta vez?"

# game/scripts/day20.rpy:4366
translate spanish d20c_e2b45a25:

    # S "By nothing, you mean..."
    S "Por nada, quieres decir..."

# game/scripts/day20.rpy:4367
translate spanish d20c_ec898cd4:

    # A "...sex! You dummyig oaf!"
    A "¡... sexo! ¡Tonta del culo!"

# game/scripts/day20.rpy:4368
translate spanish d20c_39da3b5c:

    # S "Oh, not that night. But that's okay, I don't need it every night."
    S "Oh, esa noche no. Pero está bien, no lo necesito todas las noches."

# game/scripts/day20.rpy:4371
translate spanish d20c_8e39cfc0:

    # A "So... how do you like it, now that you and [persistent.dad] do it?"
    A "Así que... ¿cómo te gusta, ahora que tú y [persistent.dad] lo hacéis?"

# game/scripts/day20.rpy:4372
translate spanish d20c_b291f582:

    # A "Does he do it just like with me...?"
    A "¿Lo hace igual que conmigo...?"

# game/scripts/day20.rpy:4375
translate spanish d20c_bc0b6c7f:

    # S "Hm... let me think..."
    S "Mmm... déjame pensar..."

# game/scripts/day20.rpy:4378
translate spanish d20c_92fbe343:

    # S "Well... I don't think he treats me exactly like you, [A]."
    S "Bueno... no creo que me trate exactamente igual que a ti, [A]."

# game/scripts/day20.rpy:4381
translate spanish d20c_9f5950f4:

    # S "He is very confident, but also gentle."
    S "Es muy seguro, pero también gentil."

# game/scripts/day20.rpy:4382
translate spanish d20c_94551ae4:

    # S "He knows that I am a bit more emotional when it comes to this, I think."
    S "Creo que él sabe que soy un poco más sensible cuando se trata de esto."

# game/scripts/day20.rpy:4385
translate spanish d20c_913771d5:

    # A "Oh, I see..."
