    # Q "W-where are you taking us..?!"
    Q "¿A-Adónde nos lleváis...?"

# game/scripts/day20.rpy:36
translate spanish d20a_shani_phase_1_daa0a824:

    # S "{i}*gasp*{/i}"
    S "{i}*jadeo*{/i}"

# game/scripts/day20.rpy:37
translate spanish d20a_shani_phase_1_7f7eba19:

    # St "Where am I..."
    St "¿Dónde estoy...?"

# game/scripts/day20.rpy:41
translate spanish d20a_shani_phase_1_103d2104:

    # St "Right... they must have taken me here."
    St "Ah, sí... ellos deben de haberme traído aquí."

# game/scripts/day20.rpy:44
translate spanish d20a_shani_phase_1_5d119c28:

    # St "...but where are [persistent.dad] and Neith?"
    St "... pero ¿dónde están [persistent.dad] y Neith?"

# game/scripts/day20.rpy:49
translate spanish d20a_shani_phase_1_335ff3c1:

    # St "Chains..."
    St "Cadenas..."

# game/scripts/day20.rpy:50
translate spanish d20a_shani_phase_1_6bc61964:

    # St "This is going to be difficult..."
    St "Esto va a ser complicado..."

# game/scripts/day20.rpy:53
translate spanish d20a_shani_phase_1_f495d28b:

    # C "{i}*whistling*{/i}"
    C "{i}*silbando*{/i}"

# game/scripts/day20.rpy:56
translate spanish d20a_shani_phase_1_54fdca13:

    # Ban2 "I see you're awake, huh..."
    Ban2 "Veo que ya estás despierta, eh..."

# game/scripts/day20.rpy:57
translate spanish d20a_shani_phase_1_971a98df:

    # S "..."
    S "..."

# game/scripts/day20.rpy:58
translate spanish d20a_shani_phase_1_1bc4b305:

    # Ban2 "Took you long enough."
    Ban2 "Te ha costado un montón."

# game/scripts/day20.rpy:61
translate spanish d20a_shani_phase_1_fee0a5ac:

    # Ban2 "I will tell you how it is, girl. You're screwed, but you're not dead, for now."
    Ban2 "Voy a decirte cómo está la cosa, chica. Estás en un lío, pero de momento no estás muerta."

# game/scripts/day20.rpy:64
translate spanish d20a_shani_phase_1_745dc458:

    # Ban2 "And neither are your companions... at least not 'til the boss decides otherwise."
    Ban2 "Y tus compañeros tampoco... al menos hasta que el jefe decida lo contrario."

# game/scripts/day20.rpy:67
translate spanish d20a_shani_phase_1_9457a2a3:

    # Ban2 "I see you looking around. I bet you're wondering where your friends are; don't. You have other things to worry about."
    Ban2 "Te veo mirando a tu alrededor. Apuesto a que te preguntas dónde están tus amigos; ni te molestes. Tienes otras cosas de qué preocuparte."

# game/scripts/day20.rpy:70
translate spanish d20a_shani_phase_1_08e56eba:

    # "He clicks with his tongue..."
    "Él chasquea la lengua..."

# game/scripts/day20.rpy:71
translate spanish d20a_shani_phase_1_9218a3e1:

    # Ban2 "You're defeated, and I am sure you know what that means; what's in store for you."
    Ban2 "Estás derrotada, y estoy seguro de que sabes lo que eso significa; lo que te espera."

# game/scripts/day20.rpy:74
translate spanish d20a_shani_phase_1_b5e8330a:

    # S "Defeated? ...You're mistaken if you think I give up that easily."
    S "¿Derrotada? ...Te equivocas si crees que me rindo tan fácilmente."

# game/scripts/day20.rpy:77
translate spanish d20a_shani_phase_1_ea3b9d8e:

    # Ban2 "Of course you would say that. You're a fighter, and a skilled one. But you {i}are{/i} defeated. Look around. Look at your chains."
    Ban2 "Claro, tenías que decir eso. Eres una luchadora, y hábil. Pero estás {i}derrotada{/i}. Mira a tu alrededor. Mira tus cadenas."

# game/scripts/day20.rpy:80
translate spanish d20a_shani_phase_1_3ebdf71f:

    # Ban2 "And worse...You might be a fighter, but you're also a damn girl. A girl who made me look like a fool in front of them."
    Ban2 "Y lo que es peor... Puede que seas una luchadora, pero también eres una maldita chica. Una chica que hizo que pareciera un idiota delante de ellos."

# game/scripts/day20.rpy:83
translate spanish d20a_shani_phase_1_26eb2006:

    # Ban2 "If I could, I would..."
    Ban2 "Si pudiera, ya te..."

# game/scripts/day20.rpy:85
translate spanish d20a_shani_phase_1_986887d7:

    # "He grunts frustrated..."
    "Él gruñe frustrado..."

# game/scripts/day20.rpy:86
translate spanish d20a_shani_phase_1_971a98df_1:

    # S "..."
    S "..."

# game/scripts/day20.rpy:89
translate spanish d20a_shani_phase_1_2aa7bca7:

    # Ban2 "Actually no. I will wait... It's only a matter of time until Father is done with you, and then..."
    Ban2 "En realidad, no. Voy a esperar... Solo es cuestión de tiempo que Padre termine contigo, y entonces..."

# game/scripts/day20.rpy:90
translate spanish d20a_shani_phase_1_13a6a2da:

    # Ban2 "...then I will have my way with you. I will break you, use you until you are grateful for it."
    Ban2 "... entonces haré lo que quiera contigo. Te quebrantaré, te usaré hasta que me lo agradezcas."

# game/scripts/day20.rpy:93
translate spanish d20a_shani_phase_1_91f3784f:

    # Ban2 "...and then, my payback for how you humiliated me, will be complete."
    Ban2 "... y entonces, mi venganza por cómo me humillaste, estará completa."

# game/scripts/day20.rpy:100
translate spanish d20a_shani_phase_1_64dee7aa:

    # S "Keep dreaming. Once these chains come off, you'll wish you'd never laid your hands on me."
    S "Sigue soñando. Cuando me quite estas cadenas, desearás no haberme tocado nunca."

# game/scripts/day20.rpy:103
translate spanish d20a_shani_phase_1_82692c1e:

    # Ban2 "Big talk, but you and your friends will soon be taken care of. Unless you somehow convince Father to let them go..."
    Ban2 "Grandes palabras, pero pronto se ocuparán de ti y tus amigos. A menos que de alguna manera convenzas a Padre para que los deje ir..."

# game/scripts/day20.rpy:108
translate spanish d20a_shani_phase_1_55309e16:

    # S "How pathetic... All these plans about me, and yet you need the approval of your daddy and hope to get his sloppy seconds.."
    S "Qué patético... Todos estos planes sobre mí, y necesitas la aprobación de tu papi y esperas quedarte con sus sobras..."

# game/scripts/day20.rpy:111
translate spanish d20a_shani_phase_1_0a2c84d7:

    # Ban2w "Shut your mouth. These... these are the tribe's rules."
    Ban2w "Cierra la boca. Estas... estas son las normas de la tribu."

# game/scripts/day20.rpy:116
translate spanish d20a_shani_phase_1_294111b2:

    # Ban2 "He's coming... Behave, if you know what's good for you."
    Ban2 "Ya viene... Pórtate bien, si sabes lo que te conviene."

# game/scripts/day20.rpy:120
translate spanish d20a_shani_phase_1_b6572ccd:

    # C2 "Is she awake..."
    C2 "¿Está despierta...?"

# game/scripts/day20.rpy:121
translate spanish d20a_shani_phase_1_77eb8bfd:

    # Ban2 "Yes Father, she is."
    Ban2 "Sí, Padre, lo está."

# game/scripts/day20.rpy:124
translate spanish d20a_shani_phase_1_de4a456b:

    # "He approaches..."
    "Se acerca..."

# game/scripts/day20.rpy:128
translate spanish d20a_shani_phase_1_b117699f:

    # Bfa "They tell me you are the woman who slayed two of my boys..."
    Bfa "Me dicen que tú eres la mujer que mató a dos de mis muchachos..."

# game/scripts/day20.rpy:129
translate spanish d20a_shani_phase_1_32ea5ef2:

    # Bfa "...and cut my daughter's hand."
    Bfa "... y le cortó la mano a mi hija."

# game/scripts/day20.rpy:130
translate spanish d20a_shani_phase_1_971a98df_2:

    # S "..."
    S "..."

# game/scripts/day20.rpy:132
translate spanish d20a_shani_phase_1_31f45b67:

    # Bfa "But now, your bloody streak has come to an end."
    Bfa "Pero ahora, tu racha sangrienta ha llegado a su fin."

# game/scripts/day20.rpy:135
translate spanish d20a_shani_phase_1_144611af:

    # Bfa "Mmmh... I see the spirit of a fighter. I am not surprised you were able to defeat those idiots."
    Bfa "Mmmh... Veo el espíritu de una luchadora. No me sorprende que hayas podido derrotar a esos idiotas."

# game/scripts/day20.rpy:137
translate spanish d20a_shani_phase_1_a0c6759b:

    # Bfa "Her defiance, boy... You promised me something else."
    Bfa "Su desafío, muchacho... Me prometiste otra cosa."

# game/scripts/day20.rpy:138
translate spanish d20a_shani_phase_1_0461b120:

    # Ban2 "Don't let her expression deceive you, father. She is smart, I am sure she has realised she is beaten."
    Ban2 "No deje que su expresión le engañe, padre. Es lista, estoy seguro de que ya se ha dado cuenta de que está acabada."

# game/scripts/day20.rpy:141
translate spanish d20a_shani_phase_1_e17e646f:

    # Bfa "You think I don't see that? I can tell she has the spirit of a fighter. A spirit capable of overpowering my two idiot sons."
    Bfa "¿Crees que no lo veo? Puedo ver que tiene el espíritu de una luchadora. Un espíritu capaz de dominar a mis dos hijos idiotas."

# game/scripts/day20.rpy:143
translate spanish d20a_shani_phase_1_ba6c349d:

    # Ban2 "Father, I..."
    Ban2 "Padre, yo..."

# game/scripts/day20.rpy:144
translate spanish d20a_shani_phase_1_30d2013a:

    # Bfa "Silence."
    Bfa "Silencio."

# game/scripts/day20.rpy:147
translate spanish d20a_shani_phase_1_8668eb1e:

    # Bfa "Have you told her about my demands?"
    Bfa "¿Le has explicado mis condiciones?"

# game/scripts/day20.rpy:150
translate spanish d20a_shani_phase_1_871a9bff:

    # Ban2 "I was getting to it, Father. She just woke up."
    Ban2 "Iba a llegar a eso, Padre. Acaba de despertarse."

# game/scripts/day20.rpy:153
translate spanish d20a_shani_phase_1_6c06c26c:

    # S "I don't know what you're hoping to get..."
    S "No sé qué esperáis conseguir..."

# game/scripts/day20.rpy:156
translate spanish d20a_shani_phase_1_ac370bf2:

    # Bfa "You may think of me as of a traditionalist, woman. Your old man must have prepared you for this possibility."
    Bfa "Puedes pensar que soy un tradicionalista, mujer. Tu viejo debe haberte preparado para esta posibilidad."

# game/scripts/day20.rpy:157
translate spanish d20a_shani_phase_1_df59aa28:

    # Bfa "It is best you accept your defeat and accept that the law of the land will be applied to you."
    Bfa "Es mejor que aceptes tu derrota y asumas que la ley de estas tierras se aplicará sobre ti."

# game/scripts/day20.rpy:158
translate spanish d20a_shani_phase_1_d603bfd2:

    # Bfa "You took three sons of mine. You will serve me for as long as I see fit, until I consider the debt repaid."
    Bfa "Te llevaste a tres de mis hijos. Me servirás durante el tiempo que yo considere oportuno, hasta que dé la deuda por saldada."

# game/scripts/day20.rpy:159
translate spanish d20a_shani_phase_1_d3ab0f46:

    # Bfa "You should count yourself lucky. It could have been blood for blood."
    Bfa "Deberías considerarte afortunada. Podría haber sido sangre por sangre."

# game/scripts/day20.rpy:162
translate spanish d20a_shani_phase_1_06616935:

    # St "He's coming closer... I need to think how to get out of here."
    St "Se está acercando... Necesito pensar cómo salir de aquí."

# game/scripts/day20.rpy:165
translate spanish d20a_shani_phase_1_584a0905:

    # St "Breaking free won't work, even if I wasn't shackled against the wall. There are too many disadvantages."
    St "Escapar a la fuerza no funcionaría, aunque no estuviera encadenada a la pared. Hay demasiadas desventajas."

# game/scripts/day20.rpy:168
translate spanish d20a_shani_phase_1_7410c376:

    # St "He looks like he's made up his mind... it will be impossible to talk him out of this. But perhaps I can win some time for [persistent.dad]?"
    St "Parece que ya ha tomado una decisión... será imposible hacerle cambiar de idea. Pero quizás pueda ganar algo de tiempo para [persistent.dad]."

# game/scripts/day20.rpy:169
translate spanish d20a_shani_phase_1_cc65a4fb:

    # St "Where are you, guys?"
    St "¿Dónde estáis, chicos?"

# game/scripts/day20.rpy:172
translate spanish d20a_shani_phase_1_e94cdd34:

    # S "What have you done to my [persistent.dad] and girlfriend?!"
    S "¿Qué habéis hecho con mi [persistent.dad] y con mi novia?!"

# game/scripts/day20.rpy:173
translate spanish d20a_shani_phase_1_dc13e0fd:

    # Bfa "Is that who they are to you?"
    Bfa "¿Es eso lo que son para ti?"

# game/scripts/day20.rpy:174
translate spanish d20a_shani_phase_1_fdddd59e:

    # Bfa "Right now, my boys are dealing with them."
    Bfa "En este momento, mis muchachos se están ocupando de ellos."

# game/scripts/day20.rpy:175
translate spanish d20a_shani_phase_1_9d652af4:

    # S "W-what do you mean by that..."
    S "¿Q-Qué quieres decir con eso...?"

# game/scripts/day20.rpy:176
translate spanish d20a_shani_phase_1_e0b303bf:

    # Bfa "Your old man is a warrior... and he embarrassed them. They are young and did not take kindly to it. They are teaching him a lesson."
    Bfa "Tu viejo es un guerrero... y los avergonzó. Son jóvenes y no se lo tomaron bien. Le están dando una lección."

# game/scripts/day20.rpy:177
translate spanish d20a_shani_phase_1_3c61a4bc:

    # Bfa "As for your girlfriend..."
    Bfa "En cuanto a tu novia..."

# game/scripts/day20.rpy:178
translate spanish d20a_shani_phase_1_b06da912:

    # S "If they hurt her in any way, I will..-"
    S "Si le hacen algún daño, yo...-"

# game/scripts/day20.rpy:179
translate spanish d20a_shani_phase_1_aba9d3ad:

    # Bfa "My boys are not allowed to take my spoils, unless I give them permission."
    Bfa "Mis muchachos no tienen permiso para tocar mi botín, a menos que yo se lo conceda."

# game/scripts/day20.rpy:180
translate spanish d20a_shani_phase_1_3e58fb61:

    # Bfa "I might even keep the other girl for my own pleasure instead of passing her around. It depends on you."
    Bfa "Incluso podría quedarme con la otra chica para mi propio placer, en lugar de pasársela a los demás. Depende de ti."

# game/scripts/day20.rpy:181
translate spanish d20a_shani_phase_1_64eae2fe:

    # Bfa "You will accept your fate and earn my favour every day. As long as you don't disappoint me, they live."
    Bfa "Aceptarás tu destino y ganarás mi favor cada día. Mientras no me decepciones, ellos vivirán."

# game/scripts/day20.rpy:182
translate spanish d20a_shani_phase_1_f0e500ad:

    # S "My fate, huh..."
    S "Mi destino, eh..."

# game/scripts/day20.rpy:183
translate spanish d20a_shani_phase_1_497d5826:

    # Bfa "Your new role. Yes."
    Bfa "Tu nuevo papel. Sí."

# game/scripts/day20.rpy:187
translate spanish d20a_shani_phase_1_d0680e2d:

    # Bfa "I lay claim to your body and soul for the coming span; you will repay in servitude your debt towards me."
    Bfa "Reclamo tu cuerpo y tu alma de ahora en adelante; pagarás tu deuda conmigo mediante la servidumbre."

# game/scripts/day20.rpy:189
translate spanish d20a_shani_phase_1_d5b7a5a8:

    # Bfa "I lay claim to your body and soul for the coming span; you will serve me until my pleasure is satisfied."
    Bfa "Reclamo tu cuerpo y tu alma de ahora en adelante; me servirás hasta que mi placer quede satisfecho."

# game/scripts/day20.rpy:190
translate spanish d20a_shani_phase_1_c7ddf4b9:

    # Bfa "In due time, I might set you free. Then again, maybe by then you will want to stay."
    Bfa "Con el tiempo, podría dejarte libre. Aunque también puede que para entonces quieras quedarte."

# game/scripts/day20.rpy:191
translate spanish d20a_shani_phase_1_7365f2fb:

    # St "He's staring..."
    St "Me está mirando fijamente..."

# game/scripts/day20.rpy:194
translate spanish d20a_shani_phase_1_db7d4434:

    # Bfa "My weak son was right. You seem defiant; I can see the wheels turning. You are thinking about your destiny."
    Bfa "Mi hijo débil tenía razón. Pareces desafiante; veo que estás dándole vueltas. Estás pensando en tu destino."

# game/scripts/day20.rpy:195
translate spanish d20a_shani_phase_1_749b8c5a:

    # Bfa "Know this though. The only alternative I offer to you is death."
    Bfa "Pero has de saber esto. La única alternativa que te ofrezco es la muerte."

# game/scripts/day20.rpy:196
translate spanish d20a_shani_phase_1_3301e672:

    # St "What is he... the only thing I am contemplating is how to get out of here."
    St "¿De qué está hablando...? Lo único en lo que pienso es en cómo salir de aquí."

# game/scripts/day20.rpy:197
translate spanish d20a_shani_phase_1_4bc7efbe:

    # St "I need time to figure out a way. I must stall him."
    St "Necesito tiempo para encontrar la manera. Tengo que ganar tiempo."

# game/scripts/day20.rpy:200
translate spanish d20a_shani_phase_1_b725b388:

    # S "I have questions."
    S "Tengo preguntas."

# game/scripts/day20.rpy:203
translate spanish d20a_shani_phase_1_628ea9a4:

    # Bfa "Your questions are irrelevant. I have spoken and you will learn your place, one way or another."
    Bfa "Tus preguntas son irrelevantes. He hablado y aprenderás cuál es tu lugar, de una forma u otra."

# game/scripts/day20.rpy:206
translate spanish d20a_shani_phase_1_bb8db71e:

    # S "I will not...-"
    S "Yo no...-"

# game/scripts/day20.rpy:209
translate spanish d20a_shani_phase_1_0d98fddf:

    # Bfa "Quiet now... you have said enough."
    Bfa "Silencio ahora... ya has dicho suficiente."

# game/scripts/day20.rpy:210
translate spanish d20a_shani_phase_1_971a98df_3:

    # S "..."
    S "..."

# game/scripts/day20.rpy:213
translate spanish d20a_shani_phase_1_38acc1bf:

    # Bfa "I approve..."
    Bfa "Doy mi aprobación..."

# game/scripts/day20.rpy:214
translate spanish d20a_shani_phase_1_9198563d:

    # Bfa "...you will make a fine concubine."
    Bfa "... serás una buena concubina."

# game/scripts/day20.rpy:217
translate spanish d20a_shani_phase_1_e3faaa3b:

    # St "He really thinks I will submit to him..."
    St "De verdad cree que me someteré a él..."

# game/scripts/day20.rpy:223
translate spanish d20a_shani_phase_1_b47de85d:

    # St "His son is watching, but..."
    St "Su hijo está mirando, pero..."

# game/scripts/day20.rpy:226
translate spanish d20a_shani_phase_1_70228dac:

    # St "...he seems angry. Is he jealous?"
    St "... parece enfadado. ¿Está celoso?"

# game/scripts/day20.rpy:229
translate spanish d20a_shani_phase_1_d0507a25:

    # Bfa "Now look at me. Show me your worth."
    Bfa "Ahora mírame. Demuéstrame tu valía."

# game/scripts/day20.rpy:234
translate spanish d20a_shani_phase_1_a3c68a48:

    # S "...!"
    S "¡...!"

# game/scripts/day20.rpy:235
translate spanish d20a_shani_phase_1_7748a769:

    # St "What is he..."
    St "Qué está..."

# game/scripts/day20.rpy:246
translate spanish d20a52_40081d9f:

    # S "{i}*crunch*{/i}"
    S "{i}*crujido*{/i}"

# game/scripts/day20.rpy:247
translate spanish d20a52_ea042db8:

    # Bfa "Argh-"
    Bfa "Argh-"

# game/scripts/day20.rpy:250
translate spanish d20a52_2fba0249:

    # Bfa "You... witch!"
    Bfa "¡Tú... bruja!"

# game/scripts/day20.rpy:259
translate spanish d20a52_1ab68f98:

    # Bfa "Silly woman."
    Bfa "Mujer tonta."

# game/scripts/day20.rpy:260
translate spanish d20a52_543c69fb:

    # St "That's what you get, asshole."
    St "Eso es lo que te mereces, hijo de puta."

# game/scripts/day20.rpy:263
translate spanish d20a52_8dbe65e4:

    # Bfa "This is your last chance. Take it, or face the consequences."
    Bfa "Esta es tu última oportunidad. Acéptala o afronta las consecuencias."

# game/scripts/day20.rpy:264
translate spanish d20a52_3c310711:

    # St "I need to win more time for [persistent.dad]..."
    St "Necesito ganar más tiempo para [persistent.dad]..."

# game/scripts/day20.rpy:277
translate spanish d20a58_971a98df:

    # S "..."
    S "..."

# game/scripts/day20.rpy:278
translate spanish d20a58_2f8eb6c6:

    # Bfa "Smart woman."
    Bfa "Mujer inteligente."

# game/scripts/day20.rpy:281
translate spanish d20a58_d12392e8:

    # S "Mgh..."
    S "Mgh..."

# game/scripts/day20.rpy:282
translate spanish d20a58_89294936:

    # Bfa "Good."
    Bfa "Bien."

# game/scripts/day20.rpy:285
translate spanish d20a58_42a659f9:

    # Bfa "I see her potential, son."
    Bfa "Veo su potencial, hijo."

# game/scripts/day20.rpy:286
translate spanish d20a58_c1bcc5be:

    # Ban2 "Thank you, Father. I knew that when I first...-"
    Ban2 "Gracias, Padre. Yo sabía que desde el principio...-"

# game/scripts/day20.rpy:287
translate spanish d20a58_a5bb44c1:

    # Bfa "Quiet now."
    Bfa "Ahora silencio."

# game/scripts/day20.rpy:290
translate spanish d20a58_9937b30a:

    # Bfa "...We will talk later."
    Bfa "... Hablaremos más tarde."

# game/scripts/day20.rpy:291
translate spanish d20a58_ac8ab799:

    # St "This is so humiliating... his finger in my mouth, while I'm tied up..."
    St "Esto es tan humillante... su dedo en mi boca, mientras estoy atada..."

# game/scripts/day20.rpy:294
translate spanish d20a58_6e41eaf0:

    # Bfa "Use your tongue, woman. Show me you are of use to me."
    Bfa "Usa la lengua, mujer. Demuéstrame que me eres útil."

# game/scripts/day20.rpy:295
translate spanish d20a58_93ba7348:

    # St "Scum..."
    St "Escoria..."

# game/scripts/day20.rpy:297
translate spanish d20a58_01acd2c8:

    # Bfa "Better."
    Bfa "Mejor."

