    # Ta "Don't worry about it, you're a smart girl."
    Ta "No te preocupes, eres una chica lista."

# game/scripts/day2.rpy:138
translate spanish d2b_7f7bfab0:

    # Ta "You will learn to judge character, in time."
    Ta "Aprenderás a juzgar el carácter, con el tiempo."

