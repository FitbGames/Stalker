    # Z "Your attitude is unbecoming for a royal guard."
    Z "Tu actitud es impropia de una guardia real."

# game/scripts/day2.rpy:110
translate spanish d2b_b5b96955:

    # Z "By your brashness, I bet you're a scavenger, and not a real guard."
    Z "Por tu descaro, apuesto a que eres una carroñera y no una verdadera guardia."

# game/scripts/day2.rpy:111
translate spanish d2b_99d0c8b1:

    # Z "Maybe your talents are better suited to work in the field, rather than guarding the entrance."
    Z "Tal vez tus talentos sean más adecuados para trabajar en el campo, en lugar de vigilar la entrada."

# game/scripts/day2.rpy:114
