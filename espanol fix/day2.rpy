    # Ta "Maybe I'll show her how to treat you properly, [persistent.player_name]."
    Ta "Tal vez la enseñe cómo tratarte correctamente, [persistent.player_name]."

# game/scripts/day2.rpy:169
translate spanish d2b_6e2bad1e:

    # Li "I don't know what you're talking about, but you can pass through, Stalker."
    Li "No sé de qué hablas, pero puedes pasar, Acechador."

