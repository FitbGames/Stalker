    # G1 "He's right [Li]. This is the entryway to the throne room."
    G1 "Él tiene razón [Li]. Esta es la entrada a la sala del trono."

# game/scripts/day2.rpy:118
translate spanish d2b_ea4607e1:

    # G1 "There are guards everywhere."
    G1 "Hay guardias por todas partes."

# game/scripts/day2.rpy:119
