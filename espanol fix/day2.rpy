translate spanish d2b_39e24245:

    # Ta "Of course she doesn't..."
    Ta "Por supuesto que ella no lo hace..."

# game/scripts/day2.rpy:178
translate spanish d2b_0d25ae4f:

    # Ta "Follow me [persistent.player_name]. And don't be too hard on her, she's trying."
    Ta "Sígueme [persistent.player_name]. Y no seas demasiado duro con ella, lo está intentando."

# game/scripts/day2.rpy:181
translate spanish d2b_11c9c061:

    # Ta "[persistent.player_name!c], the Queen is in a meeting with some mercenaries right now."
    Ta "[persistent.player_name!c], ahora mismo la Reina está en una reunión con unos mercenarios."

# game/scripts/day2.rpy:182
translate spanish d2b_39875b53_2:

    # Ta "But she will be done by the time we get there."
    Ta "Pero ya habrá terminado cuando lleguemos."

# game/scripts/day2.rpy:186
translate spanish d2b_1adf7bd1:

    # Ta "How was your trip?"
    Ta "¿Cómo fue tu viaje?"

# game/scripts/day2.rpy:187
translate spanish d2b_0d75dc3b:

    # Z "Nothing special. A few mummies here, some raiders there."
    Z "Nada especial. Unas cuantas momias por aquí, unos asaltantes por allá."

# game/scripts/day2.rpy:188
translate spanish d2b_197411aa:

    # Ta "You look great, having gone through that."
    Ta "Estás estupendo, después de haber pasado por eso."

# game/scripts/day2.rpy:189
translate spanish d2b_b73901de:

    # Z "You look nice too [Ta], as always."
    Z "Tú también estás muy guapa [Ta], como siempre."

# game/scripts/day2.rpy:190
translate spanish d2b_d4868a24:

    # Ta "What a charmer."
    Ta "Qué encantador."

# game/scripts/day2.rpy:191
translate spanish d2b_f21f4a34:

    # Ta "Why don't you show me that you mean it? It's been a while now..."
    Ta "¿Por qué no me demuestras que lo dices en serio? Ya ha pasado un tiempo..."

# game/scripts/day2.rpy:192
translate spanish d2b_a2fa4d48:

    # Z "Not today [Ta]. My [persistent.da] is waiting for me at home. Today I'm taking her on her first tomb raid."
    Z "Hoy no [Ta]. Mi [persistent.da] me espera en casa. Hoy la llevaré a su primera incursión en la tumba."

# game/scripts/day2.rpy:193
translate spanish d2b_fb766351:

    # Ta "Too bad."
    Ta "Es una pena."

# game/scripts/day2.rpy:196
translate spanish d2b_1973e2a7:

    # "{i}Soon after..."
    "{i}Poco después..."

# game/scripts/day2.rpy:203
translate spanish d2c_2f138f94:

    # Ta "Okay [persistent.player_name], here we are."
    Ta "Vale [persistent.player_name], aquí estamos."

# game/scripts/day2.rpy:204
translate spanish d2c_abf2158d:

    # Ta "You know the drill. Show respect to her authority."
    Ta "Conoces el procedimiento. Muestra respeto a su autoridad."

# game/scripts/day2.rpy:205
translate spanish d2c_1ccd9d92:

    # Z "Standard protocol..."
    Z "Protocolo estándar..."

# game/scripts/day2.rpy:208
translate spanish d2c_c57c255d:

    # Ta "Ha, I can't wait to listen to [Li]'s complaints about you already."
    Ta "Ja, ya estoy deseando escuchar las quejas de [Li] sobre ti."

# game/scripts/day2.rpy:211
translate spanish d2c_de4e48aa:

    # Z "She will get used to me."
    Z "Se acostumbrará a mí."

# game/scripts/day2.rpy:212
translate spanish d2c_6224df39:

    # Z "See you soon [Ta], take care."
    Z "Hasta pronto, [Ta], cuídate."

# game/scripts/day2.rpy:215
translate spanish d2c_892fdef5:

    # Ta "And you, [persistent.player_name]."
    Ta "Y tú, [persistent.player_name]."

# game/scripts/day2.rpy:218
translate spanish d2c_259b126d:

    # "You head inside..."
    "Te diriges al interior..."

# game/scripts/day2.rpy:219
translate spanish d2c_3170c267:

    # Q "...I want you to find whoever did this, is that clear?!"
    Q "...quiero que encuentres a quien ha hecho esto, ¿está claro?"

# game/scripts/day2.rpy:220
translate spanish d2c_f69bcd18:

    # Q "How can it happen that someone steals from the royal armoury?!"
    Q "¿Cómo puede ocurrir que alguien robe de la armería real?"

# game/scripts/day2.rpy:223
translate spanish d2c_f242a33d:

    # Q "If the...things the thief stole were to be seen by the public..."
    Q "Si las... cosas que robó el ladrón fueran vistas por el público..."

# game/scripts/day2.rpy:224
translate spanish d2c_f2f00edd:

    # Q "We can't let that happen, do you understand?!"
    Q "No podemos dejar que eso ocurra, ¿lo entiendes?"

# game/scripts/day2.rpy:227
translate spanish d2c_0cf0b9f9:

    # Q "Capture whoever did it and bring them back to me."
    Q "Captura a quien lo haya hecho y tráemelo."

# game/scripts/day2.rpy:230
translate spanish d2c_a5c133bb:

    # Q "...and then prepare a public execution of course."
    Q "... y luego prepara una ejecución pública, por supuesto."

# game/scripts/day2.rpy:233
translate spanish d2c_bf33c520:

    # Merc "Yes, my Queen."
    Merc "Sí, mi Reina."

# game/scripts/day2.rpy:236
translate spanish d2c_5d479dec:

    # Q "I want regular reports on your investigation in the matter."
    Q "Quiero informes periódicos sobre tu investigación en el asunto."

# game/scripts/day2.rpy:239
translate spanish d2c_24a87aa1:

    # Q "Oh and... my dogs are quite hungry lately..."
    Q "Oh y... mis perros están bastante hambrientos últimamente..."

# game/scripts/day2.rpy:240
translate spanish d2c_2d7a3de2:

    # Q "So if you disappoint me, trust me, I will find a different use for you!"
    Q "Así que si me decepcionas, confía en mí, ¡encontraré un uso diferente para ti!"

# game/scripts/day2.rpy:243
translate spanish d2c_01099541:

    # Q "Now go! What's next..."
    Q "¡Ahora vete! Lo que sigue..."

# game/scripts/day2.rpy:244
translate spanish d2c_061b78da:

    # Q "...oh! Look who we have here! An important guest..."
    Q "... ¡oh! ¡Mira a quién tenemos aquí! Un invitado importante..."

# game/scripts/day2.rpy:247
translate spanish d2c_e5687619:

    # Q "Stalker [persistent.player_name], what brings you to me today?"
    Q "Acechador [persistent.player_name], ¿qué te trae hoy a mí?"

# game/scripts/day2.rpy:248
translate spanish d2c_fe287936:

    # Q "Oh, I know.. You have something for me, am I right?!"
    Q "Oh, lo sé... Tienes algo para mí, ¿tengo razón?"

# game/scripts/day2.rpy:251
translate spanish d2c_d32634ef:

    # Q "So... Tell me. Was the old man right?"
    Q "Así que... Dime. ¿Tenía razón el viejo?"

# game/scripts/day2.rpy:252
translate spanish d2c_20fcdbdd:

    # Q "What did you find in those tombs?"
    Q "¿Qué encontraste en esas tumbas?"

# game/scripts/day2.rpy:259
translate spanish d2c_b17a15f7:

    # Z "I found an ancient relic. A statue of Bastet."
    Z "Encontré una reliquia antigua. Una estatua de Bastet."

# game/scripts/day2.rpy:261
translate spanish d2c_0b2e70b6:

    # Z "I'm confident it is to your tastes."
    Z "Estoy seguro de que es de tu gusto."

# game/scripts/day2.rpy:264
translate spanish d2c_12bde1ef:

    # Q "Show me what you found, then."
    Q "Enséñame entonces lo que has encontrado."

# game/scripts/day2.rpy:270
translate spanish d2c_cc330ca9:

    # Z "I found something. What do I get in return?"
    Z "He encontrado algo. ¿Qué recibo a cambio?"

# game/scripts/day2.rpy:274
translate spanish d2c_6d9a6445:

    # Q "Ohh, look at you.. a negotiator, huh?"
    Q "Ohh, mírate... un negociador, ¿eh?"

# game/scripts/day2.rpy:275
translate spanish d2c_7a84c4b5:

    # Q "Well, I could just take it and have you beheaded on the spot."
    Q "Bueno, podría cogerla y hacer que te decapitaran en el acto."

# game/scripts/day2.rpy:278
translate spanish d2c_018cdeb0:

    # Q "That would not be an unfitting reaction to your impudent question, Stalker!"
    Q "¡No sería una reacción inadecuada a tu impúdica pregunta, Acechador!"

# game/scripts/day2.rpy:281
translate spanish d2c_e69c31ab:

    # Q "But no, I'm a good Queen... do not worry."
    Q "Pero no, soy una buena Reina... no te preocupes."

# game/scripts/day2.rpy:282
translate spanish d2c_a744f025:

    # Q "Now show me what you found!"
    Q "¡Muéstrame lo que has encontrado!"

# game/scripts/day2.rpy:288
translate spanish d2c_55a70c84:

    # Z "There was nothing left. The tomb was empty."
    Z "No quedaba nada. La tumba estaba vacía."

# game/scripts/day2.rpy:291
translate spanish d2c_7ae317da:

    # Q "It was what?! You're telling me the old man was wrong?!"
    Q "¿Estaba qué? ¡¿Me estás diciendo que el viejo se equivocó?!"

# game/scripts/day2.rpy:294
translate spanish d2c_374b8f60:

    # Z "I'm not suggesting anything."
    Z "No estoy sugiriendo nada."

# game/scripts/day2.rpy:295
translate spanish d2c_339c5fb4:

    # Z "I said the tomb was empty, that's all I know."
    Z "Dije que la tumba estaba vacía, eso es todo lo que sé."

# game/scripts/day2.rpy:298
translate spanish d2c_e7ccfe72:

    # Q "[persistent.player_name!c], you disappoint me..."
    Q "[persistent.player_name!c], me decepcionas..."

# game/scripts/day2.rpy:299
translate spanish d2c_01b00eea:

    # Q "But I'm willing to give you another chance to impress me."
    Q "Pero estoy dispuesta a darte otra oportunidad para impresionarme."

# game/scripts/day2.rpy:305
translate spanish d2c_relic_reward_9c5c9e5b:

    # "You take out the Cat statue and hand it over to her..."
    "Sacas la estatua del Gato y se la entregas..."

# game/scripts/day2.rpy:306
translate spanish d2c_relic_reward_1495ae68:

    # Q "Oh my..."
    Q "Oh vaya..."

# game/scripts/day2.rpy:309
translate spanish d2c_relic_reward_15de5e48:

    # Q "This looks so cute."
    Q "Esto parece muy bonito."

# game/scripts/day2.rpy:310
translate spanish d2c_relic_reward_68416132:

    # Qw "You're mine now...!"
    Qw "¡Ahora eres mía...!"

# game/scripts/day2.rpy:313
translate spanish d2c_relic_reward_64edeb0c:

    # Qw "I will take good care of you."
    Qw "Cuidaré bien de ti."

# game/scripts/day2.rpy:316
translate spanish d2c_relic_reward_a7fd8967:

    # "She takes her time examining her latest acquisition..."
    "Se toma su tiempo para examinar su última adquisición..."

# game/scripts/day2.rpy:319
translate spanish d2c_relic_reward_c3e94881:

    # "...before carefully putting it away and turning her gaze back to you..."
    "...antes de guardarla con cuidado y volver su mirada hacia ti..."

# game/scripts/day2.rpy:322
translate spanish d2c_relic_reward_94e7368a:

    # Q "Stalker, I am pleased."
    Q "Acechador, estoy satisfecha."

# game/scripts/day2.rpy:323
translate spanish d2c_relic_reward_c042428b:

    # Q "You deserve a reward."
    Q "Te mereces una recompensa."

# game/scripts/day2.rpy:326
translate spanish d2c_relic_reward_41230b86:

    # Q "Send the slave in!"
    Q "¡Que entre la esclava!"

# game/scripts/day2.rpy:329
translate spanish d2c_relic_reward_fe969015:

    # "The door opens, and a rather unusual looking woman enters the room..."
    "La puerta se abre y entra en la habitación una mujer de aspecto poco habitual..."

# game/scripts/day2.rpy:330
translate spanish d2c_relic_reward_5fdb6883:

    # Q "Come closer, we won't bite!"
    Q "Acércate, ¡no te morderemos!"

# game/scripts/day2.rpy:333
translate spanish d2c_relic_reward_a29c6a75:

    # Q "I know you want to build yourself a little harem. What man doesn't..."
    Q "Sé que quieres construirte un pequeño harén. ¿Qué hombre no quiere...?"

# game/scripts/day2.rpy:336
translate spanish d2c_relic_reward_6352aef1:

    # Q "So I'm giving you this slave as a token of gratitude."
    Q "Te doy esta esclava como muestra de gratitud."

# game/scripts/day2.rpy:339
translate spanish d2c_relic_reward_96d27a43:

    # Q "Her name is Emilia, she's yours now. She will do whatever you want."
    Q "Se llama Emilia, y ahora es tuya. Hará todo lo que quieras."

# game/scripts/day2.rpy:340
translate spanish d2c_relic_reward_f7764fa8:

    # Q "She's good at cleaning too, so if you're still in need of a housemaid, she's a decent choice."
    Q "También es buena limpiando, así que si todavía necesitas una criada, es una buena opción."

# game/scripts/day2.rpy:345
translate spanish d2c_question_menu_e7fb723b:

    # Z "How did your soldiers find her?"
    Z "¿Cómo la encontraron tus soldados?"

# game/scripts/day2.rpy:346
translate spanish d2c_question_menu_170c51f7:

    # Z "She doesn't look like she's from around here."
    Z "Ella no parece de por aquí."

# game/scripts/day2.rpy:349
translate spanish d2c_question_menu_80521a3c:

    # Q "My soldiers found her somewhere in the west, relatively far from here."
    Q "Mis soldados la encontraron en algún lugar del oeste, relativamente lejos de aquí."

# game/scripts/day2.rpy:350
translate spanish d2c_question_menu_0b82de45:

    # Q "They picked her up from a border village, several months ago."
    Q "La recogieron en un pueblo de la frontera, hace varios meses."

# game/scripts/day2.rpy:353
translate spanish d2c_question_menu_fea68bd1:

    # Q "I don't know who she was with, but she seems to enjoy her role. So I am not concerned to find out."
    Q "No sé con quién estaba, pero parece disfrutar de su papel. Así que no me preocupa averiguarlo."

# game/scripts/day2.rpy:358
translate spanish d2c_question_menu_8d11b166:

    # Z "Thank you, Queen Merneith."
    Z "Gracias, Reina Merneith."

# game/scripts/day2.rpy:365
translate spanish d2c_question_menu_bd82efa6:

    # Z "That's a valuable reward. I accept."
    Z "Es una recompensa valiosa. Acepto."

# game/scripts/day2.rpy:372
translate spanish d2c_question_menu_c53342e8:

    # Z "I don't want her."
    Z "No la quiero."

# game/scripts/day2.rpy:375
translate spanish d2c_question_menu_a7c3703a:

    # Q "As you wish. Not that I mind keeping her."
    Q "Como quieras. No es que me importe quedarme con ella."

# game/scripts/day2.rpy:378
translate spanish d2c_question_menu_67c09e62:

    # Q "Slave, you can leave."
    Q "Esclava, puedes irte."

# game/scripts/day2.rpy:386
translate spanish d2c_question_menu_c1d5f030:

    # "The woman leaves..."
    "La mujer se va..."

# game/scripts/day2.rpy:393
translate spanish d2c_emilia_accepted_f0601e9c:

    # Q "I'll have her escorted to your estate."
    Q "Haré que la acompañen a tu finca."

# game/scripts/day2.rpy:396
translate spanish d2c_emilia_accepted_8862768b:

    # Q "You can go, slave."
    Q "Puedes irte, esclava."

# game/scripts/day2.rpy:404
translate spanish d2c_emilia_accepted_29a2de66:

    # "She leaves..."
    "Ella se va..."

# game/scripts/day2.rpy:405
translate spanish d2c_emilia_accepted_e946e253:

    # Q "Where were we... ah yes."
    Q "¿Dónde estábamos...? ah sí."

# game/scripts/day2.rpy:412
translate spanish d2c6_22e5efe8:

    # Q "Now, [persistent.player_name]..."
    Q "Ahora, [persistent.player_name]..."

# game/scripts/day2.rpy:413
translate spanish d2c6_e9b12567:

    # Q "Kneel."
    Q "De rodillas."

# game/scripts/day2.rpy:416
translate spanish d2c6_6e037dd7:

    # Z "...?"
    Z "¿...?"

# game/scripts/day2.rpy:419
translate spanish d2c6_3e79a8b1:

    # Q "I said kneel!"
    Q "¡He dicho que te arrodilles!"

# game/scripts/day2.rpy:427
translate spanish d2c6_7bb9b3ec:

    # Z "Why so polite..."
    Z "¿Por qué tanta cortes..."

# game/scripts/day2.rpy:432
translate spanish d2c6_6621f641:

    # Z "I'm not going to be shouted at."
    Z "No voy a dejar que me griten."

# game/scripts/day2.rpy:435
translate spanish d2c6_ce610f91:

    # Q "Refusing my orders..."
    Q "Negarse a mis órdenes..."

# game/scripts/day2.rpy:438
translate spanish d2c6_c479dba3:

    # Q "[persistent.player_name!c], I will give you one last warning..."
    Q "[persistent.player_name!c], te daré una última advertencia..."

# game/scripts/day2.rpy:439
translate spanish d2c6_1b415baa:

    # Q "Kneel or I'll have you escorted out and you'll never enter my throne room again."
    Q "Arrodíllate o haré que te echen y no volverás a entrar en mi sala del trono."

# game/scripts/day2.rpy:442
translate spanish d2c6_c918f50c:

    # Zt "Spoiled brat..."
    Zt "Mocosa malcriada..."

# game/scripts/day2.rpy:443
translate spanish d2c6_7b836947:

    # Zt "I should play her game for now."
    Zt "Debería seguir su juego por ahora."

# game/scripts/day2.rpy:447
translate spanish d2c6_409acac7:

    # "You kneel..."
    "Te arrodillas..."

# game/scripts/day2.rpy:451
translate spanish d2c6_411374ea:

    # Q "See? Was that so difficult?"
    Q "¿Ves? ¿Era tan difícil?"

# game/scripts/day2.rpy:452
translate spanish d2c6_5ab3574d:

    # Z "..."
    Z "..."

# game/scripts/day2.rpy:455
translate spanish d2c6_819d4b28:

    # Q "Now, I have a new mission for you."
    Q "Ahora, tengo una nueva misión para ti."

# game/scripts/day2.rpy:456
translate spanish d2c6_64f35ffa:

    # Q "And this time it is serious."
    Q "Y esta vez va en serio."

# game/scripts/day2.rpy:459
translate spanish d2c6_357a73d9:

    # Q "I know you're familiar with the decayed..."
    Q "Sé que estás familiarizado con los decaídos..."

# game/scripts/day2.rpy:460
translate spanish d2c6_7fdc86df:

    # Q "...they have taken to attacking our caravans in the north west."
    Q "... han empezado a atacar nuestras caravanas en el noroeste."

# game/scripts/day2.rpy:461
translate spanish d2c6_d21abf5d:

    # Q "I recently sent a couple soldiers out to scout the area."
    Q "Hace poco envié a un par de soldados a explorar la zona."

# game/scripts/day2.rpy:464
translate spanish d2c6_54a3b57c:

    # Q "Their report included some indications of where one of their hideouts might be."
    Q "Su informe incluía algunas indicaciones sobre dónde podría estar uno de sus escondites."

# game/scripts/day2.rpy:467
translate spanish d2c6_649b4401:

    # Z "...And you want me to head out there to verify this claim."
    Z "... Y quieres que me dirija allí para verificar esta afirmación."

# game/scripts/day2.rpy:470
translate spanish d2c6_1171081c:

    # Q "...and kill them off, yes."
    Q "... y matarlos, sí."

# game/scripts/day2.rpy:471
translate spanish d2c6_a2b4570f:

    # Q "You know they're not well organized. A tribe here, a local group there."
    Q "Sabes que no están bien organizados. Una tribu por aquí, un grupo local por allá."

# game/scripts/day2.rpy:474
translate spanish d2c6_111f8944:

    # Q "Even if you erase that nest, other groups will not be affected. But it still needs doing."
    Q "Aunque borres ese nido, los demás grupos no se verán afectados. Pero todavía hay que hacerlo."

# game/scripts/day2.rpy:477
translate spanish d2c6_74034a64:

    # Z "I will head out tomorrow and see what I can do."
    Z "Mañana saldré a ver qué puedo hacer."

# game/scripts/day2.rpy:480
translate spanish d2c6_9a39f21f:

    # Q "Impress me, and I'll have a reward for you, as always."
    Q "Impresióname y tendré una recompensa para ti, como siempre."

# game/scripts/day2.rpy:481
translate spanish d2c6_2bf1c415:

    # Q "You may leave now, Stalker."
    Q "Ya puedes irte, Acechador."

# game/scripts/day2.rpy:488
translate spanish d2c6_951a9773:

    # Zt "Despite her brashness, I should count myself lucky to receive my orders directly from the Queen herself, rather than an underling."
    Zt "A pesar de su arrogancia, debo considerarme afortunado de recibir mis órdenes directamente de la Reina, en lugar de un subordinado."

# game/scripts/day2.rpy:489
translate spanish d2c6_c346be52:

    # Zt "The decayed are indeed a divided faction. Their selfishness doesn't encourage solidarity or a common cause."
    Zt "Los Decaídos son, de hecho, una facción dividida. Su egoísmo no fomenta la solidaridad ni una causa común."

# game/scripts/day2.rpy:490
translate spanish d2c6_993d68d7:

    # Zt "But I will worry about that tomorrow."
    Zt "Pero eso me preocupará mañana."

# game/scripts/day2.rpy:491
translate spanish d2c6_bea4c0c5:

    # Zt "For now I need to head back home and pick up [S] for the raid."
    Zt "Por ahora necesito volver a casa y recoger a [S] para la incursión."

# game/scripts/day2.rpy:496
translate spanish d2d_ad4cd6dc:

    # "A short time later..."
    "Un poco más tarde..."

# game/scripts/day2.rpy:500
translate spanish d2d_5ab3574d:

    # Z "..."
    Z "..."

# game/scripts/day2.rpy:506
translate spanish d2d_5ab3574d_1:

    # Z "..."
    Z "..."

# game/scripts/day2.rpy:515
translate spanish d2d_65d25a1d:

    # "{i}*whistling noise*"
    "{i}*ruido de silbidos*"

# game/scripts/day2.rpy:516
translate spanish d2d_6e037dd7:

    # Z "...?"
    Z "¿...?"

# game/scripts/day2.rpy:519
translate spanish d2d_a0f5d7c7:

    # Zt "Wait..."
    Zt "Espera..."

# game/scripts/day2.rpy:522
translate spanish d2d_daf7d190:

    # Zt "That's her."
    Zt "Ella es."

# game/scripts/day2.rpy:525
translate spanish d2d_26a803bc:

    # C "..."
    C "..."

# game/scripts/day2.rpy:529
translate spanish d2d_8ccfe09d:

    # Z "Hey, where did you go? What happene- {p=1.3} {nw}"
    Z "Ey, ¿a dónde fuiste? ¿Qué pasó? {p=1.3} {nw}"

# game/scripts/day2.rpy:533
translate spanish d2d_82dcd0dc:

    # Z "...! {p=.8} {nw}"
    Z "... ¡! {p=.8} {nw}"

# game/scripts/day2.rpy:536
translate spanish d2d_5ab3574d_2:

    # Z "..."
    Z "..."

# game/scripts/day2.rpy:540
translate spanish d2d_5ab3574d_3:

    # Z "..."
    Z "..."

# game/scripts/day2.rpy:543
translate spanish d2d_cd899396:

    # Zt "She is quick..."
    Zt "Es rápida..."

# game/scripts/day2.rpy:544
translate spanish d2d_469b1e0c:

    # Zt "...and I don't think she was aiming to hit me."
    Zt "... y no creo que quisiera golpearme."

# game/scripts/day2.rpy:547
translate spanish d2d_de62a098:

    # Zt "What do you want to tell me, elf..."
    Zt "¿Qué me quieres contar, elfa...?"

# game/scripts/day2.rpy:548
translate spanish d2d_f6c35e2d:

    # Zt "..."
    Zt "..."

# game/scripts/day2.rpy:549
translate spanish d2d_3369c282:

    # Zt "Engraved words..."
    Zt "Palabras grabadas..."

# game/scripts/day2.rpy:550
translate spanish d2d_509570ea:

    # Zt "\"Tomorrow midnight at the market. Be there.\""
    Zt "\"Mañana a medianoche en el mercado. Estaré allí.\""

# game/scripts/day2.rpy:551
translate spanish d2d_183bcbe1:

    # Zt "Midnight you say..."
    Zt "¿Medianoche, dices...?"

# game/scripts/day2.rpy:552
translate spanish d2d_ef8eb96a:

    # Zt "There must be more to this."
    Zt "Debe haber más en esto."

# game/scripts/day2.rpy:555
translate spanish d2d_0a76840d:

    # Zt "If she wanted to kill me, this would have been her best chance."
    Zt "Si ella quisiera matarme, esta habría sido su mejor oportunidad."

# game/scripts/day2.rpy:556
translate spanish d2d_a6bc9d5a:

    # Zt "So be it, I will play your game."
    Zt "De acuerdo, jugaré tu juego."

# game/scripts/day2.rpy:560
translate spanish d2d_779b9db4:

    # Zt "Tomorrow is going to be a long day."
    Zt "Mañana será un día largo."

# game/scripts/day2.rpy:561
translate spanish d2d_b6d08405:

    # Zt "First the Queen's quest, now this..."
    Zt "Primero la misión de la Reina, ahora esto..."

# game/scripts/day2.rpy:562
translate spanish d2d_d34f9886:

    # Zt "At least that solves the question regarding the armoury's thief."
    Zt "Al menos eso resuelve la cuestión del ladrón de la armería."

# game/scripts/day2.rpy:563
translate spanish d2d_ba1e1ec4:

    # Zt "Time to head home."
    Zt "Es hora de volver a casa."

# game/scripts/day2.rpy:569
translate spanish d2d_ba1e1ec4_1:

    # Zt "Time to head home."
    Zt "Es hora de volver a casa."

# game/scripts/day2.rpy:576
translate spanish d2e_6b7f98dd:

    # "{i}Half an hour later..."
    "{i}Media hora después..."

# game/scripts/day2.rpy:587
translate spanish d2e_58114270:

    # Z "[S]! I'm back!! Are you ready?"
    Z "¡[S]! ¡¡He vuelto!! ¿Estás preparada?"

# game/scripts/day2.rpy:588
translate spanish d2e_af6ed6bf:

    # Zt "She's usually on time..."
    Zt "Ella suele ser puntual..."

# game/scripts/day2.rpy:591
translate spanish d2e_b5cfd778:

    # S "Am I really that quiet, or are you just deaf?"
    S "¿Realmente soy tan silenciosa, o sólo estás sordo?"

# game/scripts/day2.rpy:592
translate spanish d2e_283c8755:

    # Z "..!"
    Z "¡..!"

# game/scripts/day2.rpy:595
translate spanish d2e_cf1c9d02:

    # Z "Damn it [S], you are getting good at this; almost gave me a scare."
    Z "Maldita sea, [S], te estás volviendo buena en esto; casi me das un susto."

# game/scripts/day2.rpy:598
translate spanish d2e_29fc18cd:

    # S "Sorry, not sorry."
    S "Lo siento, no lo siento."

# game/scripts/day2.rpy:603
translate spanish d2e_e63584b0:

    # Zt "Here she is, ready to head out for her first tomb raid."
    Zt "Aquí está, lista para salir en su primera incursión en una tumba."

# game/scripts/day2.rpy:606
translate spanish d2e_6055f572:

    # "You look at her again, thinking about how far she's come."
    "La vuelves a mirar, pensando en todo lo que ha pasado."

# game/scripts/day2.rpy:608
translate spanish d2e_1d8b90b6:

    # "In her gaze, you recognise the pride of her mother, and your own quiet confidence."
    "En su mirada, reconoces el orgullo de su madre y tu propia confianza tranquila."

# game/scripts/day2.rpy:610
translate spanish d2e_8f69bfc3:

    # "You feel you have done a good job, as she seems to be as confident as you were at her age."
    "Sientes que has hecho un buen trabajo, ya que parece tan segura de sí misma como tú a su edad."

# game/scripts/day2.rpy:613
translate spanish d2e_b8acb9b3:

    # Z "So... have you prepared everything?"
    Z "¿Has preparado todo?"

# game/scripts/day2.rpy:616
translate spanish d2e_8474e568:

    # S "Of course I did."
    S "Por supuesto que lo hice."

# game/scripts/day2.rpy:619
translate spanish d2e_a28d7471:

    # Z "Swords?"
    Z "¿Espadas?"

# game/scripts/day2.rpy:622
translate spanish d2e_b684b47c:

    # S "In the car."
    S "En el coche."

# game/scripts/day2.rpy:625
translate spanish d2e_648c51cd:

    # Z "First aid kit?"
    Z "¿El botiquín de primeros auxilios?"

# game/scripts/day2.rpy:628
translate spanish d2e_b684b47c_1:

    # S "In the car."
    S "En el coche."

# game/scripts/day2.rpy:631
translate spanish d2e_aa52819d:

    # Z "Emergency rations?"
    Z "¿Raciones de emergencia?"

# game/scripts/day2.rpy:634
translate spanish d2e_a7fbe963:

    # S "Take a guess."
    S "Adivina."

# game/scripts/day2.rpy:637
translate spanish d2e_d78e9df7:

    # Z "That's my girl."
    Z "Esa es mi chica."

# game/scripts/day2.rpy:640
translate spanish d2e_a44efc67:

    # Z "Alright, let's go."
    Z "Muy bien, vamos."

# game/scripts/day2.rpy:641
translate spanish d2e_3edfadc4:

    # Z "That outfit suits you perfectly. I'm glad."
    Z "Esas ropas te quedan perfectas. Me alegra."

# game/scripts/day2.rpy:642
translate spanish d2e_d44120a8:

    # S "Hm."
    S "Umm."

# game/scripts/day2.rpy:645
translate spanish d2e_fcba300d:

    # "She walks towards you..."
    "Camina hacia ti..."

# game/scripts/day2.rpy:648
translate spanish d2e_3b8e71e4:

    # S "The top is a little tattered here and there, but it does feel safer than simple cotton fabric."
    S "La parte superior está un poco desgastada aquí y allá, pero se siente más seguro que una simple tela de algodón."

# game/scripts/day2.rpy:651
translate spanish d2e_2a1edd9f:

    # Z "I was lucky to find it for you."
    Z "Tuve suerte de encontrarlo para ti."

# game/scripts/day2.rpy:654
translate spanish d2e_cbc8d828:

    # S "Haha, yeah [persistent.dad]..."
    S "Jaja, sí, [persistent.dad]..."

# game/scripts/day2.rpy:655
translate spanish d2e_a49c7131:

    # S "Shall we go?"
    S "¿Vamos?"

# game/scripts/day2.rpy:658
translate spanish d2e_549bcda8:

    # Z "After you."
    Z "Después de ti."

# game/scripts/day2.rpy:661
translate spanish d2e_50303b5f:

    # "You both head to the car..."
    "Ambos os dirigís al coche..."

# game/scripts/day2.rpy:665
translate spanish d2e_0faeaa96:

    # Z "We should arrive in a few hours, it's not too far away."
    Z "Deberíamos llegar en unas horas, no está muy lejos."

# game/scripts/day2.rpy:666
translate spanish d2e_d680604d:

    # S "Further away than I've ever been."
    S "Más lejos de lo que nunca he estado."

# game/scripts/day2.rpy:667
translate spanish d2e_7d27385b:

    # S "To be honest [persistent.dad]..."
    S "Para ser honesta [persistent.dad]..."

# game/scripts/day2.rpy:670
translate spanish d2e_88d478e1:

    # S "I don't know whether to be excited or nervous."
    S "No sé si estar emocionada o nerviosa."

# game/scripts/day2.rpy:675
translate spanish d2e_fc841a11:

    # Z "Whatever happens, I've got your back."
    Z "Lo que sea que pase, te cubro las espaldas."

# game/scripts/day2.rpy:677
translate spanish d2e_2c3f45ff:

    # Z "Focus on the adventure ahead."
    Z "Concéntrate en la aventura que te espera."

# game/scripts/day2.rpy:678
translate spanish d2e_152b88c9:

    # Z "Don't think too much of what might or might not happen."
    Z "No pienses demasiado en lo que puede o no puede pasar."

# game/scripts/day2.rpy:679
translate spanish d2e_38c4dbfe:

    # Z "Try to enjoy this moment. You waited long enough."
    Z "Intenta disfrutar este momento. Esperaste lo suficiente."

# game/scripts/day2.rpy:682
translate spanish d2e_61f94511:

    # S "I will. Thanks [persistent.dad]."
    S "Lo haré. Gracias, [persistent.dad]."

# game/scripts/day2.rpy:683
translate spanish d2e_f98d8f37:

    # S "That's... good."
    S "Eso es... bueno."

# game/scripts/day2.rpy:689
translate spanish d2e_e75cbd25:

    # Z "Don't be afraid, have confidence in your skills."
    Z "No tengas miedo, confía en tus habilidades."

# game/scripts/day2.rpy:691
translate spanish d2e_2c75ac97:

    # Z "You know how to protect yourself."
    Z "Sabes cómo protegerte."

# game/scripts/day2.rpy:692
translate spanish d2e_c2eda6aa:

    # Z "You passed all the challenges you faced so far."
    Z "Has superado todos los retos a los que te has enfrentado hasta ahora."

# game/scripts/day2.rpy:693
translate spanish d2e_51c4fc0d:

    # Z "And when I will be long gone and you sit where I'm sitting,"
    Z "Y cuando yo ya no esté y tú te sientes donde yo estoy sentado,"

# game/scripts/day2.rpy:694
translate spanish d2e_76ab3dfc:

    # Z "...you will think back to this day and be able to tell yourself that you did it."
    Z "... recordarás este día y podrás decirte a ti mismo que lo hiciste."

# game/scripts/day2.rpy:697
translate spanish d2e_97d11422:

    # S "I see. It's difficult, but I will try. Thanks [persistent.dad]."
    S "Ya veo. Es difícil, pero lo intentaré. Gracias [persistent.dad]."

# game/scripts/day2.rpy:704
translate spanish d2e11x_5240e365:

    # Z "Now... are we ready to kick some ass?"
    Z "Ahora... ¿estamos preparados para patear algunos culos?"

# game/scripts/day2.rpy:707
translate spanish d2e11x_719e2b58:

    # S "You can bet yours!"
    S "¡Puedes apostar por el tuyo!"

# game/scripts/day2.rpy:710
translate spanish d2e11x_fce9b02b:

    # Z "Hah, come on. Get in."
    Z "Ja, vamos. Entra."

# game/scripts/day2.rpy:714
translate spanish d2e11x_6c46c1e4:

    # S "I can't wait, wohoo!"
    S "¡No puedo esperar, wohoo!"

# game/scripts/day2.rpy:720
translate spanish d2e11x_8528cbd3:

    # "You've been building up your pupil's skills and competence for several years now."
    "Has estado puliendo las habilidades y competencias de tu aprendiz durante varios años."

# game/scripts/day2.rpy:721
translate spanish d2e11x_2869f604:

    # "It's time to put what she has learned to the test in a more direct, dangerous way."
    "Es hora de poner a prueba lo que ha aprendido de una manera más directa y peligrosa."

# game/scripts/day2.rpy:724
translate spanish d2e11x_009650ff:

    # "You have been given directions to this reportedly abandoned ruin. A recent sandstorm cleared the dunes around it, revealing an imposing building."
    "Te han dado instrucciones para estas supuestas ruinas abandonadas. Una tormenta de arena reciente despejó las dunas a su alrededor, revelando un edificio imponente."

# game/scripts/day2.rpy:728
translate spanish d2e11x_9777982e:

    # "Ordinarily, you would scout out the place and expect it to be looted empty. This time however, the discovery is so recent that you feel you have a good shot at finding some treasure worth taking."
    "Normalmente, explorarías el lugar y esperarías que estuviera saqueado por completo. Sin embargo, esta vez el descubrimiento es tan reciente que sientes que tienes una buena oportunidad de encontrar algún tesoro que merezca la pena."

# game/scripts/day2.rpy:732
translate spanish d2e11x_196b2bf8:

    # "Additionally, rushing the job might be reckless for a single man, even one of your experience, but now you have backup, and, more importantly..."
    "Además, apresurar el trabajo podría ser imprudente para un solo hombre, incluso uno con tu experiencia, pero ahora tienes apoyo, y, más importante..."

# game/scripts/day2.rpy:736
translate spanish d2e11x_7008c8b2:

    # "She will have to really apply all she has learned, from the hours spent studying ancient lore, to the very real possibility of having to confront other looters or random creatures."
    "Tendrá que aplicar realmente todo lo que ha aprendido, desde las horas dedicadas al estudio de la antigua tradición, hasta la muy real posibilidad de enfrentarse a otros asaltantes o criaturas al azar."

# game/scripts/day2.rpy:742
translate spanish d2e11x_dd791060:

    # S "Look, [persistent.dad]!"
    S "¡Mira, [persistent.dad]!"

# game/scripts/day2.rpy:743
translate spanish d2e11x_87970e29:

    # S "A settlement!"
    S "¡Un asentamiento!"

# game/scripts/day2.rpy:749
translate spanish d2e11x_e1011a2f:

    # C3 "..."
    C3 "..."

# game/scripts/day2.rpy:751
translate spanish d2e11x_33f95c30:

    # C "Uncle.. is that a Desert Stal-"
    C "Tío... ¿es eso un Acechador del Des...?"

# game/scripts/day2.rpy:752
translate spanish d2e11x_93a508be:

    # C3 "Don't look Abena. Get back to bed."
    C3 "No mires, Abena. Vuelve a la cama."

# game/scripts/day2.rpy:762
translate spanish d2e11x_e81d87c4:

    # Z "This is the place."
    Z "Este es el lugar."

# game/scripts/day2.rpy:765
translate spanish d2e11x_80ffacf8:

    # S "...Woow!"
    S "... ¡Guauuu!"

# game/scripts/day2.rpy:768
translate spanish d2e11x_6459d215:

    # S "...this place must be full of secrets!"
    S "... ¡este lugar debe estar lleno de secretos!"

# game/scripts/day2.rpy:771
translate spanish d2e11x_5a956d13:

    # Z "Let's try to find a path before the sun sets..."
    Z "Intentemos encontrar un camino antes de que se ponga el sol..."

# game/scripts/day2.rpy:775
translate spanish d2e11x_33a46fdf:

    # "Some time later..."
    "Pasado un tiempo..."

# game/scripts/day2.rpy:776
translate spanish d2e11x_3173bcfc:

    # S "This place is huge!"
    S "¡Este lugar es enorme!"

# game/scripts/day2.rpy:777
translate spanish d2e11x_ab5d22b8:

    # Z "Yes. We will definitely have to come back here again if we want to explore everything."
    Z "Sí. Definitivamente tendremos que volver aquí si queremos explorarlo todo."

# game/scripts/day2.rpy:778
translate spanish d2e11x_2aad1094:

    # S "Let's go this way."
    S "Vamos por aquí."

# game/scripts/day2.rpy:779
translate spanish d2e11x_c80c4db3:

    # S "I have a good feeling about this."
    S "Tengo un buen presentimiento sobre esto."

# game/scripts/day2.rpy:783
translate spanish d2e11x_11e95236:

    # "An hour or more passes, and you find yourself inside a corridor buried deep at the base of the pyramid."
    "Pasa una hora o más, y te encuentras dentro de un pasillo enterrado en la base de la pirámide."

# game/scripts/day2.rpy:784
translate spanish d2e11x_14b2854e:

    # S "It looks like we are not the first ones to come here."
    S "Parece que no somos los primeros en llegar aquí."

# game/scripts/day2.rpy:785
translate spanish d2e11x_d47382b8:

    # Z "Not the first, perhaps. But certainly the first in a long time."
    Z "No el primero, tal vez. Pero ciertamente el primero en mucho tiempo."

# game/scripts/day2.rpy:788
translate spanish d2e11x_c5a2af19:

    # S "The torches and braziers are still lit..."
    S "Las antorchas y braseros aún están encendidos..."

# game/scripts/day2.rpy:789
translate spanish d2e11x_4f949733:

    # S "Someone was here not long ago."
    S "Alguien estuvo aquí no hace mucho."

# game/scripts/day2.rpy:790
translate spanish d2e11x_1aeaaa6a:

    # Z "Not necessarily..."
    Z "No necesariamente..."

# game/scripts/day2.rpy:791
translate spanish d2e11x_f1d08cb6:

    # Z "I've explored many tombs over the years, and these are not the first lit torches I have seen."
    Z "He explorado muchas tumbas a lo largo de los años, y no es la primera vez que veo antorchas encendidas."

# game/scripts/day2.rpy:794
translate spanish d2e11x_d595a3cd:

    # Z "I've talked with other Stalkers about this, several times."
    Z "He hablado con otros Acechadores sobre esto, varias veces."

# game/scripts/day2.rpy:795
translate spanish d2e11x_91321002:

    # Z "Some say the torches have some property that keeps them forever alight since the days before the End of Days."
    Z "Algunos dicen que las antorchas tienen una propiedad que las mantiene encendidas desde los días antes del Fin de los Tiempos."

# game/scripts/day2.rpy:796
translate spanish d2e11x_0e51c3f4:

    # Z "Others say that the mummies themselves ignite the torches from time to time."
    Z "Otros dicen que las propias momias encienden las antorchas de vez en cuando."

# game/scripts/day2.rpy:797
translate spanish d2e11x_31d551c3:

    # S "But you said they never wake up unless they're alerted?"
    S "¿Pero has dicho que nunca se despiertan si no se les alerta?"

# game/scripts/day2.rpy:798
translate spanish d2e11x_b5d44ba4:

    # Z "That is true according to my direct experience. They never would - when I encountered them."
    Z "Eso es cierto según mi experiencia directa. Nunca lo harían, al menos cuando los encontré."

# game/scripts/day2.rpy:799
translate spanish d2e11x_55e65650:

    # Z "But I cannot claim to know every possible thing, when I encounter these places in but a fraction of their centuries long stories."
    Z "Pero no puedo pretender saber todas las posibles cosas cuando encuentro estos lugares en solo una fracción de sus historias centenarias."

# game/scripts/day2.rpy:800
translate spanish d2e11x_ef7c8d9e:

    # Z "Some things in this world follow their own logic."
    Z "Algunas cosas en este mundo siguen su propia lógica."

# game/scripts/day2.rpy:801
translate spanish d2e11x_c81182af:

    # Z "And it is better for us not to question everything."
    Z "Y es mejor que no cuestionemos todo."

# game/scripts/day2.rpy:802
translate spanish d2e11x_5282849c:

    # S "I will... keep this in mind."
    S "Lo tendré en cuenta."

# game/scripts/day2.rpy:805
translate spanish d2e11x_5e4dee8e:

    # Z "That door won't open on its own."
    Z "Esa puerta no se abrirá sola."

# game/scripts/day2.rpy:806
translate spanish d2e11x_7a624a52:

    # Z "But I don't think this is a dead end either."
    Z "Pero tampoco creo que esto sea un callejón sin salida."

# game/scripts/day2.rpy:809
translate spanish d2e11x_665b05a0:

    # S "Let's hope you're right."
    S "Esperemos que tengas razón."

# game/scripts/day2.rpy:810
translate spanish d2e11x_dce50367:

    # Z "See if there is a hidden mechanism in place."
    Z "Revisa si hay un mecanismo oculto en algún lugar."

# game/scripts/day2.rpy:811
translate spanish d2e11x_b47813ae:

    # Z "I will scout the rest of the room and see what I can find."
    Z "Exploraré el resto de la habitación y veré qué puedo encontrar."

# game/scripts/day2.rpy:812
translate spanish d2e11x_00338f0f:

    # S "I'm on it."
    S "Me pondré con ello."

# game/scripts/day2.rpy:813
translate spanish d2e11x_ede3167f:

    # Z "Let's see..."
    Z "Veamos..."

# game/scripts/day2.rpy:823
translate spanish d2e_tomb_search_b3c330ce:

    # Zt "That was definitely set as a warning."
    Zt "Definitivamente eso fue una advertencia."

# game/scripts/day2.rpy:824
translate spanish d2e_tomb_search_fece01d2:

    # Zt "I wonder what the story behind this is."
    Zt "Me pregunto cuál es la historia detrás de esto."

# game/scripts/day2.rpy:825
translate spanish d2e_tomb_search_f6c35e2d:

    # Zt "..."
    Zt "..."

# game/scripts/day2.rpy:826
translate spanish d2e_tomb_search_ded2b599:

    # Zt "I should keep looking around."
    Zt "Debería seguir mirando alrededor."

# game/scripts/day2.rpy:833
translate spanish d2e_tomb_search_2471eb75:

    # Zt "Bones and a weapon."
    Zt "Huesos y un arma."

# game/scripts/day2.rpy:834
translate spanish d2e_tomb_search_cbe6b0cd:

    # Zt "It looks like people came here armed... Did they just all die in the same spot, or did something pile up their remains?"
    Zt "¿Pareciera que la gente vino aquí armada...? ¿Todos murieron en el mismo lugar, o algo apiló sus restos?"

# game/scripts/day2.rpy:835
translate spanish d2e_tomb_search_284d1531:

    # Zt "That looks like a serious weapon, like that of a soldier."
    Zt "Eso parece un arma seria, como la de un soldado."

# game/scripts/day2.rpy:836
translate spanish d2e_tomb_search_dca69227:

    # Zt "But this tomb isn't in Zeta's territory, and the Queen never mentioned it either."
    Zt "Pero esta tumba no está en el territorio de Zeta, y la Reina tampoco la mencionó nunca."

# game/scripts/day2.rpy:837
translate spanish d2e_tomb_search_b548e455:

    # Zt "Whoever used these weapons, they lost and didn't get very close to the door."
    Zt "Quienquiera que usara estas armas, perdió y no se acercó mucho a la puerta."

# game/scripts/day2.rpy:842
translate spanish d2e_tomb_search_d83a19fb:

    # Zt "Four braziers, four torches. Two on each side, front and back."
    Zt "Cuatro braseros, cuatro antorchas. Dos a cada lado, delante y detrás."

# game/scripts/day2.rpy:843
translate spanish d2e_tomb_search_28de9737:

    # Zt "Hm..."
    Zt "Hm..."

# game/scripts/day2.rpy:847
translate spanish d2e_tomb_search_a5b58354:

    # Zt "Whoever fought here, the victors definitely put up a warning."
    Zt "Quienquiera que luchó aquí, los vencedores dejaron una advertencia clara."

# game/scripts/day2.rpy:848
translate spanish d2e_tomb_search_5eaa970e:

    # Zt "The weapon in between those bones on the ground is of higher quality than the sword used to impale the skull too."
    Zt "El arma entre esos huesos en el suelo es de mayor calidad que la espada usada para empalar el cráneo también."

# game/scripts/day2.rpy:849
translate spanish d2e_tomb_search_f6c35e2d_1:

    # Zt "..."
    Zt "..."

# game/scripts/day2.rpy:850
translate spanish d2e_tomb_search_4edca2fb:

    # Zt "They were defending the tomb from these attackers..."
    Zt "Estaban defendiendo la tumba de estos atacantes..."

# game/scripts/day2.rpy:851
translate spanish d2e_tomb_search_01d4aad4:

    # Zt "...and the attackers knew how to get in, else there wouldn't have been a fight in the first place."
    Zt "... y los atacantes sabían cómo entrar, de lo contrario no habría habido una pelea en primer lugar."

# game/scripts/day2.rpy:854
translate spanish d2e_tomb_search_d218f7ac:

    # Z "[S], there must be an easy way to get in. Look for a loose brick in the wall."
    Z "[S], debe haber una forma fácil de entrar. Busca un ladrillo suelto en la pared."

# game/scripts/day2.rpy:855
translate spanish d2e_tomb_search_a925f58e:

    # Z "Something that might hide a mechanism, or directly a passage."
    Z "Algo que pueda esconder un mecanismo, o directamente un pasaje."

# game/scripts/day2.rpy:858
translate spanish d2e_tomb_search_333fbf1a:

    # S "I tried, but none of these are easy to move."
    S "Lo intenté, pero ninguno de estos es fácil de mover."

# game/scripts/day2.rpy:861
translate spanish d2e_tomb_search_49a420e2:

    # Zt "Let me think... there are four torches and four braziers. And one path in the middle..."
    Zt "Déjame pensar... hay cuatro antorchas y cuatro braseros. Y un camino en el medio..."

# game/scripts/day2.rpy:862
translate spanish d2e_tomb_search_8f16e540:

    # Z "Try the fourth brick from the bottom. The center one."
    Z "Intenta el cuarto ladrillo desde abajo. El del centro."

# game/scripts/day2.rpy:865
translate spanish d2e_tomb_search_33dbd5a9:

    # S "Sure. I'll call you a wizard if this works."
    S "Claro. Te llamaré mago si esto funciona."

# game/scripts/day2.rpy:868
translate spanish d2e_tomb_search_25e7a4f3:

    # Z "We have to start somewhere. Should I help?"
    Z "Tenemos que empezar por algún sitio. ¿Quieres que te ayude?"

# game/scripts/day2.rpy:871
translate spanish d2e_tomb_search_01bff019:

    # S "No, I got this."
    S "No, yo tengo esto."

# game/scripts/day2.rpy:872
translate spanish d2e_tomb_search_a90d61a1:

    # S "{i}*pushes* Hnnnnngghh..."
    S "{i}*empujones* Hnnnnngghh..."

# game/scripts/day2.rpy:873
translate spanish d2e_tomb_search_2496b4ac:

    # S "This is a tough one..!"
    S "¡Esto está duro...!"

# game/scripts/day2.rpy:876
translate spanish d2e_tomb_search_5ab3574d:

    # Z "..."
    Z "..."

# game/scripts/day2.rpy:879
translate spanish d2e_tomb_search_7fd42cc2:

    # S "Something..."
    S "Algo..."

# game/scripts/day2.rpy:880
translate spanish d2e_tomb_search_3c26340f:

    # S "is..."
    S "se está..."

# game/scripts/day2.rpy:881
translate spanish d2e_tomb_search_08fca739:

    # S "moving...!"
    S "¡moviendo...!"

# game/scripts/day2.rpy:885
translate spanish d2e_tomb_search_cc4ddf1c:

    # S "Yes!"
    S "¡Sí!"

# game/scripts/day2.rpy:888
translate spanish d2e_tomb_search_7733a63c:

    # S "Guess what [persistent.dad], you're a wizard now."
    S "Adivina qué [persistent.dad], ahora eres un mago."

# game/scripts/day2.rpy:889
translate spanish d2e_tomb_search_89b8852a:

    # S "Can I go first?"
    S "¿Puedo ir primera?"

# game/scripts/day2.rpy:890
translate spanish d2e_tomb_search_c50cf352:

    # Z "Go ahead, but be careful."
    Z "Adelante, pero ten cuidado."

# game/scripts/day2.rpy:891
translate spanish d2e_tomb_search_d5f9e8a8:

    # "{i}Moments later..."
    "{i}Momentos más tarde...{/i}"

# game/scripts/day2.rpy:895
translate spanish d2e_tomb_search_071d702f:

    # Sw "A cave inside a tomb?"
    Sw "¿Una cueva dentro de una tumba?"

# game/scripts/day2.rpy:896
translate spanish d2e_tomb_search_3d1bb50e:

    # Sw "Who would do this?"
    Sw "¿Quién haría esto?"

# game/scripts/day2.rpy:899
translate spanish d2e_tomb_search_ab1c084f:

    # Zw "Whoever needed to build another tomb... or hide something of value."
    Zw "Quienquiera que necesitara construir otra tumba... o esconder algo valioso."

# game/scripts/day2.rpy:902
translate spanish d2e_tomb_search_8b0f34c1:

    # Sw "[persistent.dad!c]... not going to lie. This is creeping me out."
    Sw "[persistent.dad!c]... no voy a mentir. Esto me está dando escalofríos."

# game/scripts/day2.rpy:905
translate spanish d2e_tomb_search_d52b160b:

    # Zw "Shh... turn around. Do you see that?"
    Zw "Shh... date la vuelta. ¿Ves eso?"

# game/scripts/day2.rpy:908
translate spanish d2e_tomb_search_e246992d:

    # S "...?"
    S "¿...?"

# game/scripts/day2.rpy:911
translate spanish d2e_tomb_search_3bb1d752:

    # Zw "Get down."
    Zw "Agáchate."

# game/scripts/day2.rpy:912
translate spanish d2e_tomb_search_ab3571ec:

    # Zw "Stay low [S]. Look closer..."
    Zw "Quédate bajo, [S]. Mira más de cerca..."

# game/scripts/day2.rpy:915
translate spanish d2e_tomb_search_c983d3c1:

    # Zw "Remember what I taught you?"
    Zw "¿Recuerdas lo que te enseñé?"

# game/scripts/day2.rpy:918
translate spanish d2e_tomb_search_d0290287:

    # Sw "Always scout the area first; do not move unnecessarily; watch your steps."
    Sw "Siempre explora el área primero; no te muevas innecesariamente; mira dónde pisas."

# game/scripts/day2.rpy:919
translate spanish d2e_tomb_search_f9e6dcdf:

    # Zw "Good. What do you see?"
    Zw "Bien. ¿Qué ves?"

# game/scripts/day2.rpy:922
translate spanish d2e_tomb_search_3d5c2f64:

    # Sw "I see... mummies...! Two of them... and one more, laying down."
    Sw "Veo... momias... ¡Dos de ellas... y una más, tumbada."

# game/scripts/day2.rpy:923
translate spanish d2e_tomb_search_5ea99a70:

    # Sw "You can barely see them in the dark."
    Sw "Apenas se ven en la oscuridad."

# game/scripts/day2.rpy:924
translate spanish d2e_tomb_search_b11d525b:

    # Zw "Expect there to be more."
    Zw "Espera que haya más."

# game/scripts/day2.rpy:927
translate spanish d2e_tomb_search_50d78fd7:

    # Sw "What do you want to do now?"
    Sw "¿Qué quieres hacer ahora?"

# game/scripts/day2.rpy:930
translate spanish d2e_tomb_search_3ac326fe:

    # Zw "Advancing any further might leave us exposed on all sides."
    Zw "Avanzar más podría dejarnos expuestos por todos lados."

# game/scripts/day2.rpy:931
translate spanish d2e_tomb_search_8df5d83e:

    # Zw "It's best if we take a stand here."
    Zw "Es mejor que tomemos una posición aquí."

# game/scripts/day2.rpy:932
translate spanish d2e_tomb_search_a6f10ae6:

    # Zw "I taught you to fight."
    Zw "Te he enseñado a luchar."

# game/scripts/day2.rpy:933
translate spanish d2e_tomb_search_634131ee:

    # Zw "It is time to show what you've learned."
    Zw "Es hora de mostrar lo que has aprendido."

# game/scripts/day2.rpy:934
translate spanish d2e_tomb_search_864884f5:

    # Zw "Why don't you make yourself known to them?"
    Zw "¿Por qué no te haces conocer entre ellos?"

# game/scripts/day2.rpy:937
translate spanish d2e_tomb_search_e9fe985c:

    # Sw "A-are you serious, [persistent.dad]?"
    Sw "¿A-eres serio, [persistent.dad]?"

# game/scripts/day2.rpy:940
translate spanish d2e_tomb_search_6d86ec00:

    # Z "To face danger and uncertainty is the path of a Desert Stalker, [S]."
    Z "Enfrentar el peligro y la incertidumbre es el camino de un Acechador del Desierto, [S]."

# game/scripts/day2.rpy:941
translate spanish d2e_tomb_search_a9759a6a:

    # Z "Mummies are much less scary once you understand how they move and act. Only through experience, will that come to you."
    Z "Las momias son mucho menos aterradoras una vez que entiendes cómo se mueven y actúan. Solo con experiencia, lo comprenderás."

# game/scripts/day2.rpy:942
translate spanish d2e_tomb_search_d8ea1b09:

    # Z "I have your back. Go on."
    Z "Te cubro. Adelante."

# game/scripts/day2.rpy:946
translate spanish d2e_tomb_search_2c5baa1a:

    # S "Okay... let's do this!"
    S "Vale... ¡hagámoslo!"

# game/scripts/day2.rpy:950
translate spanish d2e_tomb_search_a7164cc3:

    # S "Hey assholes!!"
    S "¡¡Ey, gilipollas!!"

# game/scripts/day2.rpy:951
translate spanish d2e_tomb_search_755bfcb8:

    # S "What does a girl have to do here, to have a good time?"
    S "¿Qué tiene que hacer una chica aquí para pasar un buen rato?"

# game/scripts/day2.rpy:952
translate spanish d2e_tomb_search_971a98df:

    # S "..."
    S "..."

