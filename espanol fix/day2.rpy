    # game/scripts/day2.rpy:79
    old "\"[persistent.player_name!c], Desert Stalker. I was tasked to recover an old relic.\""
    new "\"[persistent.player_name!c], Acechador del Desierto. Me han encargado que recupere una antigua reliquia.\""

    # game/scripts/day2.rpy:104
    old "\"Is this how you treat your elders?\""
    new "\"¿Es así como tratas a tus mayores?\""

    # game/scripts/day2.rpy:150
    old "\"You'll regret talking like that.\""
    new "\"Te arrepentirás de haberme hablado así.\""

    # game/scripts/day2.rpy:256
    old "\"I found an ancient relic.\""
    new "\"He encontrado una reliquia antigua.\""

    # game/scripts/day2.rpy:267
    old "\"I found something. What do I get in return?\""
    new "\"He encontrado algo. ¿Qué recibo a cambio?\""

    # game/scripts/day2.rpy:285
    old "\"There was nothing left. The tomb was empty.\" (Lie)"
    new "\"No quedaba nada. La tumba estaba vacía. (Mentira)\""

    # game/scripts/day2.rpy:344
    old "\"How did your soldiers find her?\""
    new "\"¿Cómo la encontraron tus soldados?\""

    # game/scripts/day2.rpy:357
    old "\"Thank you, Queen Merneith.\""
    new "\"Gracias, Reina Merneith.\""

    # game/scripts/day2.rpy:364
    old "\"That's a valuable reward. I accept.\""
    new "\"Es una recompensa valiosa. La acepto.\""

    # game/scripts/day2.rpy:371
    old "\"I don't want her.\""
    new "\"No la quiero.\""

    # game/scripts/day2.rpy:423
    old "Do as she says"
    new "Haz lo que te dice"

    # game/scripts/day2.rpy:426
    old "Do it reluctantly"
    new "Hazlo de mala gana"

    # game/scripts/day2.rpy:674
    old "\"Whatever happens, I got your back.\""
    new "\"Pase lo que pase, te cubriré las espaldas.\""

    # game/scripts/day2.rpy:688
    old "\"Don't be afraid, have confidence in your skills.\""
    new "\"No tengas miedo, confía en tus habilidades.\""

    # game/scripts/day2.rpy:819
    old "Look at the impaled skull"
    new "Mira el cráneo empalado"

    # game/scripts/day2.rpy:829
    old "Inspect the bones on the ground"
    new "Inspecciona los huesos del suelo"

    # game/scripts/day2.rpy:840
    old "Check out the torches and braziers"
    new "Comprueba las antorchas y los braseros"

    # game/scripts/day2.rpy:1041
    old "Kill the mummy"
    new "Mata a la momia"

    # game/scripts/day2.rpy:1098
    old "Help [S] first"
    new "Primero ayuda a [S]."

    # game/scripts/day2.rpy:1258
    old "\"Try to make the world a better place while you're here.\""
    new "\"Intenta hacer del mundo un lugar mejor mientras estés aquí\""

    # game/scripts/day2.rpy:1272
    old "\"You can't help everyone. But you should do your best.\""
    new "\"No puedes ayudar a todo el mundo. Pero debes hacer lo que puedas.\""

    # game/scripts/day2.rpy:1286
    old "\"Take care of yourself first. Then worry about others.\""
    new "\"Cuida primero de ti misma. Luego preocúpate de los demás.\""

    # game/scripts/day2.rpy:1299
    old "\"You are free. You don't owe this world anything.\""
    new "\"Eres libre. No le debes nada a este mundo.\""

    # game/scripts/day2.rpy:1419
    old "\"That's enough.\""
    new "\"Esto es suficiente.\""

