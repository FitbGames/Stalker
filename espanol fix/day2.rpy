    # Li "I know that [Ta], but protocol is protocol."
    Li "Lo sé [Ta], pero el protocolo es el protocolo."

# game/scripts/day2.rpy:125
translate spanish d2b_5c003300:

    # Ta "I'm sure you will let the protocol slide once you get to know [persistent.player_name] better..."
    Ta "Estoy segura de que dejarás pasar el protocolo una vez que conozcas mejor a [persistent.player_name]..."

# game/scripts/day2.rpy:128
translate spanish d2b_1d794823:

