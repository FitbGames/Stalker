    # Ta "What? Come on [Li], this is [persistent.player_name]. You should treat a Desert Stalker better than this. Especially him."
    Ta "¿Qué? Vamos [Li], este es [persistent.player_name]. Deberías tratar a un Acechador del Desierto mejor que esto. Especialmente a él."

# game/scripts/day2.rpy:165
translate spanish d2b_63526601:

    # Z "She will need a long time to catch up to your example, [Ta]."
    Z "Necesitará mucho tiempo para alcanzar tu ejemplo, [Ta]."

