# game/scripts/convis_zahra.rpy:22
translate spanish zahra_conversations_18f4ae8f:

    # Z "Say, do you want to introduce [F] to the household?"
    Z "Oye, ¿quieres presentar a [F] en la casa?"

# game/scripts/convis_zahra.rpy:26
translate spanish zahra_conversations_b08faca3:

    # W "Wait... [F]?"
    W "¿Espera... [F]?"

# game/scripts/convis_zahra.rpy:30
translate spanish zahra_conversations_36f0544b:

    # Z "Yeah. I'm talking about Fairy. I decided she should have a new name."
    Z "Sí, me refiero a Fairy. Decidí que debería tener un nuevo nombre."

# game/scripts/convis_zahra.rpy:33
translate spanish zahra_conversations_b2e922bc:

    # Z "The decayed probably gave her that name... And, after all those years in the darkness, she deserves a new start."
    Z "Probablemente los decaídos le dieron ese nombre... Y después de todos esos años en la oscuridad, se merece un nuevo comienzo."

# game/scripts/convis_zahra.rpy:36
translate spanish zahra_conversations_f8364c0b:

    # W "I see. You're very considerate. Did she like the idea?"
    W "Entiendo. Eres muy considerado. ¿Le gustó la idea?"

# game/scripts/convis_zahra.rpy:39
translate spanish zahra_conversations_479d3b1c:

    # Z "Yes. She asked me in the first place."
    Z "Sí, de hecho, fue ella quien me lo pidió."

# game/scripts/convis_zahra.rpy:42
translate spanish zahra_conversations_ff2ad302:

    # Z "Yeah. I'm talking about Fairy. I decided to give her a new name."
    Z "Sí, me refiero a Fairy. Decidí darle un nuevo nombre."

# game/scripts/convis_zahra.rpy:43
translate spanish zahra_conversations_e2f7f38b:

    # Z "The decayed probably gave her that name. But she's my slave now, so I gave her a new identity."
    Z "Probablemente los decaídos le dieron ese nombre. Pero ahora es mi esclava, así que le di una nueva identidad."

# game/scripts/convis_zahra.rpy:46
translate spanish zahra_conversations_c03bcd81:

    # W "She is indeed... how did she react?"
    W "Así es... ¿Cómo reaccionó ella?"

# game/scripts/convis_zahra.rpy:49
translate spanish zahra_conversations_cc271972:

    # Z "She asked me in the first place. Seems she is used to being renamed."
    Z "Fue ella quien me lo pidió al principio. Parece que está acostumbrada a que le cambien el nombre."

# game/scripts/convis_zahra.rpy:53
translate spanish zahra_conversations_a002a992:

    # W "Alright then. Yes, we can introduce her to the household. She has come a long way after all."
    W "De acuerdo entonces. Sí, podemos presentarla a la familia. Después de todo, ha recorrido un largo camino."

# game/scripts/convis_zahra.rpy:54
translate spanish zahra_conversations_99255310:

    # W "I will let everyone know to come outside, okay?"
    W "Avisaré a todo el mundo para que salga fuera, ¿de acuerdo?"

# game/scripts/convis_zahra.rpy:57
translate spanish zahra_conversations_7a961538:

    # Z "Yes. I don't want to make this too long. But the girls deserve to know more about their new servant."
    Z "Sí, no quiero que esto sea muy largo. Pero las chicas merecen saber más sobre su nueva sirvienta."

# game/scripts/convis_zahra.rpy:60
translate spanish zahra_conversations_9669528e:

    # "Later..."
    "Más tarde..."

# game/scripts/convis_zahra.rpy:66
translate spanish zahra_conversations_4450e880:

    # W "Now that you mention it, yes. We still have to introduce her to the girls."
    W "Ahora que lo dices, sí. Aún tenemos que presentársela a las chicas."

# game/scripts/convis_zahra.rpy:69
translate spanish zahra_conversations_74a2af4d:

    # W "I think she is very much ready for it. She has come a long way since she first got here."
    W "Creo que está muy preparada para ello. Ha recorrido un largo camino desde que llegó por primera vez."

# game/scripts/convis_zahra.rpy:70
translate spanish zahra_conversations_99255310_1:

    # W "I will let everyone know to come outside, okay?"
    W "Avisaré a todo el mundo para que salga fuera, ¿de acuerdo?"

# game/scripts/convis_zahra.rpy:73
translate spanish zahra_conversations_7a961538_1:

    # Z "Yes. I don't want to make this too long. But the girls deserve to know more about their new servant."
    Z "Sí, no quiero que esto sea muy largo. Pero las chicas merecen saber más sobre su nueva sirvienta."

# game/scripts/convis_zahra.rpy:76
translate spanish zahra_conversations_9669528e_1:

    # "Later..."
    "Más tarde..."

# game/scripts/convis_zahra.rpy:82
translate spanish zahra_conversations_f6d37bf3:

    # Z "I'm going to see how [S] is doing. Do you need anything?"
    Z "Voy a ver cómo está [S]. ¿Necesitas algo?"

# game/scripts/convis_zahra.rpy:85
translate spanish zahra_conversations_4ea6d9bf:

    # W "Not now, [persistent.player_name], but I am going to the market later... Could you come with me?"
    W "Ahora no, [persistent.player_name], pero voy a ir al mercado más tarde... ¿Podrías venir conmigo?"

# game/scripts/convis_zahra.rpy:86
translate spanish zahra_conversations_ddd711fc:

    # Z "Sure. I'd like to catch up with Igor."
    Z "Claro. Me gustaría ponerme al día con Igor."

# game/scripts/convis_zahra.rpy:87
translate spanish zahra_conversations_22c03785:

    # W "That's fine. I'll see you shortly then."
    W "Está bien. Entonces te veré en breve."

# game/scripts/convis_zahra.rpy:90
translate spanish zahra_conversations_8bf131c5:

    # "You and [W] eventually head out..."
    "Tú y [W] acabáis saliendo..."

# game/scripts/convis_zahra.rpy:94
translate spanish zahra_conversations_4b325b22:

    # Z "Why don't we take the day off."
    Z "¿Por qué no nos tomamos el día libre?"

# game/scripts/convis_zahra.rpy:95
translate spanish zahra_conversations_bc7b5ca0:

    # Z "The weather is nice and we could relax on the terrace."
    Z "Hace buen tiempo y podemos relajarnos en la terraza."

# game/scripts/convis_zahra.rpy:96
translate spanish zahra_conversations_c6ff85cd:

    # W "That would be nice, husband."
    W "Eso sería bueno, marido."

# game/scripts/convis_zahra.rpy:100
translate spanish zahra_conversations_4b325b22_1:

    # Z "Why don't we take the day off."
    Z "¿Por qué no nos tomamos el día libre?"

# game/scripts/convis_zahra.rpy:101
translate spanish zahra_conversations_bc7b5ca0_1:

    # Z "The weather is nice and we could relax on the terrace."
    Z "Hace buen tiempo y podemos relajarnos en la terraza."

# game/scripts/convis_zahra.rpy:102
translate spanish zahra_conversations_c6ff85cd_1:

    # W "That would be nice, husband."
    W "Eso sería bueno, marido."

# game/scripts/convis_zahra.rpy:107
translate spanish zahra_conversations_a7e80bf1:

    # Z "It has been a long time since [Ig] visited us."
    Z "Hacía mucho tiempo que [Ig] no nos visitaba."

# game/scripts/convis_zahra.rpy:108
translate spanish zahra_conversations_7dc99585:

    # Z "Why don't we invite him and his niece?"
    Z "¿Por qué no le invitamos a él y a su sobrina?"

# game/scripts/convis_zahra.rpy:111
translate spanish zahra_conversations_ae4db5b1:

    # W "Lovely idea."
    W "Una idea encantadora."

# game/scripts/convis_zahra.rpy:112
translate spanish zahra_conversations_6eca5a08:

    # W "[A] and I will arrange everything."
    W "[A] y yo lo arreglaremos todo."

# game/scripts/convis_zahra.rpy:115
translate spanish zahra_conversations_57ce72bc:

    # Z "I will prepare something to eat and drink."
    Z "Prepararé algo para comer y beber."

# game/scripts/convis_zahra.rpy:116
translate spanish zahra_conversations_f07995e9:

    # Z "Let me know when they arrive."
    Z "Avísame cuando lleguen."

# game/scripts/convis_zahra.rpy:121
translate spanish zahra_conversations_f9eac0eb:

    # Z "So... about that date we were mentioning before..."
    Z "Entonces... sobre esa cita que estábamos mencionando antes..."

# game/scripts/convis_zahra.rpy:124
translate spanish zahra_conversations_05dc3f44:

    # W "I was looking forward to you asking..."
    W "Estaba deseando que me lo pidieras..."

# game/scripts/convis_zahra.rpy:127
translate spanish zahra_conversations_2d013ad6:

    # Z "What about tonight? I have a place in mind."
    Z "¿Qué tal esta noche? Tengo un sitio en mente."

# game/scripts/convis_zahra.rpy:130
translate spanish zahra_conversations_0fcce9bb:

    # W "A surprise? You won't mind me giggling like a little girl, then?"
    W "¿Una sorpresa? Entonces, ¿no te importará que me ría como una niña pequeña?"

# game/scripts/convis_zahra.rpy:131
translate spanish zahra_conversations_62ca6110:

    # W "I will take a bath then. See you later, my love."
    W "Entonces me iré a dar un baño. Hasta luego, mi amor."

# game/scripts/convis_zahra.rpy:139
translate spanish zahra_conversations_b5e0d2c4:

    # Z "Now that [Ka] has settled in a bit, I'm thinking to invite Igor. Maybe his girlfriend will come along?"
    Z "Ahora que [Ka] se ha instalado un poco, estoy pensando en invitar a Igor. ¿Quizá venga su novia?"

# game/scripts/convis_zahra.rpy:142
translate spanish zahra_conversations_0cdac307:

    # W "Oh, right. We have yet to see the lady your friend got for himself."
    W "Oh, claro. Aún tenemos que ver a la dama que se ha conseguido tu amigo."

# game/scripts/convis_zahra.rpy:145
translate spanish zahra_conversations_aa2d9e59:

    # Z "What do you think, can you arrange it?"
    Z "¿Qué te parece, puedes organizarlo?"

# game/scripts/convis_zahra.rpy:148
translate spanish zahra_conversations_4736313c:

    # W "Sure, leave it to me. I could ask them to come over tomorrow, what do you think?"
    W "Claro, déjamelo a mí. Podría pedirles que vinieran mañana, ¿qué te parece?"

# game/scripts/convis_zahra.rpy:154
translate spanish zahra_conversations_8f698913:

    # Z "Yes, tomorrow is good."
    Z "Sí, mañana está bien."

# game/scripts/convis_zahra.rpy:157
translate spanish zahra_conversations_e6894543:

    # W "I bet Kateryna is going to be excited."
    W "Seguro que Kateryna se va a emocionar."

# game/scripts/convis_zahra.rpy:160
translate spanish zahra_conversations_f8f7aa9b:

    # Z "Tomorrow is difficult. Let's do it another time."
    Z "Mañana es difícil. Hagámoslo en otro momento."

# game/scripts/convis_zahra.rpy:163
translate spanish zahra_conversations_bec90017:

    # W "Fine by me. Just let me know then whenever you want me to ask them."
    W "Por mí, perfecto. Avísame entonces cuando quieras que se lo pida."

# game/scripts/convis_zahra.rpy:171
translate spanish zahra_conversations_7a3dc8fa:

    # Z "I want to invite Igor and Savana again. What do you think?"
    Z "Quiero invitar a Igor y Savana de nuevo. ¿Qué opinas?"

# game/scripts/convis_zahra.rpy:174
translate spanish zahra_conversations_8219416e:

    # W "Our afternoon is free today, so we could make it happen."
    W "Tenemos la tarde libre hoy, así que podríamos hacerlo realidad."

# game/scripts/convis_zahra.rpy:175
translate spanish zahra_conversations_a843ad53:

    # W "I will head over to their house and ask them to come over."
    W "Iré a su casa y les pediré que vengan."

# game/scripts/convis_zahra.rpy:179
translate spanish zahra_conversations_73fee993:

    # Z "I will have Emilia prepare the living room in the meantime."
    Z "Haré que Emilia prepare la sala de estar mientras tanto."

# game/scripts/convis_zahra.rpy:181
translate spanish zahra_conversations_6def40f6:

    # Z "I will have [A] prepare the living room in the meantime."
    Z "Haré que [A] prepare la sala de estar mientras tanto."

# game/scripts/convis_zahra.rpy:190
translate spanish zahra_conversations_7cab2a6f:

    # Z "About [A]..."
    Z "Sobre [A]..."

# game/scripts/convis_zahra.rpy:191
translate spanish zahra_conversations_4c020ac3:

    # Z "We can't just let it slide."
    Z "No podemos dejarlo pasar."

# game/scripts/convis_zahra.rpy:192
translate spanish zahra_conversations_197a979a:

    # Z "Her arrogance and obsession with attention nearly got her killed."
    Z "Su arrogancia y su obsesión por llamar la atención casi la matan."

# game/scripts/convis_zahra.rpy:193
translate spanish zahra_conversations_efad62f1:

    # Z "What do you think we should do about it?"
    Z "¿Qué crees que debemos hacer al respecto?"

# game/scripts/convis_zahra.rpy:196
translate spanish zahra_conversations_a79e2e34:

    # W "I'm glad you asked."
    W "Me alegro de que me lo preguntes."

# game/scripts/convis_zahra.rpy:197
translate spanish zahra_conversations_c9ae00c1:

    # W "[A] and I have been... talking about this matter."
    W "[A] y yo hemos estado... hablando de este asunto."

# game/scripts/convis_zahra.rpy:198
translate spanish zahra_conversations_413453e6:

    # W "I want to scold our [persistent.da] in a manner that she will remember."
    W "Quiero regañar a nuestra [persistent.da] de una manera que recordará."

# game/scripts/convis_zahra.rpy:199
translate spanish zahra_conversations_2c4e544f:

    # W "Do you mind joining me?"
    W "¿Te importa unirte a mí?"

# game/scripts/convis_zahra.rpy:202
translate spanish zahra_conversations_733ac17b:

    # Z "Lead the way, [W]. Show me what you have in mind."
    Z "Guía el camino, [W]. Muéstrame lo que tienes en mente."

# game/scripts/convis_zahra.rpy:203
translate spanish zahra_conversations_c98ea681:

    # W "Please, come with me, [persistent.player_name]."
    W "Por favor, ven conmigo, [persistent.player_name]."

# game/scripts/convis_zahra.rpy:204
translate spanish zahra_conversations_f4ad821d:

    # Z "Sure."
    Z "Claro."

# game/scripts/convis_zahra.rpy:208
translate spanish zahra_conversations_39ad751d:

    # Z "Do it without me, this time."
    Z "Hazlo sin mí, esta vez."

# game/scripts/convis_zahra.rpy:209
translate spanish zahra_conversations_06b561a4:

    # W "As you wish, husband. Give me but an hour."
    W "Como desees, marido. Dame solo una hora."

# game/scripts/convis_zahra.rpy:210
translate spanish zahra_conversations_2fe979fc:

    # W "Maybe you should visit the library in the meantime, so you don't hear her whimpering."
    W "Tal vez deberías visitar la biblioteca mientras tanto, para que no la oigas lloriqueando."

# game/scripts/convis_zahra.rpy:221
translate spanish zahra_conversations_dd6fcdc0:

    # Z "Can you tell our maid to prepare a bath? I need some time to relax."
    Z "¿Puedes decirle a nuestra sirvienta que prepare un baño? Necesito un rato para relajarme."

# game/scripts/convis_zahra.rpy:222
translate spanish zahra_conversations_52533b2d:

    # W "Of course. Want someone specific to keep you company?"
    W "Por supuesto. ¿Quieres que alguien en especial te haga compañía?"

# game/scripts/convis_zahra.rpy:225
translate spanish zahra_conversations_4a0a08c5:

    # Z "I think I will take a bath. I need some time to relax."
    Z "Creo que me daré un baño. Necesito un rato para relajarme."

# game/scripts/convis_zahra.rpy:226
translate spanish zahra_conversations_30644b3a:

    # W "Then I will gladly help prepare it. Want someone specific keep you company?"
    W "Entonces con gusto lo prepararé. ¿Quieres que alguien en especial te acompañe?"

# game/scripts/convis_zahra.rpy:228
translate spanish zahra_conversations_fad627ad:

    # Z "You know me well. But no, not today, I will rest alone."
    Z "Me conoces bien. Pero no, hoy no, descansaré solo."

# game/scripts/convis_zahra.rpy:229
translate spanish zahra_conversations_d2d524a8:

    # W "And how do you want the water, warm and cozy, or ice cold from the basement?"
    W "¿Y cómo quieres el agua, calentita y acogedora, o helada de la bodega?"

# game/scripts/convis_zahra.rpy:230
translate spanish zahra_conversations_1d8e7b8f:

    # Z "Very funny. I will leave that up to you."
    Z "Muy graciosa. Lo dejaré a tu elección."

# game/scripts/convis_zahra.rpy:231
translate spanish zahra_conversations_7f5a9f35:

    # W "Ice cold it is, then."
    W "Entonces helada será."

# game/scripts/convis_zahra.rpy:273
translate spanish zahra_conversations_289a209a:

    # Z "I have to leave for now."
    Z "Tengo que irme por ahora."

# game/scripts/convis_zahra.rpy:276
translate spanish zahra_conversations_889a8101:

    # W "See you later, love."
    W "Hasta luego, amor."

# game/scripts/convis_zahra.rpy:283
translate spanish z_convi_1_920e4e16:

    # Z "So... I swung by the market, and gave Kateryna that tour of the city I had promised her."
    Z "Así que... me pasé por el mercado y le di a Kateryna la visita a la ciudad que le había prometido."

# game/scripts/convis_zahra.rpy:286
translate spanish z_convi_1_a8a7b2d5:

    # W "She's a cute girl; did you have a good time?"
    W "Es una chica guapa; ¿te lo has pasado bien?"

# game/scripts/convis_zahra.rpy:289
translate spanish z_convi_1_a7bbc854:

    # Z "We did, yes. I think her interest in me goes further than just finding her way in the city, though."
    Z "Lo hicimos, sí. Sin embargo, creo que su interés por mí va más allá de encontrar su camino en la ciudad."

# game/scripts/convis_zahra.rpy:292
translate spanish z_convi_1_98894508:

    # W "Well, she did not make a mystery of that when we first met her, don't you think?"
    W "Bueno, no fue un misterio cuando la conocimos, ¿no crees?"

# game/scripts/convis_zahra.rpy:295
translate spanish z_convi_1_5b85319e:

    # Z "I guess not; but she's a lot less experienced, and a lot less forward, than she initially appeared."
    Z "Supongo que no; pero tiene mucha menos experiencia y es mucho menos atrevida de lo que parecía en un principio."

# game/scripts/convis_zahra.rpy:298
translate spanish z_convi_1_1ebadb7a:

    # W "We could invite her to come by more often, if you want."
    W "Podríamos invitarla a venir más a menudo, si quieres."

# game/scripts/convis_zahra.rpy:299
translate spanish z_convi_1_34ceee1e:

    # W "I think [A] would like that too. They're the same age, after all."
    W "Creo que a [A] también le gustaría. Al fin y al cabo, tienen la misma edad."

# game/scripts/convis_zahra.rpy:302
translate spanish z_convi_1_cdfed7f1:

    # W "And who knows...maybe you'll get the chance to give her what she's after."
    W "Y quién sabe... quizás tengas la oportunidad de darle lo que busca."

# game/scripts/convis_zahra.rpy:305
translate spanish z_convi_1_d2c36eb4:

    # Z "Have I told you that I love you, [W]?"
    Z "¿Te he dicho que te quiero, [W]?"

# game/scripts/convis_zahra.rpy:308
translate spanish z_convi_1_426f16ef:

    # W "Yes, but I could stand to hear you say it more often."
    W "Sí, pero no me importaría que lo dijeras más a menudo."

# game/scripts/convis_zahra.rpy:311
translate spanish z_convi_1_8c7fea79:

    # Z "Well, I do."
    Z "Bueno, lo hago."

# game/scripts/convis_zahra.rpy:314
translate spanish z_convi_1_7e827138:

    # W "I know that, you silly man..."
    W "Lo sé, tonto..."

# game/scripts/convis_zahra.rpy:317
translate spanish z_convi_1_4a138fc0:

    # Z "All sillyness aside, Igor is a good friend, and I don't want to offend him, so I won't rush things even though I've had a chat with him about it."
    Z "Dejando a un lado las tonterías, Igor es un buen amigo y no quiero ofenderle, así que no me precipitaré, aunque ya he hablado con él sobre el tema."

# game/scripts/convis_zahra.rpy:320
translate spanish z_convi_1_41ecd406:

    # W "You have already?"
    W "¿Ya lo has hecho?"

# game/scripts/convis_zahra.rpy:323
translate spanish z_convi_1_ca7737ad:

    # Z "It was his doing, actually. I think Kateryna confides in him."
    Z "En realidad, fue cosa suya. Creo que Kateryna confía en él."

# game/scripts/convis_zahra.rpy:324
translate spanish z_convi_1_b8155471:

    # Z "That said, I know that he's familiar with our customs, but she is new to these parts, and maybe I am reading her signals wrong."
    Z "Dicho esto, sé que está familiarizado con nuestras costumbres, pero ella es nueva en estos lares, y quizá esté leyendo mal sus señales."

# game/scripts/convis_zahra.rpy:327
translate spanish z_convi_1_639e7cd8:

    # W "I doubt it, [persistent.player_name]. I think she may be a little shy, but she has a very clear idea of what she wants."
    W "Lo dudo, [persistent.player_name]. Creo que puede ser un poco tímida, pero tiene una idea muy clara de lo que quiere."

# game/scripts/convis_zahra.rpy:330
translate spanish z_convi_1_6110ff9f:

    # Z "We'll see, I guess."
    Z "Ya veremos, supongo."

# game/scripts/convis_zahra.rpy:333
translate spanish z_convi_1_dba0519e:

    # W "Do you plan to bring another young woman in our family, [persistent.player_name]?"
    W "¿Planeas traer a otra joven a nuestra familia, [persistent.player_name]?"

# game/scripts/convis_zahra.rpy:336
translate spanish z_convi_1_64bc920c:

    # Z "I don't know yet, my love, I just met the girl. Igor did put that idea on the table, though."
    Z "Todavía no lo sé, mi amor, acabo de conocer a la chica. Sin embargo, Igor puso esa idea sobre la mesa."

# game/scripts/convis_zahra.rpy:337
translate spanish z_convi_1_ed585457:

    # Z "Would you oppose me if I did?"
    Z "¿Te opondrías si lo hiciera?"

# game/scripts/convis_zahra.rpy:340
translate spanish z_convi_1_e611670a:

    # W "You know I would not, [persistent.player_name]. I will say this however: if you want to have your fun with her, you have my support, as always."
    W "Sabes que no lo haría, [persistent.player_name]. Sin embargo, te diré esto: si quieres divertirte con ella, tienes mi apoyo, como siempre."

# game/scripts/convis_zahra.rpy:341
translate spanish z_convi_1_913ab1e1:

    # W "If you like this girl and want something more permanent, allow me to know her a bit better."
    W "Si te gusta esta chica y quieres algo más permanente, permíteme conocerla un poco mejor."

# game/scripts/convis_zahra.rpy:342
translate spanish z_convi_1_371443a5:

    # W "I've only met her once, and if she is to live with us, in whatever capacity and for however long, I would like to be sure she will add value to our House, and not disrupt it."
    W "Sólo la he visto una vez, y si va a vivir con nosotros, sea como sea y durante el tiempo que sea, me gustaría estar segura de que añadirá valor a nuestra Casa, y no la perturbará."

# game/scripts/convis_zahra.rpy:345
translate spanish z_convi_1_25b4a994:

    # Z "Your wisdom is as big as your heart, as always. I don't know her enough yet to have made up my mind, but should it come to it, I will listen to your opinion, as in all things."
    Z "Tu sabiduría es tan grande como tu corazón, como siempre. Todavía no la conozco lo suficiente como para haberme decidido, pero si llega el caso, escucharé tu opinión, como en todas las cosas."

# game/scripts/convis_zahra.rpy:348
translate spanish z_convi_1_72c931f5:

    # W "You're a good man, [persistent.player_name]. Stubborn and horny as a goat, but a good man."
    W "Eres un buen hombre, [persistent.player_name]. Testarudo y cachondo como una cabra, pero un buen hombre."

# game/scripts/convis_zahra.rpy:351
translate spanish z_convi_1_7b3f3431:

    # Z "I love you too, [W]..."
    Z "Yo también te quiero, [W]..."

# game/scripts/convis_zahra.rpy:356
translate spanish z_convi_2_73f19b23:

    # Z "I wanted to speak with you about something."
    Z "Quería hablar contigo de algo."

# game/scripts/convis_zahra.rpy:359
translate spanish z_convi_2_b2a7b423:

    # W "You look worried."
    W "Pareces preocupado."

# game/scripts/convis_zahra.rpy:362
translate spanish z_convi_2_ad66d9bc:

    # Z "Do you remember Master Zosar, my teacher?"
    Z "¿Recuerdas al Amo Zosar, mi maestro?"

# game/scripts/convis_zahra.rpy:365
translate spanish z_convi_2_a1b20d1a:

    # W "Of course I do. You were the disciple of a famous Desert Stalker, before you became a Stalker yourself."
    W "Por supuesto que sí. Fuiste discípulo de un famoso Acechador del Desierto, antes de convertirte tú mismo en un Acechador."

# game/scripts/convis_zahra.rpy:366
translate spanish z_convi_2_5fd53911:

    # W "My own father could not stop bragging about how his son in law was destined for greatness with such a prestigious teacher."
    W "Mi propio padre no podía dejar de presumir de que su yerno estaba destinado a la grandeza con un Amo tan prestigioso."

# game/scripts/convis_zahra.rpy:367
translate spanish z_convi_2_d4f6c467:

    # W "And the stories you told me, how could I forget?"
    W "Y las historias que me contaste, ¿cómo podría olvidarlas?"

# game/scripts/convis_zahra.rpy:370
translate spanish z_convi_2_32f6b654:

    # Z "I just met him."
    Z "Acabo de conocerlo."

# game/scripts/convis_zahra.rpy:373
translate spanish z_convi_2_c2c9cc07:

    # W "..."
    W "..."

# game/scripts/convis_zahra.rpy:374
translate spanish z_convi_2_1af296cb:

    # W "That's not.."
    W "Eso no es..."

# game/scripts/convis_zahra.rpy:377
translate spanish z_convi_2_72296b61:

    # Z "Not possible, I know. Still, it is as true as the light of the sun above."
    Z "No es posible, lo sé. Sin embargo, es tan cierto como la luz del sol sobre nosotros."

# game/scripts/convis_zahra.rpy:380
translate spanish z_convi_2_823be2d9:

    # W "How can that be? He left so long ago."
    W "¿Cómo puede ser? Se fue hace tanto tiempo."

# game/scripts/convis_zahra.rpy:381
translate spanish z_convi_2_94c07af7:

    # W "You told me he was ill and decided to take the Long Walk."
    W "Me dijiste que estaba enfermo y decidió tomar el Camino Largo."

# game/scripts/convis_zahra.rpy:384
translate spanish z_convi_2_fe7f5a16:

    # Z "He's one of them now, one of the decayed."
    Z "Ahora es uno de ellos, uno de los decaídos."

# game/scripts/convis_zahra.rpy:387
translate spanish z_convi_2_780e93c4:

    # W "Are you sure? Maybe you just met with a decayed who looks like him."
    W "¿Estás seguro? Quizás simplemente te encontraste con un decaído que se parece a él."

# game/scripts/convis_zahra.rpy:390
translate spanish z_convi_2_6438cf04:

    # Z "We spoke at length, and he called me out before I realised it was him."
    Z "Hablamos largo y tendido, y me puso en mi sitio antes de que me diera cuenta de que era él."

# game/scripts/convis_zahra.rpy:393
translate spanish z_convi_2_e1e9062b:

    # W "I didn't know decayed really could live that long. I thought those were rumours."
    W "No sabía que los decaídos pudieran vivir tanto. Creía que eran rumores."

# game/scripts/convis_zahra.rpy:396
translate spanish z_convi_2_20d41a82:

    # Z "Well, he's proof that they can."
    Z "Bueno, él es la prueba de que se puede."

# game/scripts/convis_zahra.rpy:397
translate spanish z_convi_2_fa1bce50:

    # Z "He even changed his name to Lord Abrax and became a leader of the decayed..."
    Z "Incluso ha cambiado su nombre por el de Lord Abrax y se ha convertido en un líder de los decaídos..."

# game/scripts/convis_zahra.rpy:398
translate spanish z_convi_2_27e41a82:

    # Z "And there's more... He knows about [S]."
    Z "Y hay más... Sabe lo de [S]."

# game/scripts/convis_zahra.rpy:401
translate spanish z_convi_2_4fe83485:

    # W "Great sun! Is she, are we in danger?"
    W "¡Gran sol! ¿Está, estamos en peligro?"

# game/scripts/convis_zahra.rpy:402
translate spanish z_convi_2_383cf374:

    # Z "I don't think so, but it is difficult to say. Zosar has changed a great deal."
    Z "No lo creo, pero es difícil de decir. Zosar ha cambiado mucho."

# game/scripts/convis_zahra.rpy:405
translate spanish z_convi_2_b46c9eca:

    # W "You must protect [S]!"
    W "¡Debes proteger a [S]!"

# game/scripts/convis_zahra.rpy:408
translate spanish z_convi_2_eea2fdc8:

    # Z "Calm yourself!"
    Z "¡Cálmate!"

# game/scripts/convis_zahra.rpy:409
translate spanish z_convi_2_4778b634:

    # Z "[S] is perfectly capable of looking after herself, and some things are out of our hands. But I have no intention to let anyone harm her if I can avoid it."
    Z "[S] es perfectamente capaz de cuidar de sí misma, y algunas cosas están fuera de nuestro alcance, pero no tengo intención de dejar que nadie la dañe si puedo evitarlo."

# game/scripts/convis_zahra.rpy:412
translate spanish z_convi_2_b270f53f:

    # W "I'm sorry, I spoke out of turn."
    W "Lo siento, he hablado sin saber."

# game/scripts/convis_zahra.rpy:415
translate spanish z_convi_2_014b9397:

    # Z "I don't blame you, this is unsettling news for me too."
    Z "No te culpo, esto también es una noticia inquietante para mí."

# game/scripts/convis_zahra.rpy:416
translate spanish z_convi_2_45f92146:

    # Z "There is more to my encounter with him, but you do not need to worry yourself with the details."
    Z "Hay más cosas en mi encuentro con él, pero no debes preocuparte por los detalles."

# game/scripts/convis_zahra.rpy:417
translate spanish z_convi_2_55f9fab6:

    # Z "I will be careful in my dealings with him."
    Z "Tendré cuidado en mi trato con él."

# game/scripts/convis_zahra.rpy:420
translate spanish z_convi_2_62e146ff:

    # W "Please, husband. I do not want to lose you, or our [persistent.da]."
    W "Por favor, marido. No quiero perderte, ni a nuestra [persistent.da]."

# game/scripts/convis_zahra.rpy:423
translate spanish z_convi_2_e8dcdcaa:

    # Z "You will not, don't worry."
    Z "No lo harás, no te preocupes."

# game/scripts/convis_zahra.rpy:431
translate spanish z_convi_3_3d27a78b:

    # Z "[S] is ready, and soon I will receive more information about the new Zone."
    Z "[S] está preparada, y pronto recibiré más información sobre la nueva Zona."

# game/scripts/convis_zahra.rpy:434
translate spanish z_convi_3_00e0fb98:

    # W "I know this is how it must be..."
    W "Sé que así debe de ser..."

# game/scripts/convis_zahra.rpy:437
translate spanish z_convi_3_8c4632a9:

    # Z "You're not happy."
    Z "No eres feliz."

# game/scripts/convis_zahra.rpy:440
translate spanish z_convi_3_7f716658:

    # W "Can you blame me?"
    W "¿Puedes culparme?"

# game/scripts/convis_zahra.rpy:441
translate spanish z_convi_3_4b3bc54f:

    # W "You're sending her to her death!"
    W "¡La estás enviando a la muerte!"

# game/scripts/convis_zahra.rpy:444
translate spanish z_convi_3_8b262729:

    # Z "Don't say that. She has been trained by the best."
    Z "No digas eso. Ha sido entrenada por los mejores."

# game/scripts/convis_zahra.rpy:445
translate spanish z_convi_3_ff75881b:

    # Z "She is strong: she will survive."
    Z "Ella es fuerte: sobrevivirá."

# game/scripts/convis_zahra.rpy:448
translate spanish z_convi_3_187dc3d2:

    # W "So are most of the men and women who enter a Zone. How many of them survive to become Stalkers?"
    W "Así son la mayoría de los hombres y mujeres que entran en una Zona. ¿Cuántos de ellos sobreviven para convertirse en Acechadores?"

# game/scripts/convis_zahra.rpy:451
translate spanish z_convi_3_5ab3574d:

    # Z "..."
    Z "..."

# game/scripts/convis_zahra.rpy:452
translate spanish z_convi_3_5e0287be:

    # Z "You are not wrong, but... do you not trust our [persistent.da]?"
    Z "No te equivocas, pero... ¿no confías en nuestra [persistent.da]?"

# game/scripts/convis_zahra.rpy:455
translate spanish z_convi_3_d68c6d9f:

    # W "Don't try that with me, [persistent.player_name], you know I trust her implicitly, but will that save her life?"
    W "No intentes eso conmigo, [persistent.player_name], sabes que confío en ella implícitamente, ¿pero eso le salvará la vida?"

# game/scripts/convis_zahra.rpy:458
translate spanish z_convi_3_80934701:

    # Z "No, it won't. What will is the years of training, preparation, learning, fighting... and luck."
    Z "No, no lo hará. Lo que sí lo hará son los años de entrenamiento, preparación, aprendizaje, lucha... y la suerte."

# game/scripts/convis_zahra.rpy:459
translate spanish z_convi_3_73f6235f:

    # Z "I don't deny that luck plays a part in this, [W]."
    Z "No niego que la suerte juegue un papel en esto, [W]."

# game/scripts/convis_zahra.rpy:462
translate spanish z_convi_3_eb27a3b0:

    # W "Do you understand why I am worried? Why I fear for my little girl?"
    W "¿Entiendes por qué estoy preocupada? ¿Por qué temo por mi niña?"

# game/scripts/convis_zahra.rpy:465
translate spanish z_convi_3_98f889b8:

    # Z "Your little girl, {i}our{/i} little girl, is a woman now, [W]."
    Z "Tu niña, {i}nuestra{/i} niña, es ahora una mujer, [W]."

# game/scripts/convis_zahra.rpy:466
translate spanish z_convi_3_e0810099:

    # Z "She has grown into an amazing, strong, talented and intelligent woman."
    Z "Ha crecido hasta convertirse en una mujer increíble, fuerte, con talento e inteligente."

# game/scripts/convis_zahra.rpy:467
translate spanish z_convi_3_e6983ae3:

    # Z "Do not rob her of that. Do not allow your doubts to show, to weigh her down."
    Z "No la prives de ello. No permitas que tus dudas se manifiesten, que la agobien."

# game/scripts/convis_zahra.rpy:468
translate spanish z_convi_3_48dd542d:

    # Z "When we're out there, doing what must be done, doubt is the first enemy, and often the most lethal one."
    Z "Cuando estamos fuera, haciendo lo que hay que hacer, la duda es el primer enemigo, y a menudo el más letal."

# game/scripts/convis_zahra.rpy:469
translate spanish z_convi_3_e40468d0:

    # Z "There are threats that normal people can not even imagine. And yes, the emissions, the mutants, bandits..."
    Z "Hay amenazas que la gente normal no puede ni imaginar. Y sí, las emisiones, los mutantes, los bandidos..."

# game/scripts/convis_zahra.rpy:470
translate spanish z_convi_3_6b804f6a:

    # Z "[S] will have to be prepared. And she will have to be open minded, to face whatever anomalies await her."
    Z "[S] tendrá que estar preparada. Y tendrá que tener la mente abierta, para enfrentarse a cualquier anomalía que le espere."

# game/scripts/convis_zahra.rpy:471
translate spanish z_convi_3_68587393:

    # Z "Doubt however, will kill you much faster, and when you least expect it."
    Z "La duda, sin embargo, te matará mucho más rápido, y cuando menos lo esperes."

# game/scripts/convis_zahra.rpy:472
translate spanish z_convi_3_1c952f4b:

    # Z "I'm asking you to not show doubt to [S]."
    Z "Te pido que no muestres dudas a [S]."

# game/scripts/convis_zahra.rpy:475
translate spanish z_convi_3_5aa1e42a:

    # W "I am sorry. You are right."
    W "Lo siento. Tienes razón."

# game/scripts/convis_zahra.rpy:476
translate spanish z_convi_3_1ceb32ad:

    # W "I understand what you mean... I will try to not think about it."
    W "Entiendo lo que quieres decir... Intentaré no pensar en ello."

# game/scripts/convis_zahra.rpy:481
translate spanish z_convi_3_9ae9e913:

    # Z "I did not mean to shout at you, [W]. I do not want to lose our girl either."
    Z "No quería gritarte, [W]. Tampoco quiero perder a nuestra chica."

# game/scripts/convis_zahra.rpy:484
translate spanish z_convi_3_05ca560b:

    # W "Never, my love. I know your heart is in the right place, and I know this is all [S] ever wanted."
    W "Nunca, mi amor. Sé que tu corazón está en el lugar correcto, y sé que esto es todo lo que [S] ha querido siempre."

# game/scripts/convis_zahra.rpy:485
translate spanish z_convi_3_68b0c81b:

    # W "I know you have done this all for her."
    W "Sé que has hecho todo esto por ella."

# game/scripts/convis_zahra.rpy:488
translate spanish z_convi_3_7619aa6d:

    # Z "It's been a long road, but the end is near."
    Z "Ha sido un largo camino, pero el final está cerca."

# game/scripts/convis_zahra.rpy:491
translate spanish z_convi_3_d4b704b8:

    # W "You realise she only started on this path because she wanted to make you proud, right?"
    W "Te das cuenta de que sólo ha empezado este camino porque quería enorgullecerte, ¿verdad?"

# game/scripts/convis_zahra.rpy:494
translate spanish z_convi_3_fc3f6f11:

    # Z "The thought has occurred to me, but I think she has grown out of that notion."
    Z "La idea se me ha ocurrido, pero creo que ella ha superado esa idea."

# game/scripts/convis_zahra.rpy:495
translate spanish z_convi_3_25aec860:

    # Z "She knows I would not hold it against her if she decided to aim for something else."
    Z "Sabe que no se lo reprocharía si decidiera no aspirar a otra cosa."

# game/scripts/convis_zahra.rpy:498
translate spanish z_convi_3_ff69cfa4:

    # W "I hope you're right, [persistent.player_name], for both of us."
    W "Espero que tengas razón, [persistent.player_name], por los dos."

# game/scripts/convis_zahra.rpy:501
translate spanish z_convi_3_39ceaba5:

    # Z "I know I am. Let's try to put it aside, now."
    Z "Sé que lo hago. Intentemos dejarlo a un lado, ahora."

# game/scripts/convis_zahra.rpy:505
translate spanish z_convi_3_b93f1564:

    # Z "Listen, [W]."
    Z "Escucha, [W]."

# game/scripts/convis_zahra.rpy:506
translate spanish z_convi_3_206400da:

    # Z "You have forgotten your place."
    Z "Has olvidado tu lugar."

# game/scripts/convis_zahra.rpy:507
translate spanish z_convi_3_14e9a7cc:

    # Z "You're the wife of a Stalker, and [S] will soon become one."
    Z "Eres la esposa de un Acechador, y [S] pronto se convertirá en uno."

# game/scripts/convis_zahra.rpy:510
translate spanish z_convi_3_a6270e21:

    # Z "I know you're afraid. So am I, to be true."
    Z "Sé que tienes miedo. Yo también lo tengo, la verdad."

# game/scripts/convis_zahra.rpy:513
translate spanish z_convi_3_86c96cd2:

    # W "Then you know why I struggle so much with this."
    W "Entonces sabes por qué lucho tanto con esto."

# game/scripts/convis_zahra.rpy:516
translate spanish z_convi_3_935782ba:

    # Z "You, we must not show this to her though."
    Z "Tú, sin embargo, no debemos mostrárselo a ella."

# game/scripts/convis_zahra.rpy:517
translate spanish z_convi_3_2633c5d2:

    # Z "She expects our support, not to see doubt in our eyes."
    Z "Ella espera nuestro apoyo, no ver dudas en nuestros ojos."

# game/scripts/convis_zahra.rpy:520
translate spanish z_convi_3_f3369de8:

    # W "It's not easy. She's our little girl."
    W "No es fácil. Es nuestra niña."

# game/scripts/convis_zahra.rpy:523
translate spanish z_convi_3_62484abd:

    # Z "I know you worry, when I go out there, and I know you put up a brave face when you see me out."
    Z "Sé que te preocupas, cuando salgo, y sé que pones cara de valiente cuando me ves fuera."

# game/scripts/convis_zahra.rpy:524
translate spanish z_convi_3_099d77d7:

    # Z "Please, find it in yourself to do the same for our [persistent.da], especially on her first outing."
    Z "Por favor, haz lo mismo por nuestra [persistent.da], especialmente en su primera salida."

# game/scripts/convis_zahra.rpy:525
translate spanish z_convi_3_23764c80:

    # Z "Give her the same respect you give me, in this matter."
    Z "Dale el mismo respeto que me das a mí, en este asunto."

# game/scripts/convis_zahra.rpy:528
translate spanish z_convi_3_006721a3:

    # W "I will try my best."
    W "Me esforzaré al máximo."

# game/scripts/convis_zahra.rpy:535
translate spanish z_convi_4_214fd0aa:

    # W "I met an old friend of mine at the market today, and she told me I should talk to my sister."
    W "Hoy me he encontrado con una vieja amiga en el mercado y me ha dicho que debería hablar con mi hermana."

# game/scripts/convis_zahra.rpy:538
translate spanish z_convi_4_6bd1fa37:

    # Z "Is something wrong with Rabiah?"
    Z "¿Le pasa algo a Rabiah?"

# game/scripts/convis_zahra.rpy:541
translate spanish z_convi_4_56b2fb7f:

    # W "My friend wouldn't say. She told me it would be better if I spoke with her directly, but that there were rumours."
    W "Mi amiga no quiso decírmelo. Me dijo que sería mejor que hablara con ella directamente, pero que había rumores."

# game/scripts/convis_zahra.rpy:544
translate spanish z_convi_4_b3ca693d:

    # Z "How many children do they have now?"
    Z "¿Cuántos hijos tienen ahora?"

# game/scripts/convis_zahra.rpy:547
translate spanish z_convi_4_dc852ffe:

    # W "It's been a few years now, since she's had the twins. She told me they would be her last."
    W "Hace ya unos años que tuvo a los gemelos. Me dijo que serían los últimos."

# game/scripts/convis_zahra.rpy:548
translate spanish z_convi_4_bab6ba2a:

    # W "I think her exact words were something like: I'd rather not have sex ever again!"
    W "Creo que sus palabras exactas fueron algo así como: ¡Prefiero no tener sexo nunca más!"

# game/scripts/convis_zahra.rpy:551
translate spanish z_convi_4_ebe8e3bd:

    # Z "I think we can both agree that that's a big fat lie."
    Z "Creo que ambos estamos de acuerdo en que eso es una gran mentira."

# game/scripts/convis_zahra.rpy:554
translate spanish z_convi_4_ff9b9593:

    # W "Ha! Yes, I suppose so. But still, she was exhausted."
    W "¡Ja! Sí, supongo que sí. Pero aun así, estaba agotada."

# game/scripts/convis_zahra.rpy:555
translate spanish z_convi_4_a74c7bde:

    # W "Young children will do that to you. Especially if you start having them later."
    W "Los niños pequeños te hacen eso. Sobre todo si empiezas a tenerlos más tarde."

# game/scripts/convis_zahra.rpy:558
translate spanish z_convi_4_a75ee0fa:

    # Z "Well, it wasn't for lack of trying, that she didn't have them any sooner."
    Z "Bueno, no fue por falta de intentos, que ella no los haya tenido antes."

# game/scripts/convis_zahra.rpy:561
translate spanish z_convi_4_3534109a:

    # W "I remember. I've seen you often enough."
    W "Lo recuerdo. Te vi muchas veces."

# game/scripts/convis_zahra.rpy:564
translate spanish z_convi_4_71c2cd3f:

    # Z "I know you're not jealous. Don't pretend to be."
    Z "Sé que no estás celosa. No finjas estarlo."

# game/scripts/convis_zahra.rpy:567
translate spanish z_convi_4_4c76a543:

    # W "You're no fun! Then again, I guess I did steal you from her."
    W "¡No eres divertido! Por otra parte, supongo que te robé de ella."

# game/scripts/convis_zahra.rpy:570
translate spanish z_convi_4_8367b6a8:

    # Z "Is that how you remember things going? Because my memory is a bit different."
    Z "¿Es así como recuerdas que fueron las cosas? Porque mi memoria es un poco diferente."

# game/scripts/convis_zahra.rpy:573
translate spanish z_convi_4_5765f97b:

    # W "That's why you married me, so that when you're old and your mind is all fogged up, I will be there to tell you how things really happened."
    W "Por eso te casaste conmigo, para que cuando seas viejo y se te nuble la mente, yo esté ahí para contarte cómo sucedieron realmente las cosas."

# game/scripts/convis_zahra.rpy:576
translate spanish z_convi_4_ebec6e9f:

    # Z "Let's hope that day stays far away.... Anyway, your sister..."
    Z "Esperemos que ese día quede muy lejos.... En fin, tu hermana..."

# game/scripts/convis_zahra.rpy:579
translate spanish z_convi_4_100df3f2:

    # W "Yes, I was thinking we should invite her for dinner soon."
    W "Sí, estaba pensando que pronto deberíamos invitarla a cenar."

# game/scripts/convis_zahra.rpy:580
translate spanish z_convi_4_a6b59212:

    # W "It really has been too long since I last saw her."
    W "Realmente ha pasado demasiado tiempo desde la última vez que la vi."

# game/scripts/convis_zahra.rpy:583
translate spanish z_convi_4_f902301a:

    # Z "This house is yours as much as it is mine. Do as you please."
    Z "Esta casa es tuya tanto como mía. Haz lo que quieras."

# game/scripts/convis_zahra.rpy:586
translate spanish z_convi_4_5c8ef897:

    # W "Why thank you, Master [persistent.player_name], you're too kind."
    W "Gracias, Amo [persistent.player_name], eres muy amable."

# game/scripts/convis_zahra.rpy:589
translate spanish z_convi_4_07c7698f:

    # Z "Don't mock me, woman, or I shall have to spank you!"
    Z "No te burles de mí, mujer, ¡o tendré que darte unos azotes!"

# game/scripts/convis_zahra.rpy:592
translate spanish z_convi_4_e0879194:

    # W "Is that a promise?"
    W "¿Es eso una promesa?"

# game/scripts/convis_zahra.rpy:593
translate spanish z_convi_4_5ab3574d:

    # Z "..."
    Z "..."

# game/scripts/convis_zahra.rpy:594
translate spanish z_convi_4_c75676b0:

    # W "However, I am telling you this because I would like you to be there too."
    W "Sin embargo, te cuento esto porque me gustaría que tú también estuvieras allí."

# game/scripts/convis_zahra.rpy:597
translate spanish z_convi_4_ce7d976e:

    # Z "I see. Well, I guess the house is large enough to invite her entire tribe over."
    Z "Ya veo. Bueno, supongo que la casa es lo suficientemente grande como para invitar a toda su tribu."

# game/scripts/convis_zahra.rpy:600
translate spanish z_convi_4_915a70b8:

    # W "I shall try to see if they can leave the children at home for a night."
    W "Intentaré ver si pueden dejar a los niños en casa una noche."

# game/scripts/convis_zahra.rpy:603
translate spanish z_convi_4_a63b61c4:

    # Z "You do that, yes. And let me know when they will be here."
    Z "Hazlo, sí. Y hazme saber cuándo estarán aquí."

