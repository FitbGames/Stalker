    Q "¿Mhm?"

# game/scripts/day9.rpy:669
translate spanish d9a102_2269f035:

    # Zw "You play with men and women alike, because they are beneath you, or so you think..."
    Zw "Juegas con hombres y mujeres por igual, porque están por debajo de ti, o eso crees..."

