    # Qw "...and I want nothing but honesty..."
    Qw "... y no quiero más que honestidad..."

# game/scripts/day9.rpy:612
translate spanish d9a92_71b35a12:

    # Qw "If you found your Queen in her chambers..."
    Qw "Si encuentras a tu Reina en sus aposentos..."

# game/scripts/day9.rpy:618
translate spanish d9a92_3a570772_1:

    # Qw "So I'm asking you this..."
    Qw "Así que te pregunto esto..."

# game/scripts/day9.rpy:621
