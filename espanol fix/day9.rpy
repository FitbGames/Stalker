    # Qw "Staring at your Queen is one thing..."
    Qw "Mirar fijamente a tu Reina es una cosa..."

# game/scripts/day9.rpy:625
translate spanish d9a92_f3fe35b5:

    # Qw "...Because of my status I am used to being admired, and frankly don't dislike it..."
    Qw "... debido a mi estatus estoy acostumbrada a ser admirada, y francamente no me desagrada..."

# game/scripts/day9.rpy:628
translate spanish d9a92_09d82a23:

