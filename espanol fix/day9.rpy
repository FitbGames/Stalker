    # Qw "...what would you do?"
    Qw "... ¿qué harías?"

# game/scripts/day9.rpy:641
translate spanish d9a102_e66ccc83:

    # Zw "I'm sure that if you were open to the possibilities, we could have a good time together."
    Zw "Estoy seguro de que si estuvieras abierta a las posibilidades, podríamos pasarlo bien juntos."

# game/scripts/day9.rpy:642
translate spanish d9a102_a14fa40f:

