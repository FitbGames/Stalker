    # S "What do you think?"
    S "¿Qué te parece?"

# game/scripts/day4.rpy:76
translate spanish d4c_05e3f213:

    # S "I know [A] is something else, but I think I'm not doing too bad either."
    S "Sé que [A] es otra cosa, pero creo que yo tampoco lo estoy haciendo mal."

# game/scripts/day4.rpy:77
translate spanish d4c_7c5902af:

