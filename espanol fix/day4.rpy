# game/scripts/day4.rpy:572
translate spanish d4a22_0bd60176:

    # RF "There are worse ways to wake up from one, I guess."
    RF "Supongo que hay peores formas de despertar de una, ¿no?"

# game/scripts/day4.rpy:575
translate spanish d4a22_e476ec9a:

    # RF "I thought I was going to be chopped up and served on a plate..."
    RF "Creía que me iban a trocear y servir en una bandeja..."

# game/scripts/day4.rpy:578
translate spanish d4a22_81fcb305:

    # RF "This outcome seems better..."
    RF "Este resultado parece mejor..."

# game/scripts/day4.rpy:581
translate spanish d4a22_7a2063e8:

    # "Ngh..."
    "Ngh..."

# game/scripts/day4.rpy:582
translate spanish d4a22_0a3296b5:

    # "You pick yourself up, massaging your leg where she kicked you..."
    "Te levantas, masajeando tu pierna donde ella te pateó..."

# game/scripts/day4.rpy:585
translate spanish d4a22_8ebf65db:

    # RF "So... who the fuck are you anyway?"
    RF "Entonces... ¿Quién coño eres tú, de todos modos?"

# game/scripts/day4.rpy:591
translate spanish d4a_kyra_woke_up_b130aaf3:

    # Z "I'm [persistent.player_name], a Stalker. You're in my basement."
    Z "Soy [persistent.player_name], un Acechador. Estás en mi sótano."

# game/scripts/day4.rpy:592
translate spanish d4a_kyra_woke_up_e30b63d5:

    # Z "My [persistent.da] and I found you ready to be cut to pieces in Old Cairo, and decided to take you from the decayed."
    Z "Mi [persistent.da] y yo te encontramos lista para ser cortada en pedazos en el Viejo Cairo, y decidimos sacarte de los Decaídos."

# game/scripts/day4.rpy:593
translate spanish d4a_kyra_woke_up_ea9e05ff:

    # Z "You're in Zetan territory now."
    Z "Ahora estás en territorio Zetan."

# game/scripts/day4.rpy:596
translate spanish d4a_kyra_woke_up_df16dc8c:

    # RF "Just my luck... a fucking Stalker..."
    RF "Qué suerte la mía... un maldito Acechador..."

# game/scripts/day4.rpy:601
translate spanish d4a_kyra_woke_up_1df8a34b:

    # "She stands up..."
    "Ella se levanta..."

# game/scripts/day4.rpy:604
translate spanish d4a_kyra_woke_up_61e96f62:

    # RF "{i}*sigh*{/i}... and on top of that, you put a shotgun collar around my neck!"
    RF "{i}*suspiro*{/i}... ¡y encima me pusiste un collar explosivo alrededor del cuello!"

# game/scripts/day4.rpy:605
translate spanish d4a_kyra_woke_up_7b58a05d:

    # Z "Simple precaution, so that you'll think twice about your next move."
    Z "Simple precaución, para que lo pienses dos veces antes de tu próximo movimiento."

# game/scripts/day4.rpy:608
translate spanish d4a_kyra_woke_up_21c7db8e:

    # RF "Hah... I guess I don't get to scratch your eyes out, after all..."
    RF "Ja... supongo que al final no voy a arañarte los ojos..."

# game/scripts/day4.rpy:612
translate spanish d4a_kyra_woke_up_b367ad3b:

    # RF "You're still a nutter for not waking me up before you put a dick in me."
    RF "Sigues siendo un chiflado por no despertarme antes de meterme una polla."

# game/scripts/day4.rpy:615
translate spanish d4a_kyra_woke_up_a30a5e47:

    # Z "Would that have made a difference?"
    Z "¿Habría cambiado algo?"

# game/scripts/day4.rpy:618
translate spanish d4a_kyra_woke_up_b6770c8d:

    # RF "No, it wouldn't have..."
    RF "No, no habría cambiado nada..."

# game/scripts/day4.rpy:621
translate spanish d4a_kyra_woke_up_0d2c1f02:

    # RF "I'm not stupid. You got a freaking collar around my neck..."
    RF "No soy estúpida. Tienes un maldito collar alrededor de mi cuello..."

# game/scripts/day4.rpy:622
translate spanish d4a_kyra_woke_up_f5a0d604:

    # RF "...and I'm not exactly in a position of power here."
    RF "... y no estoy exactamente en una posición de poder aquí."

# game/scripts/day4.rpy:625
translate spanish d4a_kyra_woke_up_d0c91d3f:

    # RF "Then again. Hadn't had a good fuck in ages, so I might have actually enjoyed it."
    RF "Por otro lado. No había tenido un buen polvo en años, así que tal vez realmente lo disfruté."

# game/scripts/day4.rpy:628
translate spanish d4a_kyra_woke_up_362bfe68:

    # RF "But thats not the point!"
    RF "¡Pero no se trata de eso!"

# game/scripts/day4.rpy:629
translate spanish d4a_kyra_woke_up_c9a0702f:

    # RF "Why did you bother taking me from those scabs?!"
    RF "¡¿Por qué te molestaste en sacarme de esos parias?!"

# game/scripts/day4.rpy:632
translate spanish d4a_kyra_woke_up_9b11fa79:

    # Z "I'm not sure. Instinct, business, a nice piece of fuckmeat? Take your pick."
    Z "No estoy seguro. Instinto, negocios, un buen trozo de carne para follar... Tú decides."

# game/scripts/day4.rpy:636
translate spanish d4a_kyra_woke_up_b39f7ea5:

    # RF "Still... why bother rescuing me from those scabs?!"
    RF "Aun así... ¡¿por qué molestarse en rescatarme de esos parias?!"

# game/scripts/day4.rpy:639
translate spanish d4a_kyra_woke_up_12b89112:

    # Z "I'm not sure. Instinct, business... Take your pick."
    Z "No estoy seguro. Instinto, negocios... Elige."

# game/scripts/day4.rpy:640
translate spanish d4a_kyra_woke_up_5250d8ef:

    # Z "All I know is that when I took a closer look, you reminded me of another raider I met recently."
    Z "Todo lo que sé es que cuando me fijé más de cerca, me recordaste a otra saqueadora que conocí recientemente."

# game/scripts/day4.rpy:643
translate spanish d4a_kyra_woke_up_1d707e04:

    # Z "She ambushed me not long ago. Well... tried to."
    Z "Me emboscó no hace mucho. Bueno... lo intentó."

# game/scripts/day4.rpy:644
translate spanish d4a_kyra_woke_up_9e7668de:

    # Z "She looked a bit like you, same skin tone, similar pigtails."
    Z "Se parecía un poco a ti, mismo tono de piel, coletas similares."

# game/scripts/day4.rpy:647
translate spanish d4a_kyra_woke_up_5b722b97:

    # RF "Wait, you're fucking with me, right?!"
    RF "¿Espera, me estás tomando el pelo, verdad?!"

# game/scripts/day4.rpy:648
translate spanish d4a_kyra_woke_up_3cf6d3d3:

    # RF "You met Asha?!"
    RF "¡¿Conociste a Asha?!"

# game/scripts/day4.rpy:651
translate spanish d4a_kyra_woke_up_54540464:

    # Z "So you know her?"
    Z "¿Así que la conoces?"

# game/scripts/day4.rpy:654
translate spanish d4a_kyra_woke_up_6b02f25a:

    # RF "{i}*chuckles*{/i} Fuck yeah I do..."
    RF "{i}*risilla*{/i} Claro que sí..."

# game/scripts/day4.rpy:659
translate spanish d4a_kyra_woke_up_aa64de0c:

    # "She sits down again..."
    "Se vuelve a sentar..."

# game/scripts/day4.rpy:662
translate spanish d4a_kyra_woke_up_f8da221b:

    # RF "She's my little sister, you bastard."
    RF "Es mi hermanita, bastardo."

# game/scripts/day4.rpy:665
translate spanish d4a_kyra_woke_up_fef89c59:

    # RF "She took out a group for a patrol in the desert while I went for a raid on the decayed."
    RF "Sacó a un grupo para una patrulla en el desierto mientras yo iba a una incursión contra los decaídos."

# game/scripts/day4.rpy:668
translate spanish d4a_kyra_woke_up_3ebe0c71:

    # RF "Worst decision of my life apparently..."
    RF "La peor decisión de mi vida aparentemente..."

# game/scripts/day4.rpy:671
translate spanish d4a_kyra_woke_up_57b5a078:

    # RF "Don't tell me you killed her?!"
    RF "¿No me digas que la has matado?"

# game/scripts/day4.rpy:675
translate spanish d4a_kyra_woke_up_2d797e07:

    # Z "Nope.. only her boyfriend and that other chick."
    Z "No... sólo a su novio y esa otra chica."

# game/scripts/day4.rpy:678
translate spanish d4a_kyra_woke_up_536a1413:

    # RF "Good to hear..."
    RF "Me alegra oír eso..."

# game/scripts/day4.rpy:680
translate spanish d4a_kyra_woke_up_c2037b3c:

    # Z "Nah. I let the two chicks go."
    Z "Nah. Dejé que las dos chicas se fueran."

# game/scripts/day4.rpy:681
translate spanish d4a_kyra_woke_up_bf6cf242:

    # Z "Your sister's boyfriend on the other hand met the business end of my sword."
    Z "El novio de tu hermana, en cambio, se encontró con la punta de mi espada."

# game/scripts/day4.rpy:684
translate spanish d4a_kyra_woke_up_59ce0b2d:

    # RF "Fuck that guy anyway... I'm glad you didn't do my sister in."
    RF "Que se joda ese tipo de todos modos... Me alegro de que no acabaras con mi hermana."

# game/scripts/day4.rpy:687
translate spanish d4a_kyra_woke_up_3119cf32:

    # RF "Hazim was dead from the neck up anyway. So, no big loss here."
    RF "De todas formas, Hazim estaba muerto de cuello para arriba. Así que no es una gran pérdida."

# game/scripts/day4.rpy:690
translate spanish d4a_kyra_woke_up_203e6657:

    # RF "Asha should be back home again by now..."
    RF "Asha ya debería estar de vuelta en casa..."

# game/scripts/day4.rpy:691
translate spanish d4a_kyra_woke_up_1d42c97b:

    # RF "She probably thinks I died in Old Cairo."
    RF "Seguramente piensa que he muerto en el Viejo Cairo."

# game/scripts/day4.rpy:694
translate spanish d4a_kyra_woke_up_e93559b5:

    # RF "Look, I don't know if she can even keep things under control there, without me."
    RF "Mira, no sé si ella puede siquiera mantener las cosas bajo control allí, sin mí."

# game/scripts/day4.rpy:695
translate spanish d4a_kyra_woke_up_a110f952:

    # RF "She's batshit crazy and violent, which is always good in Adira, but I was the one doing the deep thinking."
    RF "Está loca de remate y es violenta, que siempre es bueno en Adira, pero yo era la que hacía la labor de reflexión profunda."

# game/scripts/day4.rpy:696
translate spanish d4a_kyra_woke_up_183314dc:

    # RF "In short: I have to get back to Adira as soon as possible!"
    RF "En resumen: ¡tengo que volver a Adira lo antes posible!"

# game/scripts/day4.rpy:699
translate spanish d4a_kyra_woke_up_2b93dccd:

    # RF "I would say who do I have to blow to get a ride, but we're kinda past that, aren't we?"
    RF "Diría a quién tengo que chupar para conseguir un viaje, pero ya pasamos por eso, ¿no?"

# game/scripts/day4.rpy:702
translate spanish d4a_kyra_woke_up_b6e62c4d:

    # RF "You can call me Kyra. So... You had your fun, will you help me get home?"
    RF "Puedes llamarme Kyra. Entonces... ¿Te has divertido? ¿Me ayudarás a volver a casa?"

# game/scripts/day4.rpy:706
translate spanish d4a_kyra_woke_up_dbeb879e:

    # Z "Nice try, girl. A bit late to put the flirty moves on me though."
    Z "Buen intento, chica. Un poco tarde para ponerme esos movimientos coquetos, ¿no crees?"

# game/scripts/day4.rpy:708
translate spanish d4a_kyra_woke_up_b9a79a41:

    # Z "Nice try, girl."
    Z "Buen intento, chica."

# game/scripts/day4.rpy:709
translate spanish d4a_kyra_woke_up_a780f804:

    # Z "I have questions. You better answer them."
    Z "Tengo preguntas. Mejor que las respondas."

# game/scripts/day4.rpy:715
translate spanish d4a_kyra_question_menu_a9bde92d:

    # Ky "I'm glad you asked!"
    Ky "Me alegro de que me lo preguntes."

# game/scripts/day4.rpy:718
translate spanish d4a_kyra_question_menu_76199f4a:

    # Ky "My role is to... well... how do I explain it..."
    Ky "Mi papel es... bueno... ¿cómo lo explico?"

# game/scripts/day4.rpy:719
translate spanish d4a_kyra_question_menu_09d50d5a:

    # Ky "Leading my gang..."
    Ky "Encabezar mi banda..."

# game/scripts/day4.rpy:720
translate spanish d4a_kyra_question_menu_684ec087:

    # Ky "Murdering people..."
    Ky "Asesinando a la gente..."

# game/scripts/day4.rpy:721
translate spanish d4a_kyra_question_menu_379ba563:

    # Ky "Earning respect..."
    Ky "Ganarse el respeto..."

# game/scripts/day4.rpy:724
translate spanish d4a_kyra_question_menu_5b835d65:

    # Ky "Going on raids..."
    Ky "Ir a las incursiones..."

# game/scripts/day4.rpy:727
translate spanish d4a_kyra_question_menu_39e5c259:

    # Ky "Driving fast cars..."
    Ky "Conducir coches rápidos..."

# game/scripts/day4.rpy:728
translate spanish d4a_kyra_question_menu_af381576:

    # Ky "Having the time of my life..."
    Ky "Me lo estoy pasando como nunca..."

# game/scripts/day4.rpy:729
translate spanish d4a_kyra_question_menu_19a720cd:

    # Ky "Occasionally almost getting killed..."
    Ky "Ocasionalmente casi te matan..."

# game/scripts/day4.rpy:730
translate spanish d4a_kyra_question_menu_5f6c6f84:

    # Ky "Captured..."
    Ky "Capturada..."

# game/scripts/day4.rpy:731
translate spanish d4a_kyra_question_menu_08993c22:

    # Ky "Being rescued..."
    Ky "Ser rescatada..."

# game/scripts/day4.rpy:735
translate spanish d4a_kyra_question_menu_e0a3066b:

    # Ky "...and a lot of fucking in the process."
    Ky "... ¡y un montón de folladas en el proceso!"

# game/scripts/day4.rpy:737
translate spanish d4a_kyra_question_menu_a0ca78c8:

    # Ky "That's about it."
    Ky "Eso es todo."

# game/scripts/day4.rpy:744
translate spanish d4a_kyra_question_menu_a0d05fa9:

    # Z "What's your sisters role?"
    Z "¿Cuál es el papel de tu hermana?"

# game/scripts/day4.rpy:747
translate spanish d4a_kyra_question_menu_f6995bc1:

    # Ky "How about I show you when we get there, hm?"
    Ky "¿Qué tal si te lo enseño cuando lleguemos?"

# game/scripts/day4.rpy:750
translate spanish d4a_kyra_question_menu_5ab3574d:

    # Z "..."
    Z "..."

# game/scripts/day4.rpy:755
translate spanish d4a_kyra_question_menu_566da478:

    # Z "What's with your eyes? How are they so bloodshot?"
    Z "¿Qué pasa con tus ojos? ¿Por qué están tan inyectados en sangre?"

# game/scripts/day4.rpy:758
translate spanish d4a_kyra_question_menu_9f5a1a1e:

    # Ky "Well, you know... breathing in toxic gas is just so much fun!"
    Ky "Bueno, ya sabes... ¡respirar gas tóxico es tan divertido!"

# game/scripts/day4.rpy:761
translate spanish d4a_kyra_question_menu_e7ac1874:

    # Ky "I'm obviously joking."
    Ky "Obviamente estoy bromeando."

# game/scripts/day4.rpy:764
translate spanish d4a_kyra_question_menu_ae9062df:

    # Ky "...It could also be the drugs."
    Ky "... También pueden ser las drogas."

# game/scripts/day4.rpy:770
translate spanish d4a_kyra_question_menu_60c6e59b:

    # Z "Why should I help you?"
    Z "¿Por qué debería ayudarte?"

# game/scripts/day4.rpy:773
translate spanish d4a_kyra_question_menu_f32ae622:

    # Ky "Because I can be the best fuck in your life...?"
    Ky "¿Porque puedo ser el mejor polvo de tu vida...?"

# game/scripts/day4.rpy:776
translate spanish d4a_kyra_question_menu_5c0420e2:

    # Ky "Seriously, though. You have a car, don't you? That's how you got me out of Cairo."
    Ky "En serio, ¿tienes un coche, no? Así fue como me sacaste del Viejo Cairo."

# game/scripts/day4.rpy:781
translate spanish d4a_kyra_question_menu_8dd23411:

    # Z "I think I'm going to sell you on the slave market instead."
    Z "Creo que voy a venderte en el mercado de esclavos."

# game/scripts/day4.rpy:784
translate spanish d4a_kyra_question_menu_f1efca14:

    # Ky "Right..."
    Ky "Bien..."

# game/scripts/day4.rpy:787
translate spanish d4a_kyra_question_menu_35a67ac3:

    # Ky "..."
    Ky "..."

# game/scripts/day4.rpy:791
translate spanish d4a_kyra_question_menu_45012f5d:

    # Ky "Wait, you're serious?!"
    Ky "¿Espera, hablas en serio?!"

# game/scripts/day4.rpy:792
translate spanish d4a_kyra_question_menu_2984cc7a:

    # Ky "Come on, no one would want me."
    Ky "Vamos, nadie me querría."

# game/scripts/day4.rpy:795
translate spanish d4a_kyra_question_menu_a4303332:

    # Ky "Look, I'm not stupid. You won't just ruin your reputation helping out a raider, I get it."
    Ky "Mira, no soy estúpida. No vas a arruinar tu reputación ayudando a una asaltante, lo entiendo."

# game/scripts/day4.rpy:798
translate spanish d4a_kyra_question_menu_23989d77:

    # Ky "What if I made it worth your while instead?"
    Ky "¿Y si, en cambio, hiciera que te valiera la pena?"

# game/scripts/day4.rpy:801
translate spanish d4a_kyra_question_menu_0072246e:

    # Ky "You have a car, don't you? That's how you got me out of Cairo."
    Ky "Tienes un coche, ¿no? Así es como me sacaste del Viejo Cairo."

# game/scripts/day4.rpy:804
translate spanish d4a_kyra_question_menu_657a8d18:

    # Ky "What if I got you a new one in return?!"
    Ky "¿Y si te consigo uno nuevo a cambio?!"

# game/scripts/day4.rpy:807
translate spanish d4a_kyra_question_menu_2a19055b:

    # Ky "Well, almost new. Anyway, pretty fucking new!"
    Ky "Bueno, casi nuevo. De todos modos, ¡bastante jodidamente nuevo!"

# game/scripts/day4.rpy:810
translate spanish d4a_kyra_question_menu_5e3afefe:

    # Z "And why would I believe you? The last guys who trusted you ended up as a dish for the decayed."
    Z "¿Y por qué debería creerte? Los últimos que confiaron en ti terminaron siendo un plato para los corruptos."

# game/scripts/day4.rpy:813
translate spanish d4a_kyra_question_menu_bb2ec688:

    # Ky "Because I'm an honest raider who never lies!"
    Ky "Porque soy una asaltante honesta que nunca miente."

# game/scripts/day4.rpy:816
translate spanish d4a_kyra_question_menu_e20f257f:

    # Ky "You obviously can't, smartass."
    Ky "Es evidente que no puedes, listillo."

# game/scripts/day4.rpy:819
translate spanish d4a_kyra_question_menu_102459f8:

    # Ky "But I promise, I am actually not lying, this time. Is trusting me a risk for you? Yes.. but for such a prize, it's worth it!"
    Ky "Pero te prometo que esta vez no te estoy mintiendo. ¿Confiar en mí es un riesgo para ti? Sí... pero por un premio así, ¡merece la pena!"

# game/scripts/day4.rpy:822
translate spanish d4a_kyra_question_menu_5ab3574d_1:

    # Z "..."
    Z "..."

# game/scripts/day4.rpy:825
translate spanish d4a_kyra_question_menu_60b28cbe:

    # Ky "Look, I want my freedom back, and if that means cooperating with someone from the city, so be it."
    Ky "Mira, quiero recuperar mi libertad, y si eso significa cooperar con alguien de la ciudad, que así sea."

# game/scripts/day4.rpy:826
translate spanish d4a_kyra_question_menu_1442731f:

    # Ky "I was going to keep that find for myself, but my life and freedom are worth more to me."
    Ky "Iba a quedarme con ese hallazgo para mí, pero mi vida y mi libertad valen más para mí."

# game/scripts/day4.rpy:829
translate spanish d4a_kyra_question_menu_0d2ac45d:

    # Ky "I'm a leader with my people. What [Ky] says, goes. They know I keep my word, and you should too."
    Ky "Soy una líder con mi gente. Lo que [Ky] dice, va. Ellos saben que cumplo mi palabra, y tú también deberías."

# game/scripts/day4.rpy:832
translate spanish d4a_kyra_question_menu_5ab3574d_2:

    # Z "..."
    Z "..."

# game/scripts/day4.rpy:833
translate spanish d4a_kyra_question_menu_cbbe577e:

    # Z "I will think about it."
    Z "Lo pensaré."

# game/scripts/day4.rpy:836
translate spanish d4a_kyra_question_menu_ef692198:

    # Ky "Yeah yeah, go have a think while I'm making myself comfortable in this cell, with a collar around my neck..."
    Ky "Sí, sí, ve a pensar mientras me pongo cómodo en esta celda, con un collar alrededor del cuello..."

# game/scripts/day4.rpy:841
translate spanish d4a_kyra_question_menu_1c50172b:

    # "You leave the basement..."
    "Sales del sótano..."

# game/scripts/day4.rpy:846
translate spanish d4a_kyra_question_menu_cbb97b58:

    # Zt "I could easily just sell her off and be done with her."
    Zt "Podría fácilmente venderla y acabar con esto."

# game/scripts/day4.rpy:847
translate spanish d4a_kyra_question_menu_cd15cc5e:

    # Zt "There is always someone who could use a maniac like her. As fodder for the arena perhaps."
    Zt "Siempre hay alguien que podría usar a una maniaca como ella. Tal vez como carnada para la arena."

# game/scripts/day4.rpy:848
translate spanish d4a_kyra_question_menu_02519706:

    # Zt "Maybe I can get more out of her though."
    Zt "Tal vez pueda sacarle más provecho, después de todo."

# game/scripts/day4.rpy:849
translate spanish d4a_kyra_question_menu_da9fbfc2:

    # Zt "Having contact with a leader in Adira could help me collect information the Queen would be interested in..."
    Zt "Tener contacto con una líder en Adira podría ayudarme a recopilar información que interesaría a la Reina..."

# game/scripts/day4.rpy:850
translate spanish d4a_kyra_question_menu_0378ad1d:

    # Zt "I could also use the opportunity to see what Adira has to offer instead. It's not like the Queen is my only client, after all."
    Zt "También podría aprovechar la oportunidad para ver qué tiene Adira que ofrecer. No es como si la Reina fuera mi única clienta."

# game/scripts/day4.rpy:851
translate spanish d4a_kyra_question_menu_bf71cfa4:

    # Zt "I'm not sure if I can trust her, or what I should expect, but she might be my ticket to keeping that door open."
    Zt "No estoy seguro de si puedo confiar en ella o qué debería esperar, pero podría ser mi boleto para mantener esa puerta abierta."

# game/scripts/day4.rpy:852
translate spanish d4a_kyra_question_menu_8163c5de:

    # Zt "The decayed are shady guys at best, but most raiders are straight up psychopaths."
    Zt "Los Decaídos son tipos turbios como mucho, pero la mayoría de los asaltante son psicópatas directos."

# game/scripts/day4.rpy:853
