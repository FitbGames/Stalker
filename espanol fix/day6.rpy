    # C2 "I don't know... but if anyone can summon a dragon or a storm, it's our Queen."
    C2 "No sé... pero si alguien puede convocar un dragón o una tormenta, es nuestra Reina."

# game/scripts/day6.rpy:55
translate spanish d6a5_666c33f6:

    # C2 "I wish I could see the dragon with my own eyes one day."
    C2 "Me gustaría poder ver al dragón con mis propios ojos algún día."

# game/scripts/day6.rpy:56
translate spanish d6a5_b6e62cd3:

    # C2 "It must be a magnificent creature!"
    C2 "Debe ser una criatura magnífica."

# game/scripts/day6.rpy:59
translate spanish d6a5_b4fbc020:

    # C "Let us pray to the gods that it will never leave our side!"
    C "Recemos a los dioses para que nunca nos abandone."

# game/scripts/day6.rpy:62
translate spanish d6a5_b1ae1a2e:

    # Z "You have been here before, right?"
    Z "Has estado aquí antes, ¿verdad?"

# game/scripts/day6.rpy:63
