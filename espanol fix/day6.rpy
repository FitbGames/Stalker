# game/scripts/day6.rpy:28
translate spanish d6a_8074e4ee:

    # Z "I haven't forgotten my promise. I guess it's your lucky day. "
    Z "No he olvidado mi promesa. Supongo que es tu día de suerte."

# game/scripts/day6.rpy:29
