translate spanish d6a22_03354756:

    # Ka "Maybe... some other time."
    Ka "Tal vez... en otro momento."

# game/scripts/day6.rpy:299
translate spanish d6a22_88e06767:

    # Z "I will think about your offer."
    Z "Pensaré en tu oferta."

# game/scripts/day6.rpy:300
translate spanish d6a22_1b210696:

    # Z "But we should move on now, [Rm]."
    Z "Pero debemos seguir adelante ahora, [Rm]."

# game/scripts/day6.rpy:303
translate spanish d6a22_24cca3ab:

    # Rm "As you wish, Stalker."
    Rm "Como quieras, Acechador."

# game/scripts/day6.rpy:306
translate spanish d6a22_c2ab39f9:

    # "You let go of her..."
    "La sueltas..."

# game/scripts/day6.rpy:309
translate spanish d6a22_d776dffc:

    # Rm "I should leave, too."
    Rm "Yo también debería irme."

# game/scripts/day6.rpy:310
translate spanish d6a22_e49e0c1e:

    # Rm "If you change your mind, you know where to find me..."
    Rm "Si cambias de opinión, ya sabes dónde encontrarme..."

# game/scripts/day6.rpy:313
translate spanish d6a22_41b49433_1:

    # Z "I do..."
    Z "Sí..."

# game/scripts/day6.rpy:320
translate spanish d6a22_bf017998:

    # Z "Thank you, [Rm], but I want to show Kateryna around, not think about children, today."
    Z "Gracias, [Rm], pero hoy quiero enseñarle la ciudad a Kateryna, no pensar en niños."

# game/scripts/day6.rpy:321
translate spanish d6a22_f04a18e9:

    # Z "We might pay you a visit once you have delivered the baby."
    Z "Puede que te hagamos una visita cuando hayas dado a luz."

# game/scripts/day6.rpy:324
translate spanish d6a22_7fa9c634:

    # Rm "I understand..."
    Rm "Entiendo..."

# game/scripts/day6.rpy:327
translate spanish d6a22_3096efe6:

    # Ka "Stalker [persistent.player_name], can we head home soon?"
    Ka "Acechador [persistent.player_name], ¿podemos volver pronto a casa?"

# game/scripts/day6.rpy:330
translate spanish d6a22_e38bed82:

    # Z "Of course, [Ka]."
    Z "Por supuesto, [Ka]."

# game/scripts/day6.rpy:331
translate spanish d6a22_6cacc48d:

    # Z "We will head back in a moment."
    Z "Volveremos en un momento."

# game/scripts/day6.rpy:332
translate spanish d6a22_d776dffc_1:

    # Rm "I should leave, too."
    Rm "Yo también debería irme."

# game/scripts/day6.rpy:335
translate spanish d6a22_e49e0c1e_1:

    # Rm "If you change your mind, you know where to find me..."
    Rm "Si cambias de opinión, ya sabes dónde encontrarme..."

# game/scripts/day6.rpy:343
translate spanish d6a22_8b31fd2d:

    # Z "Thank you for the offer, but I am not interested."
    Z "Gracias por la oferta, pero no me interesa."

# game/scripts/day6.rpy:344
translate spanish d6a22_0d18c2b4:

    # Z "I'm sure the Temple does not lack volunteers to serve, [Rm]."
    Z "Estoy seguro de que al Templo no le faltan voluntarios para servir, [Rm]."

# game/scripts/day6.rpy:345
translate spanish d6a22_efe708cc:

    # Z "Maybe we will see each other again once your pregnancy is over..."
    Z "Tal vez nos volvamos a ver cuando termine tu embarazo..."

# game/scripts/day6.rpy:348
translate spanish d6a22_dfd0663d:

    # Rm "Hmm, you want to see how I look when I'm not with a child, is that it?"
    Rm "Umm, quieres ver cómo estoy cuando no estoy con un niño, ¿es eso?"

# game/scripts/day6.rpy:349
translate spanish d6a22_fcfcc473:

    # Rm "Serving the Temple is about more than a quick romp, you know, Stalker?"
    Rm "Servir al Templo es algo más que un rápido revolcón, ¿sabes, Acechador?"

# game/scripts/day6.rpy:352
translate spanish d6a22_3096efe6_1:

    # Ka "Stalker [persistent.player_name], can we head home soon?"
    Ka "Acechador [persistent.player_name], ¿podemos volver pronto a casa?"

# game/scripts/day6.rpy:355
translate spanish d6a22_e38bed82_1:

    # Z "Of course, [Ka]."
    Z "Por supuesto, [Ka]."

# game/scripts/day6.rpy:356
translate spanish d6a22_6cacc48d_1:

    # Z "We will head back in a moment."
    Z "Volveremos en un momento."

# game/scripts/day6.rpy:357
translate spanish d6a22_d776dffc_2:

    # Rm "I should leave, too."
    Rm "Yo también debería irme."

# game/scripts/day6.rpy:360
translate spanish d6a22_e49e0c1e_2:

    # Rm "If you change your mind, you know where to find me..."
    Rm "Si cambias de opinión, ya sabes dónde encontrarme..."

# game/scripts/day6.rpy:369
translate spanish d6a36_faf40968:

    # Rm "Come on, don't be shy..."
    Rm "Vamos, no seas tímida..."

# game/scripts/day6.rpy:372
translate spanish d6a36_20b11ad2:

    # Ka "Okay..."
    Ka "Vale..."

# game/scripts/day6.rpy:375
translate spanish d6a36_267eb20e:

    # Ka "I only need to suck, yes...?"
    Ka "Solo necesito chupar, ¿verdad...?"

# game/scripts/day6.rpy:378
translate spanish d6a36_297567b2:

    # Ka "{i}*sucking*"
    Ka "{i}*chupando*{/i}"

# game/scripts/day6.rpy:379
translate spanish d6a36_403b4020:

    # Rm "See... it's nice, isn't it?"
    Rm "Ves... es agradable, ¿verdad?"

# game/scripts/day6.rpy:382
translate spanish d6a36_1fd2ed2a:

    # Rm "That's a fine little woman you have here, Stalker."
    Rm "Es una buena mujercita la que tienes aquí, Acechador."

# game/scripts/day6.rpy:385
translate spanish d6a36_75a9cd81:

    # Ka "Mh..."
    Ka "Mh..."

# game/scripts/day6.rpy:386
translate spanish d6a36_0bf058c7:

    # Z "She seems to like the taste..."
    Z "Parece que le gusta el sabor..."

# game/scripts/day6.rpy:389
translate spanish d6a36_92f6895c:

    # Rm "There is a reason why a vessel's milk is popular."
    Rm "Hay una razón por la que la leche de una vasija es popular."

# game/scripts/day6.rpy:390
translate spanish d6a36_6b92a6ac:

    # Rm "We choose our food carefully, to encourage more and better milk."
    Rm "Elegimos la comida con cuidado para producir más leche y de mejor calidad."

# game/scripts/day6.rpy:393
translate spanish d6a36_17f2a35f:

    # Rm "Sometimes, when we really have excess, we can even sell it."
    Rm "A veces, cuando realmente nos sobra, podemos incluso venderla."

# game/scripts/day6.rpy:394
translate spanish d6a36_39a43bb6:

    # Rm "You know how popular we are in the taverns..."
    Rm "Sabes lo populares que somos en las tabernas..."

# game/scripts/day6.rpy:397
translate spanish d6a36_65f5a4f3:

    # Rm "Oh my... someone is hungry, today..."
    Rm "¡Oh, Dios mío... alguien tiene hambre hoy!"

# game/scripts/day6.rpy:400
translate spanish d6a36_51eeb4b7:

    # Ka "Nhh... this is very sweet."
    Ka "Nhh... esto es muy dulce."

# game/scripts/day6.rpy:401
translate spanish d6a36_77ce6c8b:

    # Ka "Thank you."
    Ka "Gracias."

# game/scripts/day6.rpy:404
translate spanish d6a36_406cd4f5:

    # Ka "Ah..."
    Ka "Ah..."

# game/scripts/day6.rpy:405
translate spanish d6a36_81debd6b:

    # Rm "Oh honey, it's my pleasure and duty to share the blessing."
    Rm "Oh cariño, es un placer y un deber compartir la bendición."

# game/scripts/day6.rpy:408
translate spanish d6a36_c65eb1af:

    # Rm "I will have to leave now though."
    Rm "Pero tendré que irme ahora."

# game/scripts/day6.rpy:409
translate spanish d6a36_bd3a4510:

    # Z "We should get going as well..."
    Z "Deberíamos irnos también..."

# game/scripts/day6.rpy:412
translate spanish d6a36_097be83a:

    # "{i}Kateryna gets up and you get ready to leave..."
    "{i}Kateryna se levanta y os preparáis para marcharos..."

# game/scripts/day6.rpy:415
translate spanish d6a36_f348453f:

    # "She turns around..."
    "Ella se da la vuelta..."

# game/scripts/day6.rpy:420
translate spanish d6a36_0fcfdee7:

    # Rm "You should think about my offer..."
    Rm "Deberías pensar en mi oferta..."

# game/scripts/day6.rpy:421
translate spanish d6a36_3787f7c1:

    # Rm "This little one will be seeing the Sun in a matter of weeks."
    Rm "Este pequeño verá el Sol en cuestión de semanas."

# game/scripts/day6.rpy:422
translate spanish d6a36_5964ba33:

    # Rm "After that, I can be at your service again..."
    Rm "Después de eso, podré volver a estar a tu servicio..."

# game/scripts/day6.rpy:425
translate spanish d6a36_cbbe577e:

    # Z "I will think about it."
    Z "Lo pensaré."

# game/scripts/day6.rpy:428
translate spanish d6a36_6fd59788:

    # Rm "Blessings upon you both..."
    Rm "Bendiciones para los dos..."

# game/scripts/day6.rpy:433
translate spanish d6a36_0fcfdee7_1:

    # Rm "You should think about my offer..."
    Rm "Deberías pensar en mi oferta..."

# game/scripts/day6.rpy:434
translate spanish d6a36_3787f7c1_1:

    # Rm "This little one will be seeing the Sun in a matter of weeks."
    Rm "Este pequeño verá el Sol en cuestión de semanas."

# game/scripts/day6.rpy:435
translate spanish d6a36_5137acce:

    # Rm "But after that, I can be at your service, Stalker..."
    Rm "Pero después, podré estar a tu servicio, Acechador..."

# game/scripts/day6.rpy:438
translate spanish d6a36_cbbe577e_1:

    # Z "I will think about it."
    Z "Lo pensaré."

# game/scripts/day6.rpy:439
translate spanish d6a36_61359b15:

    # Z "I'm sure we will meet again."
    Z "Estoy seguro de que nos volveremos a encontrar."

# game/scripts/day6.rpy:442
translate spanish d6a36_a7c9ba8c:

    # Rm "I'm sure we will..."
    Rm "Estoy segura de que lo haremos..."

# game/scripts/day6.rpy:450
translate spanish d6a42_382d63fd:

    # Ka "She is very experienced with making babies..."
    Ka "Tiene mucha experiencia en hacer bebés..."

# game/scripts/day6.rpy:451
translate spanish d6a42_fbc8fc73:

    # Ka "There are more women like her?"
    Ka "¿Hay más mujeres como ella?"

# game/scripts/day6.rpy:454
translate spanish d6a42_8b63631a:

    # Z "There are, yes, though not many."
    Z "Las hay, sí, aunque no muchas."

# game/scripts/day6.rpy:455
translate spanish d6a42_f65be1a3:

    # Z "Do you want to head home?"
    Z "¿Quieres volver a casa?"

# game/scripts/day6.rpy:458
translate spanish d6a42_6f4aaf3a:

    # Ka "Yes, we can go back."
    Ka "Sí, podemos volver."

# game/scripts/day6.rpy:459
translate spanish d6a42_77873acb:

    # Ka "But now I am more curious than before..."
    Ka "Pero ahora tengo más curiosidad que antes..."

# game/scripts/day6.rpy:460
translate spanish d6a42_8d3f1953:

    # Ka "Many thoughts..."
    Ka "Muchos pensamientos..."

# game/scripts/day6.rpy:465
translate spanish d6a42_a0cea2f3:

    # "{i}You and Kateryna head back to [Ig]'s place nearby the market."
    "{i}Tú y Kateryna volvéis a la casa de [Ig] cerca del mercado."

# game/scripts/day6.rpy:468
translate spanish d6a42_9957f95e:

    # Ka "Thank you for today, Stalker [persistent.player_name]."
    Ka "Gracias por lo de hoy, Acechador [persistent.player_name]."

# game/scripts/day6.rpy:469
translate spanish d6a42_1e88964e:

    # Ka "It was very interesting to see city with you. Maybe we can do again, soon."
    Ka "Fue muy interesante ver la ciudad contigo. Tal vez podamos hacerlo de nuevo, pronto."

# game/scripts/day6.rpy:472
translate spanish d6a42_278843f2:

    # Z "Maybe we can, yes."
    Z "Tal vez podamos, sí."

# game/scripts/day6.rpy:475
translate spanish d6a42_5442b423:

    # Ka "Do you want come inside? Uncle [Ig] maybe prepared dinner now?"
    Ka "¿Quieres entrar? Tío [Ig] quizá ya preparó la cena."

# game/scripts/day6.rpy:478
translate spanish d6a42_c44b79dc:

    # Z "I can stay for a while, sure."
    Z "Puedo quedarme un rato, claro."

# game/scripts/day6.rpy:479
translate spanish d6a42_d3e394c3:

    # Z "I haven't visited his home in a long time... curious to see this home bar he keeps telling me about."
    Z "No he visitado su casa en mucho tiempo... tengo curiosidad por ver este bar casero del que tanto habla."

# game/scripts/day6.rpy:482
translate spanish d6a42_1f2cae6b:

    # Ka "Okay! Come inside!"
    Ka "¡Vale! ¡Entra!"

# game/scripts/day6.rpy:487
translate spanish d6a42_74f3edd9:

    # "She waits for you at the door..."
    "Te espera en la puerta..."

# game/scripts/day6.rpy:490
translate spanish d6a42_ba4766da:

    # "She waits for you to come close, not letting her eyes off you..."
    "Espera que te acerques, sin apartar los ojos de ti..."

# game/scripts/day6.rpy:493
translate spanish d6a42_05861ffb:

    # "...and then comes closer, and hesitatingly, yet sincerely..."
    "... y luego se acerca, vacilante, pero sinceramente..."

# game/scripts/day6.rpy:496
translate spanish d6a42_75a9cd81:

    # Ka "Mh..."
    Ka "Mh..."

# game/scripts/day6.rpy:497
translate spanish d6a42_34deeb2b:

    # "...kisses you on your cheek."
    "... te besa en la mejilla."

# game/scripts/day6.rpy:500
translate spanish d6a42_83b7a7eb:

    # Ka "..."
    Ka "..."

# game/scripts/day6.rpy:503
translate spanish d6a42_2b4c8bc6:

    # "{i}You get inside and Kateryna leads you to her uncle's dining room..."
    "{i}Entras y Kateryna te lleva al comedor de su tío..."

# game/scripts/day6.rpy:506
translate spanish d6a42_495e9b85:

    # Ig "Well, haha, look who is here!"
    Ig "Bueno, jaja, ¡mira quién está aquí!"

# game/scripts/day6.rpy:509
translate spanish d6a42_c20c1784:

    # Ka "We are back, uncle!"
    Ka "¡Estamos de vuelta, tío!"

# game/scripts/day6.rpy:510
translate spanish d6a42_1758b338:

    # Ig "Oh, princess! Come say hello."
    Ig "¡Oh, princesa! Ven a saludar."

# game/scripts/day6.rpy:513
translate spanish d6a42_871246af:

    # Ig "How was it? Did [persistent.player_name] show you around?"
    Ig "¿Cómo fue? ¿Te enseñó [persistent.player_name] los alrededores?"

# game/scripts/day6.rpy:516
translate spanish d6a42_600555c6:

    # Ka "He did, Uncle. He showed sights, and Plaza, and we met a Priestess!"
    Ka "Lo hizo, tío. Mostró vistas, y Plaza, ¡y conocimos a una Sacerdotisa!"

# game/scripts/day6.rpy:519
translate spanish d6a42_fb2b44ae:

    # Ka "I asked Stalker [persistent.player_name] to come to dinner. Is okay?"
    Ka "He pedido a Acechador [persistent.player_name] que venga a cenar. ¿Te parece bien?"

# game/scripts/day6.rpy:522
translate spanish d6a42_638a9ebd:

    # Z "Feel free to say no, Igor. I am not imposing..."
    Z "Siéntete libre de decir que no, Igor. No quiero imponer..."

# game/scripts/day6.rpy:525
translate spanish d6a42_73b40afd:

    # Ig "What are you saying, [persistent.player_name]?!"
    Ig "¡¿Qué estás diciendo, [persistent.player_name]?!"

# game/scripts/day6.rpy:526
translate spanish d6a42_22a9a478:

    # Ig "You are always welcome."
    Ig "Siempre eres bienvenido."

# game/scripts/day6.rpy:527
translate spanish d6a42_121a640c:

    # Ig "Dinner is almost ready, have seat."
    Ig "La cena está casi lista, toma asiento"

# game/scripts/day6.rpy:532
translate spanish d6a42_4b018105:

    # "Igor, Kateryna and you sit down and share a meal..."
    "Igor, Kateryna y tú os sentáis y compartís una comida..."

# game/scripts/day6.rpy:535
translate spanish d6a42_e6cb04c7:

    # "You feast on the delicious stew, while Igor starts his stories about his latest adventures..."
    "Disfrutas del delicioso guiso, mientras Igor comienza sus historias sobre sus últimas aventuras..."

# game/scripts/day6.rpy:538
translate spanish d6a42_ef031ba2:

    # Ig "...and then I told her; pretty woman, no need to apologize."
    Ig "... y luego le dije; bonita mujer, no hace falta que te disculpes."

# game/scripts/day6.rpy:541
translate spanish d6a42_41f5936e:

    # Ig "And then I saw it!"
    Ig "¡Y entonces lo vi!"

# game/scripts/day6.rpy:542
translate spanish d6a42_d25d1a35:

    # Ka "What did you see?"
    Ka "¿Qué viste?"

# game/scripts/day6.rpy:543
translate spanish d6a42_37e2aba0:

    # Ig "Her smile, pretty as rising sun."
    Ig "Su sonrisa, bonita como el sol naciente."

# game/scripts/day6.rpy:544
translate spanish d6a42_1f7fbedf:

    # Ig "Like yours, princess, haha!"
    Ig "Como la tuya, princesa, ¡jajaja!"

# game/scripts/day6.rpy:545
translate spanish d6a42_a8646665:

    # Ka "You only say that to get in her bed, haha."
    Ka "Sólo lo dices para meterte en su cama, jajaja."

# game/scripts/day6.rpy:546
translate spanish d6a42_921f6938:

    # Ig "No no no, young woman, you know this is not me!"
    Ig "No, no, no, jovencita, ¡sabes que no soy yo!"

# game/scripts/day6.rpy:549
translate spanish d6a42_5da8f2dc:

    # Ka "No lying, uncle!"
    Ka "No hay que mentir, tío"

# game/scripts/day6.rpy:552
translate spanish d6a42_05dcbcd0:

    # Z "I'm pretty sure he means it, I have known him for long enough."
    Z "Estoy seguro de que lo dice en serio, le conozco desde hace bastante tiempo."

# game/scripts/day6.rpy:555
translate spanish d6a42_bcf67db5:

    # Z "Hey! Let's drink to that!"
    Z "¡Eh! ¡Brindemos por eso!"

# game/scripts/day6.rpy:556
translate spanish d6a42_e160fc7d:

    # Z "The old man found a new girlfriend, finally!"
    Z "El viejo encontró una nueva novia, ¡por fin!"

# game/scripts/day6.rpy:559
translate spanish d6a42_cce9ed01:

    # Ka "Pust' ty budesh' schastliv do kontsa svoikh dney!"
    Ka "¡Pust' ty budesh' schastliv do kontsa svoikh dney! (Vamos a mantenerte en la cuenta de tus días)"

# game/scripts/day6.rpy:562
translate spanish d6a42_101f3ee0:

    # Z "Shereve!"
    Z "¡Shereve!"

# game/scripts/day6.rpy:563
translate spanish d6a42_8b0828b5:

    # Ig "Za tvoe schast'e!"
    Ig "¡Za tvoe schast'e!"

# game/scripts/day6.rpy:566
translate spanish d6a42_335efd1d:

    # Ig "{i}*slurp*{/i}"
    Ig "{i}*chupada*{/i}"

# game/scripts/day6.rpy:567
translate spanish d6a42_62915b43:

    # Z "Pace yourself, old friend!"
    Z "Ve con calma, viejo amigo."

# game/scripts/day6.rpy:568
translate spanish d6a42_5b9e9dd5:

    # Ka "I try to tell him always..."
    Ka "Intento decírselo siempre..."

# game/scripts/day6.rpy:569
translate spanish d6a42_2796da5d:

    # Z "{i}*laughs*"
    Z "{i}*risas*"

# game/scripts/day6.rpy:573
translate spanish d6a42_c7d9942b:

    # "{i}You talk and drink, and have a good time."
    "{i}Habláis y bebéis, y pasáis un buen rato."

# game/scripts/day6.rpy:574
translate spanish d6a42_65ee4912:

    # "{i}Eventually, Kateryna thanks [Ig] for the dinner and excuses herself."
    "{i}Al final, Kateryna agradece a [Ig] la cena y se excusa."

# game/scripts/day6.rpy:578
translate spanish d6a42_63123240:

    # Ig "[persistent.player_name!c], I tell you, we are become lightweight."
    Ig "[persistent.player_name!c], te digo que nos hemos vuelto ligeros."

# game/scripts/day6.rpy:579
translate spanish d6a42_1f165f75:

    # Ig "Three beer and we are full..."
    Ig "Tres cervezas y estamos llenos..."

# game/scripts/day6.rpy:580
translate spanish d6a42_659c4d56:

    # Z "You speak the truth, my friend. Time passes faster now..."
    Z "Dices la verdad, amigo mío. El tiempo pasa más rápido ahora..."

# game/scripts/day6.rpy:581
translate spanish d6a42_5de0b2c3:

    # Z "I should get back home soon."
    Z "Debería volver a casa pronto."

# game/scripts/day6.rpy:582
translate spanish d6a42_faab82ed:

    # Z "I had a good time, as always."
    Z "Me lo he pasado bien, como siempre."

# game/scripts/day6.rpy:585
translate spanish d6a42_5fde9246:

    # Ig "You are friend, and honoured guest."
    Ig "Eres un amigo y un invitado de honor."

# game/scripts/day6.rpy:586
translate spanish d6a42_99508e53:

    # Ig "Before you go, I want to tell you something."
    Ig "Antes de que te vayas, quiero decirte algo."

# game/scripts/day6.rpy:589
translate spanish d6a42_4160013e:

    # Ig "Early today, Kateryna could not stop talking about you."
    Ig "Hoy temprano, Kateryna no podía dejar de hablar de ti."

# game/scripts/day6.rpy:592
translate spanish d6a42_fda3b9f2:

    # Ig "She seems very taken by you, haha."
    Ig "Parece que le has gustado mucho, jajaja."

# game/scripts/day6.rpy:595
translate spanish d6a42_282edf1b:

    # Z "She is very... interested in our culture here, yes."
    Z "Ella está muy... interesada en nuestra cultura de aquí, sí."

# game/scripts/day6.rpy:598
translate spanish d6a42_bd45af2f:

    # Ig "Don't hide behind words, my friend."
    Ig "No te escondas detrás de las palabras, amigo mío."

# game/scripts/day6.rpy:599
translate spanish d6a42_013ee464:

    # Ig "I know her well; and I know you."
    Ig "La conozco bien; y te conozco a ti."

# game/scripts/day6.rpy:600
translate spanish d6a42_913cb16f:

    # Ig "She is girl who likes new things."
    Ig "Es una chica que le gustan las cosas nuevas."

# game/scripts/day6.rpy:603
translate spanish d6a42_f1437b47:

    # Ig "But she is also scared of world, she wants secure home."
    Ig "Pero ella también tiene miedo del mundo, quiere un hogar seguro."

# game/scripts/day6.rpy:604
translate spanish d6a42_06978a54:

    # Ig "I don't know if she told you, but her home village..."
    Ig "No sé si te lo dijo, pero su pueblo natal..."

# game/scripts/day6.rpy:607
translate spanish d6a42_6ab6d6e9:

    # Ig "...is not very safe there."
    Ig "... no es muy seguro en ese lugar."

# game/scripts/day6.rpy:608
translate spanish d6a42_63d35322:

    # Ig "She has not much to return to, maybe nothing."
    Ig "No tiene mucho que retomar, tal vez nada."

# game/scripts/day6.rpy:611
translate spanish d6a42_fbfee575:

    # Ig "I am not always around, [persistent.player_name]."
    Ig "No estoy siempre presente, [persistent.player_name]."

# game/scripts/day6.rpy:612
translate spanish d6a42_d9f8d45b:

    # Ig "I am trader. She can not come with me always. And I want her to have good man, not one who treats her badly."
    Ig "Soy comerciante. Ella no puede venir conmigo siempre. Y quiero que tenga un buen hombre, no uno que la trate mal."

# game/scripts/day6.rpy:613
translate spanish d6a42_a0588ebb:

    # Ig "So..."
    Ig "Así que..."

# game/scripts/day6.rpy:616
translate spanish d6a42_830a8552:

    # Ig "I think she likes you."
    Ig "Creo que le gustas."

# game/scripts/day6.rpy:617
translate spanish d6a42_85941533:

    # Ig "If she wants to make life with you, I am not against."
    Ig "Si quiere hacer vida contigo, no estoy en contra."

# game/scripts/day6.rpy:618
translate spanish d6a42_5183b6d7:

    # Ig "You are good man and I trust you."
    Ig "Eres un buen hombre y confío en ti."

# game/scripts/day6.rpy:621
translate spanish d6a42_0412d5d7:

    # Ig "She is young, and exploring world."
    Ig "Ella es joven y está explorando el mundo."

# game/scripts/day6.rpy:622
translate spanish d6a42_2b0713e8:

    # Ig "Maybe she will forget tomorrow, and find other interest.."
    Ig "Tal vez se olvide mañana, y encuentre otro interés..."

# game/scripts/day6.rpy:623
translate spanish d6a42_c34ba92c:

    # Ig "But I think not, so... what to do?"
    Ig "Pero creo que no, así que... ¿qué hacer?"

# game/scripts/day6.rpy:624
translate spanish d6a42_bbf07eb2:

    # Ig "I know it is big ask. You don't have to reply now."
    Ig "Sé que es una gran petición. No hace falta que respondas ahora."

# game/scripts/day6.rpy:629
translate spanish d6a42_daaffd9f:

    # Z "I will remember that, [Ig]."
    Z "Lo recordaré, [Ig]."

# game/scripts/day6.rpy:630
translate spanish d6a42_330f78fe:

    # Z "I understand your worries about her future."
    Z "Entiendo tu preocupación por su futuro."

# game/scripts/day6.rpy:631
translate spanish d6a42_81cdc01d:

    # Z "I have a big household already."
    Z "Ya tengo un gran hogar."

# game/scripts/day6.rpy:632
translate spanish d6a42_f2b08863:

    # Z "But if she should truly desire to live with me and my family, I will give it some thought."
    Z "Pero si realmente desea vivir conmigo y con mi familia, me lo pensaré."

# game/scripts/day6.rpy:635
translate spanish d6a42_171dfc89:

    # Ig "Thank you, old friend."
    Ig "Gracias, viejo amigo."

# game/scripts/day6.rpy:636
translate spanish d6a42_35345805:

    # Ig "I made promise to her mother, that I will see her happy and safe."
    Ig "Le prometí a su madre que la vería feliz y segura."

# game/scripts/day6.rpy:641
translate spanish d6a42_b042c1f2:

    # Z "She's a nice girl, I like her."
    Z "Es una chica bonita, me gusta."

# game/scripts/day6.rpy:642
translate spanish d6a42_18674b78:

    # Z "We should see what she truly wants."
    Z "Deberíamos ver lo que realmente quiere."

# game/scripts/day6.rpy:643
translate spanish d6a42_2c732551:

    # Z "Maybe she just feels unsafe at the moment and looks up to me for some reassurance."
    Z "Tal vez sólo se sienta insegura en este momento y me busque para que la tranquilice."

# game/scripts/day6.rpy:646
translate spanish d6a42_01c3b9ed:

    # Ig "Let me say thing I noticed."
    Ig "Déjame decir algo que he notado."

# game/scripts/day6.rpy:647
translate spanish d6a42_22e23278:

    # Ig "She never likes boys her age."
    Ig "Nunca le gustan los chicos de su edad."

# game/scripts/day6.rpy:648
translate spanish d6a42_b8f408a7:

    # Ig "I made promise to mother, that I will see her happy and safe."
    Ig "Le prometí a su madre que la vería feliz y segura."

# game/scripts/day6.rpy:653
translate spanish d6a42_867b2b46:

    # Z "She's cute, and I like her."
    Z "Es guapa y me gusta."

# game/scripts/day6.rpy:654
translate spanish d6a42_4cf9ef0d:

    # Z "But you know I already have a family, and if she wants to join the household..."
    Z "Pero sabes que ya tengo una familia, y si ella quiere unirse a la casa..."

# game/scripts/day6.rpy:655
translate spanish d6a42_332696d3:

    # Z "...I'm afraid she will have to work for it, like other servants."
    Z "... me temo que tendrá que trabajar por ello, como otras sirvientas."

# game/scripts/day6.rpy:656
translate spanish d6a42_83732633:

    # Z "But we will see about that."
    Z "Pero eso ya lo veremos."

# game/scripts/day6.rpy:659
translate spanish d6a42_1dd211a5:

    # Ig "I am sure this will be no problem."
    Ig "Estoy seguro de que eso no supondrá ningún problema."

# game/scripts/day6.rpy:660
translate spanish d6a42_83fd7805:

    # Ig "She is always very diligent in house."
    Ig "Ella siempre es muy diligente en la casa."

# game/scripts/day6.rpy:663
translate spanish d6a42_35345805_1:

    # Ig "I made promise to her mother, that I will see her happy and safe."
    Ig "Le prometí a su madre que la vería feliz y segura."

# game/scripts/day6.rpy:664
translate spanish d6a42_20c0c146:

    # Ig "If serving you will make her happy, I know you will protect her."
    Ig "Si servirte la hace feliz, sé que la protegerás."

# game/scripts/day6.rpy:672
translate spanish d6a64_7ae72290:

    # "{i}You get up and ready to leave..."
    "{i}Te levantas y te preparas para salir..."

# game/scripts/day6.rpy:675
translate spanish d6a64_bebe7451:

    # Z "Thank you for the dinner."
    Z "Gracias por la cena."

# game/scripts/day6.rpy:676
translate spanish d6a64_3046345b:

    # Z "I will say goodbye to [Ka] and head out."
    Z "Me despediré de [Ka] y me iré."

# game/scripts/day6.rpy:679
translate spanish d6a64_d1128716:

    # Ig "You do so; will see you again soon, I'm sure."
    Ig "Hazlo; te veré pronto, estoy seguro."

# game/scripts/day6.rpy:682
translate spanish d6a64_c1bbc3d9:

    # Z "Until then, take care out there."
    Z "Hasta entonces, cuídate ahí fuera."

# game/scripts/day6.rpy:685
translate spanish d6a64_2a098ac9:

    # "You head to her room..."
    "Te diriges a su habitación..."

# game/scripts/day6.rpy:688
translate spanish d6a64_d11f277d:

    # Z "[Ka]? Are you in here?"
    Z "¿[Ka]? ¿Estás aquí?"

# game/scripts/day6.rpy:689
translate spanish d6a64_b1d62cf8:

    # Z "I am leaving and wanted to say goodbye."
    Z "Me voy y quería despedirme."

# game/scripts/day6.rpy:692
translate spanish d6a64_2e40f74c:

    # Z "Hey... Is everything okay?"
    Z "Oye... ¿todo bien?"

# game/scripts/day6.rpy:693
translate spanish d6a64_7d8aea14:

    # Ka "Yes, Stalker [persistent.player_name]..."
    Ka "Sí, Acechador [persistent.player_name]..."

# game/scripts/day6.rpy:699
translate spanish d6a64_8ca25af1:

    # Z "What's wrong?"
    Z "¿Qué pasa?"

# game/scripts/day6.rpy:700
translate spanish d6a64_7beba1dc:

    # Z "You can tell me."
    Z "Puedes decírmelo."

# game/scripts/day6.rpy:703
translate spanish d6a64_5be478bd:

    # Ka "The woman before..."
    Ka "La mujer de antes..."

# game/scripts/day6.rpy:704
translate spanish d6a64_46b088eb:

    # Ka "She looked pretty, yes?"
    Ka "Estaba muy guapa, ¿verdad?"

# game/scripts/day6.rpy:707
translate spanish d6a64_e286ecdd:

    # Z "Very, yes..."
    Z "Mucho, sí..."

# game/scripts/day6.rpy:710
translate spanish d6a64_db57c516:

    # Ka "She said I don't have body like her..."
    Ka "Dijo que yo no tenía cuerpo como ella..."

# game/scripts/day6.rpy:711
translate spanish d6a64_85289359:

    # Ka "You think she is right...?"
    Ka "¿Crees que tiene razón?"

# game/scripts/day6.rpy:712
translate spanish d6a64_320f3187:

    # Ka "You think I am pretty, Stalker [persistent.player_name]?"
    Ka "¿Crees que soy bonita, Acechador [persistent.player_name]?"

# game/scripts/day6.rpy:718
translate spanish d6a64_bd293341:

    # Z "I do think so."
    Z "Sí lo creo."

# game/scripts/day6.rpy:719
translate spanish d6a64_468b7bf1:

    # Z "You are a very pretty woman, on the inside and out."
    Z "Eres una mujer muy bonita, por dentro y por fuera."

# game/scripts/day6.rpy:720
translate spanish d6a64_1108f7ea:

    # Ka "And..."
    Ka "Y..."

# game/scripts/day6.rpy:723
translate spanish d6a64_a07a6057:

    # Ka "...can I do what the priestess does, too...?"
    Ka "... ¿puedo hacer también lo que hace la sacerdotisa?"

# game/scripts/day6.rpy:724
translate spanish d6a64_c51da8ef:

    # Ka "Make... many babies?"
    Ka "¿Hacer... muchos bebés?"

# game/scripts/day6.rpy:730
translate spanish d6a64_0ac77690:

    # Z "I don't see why not."
    Z "No veo por qué no."

# game/scripts/day6.rpy:733
translate spanish d6a64_4b9e2f73:

    # Z "You may not have her proportions, or ample bosom..."
    Z "Puede que no tengas sus proporciones, ni su amplio pecho..."

# game/scripts/day6.rpy:736
translate spanish d6a64_3764a18f:

    # Z "But you are a young and healthy woman...."
    Z "Pero eres una mujer joven y sana...."

# game/scripts/day6.rpy:739
translate spanish d6a64_75a9cd81:

    # Ka "Mh..."
    Ka "Mh..."

# game/scripts/day6.rpy:740
translate spanish d6a64_1eb58b20:

    # Z "If that is what you want, I see nothing that could stop you."
    Z "Si eso es lo que quieres, no veo nada que pueda detenerte."

# game/scripts/day6.rpy:743
translate spanish d6a64_58d57ebc:

    # Z "So what if you're a bit slimmer than the Priestess... Many women are."
    Z "Y qué importa que seas un poco más delgada que la Sacerdotisa... Muchas mujeres lo son."

# game/scripts/day6.rpy:746
translate spanish d6a64_80732329:

    # Z "You will discover that childbearing changes a woman's body."
    Z "Descubrirás que la maternidad cambia el cuerpo de una mujer."

# game/scripts/day6.rpy:749
translate spanish d6a64_2462a5df:

    # Z "Who is to say how your body will react when the time comes?"
    Z "¿Quién puede decir cómo reaccionará tu cuerpo cuando llegue el momento?"

# game/scripts/day6.rpy:752
translate spanish d6a64_87624d29:

    # Ka "It must... feel nice..."
    Ka "Debe... sentirse bien..."

# game/scripts/day6.rpy:753
translate spanish d6a64_3cf11edf:

    # Z "What do you mean?"
    Z "¿Qué quieres decir?"

# game/scripts/day6.rpy:754
translate spanish d6a64_44378df0:

    # Ka "Making a life, and feeling it grow inside you."
    Ka "Hacer una vida, y sentirla crecer dentro de ti."

# game/scripts/day6.rpy:757
translate spanish d6a64_b05b9cb9:

    # Z "Maybe you will find out one day..."
    Z "Tal vez lo descubras algún día..."

# game/scripts/day6.rpy:760
translate spanish d6a64_664a46a2:

    # Ka "Also the making...of love."
    Ka "También la fabricación... del amor."

# game/scripts/day6.rpy:761
translate spanish d6a64_2700272a:

    # Ka "I would like to know more. I have seen the animals... and others in my family."
    Ka "Me gustaría saber más. He visto a los animales... y a otros de mi familia."

# game/scripts/day6.rpy:764
translate spanish d6a64_900f0148:

    # Z "Hm..."
    Z "Hm..."

# game/scripts/day6.rpy:767
translate spanish d6a64_2eb95a23:

    # Z "Your day will come, Kateryna..."
    Z "Tu día llegará, Kateryna..."

# game/scripts/day6.rpy:770
translate spanish d6a64_0590594b:

    # Ka "...mnh."
    Ka "... mnh."

# game/scripts/day6.rpy:771
translate spanish d6a64_bea4b7d5:

    # Z "...I am sure of it."
    Z "... estoy seguro de ello."

# game/scripts/day6.rpy:777
translate spanish d6a64_34552c9e:

    # Z "I see no reason why you should not be able to bear children, even now."
    Z "No veo ninguna razón por la que no puedas tener hijos, incluso ahora."

# game/scripts/day6.rpy:780
translate spanish d6a64_b2a024d2:

    # Z "...but you can always consider having them later."
    Z "... pero siempre puedes considerar tenerlos más tarde."

# game/scripts/day6.rpy:781
translate spanish d6a64_8ab647ce:

    # Ka "Later... yes..."
    Ka "Después... sí..."

# game/scripts/day6.rpy:784
translate spanish d6a64_95a75121:

    # Z "With a body like yours..."
    Z "Con un cuerpo como el tuyo..."

# game/scripts/day6.rpy:787
translate spanish d6a64_dfceba5e:

    # "You slowly, and sensually roam around her breasts..."
    "Recorres lentamente y con sensualidad sus pechos..."

# game/scripts/day6.rpy:790
translate spanish d6a64_75a9cd81_1:

    # Ka "Mh..."
    Ka "Mh..."

# game/scripts/day6.rpy:793
translate spanish d6a64_9358157a:

    # "...uncovering her loose dress little by little..."
    "... descubriendo su vestido suelto poco a poco..."

# game/scripts/day6.rpy:796
translate spanish d6a64_d92e2f32:

    # Z "...and such pretty lips..."
    Z "... y unos labios tan bonitos..."

# game/scripts/day6.rpy:799
translate spanish d6a64_95c8e82e:

    # Ka "Hah..."
    Ka "Hah..."

# game/scripts/day6.rpy:800
translate spanish d6a64_ee98fc2e:

    # Z "...you can, if you want to, explore life to the fullest, before settling down with someone worthy and having his children."
    Z "... puedes, si quieres, explorar la vida al máximo, antes de establecerte con alguien digno y tener sus hijos."

# game/scripts/day6.rpy:801
translate spanish d6a64_4c28c722:

    # Ka "I want to... experience it."
    Ka "Quiero... experimentarlo."

# game/scripts/day6.rpy:802
translate spanish d6a64_b8659685:

    # Z "You have never before...?"
    Z "¿Nunca antes lo has hecho...?"

# game/scripts/day6.rpy:803
translate spanish d6a64_196b2f92:

    # Ka "No..."
    Ka "No..."

# game/scripts/day6.rpy:806
translate spanish d6a64_900f0148_1:

    # Z "Hm..."
    Z "Hm..."

# game/scripts/day6.rpy:807
translate spanish d6a64_39447400:

    # Z "Maybe you will one day."
    Z "Tal vez algún día."

# game/scripts/day6.rpy:810
translate spanish d6a64_fe7886cf:

    # Ka "One day..."
    Ka "Un día..."

# game/scripts/day6.rpy:813
translate spanish d6a64_406cd4f5:

    # Ka "Ah..."
    Ka "Ah..."

# game/scripts/day6.rpy:814
translate spanish d6a64_37cbe629:

    # Z "One day."
    Z "Un día."

# game/scripts/day6.rpy:821
translate spanish d6a64_9658e416:

    # Z "You are a very pretty woman, [Ka]."
    Z "Eres una mujer muy bonita, [Ka]."

# game/scripts/day6.rpy:822
translate spanish d6a64_735aef12:

    # Z "Don't let the words of the Priestess bother you."
    Z "No dejes que las palabras de la Sacerdotisa te molesten."

# game/scripts/day6.rpy:825
translate spanish d6a64_31c8daa3:

    # Z "There are many men, and women too, who would give everything to see your smile every day, trust me."
    Z "Hay muchos hombres, y también mujeres, que lo darían todo por ver tu sonrisa cada día, créeme."

# game/scripts/day6.rpy:826
translate spanish d6a64_83b7a7eb:

    # Ka "..."
    Ka "..."

# game/scripts/day6.rpy:829
translate spanish d6a64_99fbee55:

    # Z "I have to leave now."
    Z "Tengo que irme por ahora."

# game/scripts/day6.rpy:832
translate spanish d6a64_f39725f2:

    # Ka "We see each other soon?"
    Ka "¿Nos veremos pronto?"

# game/scripts/day6.rpy:835
translate spanish d6a64_2fd5c86a:

    # Z "We can, yes."
    Z "Podemos, sí."

# game/scripts/day6.rpy:840
translate spanish d6a64_9957f95e:

    # Ka "Thank you for today, Stalker [persistent.player_name]."
    Ka "Gracias por lo de hoy, Acechador [persistent.player_name]."

# game/scripts/day6.rpy:843
translate spanish d6a64_e9c99b89:

    # Z "You don't have to call me Stalker next time we meet, okay?"
    Z "No tienes que llamarme Acechador la próxima vez que nos veamos, ¿vale?"

# game/scripts/day6.rpy:844
translate spanish d6a64_d5771d5b:

    # Z "Bye for now, [Ka]."
    Z "Adiós por ahora, [Ka]."

# game/scripts/day6.rpy:847
translate spanish d6a64_bdddb7ff:

    # Ka "Okay... Bye, [persistent.player_name]..."
    Ka "Vale... Adiós, [persistent.player_name]..."

# game/scripts/day6.rpy:852
translate spanish d6a64_b4736591:

    # "{i}You head home..."
    "{i}Te diriges a tu casa..."

# game/scripts/day6.rpy:858
translate spanish d6a78_3edc0075:

    # Z "I have to leave you now, sweet [Ka]."
    Z "Tengo que dejarte ahora, dulce [Ka]."

# game/scripts/day6.rpy:861
translate spanish d6a78_f61fa7dc:

    # Ka "Can we... meet again soon, Stalker [persistent.player_name]?"
    Ka "¿Podemos... volver a vernos pronto, Acechador [persistent.player_name]?"

# game/scripts/day6.rpy:864
translate spanish d6a78_2fd5c86a:

    # Z "We can, yes."
    Z "Podemos, sí."

# game/scripts/day6.rpy:867
translate spanish d6a78_e8c8473a:

    # Z "You don't have to call me Stalker every time."
    Z "No tienes que llamarme Acechador cada vez."

# game/scripts/day6.rpy:868
translate spanish d6a78_bba19d52:

    # Z "Next time we meet; [persistent.player_name] will do."
    Z "La próxima vez que nos encontremos; [persistent.player_name] servirá."

# game/scripts/day6.rpy:869
translate spanish d6a78_d5771d5b:

    # Z "Bye for now, [Ka]."
    Z "Adiós por ahora, [Ka]."

# game/scripts/day6.rpy:872
translate spanish d6a78_bdddb7ff:

    # Ka "Okay... Bye, [persistent.player_name]..."
    Ka "Vale... Adiós, [persistent.player_name]..."

# game/scripts/day6.rpy:877
translate spanish d6a78_b4736591:

    # "{i}You head home..."
    "{i}Te diriges a tu casa..."

# game/scripts/day6.rpy:885
translate spanish d6b1_49688798:

    # Zt "I guess it's time to check the map [Ky] gave me and figure out where that car is..."
    Zt "Supongo que es hora de revisar el mapa que me dio [Ky] y averiguar dónde está ese coche..."

# game/scripts/day6.rpy:889
translate spanish d6b1_bdcecafd:

    # Zt "Southwest of Adira... hmm..."
    Zt "Al suroeste de Adira... hmm..."

# game/scripts/day6.rpy:892
translate spanish d6b1_49359a23:

    # Zt "Should be a couple of hours ride from here."
    Zt "Deberían ser un par de horas de viaje desde aquí."

# game/scripts/day6.rpy:893
translate spanish d6b1_b55c5613:

    # Zt "In the barren lands, just a little away from the riverbed."
    Zt "En las tierras áridas, justo un poco alejadas del lecho del río."

# game/scripts/day6.rpy:894
translate spanish d6b1_70c836aa:

    # Zt "Whoever manages to survive out there must be tough."
    Zt "Quienquiera que sobreviva ahí afuera debe ser duro."

# game/scripts/day6.rpy:897
translate spanish d6b1_bdcecafd_1:

    # Zt "Southwest of Adira... hmm..."
    Zt "Al suroeste de Adira... hmm..."

# game/scripts/day6.rpy:898
translate spanish d6b1_9a02f12a:

    # Zt "That's a rotten place to live in, so far out in the desert, removed from everything."
    Zt "Es un lugar horrible para vivir, tan lejos en el desierto, aislado de todo."

# game/scripts/day6.rpy:901
translate spanish d6b1_43c91b12:

    # Zt "Should be a 45 minute ride from here, to find this girl... Asani, she said."
    Zt "Debería ser un viaje de 45 minutos desde aquí, para encontrar a esta chica... Asani, dijo."

# game/scripts/day6.rpy:902
translate spanish d6b1_b55c5613_1:

    # Zt "In the barren lands, just a little away from the riverbed."
    Zt "En las tierras áridas, justo un poco alejadas del lecho del río."

# game/scripts/day6.rpy:903
translate spanish d6b1_5732302b:

    # Zt "I wonder how she survives out there."
    Zt "Me pregunto cómo sobrevive ahí fuera."

# game/scripts/day6.rpy:907
translate spanish d6b1_b05bb276:

    # Z "Well..."
    Z "Bueno..."

# game/scripts/day6.rpy:911
translate spanish d6b1_3911c0f8:

    # Z "...time to find out."
    Z "... hora de averiguarlo."

# game/scripts/day6.rpy:921
translate spanish d6b1_964ef893:

    # "{i}A while later..."
    "{i}Un rato después..."

# game/scripts/day6.rpy:924
translate spanish d6b1_1263fd2e:

    # Zt "This should be the place..."
    Zt "Este debería ser el lugar..."

# game/scripts/day6.rpy:927
translate spanish d6b1_96d6f19a:

    # Zt "No activity, no sounds or signs of life..."
    Zt "Sin actividad, sin sonidos o signos de vida..."

# game/scripts/day6.rpy:930
translate spanish d6b1_bf331151:

    # Zt "...but you can never be too sure."
    Zt "... pero nunca se puede estar demasiado seguro."

# game/scripts/day6.rpy:933
translate spanish d6b1_5ab3574d:

    # Z "..."
    Z "..."

# game/scripts/day6.rpy:937
translate spanish d6b1_1da472a3:

    # Z "Anyone home?!"
    Z "¿Hay alguien en casa?"

# game/scripts/day6.rpy:938
translate spanish d6b1_fff1d41e:

    # Z "I won't ask again!"
    Z "No volveré a pedirlo."

# game/scripts/day6.rpy:939
translate spanish d6b1_27fe6775:

    # C "Who is it!?"
    C "¡¿Quién es?!"

# game/scripts/day6.rpy:940
translate spanish d6b1_90fa3dc6:

    # C "You knocked on the wrong door, buddy..."
    C "Has llamado a la puerta equivocada, amigo..."

# game/scripts/day6.rpy:943
translate spanish d6b1_2811886c:

    # C "Let's see who wants to..."
    C "A ver quién quiere..."

# game/scripts/day6.rpy:947
translate spanish d6b1_26a803bc:

    # C "..."
    C "..."

# game/scripts/day6.rpy:948
translate spanish d6b1_e77dc794:

    # Z "{i}You{/i} are [Asa]?"
    Z "{i}¿Tú{/i} eres [Asa]?"

# game/scripts/day6.rpy:949
translate spanish d6b1_de528326:

    # Asa "So we meet again..."
    Asa "Así que nos encontramos de nuevo..."

# game/scripts/day6.rpy:953
translate spanish d6b1_3fe37e2a:

    # Asa "I expected many things when I got up this morning."
    Asa "Esperaba muchas cosas cuando me levanté esta mañana."

# game/scripts/day6.rpy:954
translate spanish d6b1_049de7d2:

    # Asa "You were not one of them."
    Asa "Tú no eras uno de ellos."

# game/scripts/day6.rpy:957
translate spanish d6b1_800d43ff:

    # Z "I need your help with something."
    Z "Necesito tu ayuda para algo."

# game/scripts/day6.rpy:960
translate spanish d6b1_20a6c135:

    # Asa "After you spared my life?"
    Asa "Después de perdonarme la vida..."

# game/scripts/day6.rpy:961
translate spanish d6b1_8cb467df:

    # Asa "{i}*chuckles*{/i} Of course, come inside."
    Asa "{i}*risilla*{/i} Por supuesto, entra."

# game/scripts/day6.rpy:965
translate spanish d6b1_bbb67bf1:

    # Z "I spared your life, remember?"
    Z "Te perdoné la vida, ¿recuerdas?"

# game/scripts/day6.rpy:966
translate spanish d6b1_507426a1:

    # Z "I need you to do something for me now."
    Z "Necesito que hagas algo por mí ahora."

# game/scripts/day6.rpy:967
translate spanish d6b1_1a2edaaf:

    # Asa "Sure... come inside."
    Asa "Claro... entra."

# game/scripts/day6.rpy:975
translate spanish d6b1_cd6d0dc0:

    # Z "Yes... yes... coming..."
    Z "Sí... sí... pasa..."

# game/scripts/day6.rpy:978
translate spanish d6b1_61b72c4f:

    # Ig "[persistent.player_name!c]? Do you have time for an old friend?"
    Ig "[persistent.player_name!c]? ¿Tienes tiempo para un viejo amigo?"

# game/scripts/day6.rpy:979
translate spanish d6b1_b09fe361:

    # Z "Igor, my friend."
    Z "Igor, mi amigo."

# game/scripts/day6.rpy:980
translate spanish d6b1_21183534:

    # Ig "Well met, [persistent.player_name]. I have something you will be interested in."
    Ig "Bien visto, [persistent.player_name]. Tengo algo que te interesará."

# game/scripts/day6.rpy:981
translate spanish d6b1_330c0287:

    # Z "Do tell. Do you want to come inside?"
    Z "Dilo. ¿Quieres entrar?"

# game/scripts/day6.rpy:984
translate spanish d6b1_c026ac54:

    # Ig "Thank you, but no. My men and women wait for me."
    Ig "Gracias, pero no. Mis hombres y mujeres me esperan."

# game/scripts/day6.rpy:985
translate spanish d6b1_f20343e1:

    # Z "Suit yourself. So... what do you have for me?"
    Z "Como quieras. Entonces... ¿qué tienes para mí?"

# game/scripts/day6.rpy:986
translate spanish d6b1_62c71426:

    # Ig "I am coming home from supply run. I travel new route, or so it seems. Dunes have shifted a lot, with wind."
    Ig "Vengo a casa de una vuelta por suministros. Viajo por una ruta nueva, o eso parece. Las dunas se han movido mucho, con el viento."

# game/scripts/day6.rpy:987
translate spanish d6b1_6a4ba624:

    # Ig "I saw dunes have revealed old scavenge outpost, and I think of my friend [persistent.player_name]."
     Ig "He visto cómo las dunas han revelado un viejo puesto de saqueo, y pienso en mi amigo [persistent.player_name]."

# game/scripts/day6.rpy:988
translate spanish d6b1_4226cb51:

    # Z "And you want me to take a look at it. But why not do it yourself?"
    Z "Y quieres que lo mire yo. Pero ¿por qué no lo haces tú mismo?"

# game/scripts/day6.rpy:991
translate spanish d6b1_90104819:

    # Ig "I saw it in distance. I carry fruit today."
    Ig "Lo vi en la distancia. Hoy traigo fruta."

# game/scripts/day6.rpy:992
translate spanish d6b1_5657dd92:

    # Ig "Not good idea to stay in sun if you want to sell it fresh."
    Ig "No es buena idea quedarse al sol si quieres venderlo fresco."

# game/scripts/day6.rpy:993
translate spanish d6b1_340df797:

    # Z "So... you want me to do the actual hard work...?"
    Z "Así que... ¿quieres que yo haga el trabajo duro de verdad...?"

# game/scripts/day6.rpy:994
translate spanish d6b1_e0c5ce13:

    # Ig "You have comfy car. You want I lend you camel, so you learn about hard work?"
    Ig "Tienes un coche cómodo. ¿Quieres que te preste un camello, para que aprendas sobre el trabajo duro?"

# game/scripts/day6.rpy:995
translate spanish d6b1_b49043a2:

    # Z "Ha, no thank you! I'll go have a look and see if there's anything valuable."
    Z "¡Ja, no, gracias! Iré a echar un vistazo para ver si hay algo valioso."

# game/scripts/day6.rpy:996
translate spanish d6b1_02e69010:

    # Ig "Good. If you find good stuff, remember that you have good friend who is merchant, yes?"
    Ig "Bien. Si encuentras cosas buenas, recuerda que tienes un buen amigo que es comerciante, ¿sí?"

# game/scripts/day6.rpy:997
translate spanish d6b1_7cf43d00:

    # Z "As always, Igor, you will get your cut for sure, in goods or coin."
    Z "Como siempre, Igor, seguro que te llevas tu parte, en bienes o en monedas."

# game/scripts/day6.rpy:998
translate spanish d6b1_a5f53951:

    # Ig "Good friend. Now I go. My camels get restless. If camels get restless, my men get restless. If my men get restless, they protest, and I don't sleep well. I get..."
    Ig "Buen amigo. Ahora me voy. Mis camellos se inquietan. Si los camellos se inquietan, mis hombres se inquietan. Si mis hombres se inquietan, protestan, y yo no duermo bien. Me pongo..."

# game/scripts/day6.rpy:1001
translate spanish d6b1_b237a031:

    # Z "Restless, I get it. Your wit is so sharp you'll cut yourself, one of these days. Go home, before your melons go to waste."
    Z "Inquieto, lo entiendo. Tu ingenio es tan agudo que te cortarás, un día de estos. Vete a casa, antes de que tus melones se echen a perder."

# game/scripts/day6.rpy:1002
translate spanish d6b1_be17d68e:

    # Ig "Always same story! Igor makes good joke, but friend [persistent.player_name] is sourpuss and does not appreciate. [persistent.player_name] will not get any of my melons."
    Ig "¡Siempre la misma historia! Igor hace un buen chiste, pero el amigo [persistent.player_name] es un amargado y no lo aprecia. [persistent.player_name] no recibirá ninguno de mis melones."

# game/scripts/day6.rpy:1003
translate spanish d6b1_5d419d8c:

    # Z "How shall I possibly survive without melons?"
    Z "¿Cómo voy a sobrevivir sin melones?"

# game/scripts/day6.rpy:1004
translate spanish d6b1_b743705e:

    # Ig "You shall survive melonless."
    Ig "Sobrevivirás sin melones."

# game/scripts/day6.rpy:1005
translate spanish d6b1_d7efeaba:

    # Z "With a heavy heart. See you soon, [Ig]."
    Z "Con el corazón encogido. Hasta pronto, [Ig]."

# game/scripts/day6.rpy:1006
translate spanish d6b1_63ee839f:

    # Ig "Until next time, [persistent.player_name]."
    Ig "Hasta la próxima vez, [persistent.player_name]."

# game/scripts/day6.rpy:1009
translate spanish d6b1_9efa7807:

    # Zt "That's not far away. About a few hours from here."
    Zt "Eso no está lejos. A unas pocas horas de aquí."

# game/scripts/day6.rpy:1010
translate spanish d6b1_4aad367a:

    # Z "Alright then."
    Z "De acuerdo entonces."

# game/scripts/day6.rpy:1014
translate spanish d6b1_b05bb276_1:

    # Z "Well..."
    Z "Bueno..."

# game/scripts/day6.rpy:1018
translate spanish d6b1_2011df74:

    # Z "...time to find out what Igor actually saw."
    Z "... hora de averiguar lo que realmente vio Igor."

# game/scripts/day6.rpy:1028
translate spanish d6b1_964ef893_1:

    # "{i}A while later..."
    "{i}Un rato después..."

# game/scripts/day6.rpy:1031
translate spanish d6b1_2e9cb945:

    # Zt "I'm going in the right direction, I know that much."
    Zt "Voy en la dirección correcta, estoy seguro de eso."

# game/scripts/day6.rpy:1032
translate spanish d6b1_99d814ad:

    # "{i}You scour the dunes, coasting alongside what used to be the expanded riverbed of the Sacred Nile, before the river dried up."
    "{i}Recorres las dunas, costeando lo que fue el cauce expandido del Nilo Sagrado, antes de que el río se secara."

# game/scripts/day6.rpy:1034
translate spanish d6b1_2e9cb945_1:

    # Zt "I'm going in the right direction, I know that much."
    Zt "Voy en la dirección correcta, estoy seguro de eso."

# game/scripts/day6.rpy:1035
translate spanish d6b1_2c18d7b2:

    # "{i}You scour the dunes, coasting alongside what used to be the expanded riverbed of the Sacred Nile, before the river dried up. Before you find the place your friend Igor has told you about, you bump into what looks like a small shack."
    "{i}Recorres las dunas, bordeando lo que solía ser el cauce expandido del Nilo Sagrado, antes de que el río se secara. Antes de encontrar el lugar del que te ha hablado tu amigo Igor, te topas con lo que parece una pequeña choza."

# game/scripts/day6.rpy:1036
translate spanish d6b1_cbade631:

    # "{i}Not many people can survive out here on their own. You decide to have a closer look."
    "{i}No hay mucha gente que pueda sobrevivir aquí sola. Decides echar un vistazo más de cerca."

# game/scripts/day6.rpy:1039
translate spanish d6b1_96d6f19a_1:

    # Zt "No activity, no sounds or signs of life..."
    Zt "Sin actividad, sin sonidos o signos de vida..."

# game/scripts/day6.rpy:1042
translate spanish d6b1_bf331151_1:

    # Zt "...but you can never be too sure."
    Zt "... pero nunca se puede estar demasiado seguro."

# game/scripts/day6.rpy:1045
translate spanish d6b1_5ab3574d_1:

    # Z "..."
    Z "..."

# game/scripts/day6.rpy:1049
translate spanish d6b1_1da472a3_1:

    # Z "Anyone home?!"
    Z "¿Hay alguien en casa?"

# game/scripts/day6.rpy:1050
translate spanish d6b1_fff1d41e_1:

    # Z "I won't ask again!"
    Z "No volveré a pedirlo."

# game/scripts/day6.rpy:1051
translate spanish d6b1_27fe6775_1:

    # C "Who is it!?"
    C "¡¿Quién es?!"

# game/scripts/day6.rpy:1052
translate spanish d6b1_90fa3dc6_1:

    # C "You knocked on the wrong door, buddy..."
    C "Has llamado a la puerta equivocada, amigo..."

# game/scripts/day6.rpy:1055
translate spanish d6b1_2811886c_1:

    # C "Let's see who wants to..."
    C "A ver quién quiere..."

# game/scripts/day6.rpy:1059
translate spanish d6b1_26a803bc_1:

    # C "..."
    C "..."

# game/scripts/day6.rpy:1060
translate spanish d6b1_cb6a38c8:

    # Z "You!"
    Z "¡Tú!"

# game/scripts/day6.rpy:1061
translate spanish d6b1_80db0624:

    # C "So we meet again..."
    C "Así que nos encontramos de nuevo..."

# game/scripts/day6.rpy:1064
translate spanish d6b1_7ae209db:

    # C "I expected many things, when I got up this morning."
    C "Esperaba muchas cosas, cuando me levanté esta mañana."

# game/scripts/day6.rpy:1065
translate spanish d6b1_14892d27:

    # C "But you were not one of them."
    C "Pero tú no eras uno de ellos."

# game/scripts/day6.rpy:1071
translate spanish d6b18_ab90d02d:

    # Z "You never told me your name."
    Z "Nunca me has dicho tu nombre."

# game/scripts/day6.rpy:1072
translate spanish d6b18_cb63dffd:

    # C "You never asked."
    C "Nunca preguntaste."

# game/scripts/day6.rpy:1073
translate spanish d6b18_9d3fea00:

    # Z "I had no reason to then, but... let's start over."
    Z "Entonces no tenía motivos para hacerlo, pero... volvamos a empezar."

# game/scripts/day6.rpy:1074
translate spanish d6b18_5262bce5:

    # Z "My name is [persistent.player_name]."
    Z "Me llamo [persistent.player_name]."

# game/scripts/day6.rpy:1075
translate spanish d6b18_31e8ada0:

    # Asa "I am Asani."
    Asa "Soy Asani."

# game/scripts/day6.rpy:1076
translate spanish d6b18_b037770f:

    # Asa "Have a seat, Stalker."
    Asa "Toma asiento, Acechador."

# game/scripts/day6.rpy:1077
translate spanish d6b18_f321bde3:

    # Asa "You remember I told you I would cut ties with the Raiders, right?"
    Asa "Recuerdas que te dije que cortaría los lazos con los Asaltantes, ¿verdad?"

# game/scripts/day6.rpy:1078
translate spanish d6b18_20707086:

    # Asa "Well, with it comes a... simpler life... but I'm doing better now."
    Asa "Bueno, con ello viene una vida... más sencilla... pero ahora me va mejor."

# game/scripts/day6.rpy:1081
translate spanish d6b18_a4f9a8a6:

    # Asa "Anyway... let's talk."
    Asa "En fin... Hablemos."

# game/scripts/day6.rpy:1082
translate spanish d6b18_5ab3574d:

    # Z "..."
    Z "..."

# game/scripts/day6.rpy:1085
translate spanish d6b18_809b1b6f:

    # Asa "Now..."
    Asa "Ahora bien..."

# game/scripts/day6.rpy:1088
translate spanish d6b18_c2465bbc:

    # Asa "To what exactly do I owe the pleasure of meeting you again, hm?"
    Asa "... ¿a qué debo exactamente el placer de volver a encontrarme contigo, hm?"

# game/scripts/day6.rpy:1089
translate spanish d6b18_df3976d9:

    # Z "Sit with me and I will tell you."
    Z "Siéntate conmigo y te lo diré."

# game/scripts/day6.rpy:1095
translate spanish d6b18_39511d96:

    # Z "I've been given a lead to some potential findings by a business associate of mine."
    Z "Un socio mío me ha dado una pista sobre algunos posibles hallazgos."

# game/scripts/day6.rpy:1096
translate spanish d6b18_a76cab0c:

    # Z "I am on my way there now, and I had no idea anyone actually could live here indefinitely."
    Z "Ya estoy de camino, y no tenía ni idea de que alguien pudiera vivir aquí indefinidamente."

# game/scripts/day6.rpy:1097
translate spanish d6b18_ba60a037:

    # Asa "Well, you're not wrong. It's not easy, but this is where I am, especially since our last encounter."
    Asa "No te equivocas. No es fácil, pero aquí es donde estoy, sobre todo desde nuestro último encuentro."

# game/scripts/day6.rpy:1100
translate spanish d6b18_0de5f0f5:

    # Asa "But don't worry, I'm not blaming you for this."
    Asa "Pero no te preocupes, no te estoy culpando por eso."

# game/scripts/day6.rpy:1103
translate spanish d6b18_fe25d773:

    # Z "You've been alone for days now."
    Z "Hace días que estás sola."

# game/scripts/day6.rpy:1104
translate spanish d6b18_6e0b8161:

    # Z "Where do you get your supplies from?"
    Z "¿De dónde sacas tus provisiones?"

# game/scripts/day6.rpy:1107
translate spanish d6b18_57b8e6c7:

    # Z "I don't know of anyone growing anything in these barren lands."
    Z "No conozco a nadie que cultive algo en estas tierras áridas."

# game/scripts/day6.rpy:1108
translate spanish d6b18_a07e52ee:

    # Asa "Oh, it has just been a couple of days."
    Asa "Oh, sólo han pasado un par de días."

# game/scripts/day6.rpy:1109
translate spanish d6b18_47db33f4:

    # Asa "Scavengers and traders occasionally pass by and trade food, you know."
    Asa "Los carroñeros y los comerciantes pasan de vez en cuando y comercian con comida, ya sabes."

# game/scripts/day6.rpy:1112
translate spanish d6b18_98c666e0:

    # Z "What are they trading it for though?"
    Z "¿Por qué la cambian?"

# game/scripts/day6.rpy:1113
translate spanish d6b18_ad4f118e:

    # Asa "Oh, you know, I didn't start out here yesterday. I have a few more valuable items hidden here and there."
    Asa "Oh, sabes, no empecé aquí ayer. Tengo algunos objetos más valiosos escondidos aquí y allá."

# game/scripts/day6.rpy:1114
translate spanish d6b18_4d84ab0b:

    # Asa "The raiders didn't seem to mind me taking my share of what they had in their base..."
    Asa "A los asaltantes no pareció importarles que tomara mi parte de lo que tenían en su base..."

# game/scripts/day6.rpy:1115
translate spanish d6b18_db1e1329:

    # Asa "Anyway, enough with the questions honey."
    Asa "De todos modos, basta de preguntas, cariño."

# game/scripts/day6.rpy:1118
translate spanish d6b18_b4fb37b5:

    # Asa "I do remember what I promised you during our first encounter..."
    Asa "Recuerdo lo que te prometí durante nuestro primer encuentro..."

# game/scripts/day6.rpy:1119
translate spanish d6b18_044d967d:

    # Zt "Merneith be blessed..."
    Zt "Merneith sea bendita..."

# game/scripts/day6.rpy:1122
translate spanish d6b18_4df22afa:

    # Asa "How about you go follow your lead and find whatever treasure you think is buried in these dunes..."
    Asa "¿Qué tal si vas a seguir tu pista y encuentras el tesoro que crees que está enterrado en estas dunas?"

# game/scripts/day6.rpy:1123
translate spanish d6b18_990b0a52:

    # Asa "And when you come back, you and I take some time for ourselves..."
    Asa "Y cuando vuelvas, tú y yo nos tomamos un tiempo para nosotros..."

# game/scripts/day6.rpy:1124
translate spanish d6b18_af96e8d1:

    # Asa "If you get it done quickly, you don't have to camp out in the desert."
    Asa "Si lo haces rápidamente, no tendrás que acampar en el desierto."

# game/scripts/day6.rpy:1127
translate spanish d6b18_31a467d5:

    # Asa "It's quite lonely out there... And it gets lonely here too..."
    Asa "Es bastante solitario ahí fuera... Y aquí también se siente la soledad..."

# game/scripts/day6.rpy:1130
translate spanish d6b18_788334d2:

    # Asa "I really am grateful for you getting me out of that crew, and I will make sure to treat you like a king once you return."
    Asa "Te agradezco mucho que me hayas sacado de esa tripulación, y me aseguraré de tratarte como a un rey cuando vuelvas."

# game/scripts/day6.rpy:1133
translate spanish d6b18_ff304532:

    # Asa "What do you say?"
    Asa "¿Qué dices?"

# game/scripts/day6.rpy:1139
translate spanish d6b18_47f0b726:

    # Z "I say we will have a lot of fun together."
    Z "Yo digo que nos divertiremos mucho juntos."

# game/scripts/day6.rpy:1142
translate spanish d6b18_7f9261e1:

    # Z "I've been looking forward to play with these tits since I got here..."
    Z "Desde que llegué aquí tengo ganas de jugar con esas tetas..."

# game/scripts/day6.rpy:1145
translate spanish d6b18_92369967:

    # Asa "And you will, I promise..."
    Asa "Y lo harás, te lo prometo..."

# game/scripts/day6.rpy:1146
translate spanish d6b18_c4493607:

    # Asa "Go on your way, Stalker, I will be waiting..."
    Asa "Sigue tu camino, Acechador, te estaré esperando..."

# game/scripts/day6.rpy:1151
translate spanish d6b18_52fa77f4:

    # Z "We will see..."
    Z "Ya veremos..."

# game/scripts/day6.rpy:1152
translate spanish d6b18_fa2c25d2:

    # Z "First I want to complete this job, find whatever is out there to find."
    Z "Primero quiero completar este trabajo, encontrar lo que haya que encontrar."

# game/scripts/day6.rpy:1155
translate spanish d6b18_7b91ff07:

    # Asa "You really like to make a woman beg, don't you?"
    Asa "Realmente te gusta hacer rogar a una mujer, ¿verdad?"

# game/scripts/day6.rpy:1156
translate spanish d6b18_c0d9e9a3:

    # Asa "See you later, Stalker."
    Asa "Hasta luego, Acechador."

# game/scripts/day6.rpy:1160
translate spanish d6b18_eb0103ea:

    # Z "I want this done quickly."
    Z "Quiero que esto se haga rápidamente."

# game/scripts/day6.rpy:1161
translate spanish d6b18_2ee807ee:

    # Z "I'm just looking to score something to loot. Finding your place was a happy accident."
    Z "Sólo estoy buscando algo para saquear. Encontrar tu casa fue un feliz accidente."

# game/scripts/day6.rpy:1162
translate spanish d6b18_c9cf0335:

    # Z "If I can make it before sundown, I won't need your hospitality."
    Z "Si consigo llegar antes del atardecer, no necesitaré tu hospitalidad."

# game/scripts/day6.rpy:1163
translate spanish d6b18_3e3ad588:

    # Z "But we will see how it goes..."
    Z "Pero ya veremos cómo va..."

# game/scripts/day6.rpy:1166
translate spanish d6b18_de375b8e:

    # Asa "Hmm.. what a shame..."
    Asa "Umm... qué pena..."

# game/scripts/day6.rpy:1169
translate spanish d6b18_a148d609:

    # Asa "You should go follow your lead then."
    Asa "Deberías ir a seguir tu pista entonces."

# game/scripts/day6.rpy:1170
translate spanish d6b18_92ef027a:

    # Z "Thank you, I will."
    Z "Gracias, lo haré."

# game/scripts/day6.rpy:1176
translate spanish d6b18_e6aa15e6:

    # "{i}You repeat Kyra's words, and her assurance that Asani should know the location of the hidden car."
    "{i}Repites las palabras de Kyra, y su seguridad de que Asani debe conocer la ubicación del coche escondido."

# game/scripts/day6.rpy:1179
translate spanish d6b18_6426cd89:

    # Asa "Well... she is not wrong."
    Asa "Bueno... no se equivoca."

# game/scripts/day6.rpy:1180
translate spanish d6b18_d28737b7:

    # Asa "I could lead you to the location."
    Asa "Podría guiarte hasta el lugar."

# game/scripts/day6.rpy:1183
translate spanish d6b18_1b114b56:

    # Z "How long have you known about this?"
    Z "¿Desde cuándo lo sabes?"

# game/scripts/day6.rpy:1184
translate spanish d6b18_4dbd3b4b:

    # Z "And tell me, why didn't you go and take it for yourself?"
    Z "Y dime, ¿por qué no fuiste y lo agarraste para ti?"

# game/scripts/day6.rpy:1187
translate spanish d6b18_e4587475:

    # Asa "I discovered it not long ago."
    Asa "Lo descubrí no hace mucho."

# game/scripts/day6.rpy:1188
translate spanish d6b18_bfa3fd05:

    # Asa "I bumped into the place about a day before Asha kinda forced me into a raiding tour that ended up crossing your path."
    Asa "Me topé con el lugar más o menos un día antes de que Asha me obligara a realizar una incursión que acabó cruzando tu camino."

# game/scripts/day6.rpy:1191
translate spanish d6b18_dbcfb2d8:

    # Asa "It's several containers and shacks, piled up in the sand, some buried, and some in the open."
    Asa "Son varios contenedores y chabolas, apilados en la arena, algunos enterrados y otros al descubierto."

# game/scripts/day6.rpy:1192
translate spanish d6b18_c30bdd4f:

    # Asa "I imagine it was a scavenger base of some sort. What happened to them, I don't know."
    Asa "Imagino que fue una base de carroñeros o algo así. Qué les pasó, no lo sé."

# game/scripts/day6.rpy:1193
translate spanish d6b18_faf52882:

    # Asa "Anyway, all I saw was a bunch of containers and half repaired vehicles..."
    Asa "En fin, todo lo que vi fueron un montón de contenedores y vehículos medio reparados..."

# game/scripts/day6.rpy:1196
translate spanish d6b18_54b233dc:

    # Z "Containers? And you didn't open them?"
    Z "¿Contenedores? ¿Y no los abriste?"

# game/scripts/day6.rpy:1199
translate spanish d6b18_ec9ee967:

    # Asa "I did open a couple... there was one that was looking promising, but it didn't start up."
    Asa "Abrí un par... había uno que parecía prometedor, pero no arrancaba."

# game/scripts/day6.rpy:1200
translate spanish d6b18_a9648404:

    # Asa "...and it was getting quite dark out there."
    Asa "...y empezaba a oscurecer bastante."

# game/scripts/day6.rpy:1203
translate spanish d6b18_d1e0e12d:

    # Asa "I don' t have to tell you that the desert can become a bad place at night..."
    Asa "No hace falta que te diga que el desierto puede volverse un mal lugar por la noche..."

# game/scripts/day6.rpy:1206
translate spanish d6b18_7fd98aaf:

    # Asa "I made the mistake of talking about it to Kyra, before leaving for the raid."
    Asa "Cometí el error de hablar de ello con Kyra, antes de partir para la incursión."

# game/scripts/day6.rpy:1207
translate spanish d6b18_79d54661:

    # Asa "Of course that meant that my chances of keeping it for myself were pretty much gone."
    Asa "Por supuesto que eso significaba que mis posibilidades de quedarme con él se habían esfumado."

# game/scripts/day6.rpy:1208
translate spanish d6b18_398413c6:

    # Asa "I'm actually surprised..."
    Asa "De hecho, estoy sorprendida..."

# game/scripts/day6.rpy:1209
translate spanish d6b18_d916161b:

    # Asa "What have you done for her, that she would give it up to you?"
    Asa "¿Qué has hecho tú por ella para que te lo entregue?"

# game/scripts/day6.rpy:1212
translate spanish d6b18_2974134e:

    # Z "Let's just say she owes me... A lot."
    Z "Digamos que ella me debe... Mucho."

# game/scripts/day6.rpy:1213
translate spanish d6b18_5ab3574d_1:

    # Z "..."
    Z "..."

# game/scripts/day6.rpy:1216
translate spanish d6b18_fe25d773_1:

    # Z "You've been alone for days now."
    Z "Hace días que estás sola."

# game/scripts/day6.rpy:1217
translate spanish d6b18_6e0b8161_1:

    # Z "Where do you get your supplies from?"
    Z "¿De dónde sacas tus provisiones?"

# game/scripts/day6.rpy:1220
translate spanish d6b18_44707e79:

    # Z "I can't remember anyone growing anything in these barren lands."
    Z "No recuerdo que nadie haya cultivado nada en estas tierras estériles."

# game/scripts/day6.rpy:1221
translate spanish d6b18_a07e52ee_1:

    # Asa "Oh, it has just been a couple of days."
    Asa "Oh, sólo han pasado un par de días."

# game/scripts/day6.rpy:1222
translate spanish d6b18_47db33f4_1:

    # Asa "Scavengers and traders occasionally pass by and trade food, you know."
    Asa "Los carroñeros y los comerciantes pasan de vez en cuando y comercian con comida, ya sabes."

# game/scripts/day6.rpy:1225
translate spanish d6b18_98c666e0_1:

    # Z "What are they trading it for though?"
    Z "¿Por qué la cambian?"

# game/scripts/day6.rpy:1226
translate spanish d6b18_ad4f118e_1:

    # Asa "Oh, you know, I didn't start out here yesterday. I have a few more valuable items hidden here and there."
    Asa "Oh, sabes, no empecé aquí ayer. Tengo algunos objetos más valiosos escondidos aquí y allá."

# game/scripts/day6.rpy:1227
translate spanish d6b18_4d84ab0b_1:

    # Asa "The raiders didn't seem to mind me taking my share of what they had in their base..."
    Asa "A los asaltantes no pareció importarles que tomara mi parte de lo que tenían en su base..."

# game/scripts/day6.rpy:1228
translate spanish d6b18_db1e1329_1:

    # Asa "Anyway, enough with the questions honey."
    Asa "De todos modos, basta de preguntas, cariño."

# game/scripts/day6.rpy:1231
translate spanish d6b18_b4fb37b5_1:

    # Asa "I do remember what I promised you during our first encounter..."
    Asa "Recuerdo lo que te prometí durante nuestro primer encuentro..."

# game/scripts/day6.rpy:1232
translate spanish d6b18_044d967d_1:

    # Zt "Merneith be blessed..."
    Zt "Merneith sea bendita..."

# game/scripts/day6.rpy:1235
translate spanish d6b18_83bb5180:

    # Asa "How about you go get your car..."
    Asa "¿Qué tal si vas a por tu coche...?"

# game/scripts/day6.rpy:1236
translate spanish d6b18_990b0a52_1:

    # Asa "And when you come back, you and I take some time for ourselves..."
    Asa "Y cuando vuelvas, tú y yo nos tomamos un tiempo para nosotros..."

# game/scripts/day6.rpy:1237
translate spanish d6b18_af96e8d1_1:

    # Asa "If you get it done quickly, you don't have to camp out in the desert."
    Asa "Si lo haces rápidamente, no tendrás que acampar en el desierto."

# game/scripts/day6.rpy:1240
translate spanish d6b18_31a467d5_1:

    # Asa "It's quite lonely out there... And it gets lonely here too..."
    Asa "Es bastante solitario ahí fuera... Y aquí también se siente la soledad..."

# game/scripts/day6.rpy:1243
translate spanish d6b18_788334d2_1:

    # Asa "I really am grateful for you getting me out of that crew, and I will make sure to treat you like a king once you return."
    Asa "Te agradezco mucho que me hayas sacado de esa tripulación, y me aseguraré de tratarte como a un rey cuando vuelvas."

# game/scripts/day6.rpy:1246
translate spanish d6b18_ff304532_1:

    # Asa "What do you say?"
    Asa "¿Qué dices?"

# game/scripts/day6.rpy:1252
translate spanish d6b18_47f0b726_1:

    # Z "I say we will have a lot of fun together."
    Z "Yo digo que nos divertiremos mucho juntos."

# game/scripts/day6.rpy:1255
translate spanish d6b18_7f9261e1_1:

    # Z "I've been looking forward to play with these tits since I got here..."
    Z "Desde que llegué aquí tengo ganas de jugar con esas tetas..."

# game/scripts/day6.rpy:1258
translate spanish d6b18_92369967_1:

    # Asa "And you will, I promise..."
    Asa "Y lo harás, te lo prometo..."

# game/scripts/day6.rpy:1259
translate spanish d6b18_c4493607_1:

    # Asa "Go on your way, Stalker, I will be waiting..."
    Asa "Sigue tu camino, Acechador, te estaré esperando..."

# game/scripts/day6.rpy:1264
translate spanish d6b18_52fa77f4_1:

    # Z "We will see..."
    Z "Ya veremos..."

# game/scripts/day6.rpy:1265
translate spanish d6b18_82693cbd:

    # Z "I will go get the car first."
    Z "Primero iré a por el coche."

# game/scripts/day6.rpy:1268
translate spanish d6b18_7b91ff07_1:

    # Asa "You really like to make a woman beg, don't you?"
    Asa "Realmente te gusta hacer rogar a una mujer, ¿verdad?"

# game/scripts/day6.rpy:1269
translate spanish d6b18_c0d9e9a3_1:

    # Asa "See you later, Stalker."
    Asa "Hasta luego, Acechador."

# game/scripts/day6.rpy:1273
