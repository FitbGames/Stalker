    Z "Podrías llamar a esta plaza el corazón de la ciudad."

# game/scripts/day6.rpy:69
translate spanish d6a5_b9ac060b:

    # Z "Go straight ahead, and you will enter the Queen's Palace."
    Z "Sigue recto y entrarás en el Palacio de la Reina."

# game/scripts/day6.rpy:70
translate spanish d6a5_014f8bdb:

    # Z "Unlike the market, not everyone is allowed to enter this plaza."
    Z "A diferencia del mercado, no todo el mundo puede entrar en esta plaza."

# game/scripts/day6.rpy:71
