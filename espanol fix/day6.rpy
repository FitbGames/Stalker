    Z "Pero dentro de estos muros, estás a salvo; este lugar está protegido."

# game/scripts/day6.rpy:87
translate spanish d6a5_4efc9560:

    # Z "You can be sure about that."
    Z "Puedes estar segura de eso."

# game/scripts/day6.rpy:88
