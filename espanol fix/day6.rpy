# game/scripts/day6.rpy:93
translate spanish re_d6a13_e4e40b9d:

    # Ka "A happy couple!"
    Ka "¡Una pareja feliz!"

# game/scripts/day6.rpy:96
translate spanish re_d6a13_8ab35088:

    # Ka "And she is pregnant..."
    Ka "Y está embarazada..."

# game/scripts/day6.rpy:99
translate spanish re_d6a13_cdd84a9d:

    # Z "She is..."
    Z "Ella es..."

# game/scripts/day6.rpy:100
translate spanish re_d6a13_52fd1813:

    # Z "But they are not a couple..."
    Z "Pero no son una pareja..."

# game/scripts/day6.rpy:103
translate spanish re_d6a13_4dc1c3ec:

    # Ci "Blessings upon you, Revered Mother..."
    Ci "Bendiciones para ti, Reverenda Madre..."

# game/scripts/day6.rpy:104
translate spanish re_d6a13_9d06d11a:

    # Ci "How long before a new Child of Zeta joins us?"
    Ci "¿Cuánto tiempo falta para que un nuevo Niño de Zeta se una a nosotros?"

# game/scripts/day6.rpy:107
translate spanish re_d6a13_1f0295c0:

    # C2 "About six weeks, I think."
    C2 "Unas seis semanas, creo."

# game/scripts/day6.rpy:110
translate spanish re_d6a13_06c79f2e:

    # Ci "Thank you for your service."
    Ci "Gracias por tu servicio."

# game/scripts/day6.rpy:113
translate spanish re_d6a13_e3e328b4:

    # Ka "I don't understand..."
    Ka "No entiendo..."

# game/scripts/day6.rpy:114
translate spanish re_d6a13_8c9deb49:

    # Z "She's a Vessel of Zeta, a Priestess of the Temple."
    Z "Es una Vasija de Zeta, una Sacerdotisa del Templo."

# game/scripts/day6.rpy:117
translate spanish re_d6a13_32093b6f:

    # Z "When a young woman joins the service of the temple, her first thirty years are dedicated to raising the Children of Zeta."
    Z "Cuando una joven se une al servicio del templo, sus primeros treinta años se dedican a criar a los Hijos de Zeta."

# game/scripts/day6.rpy:118
translate spanish re_d6a13_498b5300:

    # Z "During that time, she is known as a Vessel, because through her, the people of Zeta grow, with the blessing of the gods."
    Z "Durante ese tiempo, se la conoce como Vasija, porque a través de ella, el pueblo de Zeta crece, con la bendición de los dioses."

# game/scripts/day6.rpy:121
translate spanish re_d6a13_bd6124ec:

    # Ka "You know her?"
    Ka "¿La conoces?"

# game/scripts/day6.rpy:122
