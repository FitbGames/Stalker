    St "¿Ella va a...?"

# game/scripts/day19.rpy:3210
translate spanish d19e209_8334d4c9:

    # "The woman holds the blade against Domitius' throat for a second, steadying herself..."
    "La mujer apoya la hoja contra la garganta de Domitius por un instante, afirmándose..."

