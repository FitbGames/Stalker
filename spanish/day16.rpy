    Q "Fantástico. Entonces no perdamos el tiempo."

# game/scripts/day16.rpy:2752
translate spanish d16a128_22ecde2a:

    # Q "Guard? Lead your companion to the chambers, and have my slaves prepare her."
    Q "¿Guardia? Lleva a tu compañera a las cámaras y haz que mis esclavas la preparen."

# game/scripts/day16.rpy:2756
translate spanish d16a128_33a46fdf:

