    Q "¿O había algo más?"

# game/scripts/day16.rpy:2696
translate spanish d16a128_012eb4f5:

    # Li "I am committed to serving you, my Queen."
    Li "Estoy comprometida a servirte, mi Reina."

# game/scripts/day16.rpy:2697
translate spanish d16a128_4f644b5f:

    # Li "I accept whatever discipline or punishment you deem necessary."
    Li "Acepto cualquier disciplina o castigo que consideres necesario."

# game/scripts/day16.rpy:2700
