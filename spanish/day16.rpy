    Zt "Justo en sus ojos..."

# game/scripts/day16.rpy:266
translate spanish re_d1620_3e70ae4b:

    # Z "That looks good on you. You're almost as good a cum dumpster as you are a guard."
    Z "Te queda muy bien. Eres casi tan buen contenedor de basura como guardia."

# game/scripts/day16.rpy:267
translate spanish re_d1620_d402b4da:

    # Z "I needed that. Now lick me clean."
    Z "Lo necesitaba. Ahora lámemela bien hasta dejarme limpio."

# game/scripts/day16.rpy:270
