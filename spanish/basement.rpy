# game/scripts/basement.rpy:1315
translate spanish basement_ain_d5g29_32b2b401:

    # A "Understood, [persistent.dad]."
    A "Entendido, [persistent.dad]."

# game/scripts/basement.rpy:1317
translate spanish basement_ain_d5g29_67b65df8:

    # A "Got it. I will wait."
    A "Entendido. Esperaré."

# game/scripts/basement.rpy:1333
translate spanish basement_fairy_2_e7913b4a:

    # F "..."
    F "..."

# game/scripts/basement.rpy:1334
translate spanish basement_fairy_2_e7285fd6:

    # "She appears to be sleeping..."
    "Parece que está durmiendo..."

# game/scripts/basement.rpy:1337
translate spanish basement_fairy_2_579e8017:

    # F "Hn..."
    F "Hn..."

# game/scripts/basement.rpy:1340
translate spanish basement_fairy_2_fbefe4c1:

    # "She just woke up. She seems to have slept well, judging by how dizzy she looks."
    "Acaba de despertarse. Parece que ha dormido bien, a juzgar por lo mareada que se encuentra."

# game/scripts/basement.rpy:1341
translate spanish basement_fairy_2_8df441ae:

    # "At least she seems relaxed."
    "Al menos parece relajada."

# game/scripts/basement.rpy:1344
translate spanish basement_fairy_2_e7913b4a_1:

    # F "..."
    F "..."

# game/scripts/basement.rpy:1347
translate spanish basement_fairy_2_089fd57d:

    # F "M-Master-"
    F "A-Amo..."

# game/scripts/basement.rpy:1350
translate spanish basement_fairy_2_80f38435:

    # "She hurries over..."
    "Ella se apresura..."

# game/scripts/basement.rpy:1355
translate spanish basement_fairy_2_e7913b4a_2:

    # F "..."
    F "..."

# game/scripts/basement.rpy:1356
translate spanish basement_fairy_2_8de76b02:

    # "She seems to be sleeping..."
    "Parece que está durmiendo..."

# game/scripts/basement.rpy:1359
translate spanish basement_fairy_2_579e8017_1:

    # F "Hn..."
    F "Hn..."

# game/scripts/basement.rpy:1362
translate spanish basement_fairy_2_07958ec5:

    # "She gets up. it seems she was in a pretty deep slumber. Unusual for her..."
    "Se levanta. Parece que estaba profundamente dormida. No es habitual en ella..."

# game/scripts/basement.rpy:1365
translate spanish basement_fairy_2_e7913b4a_3:

    # F "..."
    F "..."

# game/scripts/basement.rpy:1368
translate spanish basement_fairy_2_8fe7c682:

    # F "M-Master!! Sorry!!"
    F "¡¡A-Amo!! ¡¡Lo siento!!"

# game/scripts/basement.rpy:1371
translate spanish basement_fairy_2_80f38435_1:

    # "She hurries over..."
    "Se acerca rápidamente..."

# game/scripts/basement.rpy:1377
translate spanish basement_fairy_2_e7913b4a_4:

    # F "..."
    F "..."

# game/scripts/basement.rpy:1378
translate spanish basement_fairy_2_e7285fd6_1:

    # "She appears to be sleeping..."
    "Parece que está durmiendo..."

# game/scripts/basement.rpy:1381
translate spanish basement_fairy_2_e7913b4a_5:

    # F "..."
    F "..."

# game/scripts/basement.rpy:1384
translate spanish basement_fairy_2_c78307ab:

    # "She looks at you, appearing to be waking up from a good rest..."
    "Te mira, parece despertarse de un buen descanso..."

# game/scripts/basement.rpy:1387
translate spanish basement_fairy_2_80f38435_2:

    # "She hurries over..."
    "Ella se apresura..."

# game/scripts/basement.rpy:1392
translate spanish basement_fairy_2_e7913b4a_6:

    # F "..."
    F "..."

# game/scripts/basement.rpy:1393
translate spanish basement_fairy_2_e7285fd6_2:

    # "She appears to be sleeping..."
    "Parece que está durmiendo..."

# game/scripts/basement.rpy:1396
translate spanish basement_fairy_2_e7913b4a_7:

    # F "..."
    F "..."

# game/scripts/basement.rpy:1397
translate spanish basement_fairy_2_200eccf2:

    # "Looks like she just woke up..."
    "Parece que se acaba de despertar..."

# game/scripts/basement.rpy:1400
translate spanish basement_fairy_2_dcbda278:

    # F "Master..."
    F "Amo..."

# game/scripts/basement.rpy:1401
translate spanish basement_fairy_2_80f38435_3:

    # "She hurries over..."
    "Ella se apresura..."

# game/scripts/basement.rpy:1407
translate spanish basement_fairy_2_3941b5f8:

    # "That didn't last long. She still looks happier than when you first brought her here, but she's still behaving as if pulled on a string."
    "Eso no ha durado mucho. Se la ve más contenta que cuando la trajiste, pero sigue comportándose como si fuera una marioneta."

# game/scripts/basement.rpy:1409
translate spanish basement_fairy_2_f667c560:

    # "Even though she was dizzy for a moment, she's back to her old self, if a little more domesticated than last time."
    "Aunque ha estado aturdida un momento, ha vuelto a ser la de antes, aunque un poco más domesticada."

# game/scripts/basement.rpy:1415
translate spanish basement_fairy_2_320d7c13:

    # F "Hello Master. Happy to serve!"
    F "Hola Amo. ¡Encantada de servirte!"

# game/scripts/basement.rpy:1423
translate spanish basement_fairy_2_4cd63918:

    # "She kneels down, looking straight through you."
    "Se arrodilla, mirándote con la vista fija en la nada."

# game/scripts/basement.rpy:1424
translate spanish basement_fairy_2_4776b124:

    # "Something has changed..."
    "Algo ha cambiado..."

# game/scripts/basement.rpy:1429
translate spanish basement_fairy_2_ecedf382:

    # "Master. I serve."
    "Amo. Yo te sirvo."

# game/scripts/basement.rpy:1447
translate spanish basement_fairy_2_649ea244:

    # Z "Alright... let's try this again..."
    Z "Muy bien... intentémoslo de nuevo..."

# game/scripts/basement.rpy:1450
translate spanish basement_fairy_2_00ce3ad2:

    # "You sit down..."
    "Te sientas..."

# game/scripts/basement.rpy:1453
translate spanish basement_fairy_2_5ab3574d:

    # Z "..."
    Z "..."

# game/scripts/basement.rpy:1457
translate spanish basement_fairy_2_525e51a7:

    # Z "I've tried before... to communicate with you."
    Z "Ya he intentado antes... comunicarme contigo."

# game/scripts/basement.rpy:1459
translate spanish basement_fairy_2_609ebf3b:

    # Z "I hoped that giving you a better place to sleep would help."
    Z "Esperaba que darte un lugar mejor para dormir te ayudara."

# game/scripts/basement.rpy:1460
translate spanish basement_fairy_2_8a4763d2:

    # Z "And I know very well that this basement is not a good place to forget about what you've experienced."
    Z "Y sé muy bien que este sótano no es un buen lugar para olvidar lo que has vivido."

# game/scripts/basement.rpy:1462
translate spanish basement_fairy_2_897cca7e:

    # Z "I know very well that this basement is not a good place to forget about what you've experienced."
    Z "Sé muy bien que este sótano no es un buen lugar para olvidar lo que has vivido."

# game/scripts/basement.rpy:1463
translate spanish basement_fairy_2_0b867335:

    # Z "But as I said before, I need to make sure you're not going to try to harm my girls."
    Z "Pero como ya te he dicho antes, necesito asegurarme de que no vas a intentar hacer daño a mis hijas."

# game/scripts/basement.rpy:1464
translate spanish basement_fairy_2_e0fe2d44:

    # Z "So I will try again..."
    Z "Lo intentaré de nuevo..."

# game/scripts/basement.rpy:1465
translate spanish basement_fairy_2_07ff4307:

    # Z "...Are you feeling better? Because I want to get you out of this basement."
    Z "... ¿Te sientes mejor? Porque quiero sacarte de este sótano."

# game/scripts/basement.rpy:1468
translate spanish basement_fairy_2_5db6ba2d:

    # Z "I've tried to get through to you before, you know."
    Z "He tratado de llegar a ti antes, sabes."

# game/scripts/basement.rpy:1470
translate spanish basement_fairy_2_69f9306f:

    # Z "I've given you a good bed. It's not perfect, but seeing how you acted before..."
    Z "Te he dado una buena cama. No es perfecta, pero viendo cómo actuaste antes..."

# game/scripts/basement.rpy:1471
translate spanish basement_fairy_2_ea3497b2:

    # Z "Listen... you can talk to me. You must know by now that I am not like your former Masters."
    Z "Escucha... puedes hablar conmigo. Ya debes saber que no soy como tus antiguos Amos."

# game/scripts/basement.rpy:1472
translate spanish basement_fairy_2_d570c9cb:

    # Z "If not, I can't let you out."
    Z "Si no, no puedo dejarte salir."

# game/scripts/basement.rpy:1478
translate spanish basement_fairy_2_21b1843f:

    # "Fairy seems hesitant, uncertain on how to reply in a way that might not provoke anger."
    "Fairy parece indecisa, insegura sobre cómo responder de una manera que no provoque enfado."

# game/scripts/basement.rpy:1479
translate spanish basement_fairy_2_5480dce3:

    # Z "Come now, girl. You are not in Old Cairo anymore. You can let go of the fear for your life."
    Z "Vamos, muchacha. Ya no estás en el Viejo Cairo. Puedes dejar de temer por tu vida."

# game/scripts/basement.rpy:1482
translate spanish basement_fairy_2_57743661:

    # Fw "Thank you, master. I serve."
    Fw "Gracias, amo. Yo te sirvo."

# game/scripts/basement.rpy:1485
translate spanish basement_fairy_2_ef6059a1:

    # Z "Look at me, girl!"
    Z "¡Mírame a la cara, muchacha!"

# game/scripts/basement.rpy:1488
translate spanish basement_fairy_2_e7913b4a_8:

    # F "..."
    F "..."

# game/scripts/basement.rpy:1489
translate spanish basement_fairy_2_dcd1da93:

    # Z "Look around you. This place is clean, there are no people around wanting to eat you. You are being fed and washed and left alone."
    Z "Mira a tu alrededor. Este lugar está limpio, no hay gente alrededor queriendo comerte. Te dan de comer, te lavan y te dejan en paz."

# game/scripts/basement.rpy:1490
translate spanish basement_fairy_2_90dd0a15:

    # Z "Is that not better than how you've had it in a long time?"
    Z "¿No es esto mejor que cómo lo has tenido en mucho tiempo?"

# game/scripts/basement.rpy:1493
translate spanish basement_fairy_2_0319f177:

    # Fw "Thank you master, yes. Better."
    Fw "Gracias amo, sí. Mejor."

# game/scripts/basement.rpy:1496
translate spanish basement_fairy_2_ed7f8dbf:

    # Z "Speak up, girl."
    Z "Habla más alto, muchacha."

# game/scripts/basement.rpy:1499
translate spanish basement_fairy_2_e1c4aa92:

    # F "Thank you, master! Yes, is... better."
    F "¡Gracias, amo! Sí, es... mejor."

# game/scripts/basement.rpy:1502
translate spanish basement_fairy_2_319d9ebd:

    # Z "So you do have a voice."
    Z "Así que tienes voz."

# game/scripts/basement.rpy:1505
translate spanish basement_fairy_2_cb261f3a:

    # F "...Yes, I..sorry."
    F "... Sí, yo...  lo siento."

# game/scripts/basement.rpy:1508
translate spanish basement_fairy_2_6713ce4e:

    # Z "You have been confined here for a few days now. Do you feel safer now?"
    Z "Llevas unos días encerrada aquí. ¿Te sientes más segura?"

# game/scripts/basement.rpy:1509
translate spanish basement_fairy_2_096c84b7:

    # F "Safe, yes."
    F "Segura, sí."

# game/scripts/basement.rpy:1510
translate spanish basement_fairy_2_c87e3976:

    # Z "You have met several members of the household now. What do you think of them?"
    Z "Ya has conocido a varios miembros de la casa. ¿Qué opinas de ellas?"

# game/scripts/basement.rpy:1511
translate spanish basement_fairy_2_5b78e34b:

    # F "Nice... Kind women."
    F "Agradables... Mujeres amables."

# game/scripts/basement.rpy:1512
translate spanish basement_fairy_2_68d1a2ea:

    # Z "Can I trust that you will not try to harm them?"
    Z "¿Puedo confiar en que no intentarás hacerles daño?"

# game/scripts/basement.rpy:1513
translate spanish basement_fairy_2_a512958a:

    # F "No! No harm! Never!"
    F "¡No! ¡Hacer daño no! ¡Nunca!"

# game/scripts/basement.rpy:1514
translate spanish basement_fairy_2_a7ba7e62:

    # Z "Calm down... I am not accusing you, Fairy."
    Z "Cálmate... No te estoy acusando, Fairy."

# game/scripts/basement.rpy:1515
translate spanish basement_fairy_2_5798440c:

    # F "Promise.. Never harm."
    F "Lo prometo... Nunca hacer daño."

# game/scripts/basement.rpy:1516
translate spanish basement_fairy_2_bed16d87:

    # Z "I believe you."
    Z "Te creo."

# game/scripts/basement.rpy:1519
translate spanish basement_fairy_2_412734cb:

    # Z "Do you have any questions for me?"
    Z "¿Tienes alguna pregunta para mí?"

# game/scripts/basement.rpy:1522
translate spanish basement_fairy_2_aef19f13:

    # F "Food is good... can I have... more?"
    F "La comida está buena... ¿puedo tomar... más?"

# game/scripts/basement.rpy:1525
translate spanish basement_fairy_2_125a12ee:

    # Z "Dinner will be served in a while."
    Z "La cena se servirá dentro de un rato."

# game/scripts/basement.rpy:1528
translate spanish basement_fairy_2_b05546ec:

    # F "Is not.. night?"
    F "¿No es... de noche?"

# game/scripts/basement.rpy:1531
translate spanish basement_fairy_2_c8c0acf0:

    # Z "No, Fairy. The sun is high in the sky, outside."
    Z "No, Fairy. El sol está alto en el cielo, afuera."

# game/scripts/basement.rpy:1534
translate spanish basement_fairy_2_e7913b4a_9:

    # F "..."
    F "..."

# game/scripts/basement.rpy:1536
translate spanish basement_fairy_2_4a62f714:

    # F "Can... Can I see?"
    F "Puedo... ¿Puedo verlo?"

# game/scripts/basement.rpy:1539
translate spanish basement_fairy_2_254cd99f:

    # "She looks at you with an expression which tells that she doesn't know whether to regret what she just said or not, but her curiosity takes over."
    "Te mira con una expresión que indica que no sabe si arrepentirse o no de lo que acaba de decir, pero la curiosidad se apodera de ella."

# game/scripts/basement.rpy:1540
translate spanish basement_fairy_2_2a93c42e:

    # "She awaits eagerly for your answer."
    "Ella espera ansiosa tu respuesta."

# game/scripts/basement.rpy:1543
translate spanish basement_fairy_2_ac1fff0f:

    # Z "You want to leave the basement?"
    Z "¿Quieres salir del sótano?"

# game/scripts/basement.rpy:1544
translate spanish basement_fairy_2_cc5a1d47:

    # "Fairy nods emphatically."
    "Fairy asiente con énfasis."

# game/scripts/basement.rpy:1545
translate spanish basement_fairy_2_f7c3101e:

    # Z "Do you think you are ready?"
    Z "¿Crees que estás lista?"

# game/scripts/basement.rpy:1546
translate spanish basement_fairy_2_e41197bd:

    # F "I... try?"
    F "¿Lo... lo intento?"

# game/scripts/basement.rpy:1547
translate spanish basement_fairy_2_e7913b4a_10:

    # F "..."
    F "..."

# game/scripts/basement.rpy:1548
translate spanish basement_fairy_2_54ef4eb3:

    # "You notice she doesn't seem to whisper anymore, and doesn't try to shy away from you."
    "Te das cuenta de que ya no parece susurrar y de que no intenta alejarse de ti."

# game/scripts/basement.rpy:1551
translate spanish basement_fairy_2_9f1c2a3b:

    # Z "From what I gather, you were not always a slave, a sex toy to your masters, so I would like you to speak plainly and in full sentences."
    Z "Por lo que veo, no siempre fuiste una esclava, un juguete sexual para tus amos. Así que te agradecería que hablaras claro y con frases completas."

# game/scripts/basement.rpy:1552
translate spanish basement_fairy_2_d32e1b15:

    # Z "Show me you have something of value, beyond those pretty eyes."
    Z "Muéstrame que tienes algo de valor, más allá de esos bonitos ojos."

# game/scripts/basement.rpy:1555
translate spanish basement_fairy_2_5c1c01d5:

    # F "Yes, Master... I will. I... can talk.. normally.."
    F "Sí, Amo... lo haré. Yo... ¿puedo hablar... normalmente?"

# game/scripts/basement.rpy:1558
translate spanish basement_fairy_2_78049074:

    # Z "...So you have had bad masters. You will find that I am more discerning."
    Z "... Así que has tenido malos amos. Ya verás que yo tengo un criterio muy distinto."

# game/scripts/basement.rpy:1559
translate spanish basement_fairy_2_4489f514:

    # F "Discerning?"
    F "¿Criterio?"

# game/scripts/basement.rpy:1560
translate spanish basement_fairy_2_4146c056:

    # Z "I don't give punishments unless they are deserved."
    Z "No aplico castigos a menos que sean merecidos."

# game/scripts/basement.rpy:1561
translate spanish basement_fairy_2_41af8b2d:

    # Z "Take notice: In this house, you have nothing to fear but the consequences of your own actions. This I promise."
    Z "Toma nota: En esta casa, no tienes nada que temer salvo las consecuencias de tus propios actos. Te lo prometo."

# game/scripts/basement.rpy:1562
translate spanish basement_fairy_2_413482d6:

    # Z "You are, all things considered, in a safe place, Fairy. It is time for you to heal."
    Z "En general, estás en un lugar seguro, Fairy. Es hora de que te cures."

# game/scripts/basement.rpy:1563
translate spanish basement_fairy_2_74e32ec2:

    # F "Master... good master!"
    F "Amo... ¡buen Amo!"

# game/scripts/basement.rpy:1564
translate spanish basement_fairy_2_450c0431:

    # Z "My name is [persistent.player_name]. Say it."
    Z "Mi nombre es [persistent.player_name]. Dilo."

# game/scripts/basement.rpy:1565
translate spanish basement_fairy_2_2f6a55c8:

    # Fw "Master [persistent.player_name]."
    Fw "Amo [persistent.player_name]."

# game/scripts/basement.rpy:1566
translate spanish basement_fairy_2_3605dc61:

    # F "Master [persistent.player_name]..."
    F "Amo [persistent.player_name]..."

# game/scripts/basement.rpy:1569
translate spanish basement_fairy_2_60822ee1:

    # "That is when [W] walks into the cell."
    "Es entonces cuando [W] entra en la celda."

# game/scripts/basement.rpy:1570
translate spanish basement_fairy_2_7ead62a9:

    # Z "In time, we will find out if you will be a good servant, or if you can be something more. Now let [W] get you sorted out."
    Z "Con el tiempo sabremos si vas a ser una buena sirvienta o si sirves para algo más. Ahora deja que [W] se encargue de ti."

# game/scripts/basement.rpy:1573
translate spanish basement_fairy_2_c193b668:

    # W "I'll take it from here..."
    W "Yo me encargo a partir de aquí..."

# game/scripts/basement.rpy:1576
translate spanish basement_fairy_2_442490c9:

    # Z "You know what to do with her."
    Z "Ya sabes qué hacer con ella."

# game/scripts/basement.rpy:1586
translate spanish basement_fairy_2_1f9c9dd1:

    # Z "Im glad that you are learning a bit of discipline."
    Z "Me alegro de que vayas aprendiendo algo de disciplina."

# game/scripts/basement.rpy:1588
translate spanish basement_fairy_2_3e2e174a:

    # Z "It took you long enough to find some discipline."
    Z "Te llevó bastante tiempo encontrar algo de disciplina."

# game/scripts/basement.rpy:1591
translate spanish basement_fairy_2_18a86759:

    # "The girl sits at your feet, her eyes fixed upon your face, expectantly."
    "La muchacha se sienta a tus pies, con los ojos fijos en tu rostro, expectante."

# game/scripts/basement.rpy:1592
translate spanish basement_fairy_2_f8edc8e9:

    # Z "What should I do with you..."
    Z "Qué debería hacer contigo..."

# game/scripts/basement.rpy:1595
translate spanish basement_fairy_2_b4a40f20:

    # F "No kill, please... Mercy.. No kill."
    F "No matar, por favor... Misericordia... No matar."

# game/scripts/basement.rpy:1596
translate spanish basement_fairy_2_5c7bda15:

    # F "Please... I serve. Mercy."
    F "Por favor... Yo sirvo. Piedad."

# game/scripts/basement.rpy:1599
translate spanish basement_fairy_2_0e9f27cf:

    # Z "You can put your mind at ease, Fairy. You are safe here."
    Z "Puedes estar tranquila, Fairy. Aquí estás a salvo."

# game/scripts/basement.rpy:1602
translate spanish basement_fairy_2_c3925d66:

    # F "No kill?"
    F "¿Sin matar?"

# game/scripts/basement.rpy:1605
translate spanish basement_fairy_2_12df1896:

    # Z "No kill, but no nonsense either."
    Z "No matar, pero sin tonterías tampoco."

# game/scripts/basement.rpy:1606
translate spanish basement_fairy_2_5ddc3911:

    # Z "You will earn your keep by serving in my House, and there will be some rules for you to follow."
    Z "Te ganarás el sustento sirviendo en mi Casa, y habrá algunas reglas que deberás seguir."

# game/scripts/basement.rpy:1607
translate spanish basement_fairy_2_8490c98f:

    # Z "Yes, punishments do exist, if you violate them, but I think you will find that I am a strict but fair master."
    Z "Sí, existen castigos, si los infringes, pero creo que descubrirás que soy un amo estricto pero justo."

# game/scripts/basement.rpy:1608
translate spanish basement_fairy_2_02d4ebf4:

    # Z "Do as you are told, carry yourself appropriately and do not make me regret the decision to keep you."
    Z "Haz lo que se te diga, compórtate adecuadamente y no hagas que me arrepienta de la decisión de quedarme contigo."

# game/scripts/basement.rpy:1609
translate spanish basement_fairy_2_db9ee9ec:

    # Z "Ultimately, you are bought and paid for, but I do not deal in the misery of people."
    Z "En última instancia, estás comprada y pagada, pero yo no negocio con la miseria de la gente."

# game/scripts/basement.rpy:1610
translate spanish basement_fairy_2_44e2eb1f:

    # Z "Your life will be protected, in this House."
    Z "Tu vida estará protegida, en esta Casa."

# game/scripts/basement.rpy:1611
translate spanish basement_fairy_2_7bda1fa2:

    # F "Master..?"
    F "¿Amo...?"

# game/scripts/basement.rpy:1612
translate spanish basement_fairy_2_5262bce5:

    # Z "My name is [persistent.player_name]."
    Z "Me llamo [persistent.player_name]."

# game/scripts/basement.rpy:1613
translate spanish basement_fairy_2_e134c4b6:

    # F "Master [persistent.player_name]"
    F "Amo [persistent.player_name]"

# game/scripts/basement.rpy:1616
translate spanish basement_fairy_2_c18c8251:

    # Z "Indeed, now go with my wife, and she will sort you out."
    Z "En efecto, ahora ve con mi mujer, y ella te pondrá en orden."

