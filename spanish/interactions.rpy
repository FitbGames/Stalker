    # Zt "She's meditating again?"
    Zt "¿Está meditando otra vez?"

# game/scripts/interactions.rpy:141
translate spanish vsi_2_c00933d7:

    # Z "Hey, my favourite warrior."
    Z "Hola, mi guerrera favorita."

# game/scripts/interactions.rpy:144
translate spanish vsi_2_f1bca22a:

    # S "Hmm..."
    S "Hmm..."

# game/scripts/interactions.rpy:147
translate spanish vsi_2_a360bf2c:

    # S "Oh, hey [persistent.dad]. I think I dozed off, give me a minute."
    S "¡Oh, hola, [persistent.dad]! Creo que me quedé dormida, dame un minuto."

# game/scripts/interactions.rpy:153
translate spanish vsi_3_679b1974:

    # "As you enter her room, you hear [S] whispering incorrible words, most likely meditating prayers."
    "Al entrar en su habitación, escuchas a [S] susurrando palabras ininteligibles, probablemente rezos de meditación."

# game/scripts/interactions.rpy:156
translate spanish vsi_3_43868397:

    # "Seeing how she did not respond to your footsteps, you decide to come back in a few, to not disturb her focus."
    "Al ver que no respondió a tus pasos, decides volver en unos minutos para no interrumpir su concentración."

# game/scripts/interactions.rpy:164
translate spanish vsi_4_a18b4e6f:

    # E "{i}*humming*{/i}"
    E "{i}*tarareando*{/i}"

# game/scripts/interactions.rpy:167
translate spanish vsi_4_c3531264:

    # S "Can you make sure to wipe the corners under the ceiling? I can barely reach it, thank you!"
    S "¿Puedes asegurarte de limpiar las esquinas bajo el techo? Apenas puedo alcanzarlas, ¡gracias!"

# game/scripts/interactions.rpy:170
translate spanish vsi_4_3272fef4:

    # E "But... I am not much taller than you, my lady."
    E "Pero... no soy mucho más alta que tú, mi señora."

# game/scripts/interactions.rpy:173
translate spanish vsi_4_64328860:

    # S "That's okay, just stack the chairs or something."
    S "Está bien, solo apila las sillas o algo así."

# game/scripts/interactions.rpy:181
translate spanish vsi_5_a18b4e6f:

    # E "{i}*humming*{/i}"
    E "{i}*tarareando*{/i}"

# game/scripts/interactions.rpy:184
translate spanish vsi_5_9b801cc7:

    # E "Oh...! Almost fell down..."
    E "¡Oh...! Casi me caigo..."

# game/scripts/interactions.rpy:187
translate spanish vsi_5_3a3f13fa:

    # Ew "Silly chair. I should tell lady [W] that this room is a mess...!"
    Ew "Silla estúpida. Debería decirle a la señora [W] que esta habitación es un desastre...!"

# game/scripts/interactions.rpy:198
translate spanish vzi_1_aafd4e2c:

    # Ww "Mh... Let's see how this one will fit..."
    Ww "Mh... Veamos cómo encaja esta..."

# game/scripts/interactions.rpy:201
translate spanish vzi_1_79b8d159:

    # Ww "Such a chore... it better be worth it..."
    Ww "Qué lata... más vale que merezca la pena..."

# game/scripts/interactions.rpy:204
translate spanish vzi_1_0b9b93a6:

    # W "Oh, hello, husband? Have you been spying on me?"
    W "Oh, hola, marido. ¿Me estabas espiando?"

# game/scripts/interactions.rpy:205
translate spanish vzi_1_b6c0fac3:

    # W "Tell me, what do you think of this one?"
    W "Dime, ¿qué opinas de este?"

# game/scripts/interactions.rpy:208
translate spanish vzi_1_6cff24e8:

    # Z "It's excellent. I could see you ruling the household in this one."
    Z "Es excelente. Puedo verte gobernando la casa con este."

# game/scripts/interactions.rpy:216
translate spanish vzi_2_e3ab037d:

    # Ww "Hm... I don't think I can visit the market without an escort, in this one..."
    Ww "Hm... no creo que pueda ir al mercado sin acompañante con este..."

# game/scripts/interactions.rpy:219
translate spanish vzi_2_5df0e6e0:

    # W "Hello there, my love. I was just trying this dress again."
    W "Hola, mi amor. Solo estaba probándome este vestido otra vez."

# game/scripts/interactions.rpy:220
translate spanish vzi_2_eb015267:

    # W "Let me switch back, and then I am all yours."
    W "Déjame cambiarme y luego seré toda tuya."

# game/scripts/interactions.rpy:230
translate spanish vzi_3_52db397f:

    # Z "More lingerie? I could see you wearing this in the city."
    Z "¿Más lencería? Me imagino perfectamente que lleves esto por la ciudad."

# game/scripts/interactions.rpy:233
translate spanish vzi_3_a47ef953:

    # W "Of course you can. But can you also protect me from ill-minded strangers...?"
    W "Por supuesto que sí. Pero ¿también podrías protegerme de desconocidos con malas intenciones...?"

# game/scripts/interactions.rpy:235
translate spanish vzi_3_a578c81e:

    # Z "I always can... that doesn't mean I always will."
    Z "Siempre puedo... eso no significa que siempre lo haga."

# game/scripts/interactions.rpy:237
translate spanish vzi_3_fdb03972:

    # Z "Of course. Why would I let those legs wander anywhere else?"
    Z "Por supuesto. ¿Por qué iba a dejar que esas piernas se fueran a otra parte?"

# game/scripts/interactions.rpy:245
translate spanish vzi_4_2f2f3726:

    # Ww "Mh... I wonder if he likes it..."
    Ww "Mh... me pregunto si le gustará..."

# game/scripts/interactions.rpy:249
translate spanish vzi_4_e49ce34e:

    # Z "Hello, wife."
    Z "Hola, esposa."

# game/scripts/interactions.rpy:252
translate spanish vzi_4_70276562:

    # W "Hello, husband. I was just thinking of you. Stay outside for a moment, please?"
    W "Hola, marido. Estaba pensando en ti. ¿Puedes esperar fuera un momento, por favor?"

# game/scripts/interactions.rpy:255
translate spanish vzi_4_eccb0c7f:

    # Z "As you wish."
    Z "Como desees."

