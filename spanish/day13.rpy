    # A "...!"
    A "¡...!"

# game/scripts/day13.rpy:2463
translate spanish d13f_065f24d9_1:

    # S "[A!u]!!!"
    S "¡¡¡[A!u]!!!"

# game/scripts/day13.rpy:2464
translate spanish d13f_04f86b0a:

    # "Right before [S] eyes, an arrow pierces [A]'s head..."
    "Justo ante los ojos de [S], una flecha atraviesa la cabeza de [A]..."

# game/scripts/day13.rpy:2465
translate spanish d13f_72991186_1:

    # A "Oh... [S]... I..."
    A "Oh... [S]... Yo..."

# game/scripts/day13.rpy:2466
translate spanish d13f_f27e0c45_1:

    # A "Hurts..."
    A "Duele..."

# game/scripts/day13.rpy:2468
translate spanish d13f_a0534358:

    # "[A] stumbles and falls to the ground."
    "[A] tropieza y cae al suelo."

# game/scripts/day13.rpy:2469
translate spanish d13f_845ddef2_1:

    # S "No-no no... NO!... [A]!"
    S "No, no, no... ¡NO!... ¡[A]!"

# game/scripts/day13.rpy:2470
translate spanish d13f_6e39edf1_1:

    # A "Should've... should..."
    A "Debería... debería..."

# game/scripts/day13.rpy:2471
translate spanish d13f_44020521_1:

    # A "...I don't... feel so good..."
    A "... No... me siento muy bien..."

# game/scripts/day13.rpy:2472
translate spanish d13f_d8654138:

    # A "..."
    A "..."

# game/scripts/day13.rpy:2473
translate spanish d13f_5bc09690:

    # C3 "Is she talking to someone?"
    C3 "¿Está hablando con alguien?"

# game/scripts/day13.rpy:2474
translate spanish d13f_0c655462:

    # C2 "I can't see shit from here, let's get closer."
    C2 "No puedo ver nada desde aquí, acerquémonos."

# game/scripts/day13.rpy:2477
