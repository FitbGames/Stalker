# game/scripts/day13.rpy:350
translate spanish d13a95_dc2f2800:

    # Narg "You feel just like I imagine one of those palace girls the bitch Queen keeps around would feel."
    Narg "Te sientes tal y como imagino que se sentiría una de esas chicas de palacio que la zorra de la Reina mantiene a su alrededor."

# game/scripts/day13.rpy:351
translate spanish d13a95_7b2207a4:

    # Narg "Is that who you are? The Queen's bitch?"
    Narg "¿Eres tú? ¿La zorra de la Reina?"

# game/scripts/day13.rpy:352
translate spanish d13a95_8b04aff4:

    # "His speech becomes more impatient and suggestive..."
    "Su discurso se vuelve más impaciente y sugerente..."

# game/scripts/day13.rpy:355
translate spanish d13a95_425eca63:

    # Narg "I asked you a question, girl. Did she send you after me?"
    Narg "Te he hecho una pregunta, muchacha. ¿Te envió ella a por mí?"

# game/scripts/day13.rpy:358
