    # S "Ngh..."
    S "Ngh..."

# game/scripts/day13.rpy:359
translate spanish d13a95_ce253f27:

    # "His fingers close ever tighter on [S]'s neck. His grip is strong, and breathing becomes difficult."
    "Sus dedos se cierran cada vez más sobre el cuello de [S]. Su agarre es fuerte, y la respiración se hace difícil."

# game/scripts/day13.rpy:362
translate spanish d13a95_eb7b3d98:

    # "[S] lowers her arms, trying to avoid further choking..."
    "[S] baja los brazos, intentando evitar más ahogos..."

# game/scripts/day13.rpy:363
translate spanish d13a95_3ececb35:

    # Narg "Look at you, so obedient. Maybe you really are one of her palace girls."
    Narg "Mírate, tan obediente. Quizá seas realmente una de sus chicas de palacio."

# game/scripts/day13.rpy:367
translate spanish d13a95_e6da501e:

    # "He throws his dagger aside, on the table..."
    "Arroja la daga a un lado de la mesa..."

# game/scripts/day13.rpy:368
translate spanish d13a95_c4859ac7:

    # Narg "Maybe I can have some fun before these guys are back and we decide what to do with you."
    Narg "Tal vez pueda divertirme un poco antes de que esos tipos vuelvan y decidamos qué hacer contigo."

# game/scripts/day13.rpy:371
translate spanish d13a95_40d90942:

    # "The man's free hand scours her body, touching her belt."
    "La mano libre del hombre recorre su cuerpo, tocando su cinturón."

# game/scripts/day13.rpy:377
translate spanish d13a95_15333434:

    # "He lifts her shirt, his fingers grazing on her naked skin."
    "Le levanta la camisa, sus dedos rozan su piel desnuda."

# game/scripts/day13.rpy:378
translate spanish d13a95_a07d0c99:

    # Narg "Someone as pretty as you... is rare in these places..."
    Narg "Alguien tan guapa como tú... es raro en estos lugares..."

# game/scripts/day13.rpy:381
translate spanish d13a95_971a98df_1:

    # S "..."
    S "..."

# game/scripts/day13.rpy:382
translate spanish d13a95_c46e9dfc:

    # "His hands roam lower..."
    "Sus manos bajan..."

# game/scripts/day13.rpy:383
translate spanish d13a95_f7f8563c:

    # Narg "I probably will have to pass you around, you know? I bet that would convince them to not kill you on sight."
    Narg "Probablemente tenga que compartirte, ¿sabes?. Apuesto a que eso les convencería de no matarte nada más verte."

# game/scripts/day13.rpy:386
translate spanish d13a95_c03905ea:

    # "Greedily, he slides the tip of his fingers underneath her belt."
    "Ávidamente, desliza la punta de sus dedos debajo de su cinturón."

# game/scripts/day13.rpy:387
translate spanish d13a95_01b8cffa:

    # Narg "I wonder if you're still pure down there."
    Narg "Me pregunto si seguirás siendo pura ahí abajo."

# game/scripts/day13.rpy:388
translate spanish d13a95_3d7fe2f9:

    # Narg "I could sell you off to the tribes... you'd make a fine slave."
    Narg "Podría venderte a las tribus... serías una buena esclava."

# game/scripts/day13.rpy:389
translate spanish d13a95_3fbb0e5c:

    # Narg "...Or I'll really keep you for myself, if you're obedient enough."
    Narg "... o realmente te guardaré para mí, si eres lo bastante obediente."

# game/scripts/day13.rpy:392
translate spanish d13a95_7ed9d22e:

    # Sw "There is... one..."
    Sw "Hay... un..."

# game/scripts/day13.rpy:395
translate spanish d13a95_01cfd0c7:

    # "Her words can't come out. In an attempt to lower the choke pressure, she stops trying to speak..."
    "No le salen las palabras. En un intento de reducir la presión del ahogo, deja de intentar hablar..."

# game/scripts/day13.rpy:396
translate spanish d13a95_dee2ec19:

    # Narg "What are you saying? There is one what?"
    Narg "¿Qué estás diciendo? ¿Que hay un qué?"

