translate spanish d13f_c1992dc6:

    # A "...!"
    A "¡...!"

# game/scripts/day13.rpy:2440
translate spanish d13f_065f24d9:

    # S "[A!u]!!!"
    S "¡¡¡[A!u]!!!"

# game/scripts/day13.rpy:2443
translate spanish d13f_72991186:

    # A "Oh... [S]... I..."
    A "Oh... [S]... Yo..."

# game/scripts/day13.rpy:2446
