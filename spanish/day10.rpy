    # Zi "Hey!"
    Zi "¡Eh!"

# game/scripts/day10.rpy:3346
translate spanish d10b143_33ddb07f:

    # Ca "...!"
    Ca "¡...!"

# game/scripts/day10.rpy:3347
translate spanish d10b143_a6a21be5:

    # Zi "Wake the fuck up!"
    Zi "¡Despierta, joder!"

# game/scripts/day10.rpy:3350
translate spanish d10b143_c024f919:

    # Zi "Morning, had a good sleep?!"
    Zi "Buenos días, ¿has dormido bien?"

# game/scripts/day10.rpy:3351
translate spanish d10b143_913d9fa0:

    # Ca "Wha..."
    Ca "¿Qué..."

# game/scripts/day10.rpy:3354
