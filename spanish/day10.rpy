translate spanish d10b143_c6e987a9:

    # C2 "{i}*mumbling* Asha... you... looking...?!"
    C2 "{i}*murmullos* ¡¿Asha... estás... observando...?!"

# game/scripts/day10.rpy:3275
translate spanish d10b143_5a70da15:

    # C "I count six... why do they leave it lying ther-"
    C "Cuento seis... ¿por qué los dejan tirados?"

