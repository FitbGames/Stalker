    # Ca "Good.. good sleep yes, I..."
    Ca "Bien... buen sueño sí, yo..."

# game/scripts/day10.rpy:3357
translate spanish d10b143_fd7980fa:

    # Ca "Oh! Good morning, girlfriend. How are you doing toda-"
    Ca "¡Oh! Buenos días, novia. ¿Cómo estás hoy?"

# game/scripts/day10.rpy:3360
translate spanish d10b143_29a9ea28:

    # Zi "Shut up. It's happening, so you better prepare yourself. The gate isn't going to open on its own."
    Zi "Cállate. Está ocurriendo, así que será mejor que te prepares. La puerta no se va a abrir sola."

# game/scripts/day10.rpy:3363
translate spanish d10b143_d39680cd:

    # Ca "Oh... a new raid? Sounds great, love. I look forward to it!"
    Ca "Oh... ¿una nueva incursión? Suena muy bien, amor. ¡Estoy deseando de que llegue!"

# game/scripts/day10.rpy:3364
translate spanish d10b143_7118f3ed:

    # Ca "Is it going to be like back in the day when we took a ride together? Hahaha?! Remember?!"
    Ca "¿Va a ser como en su día, cuando dimos un paseo juntos? ¡Jajajaja?! ¿Te acuerdas?"

# game/scripts/day10.rpy:3367
translate spanish d10b143_b3169ba4:

    # Ca "I'm going to enjoy this very much, yes! Yes... it will be good... very good day..."
    Ca "Voy a disfrutar mucho de esto, ¡sí! Sí... será un buen... muy buen día..."

# game/scripts/day10.rpy:3371
translate spanish raid_anim_test_40bf2769:

    # Ca "I see the place... I see the wall... wall must be broken... and broken it will be! Hahaha!"
    Ca "Veo el lugar...  Veo el muro... el muro debe romperse... ¡y se romperá! ¡Jajaja!"

# game/scripts/day10.rpy:3396
translate spanish d10b_raid_1099e818:

    # Ca "Ah... what a lovely day!!{w=3}{nw}"
    Ca "Ah... ¡qué día tan bonito! {w=3}{nw}"

# game/scripts/day10.rpy:3398
translate spanish d10b_raid_20badd32:

    # Ky "Do you always have to be on top of the car, Asha?!{w=2.5}{nw}"
    Ky "¿Siempre tienes que estar encima del coche, Asha?! {w=2.5}{nw}"

# game/scripts/day10.rpy:3403
translate spanish d10b_raid_bb297580:

    # As "I want to see where we're going, sis, that's all!"
    As "Quiero ver a dónde vamos, hermana, ¡eso es todo!"

# game/scripts/day10.rpy:3404
translate spanish d10b_raid_7fd79317:

    # As "It's not like busting through a metal gate is any safer back in there!"
    As "No es que atravesar una verja metálica sea más seguro ahí dentro."

# game/scripts/day10.rpy:3405
translate spanish d10b_raid_b120c59b:

    # Ky "Of course it fucking is! Whatever you do, don't forget to keep an eye out for that General fuck!"
    Ky "¡Por supuesto que lo es, joder! ¡Hagas lo que hagas, no te olvides de vigilar a ese puto general!"

# game/scripts/day10.rpy:3406
translate spanish d10b_raid_479b0b5a:

    # Ky "If we nail him first, the rest will fold."
    Ky "Si lo atrapamos primero, el resto se doblará."

# game/scripts/day10.rpy:3407
translate spanish d10b_raid_f4d9a90f:

    # As "Get the big guy... I got it, sis!"
    As "Coge al grandullón...  ¡Ya lo tengo, hermanita!"

