    "Subes las escaleras con la Reina cerca..."

# game/scripts/day10.rpy:1077
translate spanish d10a30_943a84b7:

    # Z "I will pass. My business is concluded. I will not take part in your ceremony."
    Z "Paso. Mis asuntos han concluido. No participaré en tu ceremonia."

