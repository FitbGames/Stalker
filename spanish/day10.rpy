    # C "Hmm.. but what's that?"
    C "Hmm... ¿pero qué es eso?"

# game/scripts/day10.rpy:3268
translate spanish d10b143_bb10e93f:

    # C2 "{i}*more mumbling*"
    C2 "{i}*más murmullos*"

# game/scripts/day10.rpy:3271
translate spanish d10b143_7c00691a:

    # C "At least they know how to spend their free time..."
    C "Al menos saben cómo pasar su tiempo libre..."

