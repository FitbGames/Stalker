# game/scripts/palace.rpy:23
translate spanish palace_throne_menu_8c11b0d1:

    # Q "So... now that we got that out of the way..."
    Q "Entonces... ahora que hemos aclarado eso..."

# game/scripts/palace.rpy:24
translate spanish palace_throne_menu_8fffe919:

    # Q "What would you like to help me with, Stalker [persistent.player_name]?"
    Q "¿En qué quieres ayudarme, Acechador [persistent.player_name]?"

# game/scripts/palace.rpy:25
translate spanish palace_throne_menu_44e92703:

    # Q "There are multiple things I could use your help with. Some involve a bit more strategy, others are more menial tasks."
    Q "Hay varias cosas en las que podría necesitar tu ayuda. Algunas implican un poco más de estrategia, otras son tareas más simples."

# game/scripts/palace.rpy:26
translate spanish palace_throne_menu_87c0f851:

    # Q "Amongst other things, I will need your presence during upcoming public hearings. A man of your experience knows wastelanders better than many of my advisors and there are a few disputes that need to be settled."
    Q "Entre otras cosas, necesitaré tu presencia durante las próximas audiencias públicas. Un hombre de tu experiencia conoce mejor a los habitantes del yermo que muchos de mis consejeros y hay algunas disputas que necesitan resolverse."

# game/scripts/palace.rpy:28
translate spanish palace_throne_menu_c227c8f4:

    # Q "Welcome back, [persistent.player_name]."
    Q "Bienvenido de nuevo, [persistent.player_name]."

# game/scripts/palace.rpy:29
translate spanish palace_throne_menu_fc4a84ec:

    # Q "How do you intend to assist me today?"
    Q "¿Cómo piensas ayudarme hoy?"

# game/scripts/palace.rpy:39
translate spanish palace_throne_menu_b8b70ce8:

    # Z "I have time for a simple job."
    Z "Tengo tiempo para un trabajo sencillo."

# game/scripts/palace.rpy:43
translate spanish palace_throne_menu_45977baf:

    # Q "Very well, head to the plaza. My guards will show you what to do."
    Q "Muy bien, dirígete a la plaza. Mis guardias te mostrarán qué hacer."

# game/scripts/palace.rpy:45
translate spanish palace_throne_menu_a6151e50:

    # Q "Very well... there are a few things for you to do."
    Q "Muy bien... hay unas cuantas cosas que puedes hacer."

# game/scripts/palace.rpy:46
translate spanish palace_throne_menu_254300f9:

    # Q "I expect you to report to me in my quarters when you're done, okay?"
    Q "Espero que me informes en mis aposentos cuando hayas terminado, ¿de acuerdo?"

# game/scripts/palace.rpy:48
translate spanish palace_throne_menu_e3f8b0fe:

    # Q "There is only a minor thing to do today, should take no longer than ten minutes."
    Q "Hoy solo hay una tarea menor, no debería llevar más de diez minutos."

# game/scripts/palace.rpy:49
translate spanish palace_throne_menu_d2fba5fc:

    # Q "Report to me in my quarters again. I need... your advice on something."
    Q "Ven a mis aposentos de nuevo. Necesito... tu consejo sobre algo."

# game/scripts/palace.rpy:62
translate spanish palace_throne_menu_b5934fe6:

    # Z "Let us return to the war room."
    Z "Volvamos a la sala de guerra."

# game/scripts/palace.rpy:65
translate spanish palace_throne_menu_b2d89539:

    # Q "Yes, there is work to be done. Go ahead; I will join you shortly."
    Q "Sí, hay trabajo que hacer. Adelante; me reuniré contigo enseguida."

# game/scripts/palace.rpy:76
translate spanish palace_throne_menu_76a6a653:

    # Z "I am here to participate in the hearings."
    Z "Estoy aquí para participar en las audiencias."

# game/scripts/palace.rpy:79
translate spanish palace_throne_menu_d8434759:

    # Q "Very good, we have one scheduled soon."
    Q "Muy bien, tenemos una programada pronto."

# game/scripts/palace.rpy:80
translate spanish palace_throne_menu_193b1f2c:

    # Q "Follow me. It is almost time."
    Q "Sígueme. Ya es casi la hora."

# game/scripts/palace.rpy:90
translate spanish palace_throne_menu_5c42468d:

    # Z "We were discussing about a certain person of interest last time."
    Z "La última vez hablamos de cierta persona de interés."

# game/scripts/palace.rpy:93
translate spanish palace_throne_menu_1c3538d2:

    # Q "Indeed, we were. I was hoping you'd ask."
    Q "Así es. Estaba esperando que lo preguntaras."

# game/scripts/palace.rpy:94
translate spanish palace_throne_menu_039b2da1:

    # Q "If you don't mind, I'll have my guards escort you to the chambers."
    Q "Si no te importa, haré que mis guardias te escolten hasta los aposentos."

# game/scripts/palace.rpy:102
translate spanish palace_throne_menu_dd8cb38f:

    # Z "I just came by to notify you that I won't be available today. I have a few other things that I need to do."
    Z "Solo vine a avisarte de que hoy no estaré disponible. Tengo otras cosas que hacer."

# game/scripts/palace.rpy:103
translate spanish palace_throne_menu_4fec0997:

    # Z "I will see you another time."
    Z "Nos veremos en otro momento."

# game/scripts/palace.rpy:106
translate spanish palace_throne_menu_b5ae0399:

    # Q "Well, that wasn't necessary. Anyways... Until next time, Stalker [persistent.player_name]."
    Q "Bueno, no hacía falta. En fin... Hasta la próxima, Acechador [persistent.player_name]."

# game/scripts/palace.rpy:117
translate spanish palace_bedroom_1_ad76a09c:

    # "After completing the required task, you move unchallenged towards the private chambers."
    "Tras completar la tarea, te diriges sin que nadie te detenga hacia los aposentos privados."

# game/scripts/palace.rpy:118
translate spanish palace_bedroom_1_a0ae3b23:

    # "You know that the point of all this ultimately isn't really the work itself..."
    "Sabes que el propósito de todo esto no es realmente el trabajo en sí..."

# game/scripts/palace.rpy:121
translate spanish palace_bedroom_1_f0e8f4ad:

    # Q "{i}*humming*{/i}"
    Q "{i}*tarareando*{/i}"

# game/scripts/palace.rpy:124
translate spanish palace_bedroom_1_bdc61a01:

    # Q "..."
    Q "..."

# game/scripts/palace.rpy:129
translate spanish palace_bedroom_1_0ee72620:

    # Q "[persistent.player_name], is that you?"
    Q "[persistent.player_name], ¿eres tú?"

# game/scripts/palace.rpy:132
translate spanish palace_bedroom_1_be3482cd:

    # "You step inside..."
    "Entras..."

# game/scripts/palace.rpy:135
translate spanish palace_bedroom_1_f56a209d:

    # Q "I hope the job wasn't too tedious."
    Q "Espero que el trabajo no haya sido demasiado tedioso."

# game/scripts/palace.rpy:138
translate spanish palace_bedroom_1_8de687f8:

    # Z "A dull excuse to be able to speak in private, but an excuse nonetheless."
    Z "Una excusa aburrida para poder hablar en privado, pero una excusa al fin y al cabo."

# game/scripts/palace.rpy:139
translate spanish palace_bedroom_1_07ac6529:

    # Z "I see you are trying out the skirt [S] was wearing."
    Z "Veo que te estás probando la falda que [S] llevaba puesta."

# game/scripts/palace.rpy:142
translate spanish palace_bedroom_1_4c576581:

    # Q "It's... um..."
    Q "Es... eh..."

# game/scripts/palace.rpy:143
translate spanish palace_bedroom_1_eb66110c:

    # Q "I've had that in my wardrobe well before she did."
    Q "Ya la tenía en mi armario mucho antes que ella."

# game/scripts/palace.rpy:146
translate spanish palace_bedroom_1_404d02aa:

    # Z "It suits you just as well as it suits her. You will turn many heads."
    Z "Te queda tan bien como a ella. Atraerás muchas miradas."

# game/scripts/palace.rpy:149
translate spanish palace_bedroom_1_bdc61a01_1:

    # Q "..."
    Q "..."

# game/scripts/palace.rpy:152
translate spanish palace_bedroom_1_f0192a96:

    # Q "I am the Queen, [persistent.player_name]... I always turn heads."
    Q "Soy la Reina, [persistent.player_name]... Siempre atraigo miradas."

# game/scripts/palace.rpy:155
translate spanish palace_bedroom_1_f4c0ca56:

    # "She is right, but you sense that your words have struck a chord..."
    "Tiene razón, pero sientes que tus palabras han tocado una fibra sensible..."

# game/scripts/palace.rpy:158
translate spanish palace_bedroom_1_4fd8118e:

    # Z "So, tell me... what's on your mind today. You wanted to speak about something."
    Z "Entonces, cuéntame... ¿En qué estás pensando hoy? Querías hablar de algo."

# game/scripts/palace.rpy:161
translate spanish palace_bedroom_1_bb6be85b:

    # Q "{i}*sigh*{/i} Not sure if I need to speak about anything, right now."
    Q "{i}*suspiro*{/i} No estoy segura de si necesito hablar de algo en este momento."

# game/scripts/palace.rpy:162
translate spanish palace_bedroom_1_1ab58abf:

    # Q "I am probably just wasting your time today."
    Q "Probablemente hoy solo te esté haciendo perder el tiempo."

# game/scripts/palace.rpy:165
translate spanish palace_bedroom_1_26125fdd:

    # Q "It's one of those days. Elders playing politics and trying to one-up each other and treating me like I'm a stupid doll."
    Q "Es uno de esos días. Los ancianos jugando a la política e intentando superarse unos a otros y tratándome como si fuera una muñeca estúpida."

# game/scripts/palace.rpy:166
translate spanish palace_bedroom_1_55f4d40c:

    # Q "...Then there's guards slacking in their duties and people coming to me for a ruling on the dumbest of things..."
    Q "... Luego están los guardias que descuidan sus deberes y la gente que acude a mí para que decida sobre las cosas más absurdas..."

# game/scripts/palace.rpy:169
translate spanish palace_bedroom_1_bc66c47a:

    # Q "On top of all that, there's nothing that spices up your day better than being almost attacked by some fanatic, mentally deranged citizens whose only point of existence is to worship their {i}dear Queen{/i}."
    Q "Y, por si fuera poco, nada anima más el día que estar a punto de ser atacada por unos fanáticos trastornados cuyo único propósito en la vida es adorar a su {i}querida Reina{/i}."

# game/scripts/palace.rpy:170
translate spanish palace_bedroom_1_1dbe03d9:

    # Q "Why do they keep letting these people close to me in the first place?! What are guards for?!"
    Q "¿Por qué siguen dejando que esta gente se acerque a mí en primer lugar? ¿Para qué sirven los guardias?"

# game/scripts/palace.rpy:173
translate spanish palace_bedroom_1_21a6cdff:

    # Q "It's idiotic. So damn frustrating!"
    Q "Es una idiotez. ¡Es jodidamente frustrante!"

# game/scripts/palace.rpy:176
translate spanish palace_bedroom_1_2f7f5e9f:

    # "She pauses..."
    "Hace una pausa..."

# game/scripts/palace.rpy:180
translate spanish palace_bedroom_1_64d3e914:

    # "...before continuing, with a voice like dripping venom..."
    "... antes de continuar con una voz cargada de veneno..."

# game/scripts/palace.rpy:183
translate spanish palace_bedroom_1_b1c3512f:

    # Q "And half the time these {i}oh so wise Elders{/i} don't even really want my input on things and don't expect me to actually take an interest. Why the hell ask me then in the first place?!!"
    Q "Y la mitad de las veces estos {i}oh tan sabios Ancianos{/i} ni siquiera quieren realmente mi opinión sobre las cosas y no esperan que me interese realmente. Entonces, ¿para qué demonios me preguntan?"

# game/scripts/palace.rpy:184
translate spanish palace_bedroom_1_0fb0b647:

    # Q "I've been raised by these fools, and now I am supposed to keep them in line?!"
    Q "Me han criado esos tontos, ¿y ahora se supone que tengo que mantenerlos a raya?"

# game/scripts/palace.rpy:187
translate spanish palace_bedroom_1_020e1aa6:

    # Q "They {i}RAISED{/i} me!! As if it was just a {i}job{/i} to take off the checklist for them, so what are they doing!?"
    Q "¡¡Me {i}CRIARON{/i}!! Como si solo fuera una {i}tarea{/i} que tachar de una lista. Entonces, ¿¡qué demonios están haciendo!?"

# game/scripts/palace.rpy:190
translate spanish palace_bedroom_1_bdc61a01_2:

    # Q "..."
    Q "..."

# game/scripts/palace.rpy:194
translate spanish palace_bedroom_1_be9d070a:

    # Q "Screw this..."
    Q "A la mierda..."

# game/scripts/palace.rpy:200
translate spanish palace_bedroom_1_bdc61a01_3:

    # Q "..."
    Q "..."

# game/scripts/palace.rpy:203
translate spanish palace_bedroom_1_dbee2d21:

    # Q "I'm sorry. I know it's hard to respond to that."
    Q "Lo siento. Sé que es difícil responder a eso."

# game/scripts/palace.rpy:206
translate spanish palace_bedroom_1_7accb78b:

    # Z "I'm listening. That's why I'm here today."
    Z "Te escucho. Por eso estoy aquí hoy."

# game/scripts/palace.rpy:209
translate spanish palace_bedroom_1_bdc61a01_4:

    # Q "..."
    Q "..."

# game/scripts/palace.rpy:213
translate spanish palace_bedroom_1_fc6958c0:

    # Q "I didn't expect... that it would feel good to let it out."
    Q "No esperaba... sentirme tan bien al desahogarme."

# game/scripts/palace.rpy:218
translate spanish palace_bedroom_1_8c8ec2b4:

    # Z "I'm glad you feel better."
    Z "Me alegra que te sientas mejor."

# game/scripts/palace.rpy:219
translate spanish palace_bedroom_1_ae66c791:

    # Z "I will be here more often from now on. You should make use of that."
    Z "Estaré aquí más a menudo a partir de ahora. Deberías aprovecharlo."

# game/scripts/palace.rpy:222
translate spanish palace_bedroom_1_cfe8bec6:

    # "There is a faint smile behind her expression..."
    "Una leve sonrisa asoma en su rostro..."

# game/scripts/palace.rpy:225
translate spanish palace_bedroom_1_6ea2d249:

    # Q "I guess..."
    Q "Supongo..."

# game/scripts/palace.rpy:228
translate spanish palace_bedroom_1_fad29142:

    # Z "It seems you needed to get this off your chest."
    Z "Parece que necesitabas quitártelo de encima."

# game/scripts/palace.rpy:229
translate spanish palace_bedroom_1_2bd5965b:

    # Z "It doesn't hurt to vent sometimes."
    Z "A veces no hace daño desahogarse."

# game/scripts/palace.rpy:232
translate spanish palace_bedroom_1_b5ee5e18:

    # Q "If only that was possible."
    Q "Si tan sólo eso fuera posible."

# game/scripts/palace.rpy:233
translate spanish palace_bedroom_1_a5de566e:

    # Q "You're the first person I could speak to openly... without worrying for my reputation..."
    Q "Eres la primera persona con la que puedo hablar abiertamente... sin preocuparme por mi reputación..."

# game/scripts/palace.rpy:237
translate spanish palace_bedroom_1_e45d10c3:

    # Q "Anyways... thank you... for listening, [persistent.player_name]."
    Q "En fin... gracias... por escucharme, [persistent.player_name]."

# game/scripts/palace.rpy:238
translate spanish palace_bedroom_1_d5ec6ea4:

    # Q "I assume your family misses you. If you don't mind, I would like to take a bath by myself, and contemplate things..."
    Q "Supongo que tu familia te echa de menos. Si no te importa, me gustaría darme un baño a solas y pensar un poco..."

# game/scripts/palace.rpy:241
translate spanish palace_bedroom_1_048a1b85:

    # Z "Yes, I will see you another time. Try to get some rest for now."
    Z "Sí, te veré en otro momento. Trata de descansar por ahora."

# game/scripts/palace.rpy:251
translate spanish palace_bedroom_2_77dd2415:

    # "After quickly completing the task, you head towards the bedroom."
    "Después de completar rápidamente la tarea, te diriges hacia el dormitorio."

# game/scripts/palace.rpy:254
translate spanish palace_bedroom_2_b1c4e41e:

    # Q "Hello, [persistent.player_name]..."
    Q "Hola, [persistent.player_name]..."

# game/scripts/palace.rpy:257
translate spanish palace_bedroom_2_85290699:

    # "She looks to one side, frustrated... or maybe, sad?"
    "Mira hacia un lado, frustrada... o quizá triste."

# game/scripts/palace.rpy:260
translate spanish palace_bedroom_2_d9286bd9:

    # Z "I know that look. What's wrong?"
    Z "Conozco esa expresión. ¿Qué pasa?"

# game/scripts/palace.rpy:264
translate spanish palace_bedroom_2_5ac7c0d1:

    # Z "What kind of greeting is that supposed to be?"
    Z "¿Qué clase de saludo es ese?"

# game/scripts/palace.rpy:265
translate spanish palace_bedroom_2_2857317e:

    # Z "I think you can do better than that."
    Z "Creo que puedes hacerlo mejor que eso."

# game/scripts/palace.rpy:268
translate spanish palace_bedroom_2_bdc61a01:

    # Q "..."
    Q "..."

# game/scripts/palace.rpy:271
translate spanish palace_bedroom_2_de157343:

    # Q "I'm sorry, it's just..."
    Q "Lo siento, es solo que..."

# game/scripts/palace.rpy:274
translate spanish palace_bedroom_2_2fdb17d6:

    # Z "Go on, tell me what's wrong. That is why you wanted me here, isn't it?"
    Z "Vamos, dime qué te pasa. Para eso querías que viniera, ¿no?"

# game/scripts/palace.rpy:278
translate spanish palace_bedroom_2_bdc61a01_1:

    # Q "..."
    Q "..."

# game/scripts/palace.rpy:279
translate spanish palace_bedroom_2_e054c8d7:

    # "You stand there for a short moment, waiting for her reply..."
    "Te quedas allí un momento, esperando su respuesta..."

# game/scripts/palace.rpy:282
translate spanish palace_bedroom_2_28b90c10:

    # Q "{i}*sigh*{/i}"
    Q "{i}*suspiro*{/i}"

# game/scripts/palace.rpy:283
translate spanish palace_bedroom_2_967a60f4:

    # Q "It's nothing, I shouldn't bother you with it. I have to deal with it and move on."
    Q "No es nada, no debería molestarte con esto. Tengo que afrontarlo y seguir adelante."

# game/scripts/palace.rpy:286
translate spanish palace_bedroom_2_5ab3574d:

    # Z "..."
    Z "..."

# game/scripts/palace.rpy:287
translate spanish palace_bedroom_2_ee087e94:

    # Z "Fine, scooch over please."
    Z "Bien, muévete, por favor."

# game/scripts/palace.rpy:290
translate spanish palace_bedroom_2_568f8868:

    # Q "What do you mean?"
    Q "¿Qué quieres decir?"

# game/scripts/palace.rpy:293
translate spanish palace_bedroom_2_9f0b3135:

    # Z "Take a few steps back, and sit your pretty booty on the chair."
    Z "Da unos pasos atrás y planta ese bonito culo en la silla."

# game/scripts/palace.rpy:296
translate spanish palace_bedroom_2_0cca8624:

    # "Moments later..."
    "Momentos más tarde..."

# game/scripts/palace.rpy:299
translate spanish palace_bedroom_2_8916358c:

    # Z "Go on, take a seat."
    Z "Vamos, siéntate."

# game/scripts/palace.rpy:300
translate spanish palace_bedroom_2_3aa81aa6:

    # Z "I will sit on the bed and we can talk a bit."
    Z "Yo me sentaré en la cama y podremos hablar un poco."

# game/scripts/palace.rpy:303
translate spanish palace_bedroom_2_bdc61a01_2:

    # Q "..."
    Q "..."

# game/scripts/palace.rpy:306
translate spanish palace_bedroom_2_5aabd8dd:

    # Z "Now, I've got all the time in the world."
    Z "Ahora, tengo todo el tiempo del mundo."

# game/scripts/palace.rpy:307
translate spanish palace_bedroom_2_b7fb8b20:

    # Z "Last time you were blowing up over...well, life."
    Z "La última vez estabas desahogándote por... bueno, la vida."

# game/scripts/palace.rpy:310
translate spanish palace_bedroom_2_22d6e7f0:

    # Z "What is it this time?"
    Z "¿Qué pasa esta vez?"

# game/scripts/palace.rpy:311
translate spanish palace_bedroom_2_af3110a5:

    # Z "What has brought your mood down today? Stress again?"
    Z "¿Qué te ha bajado el ánimo hoy? ¿Otra vez el estrés?"

# game/scripts/palace.rpy:314
translate spanish palace_bedroom_2_80072c0f:

    # Q "Eh, I have been under pressure ever since I became the heir to the previous Queen. I guess I boiled over, the last time you were here."
    Q "Eh, he estado bajo presión desde que me convertí en la heredera de la Reina anterior. Supongo que me desbordé la última vez que estuviste aquí."

# game/scripts/palace.rpy:315
translate spanish palace_bedroom_2_ae7effec:

    # Q "This time it's different."
    Q "Esta vez es diferente."

# game/scripts/palace.rpy:316
translate spanish palace_bedroom_2_2dbcc6ea:

    # Q "{i}*sigh*{/i} It's about Sharifa."
    Q "{i}*suspiro*{/i}... Se trata de Sharifa."

# game/scripts/palace.rpy:317
translate spanish palace_bedroom_2_c561e53a:

    # Z "The one you want to feed me my balls?"
    Z "¿La que quieres que me haga comerme mis propios huevos?"

# game/scripts/palace.rpy:320
translate spanish palace_bedroom_2_cdb3391c:

    # "With a wry smile, the Queen continues."
    "Con una sonrisa irónica, la Reina continúa."

# game/scripts/palace.rpy:321
translate spanish palace_bedroom_2_7ebd98b3:

    # Q "One of my closest advisors has informed me that Sharifa has done a lot of bad things to climb the ranks into her current position. Blackmail was mentioned, and worse."
    Q "Uno de mis consejeros más cercanos me informó que Sharifa ha hecho muchas cosas malas para ascender en su posición actual. Se mencionó el chantaje y cosas peores."

# game/scripts/palace.rpy:324
translate spanish palace_bedroom_2_20d7fb12:

    # Q "Do you remember that guard that I killed?"
    Q "¿Recuerdas al guardia que maté?"

# game/scripts/palace.rpy:325
translate spanish palace_bedroom_2_6c3713c9:

    # Q "He was one of my closest advisors on the field, he was on the shortlist for the position of captain of my personal guard, a position that eventually went to Sharifa."
    Q "Era uno de mis consejeros más cercanos en el campo, estaba en la lista corta para el puesto de capitán de mi guardia personal, un puesto que finalmente fue para Sharifa."

# game/scripts/palace.rpy:326
translate spanish palace_bedroom_2_62df6c42:

    # Q "After some interrogations, I found out that [Mi] never in fact preyed on the slave that accused him. He was put in a position that made it look like he did."
    Q "Después de varios interrogatorios, descubrí que [Mi] nunca abusó de la esclava que lo acusó. Lo pusieron en una situación que hacía parecer que sí."

# game/scripts/palace.rpy:329
translate spanish palace_bedroom_2_45a8deb7:

    # Q "And I executed him... for his mistake and his supposed betrayal of my trust."
    Q "Y lo ejecuté... por su error y su supuesta traición a mi confianza."

# game/scripts/palace.rpy:330
translate spanish palace_bedroom_2_41a1cf03:

    # Q "There were other rumors circulating about him, so I had to do what I had to do, I thought."
    Q "Había otros rumores circulando sobre él, así que pensé que tenía que hacer lo que tenía que hacer."

# game/scripts/palace.rpy:333
translate spanish palace_bedroom_2_74277422:

    # Q "Well, it turns out I was just playing her game all along."
    Q "Bueno, pues resulta que yo sólo estaba jugando a su juego todo el tiempo."

# game/scripts/palace.rpy:334
translate spanish palace_bedroom_2_bd927441:

    # Q "She confessed to spreading those rumors to have a better shot at becoming my personal guard herself."
    Q "Ella confesó haber difundido esos rumores para tener una mejor oportunidad de convertirse en mi guardaespaldas personal."

# game/scripts/palace.rpy:335
translate spanish palace_bedroom_2_05179602:

    # Q "She told me she wasn't responsible for the situation that forced my hand, but only for the rumors... And I don't know if I can trust her."
    Q "Me dijo que no era responsable de la situación que me obligó a actuar, sino solo de los rumores... Y no sé si puedo confiar en ella."

# game/scripts/palace.rpy:336
translate spanish palace_bedroom_2_efd33d23:

    # Q "She lied to me and maneuvered to get close to me."
    Q "Me mintió y maniobró para acercarse a mí."

# game/scripts/palace.rpy:341
translate spanish palace_bedroom_2_8a28b53f:

    # Z "I suppose it's hard to find people you can trust in your position."
    Z "Supongo que es difícil encontrar personas en las que puedas confiar en tu posición."

# game/scripts/palace.rpy:342
translate spanish palace_bedroom_2_4a4859b1:

    # Z "Everybody that interacts with you has something to gain from your favour, even if it is just your favour."
    Z "Todos los que interactúan contigo tienen algo que ganar con tu favor, incluso si es solo tu favor."

# game/scripts/palace.rpy:343
translate spanish palace_bedroom_2_145384d2:

    # Z "That alone, played in the right way, can be a mighty boon for anybody."
    Z "Eso por sí solo, bien aprovechado, puede ser una gran ventaja para cualquiera."

# game/scripts/palace.rpy:346
translate spanish palace_bedroom_2_989b261a:

    # Q "Yes, I learned that a long time ago."
    Q "Sí, aprendí eso hace mucho tiempo."

# game/scripts/palace.rpy:350
translate spanish palace_bedroom_2_a82059e2:

    # Z "Maybe her admiration for you is real, but her methods...."
    Z "Tal vez su admiración por ti sea real, pero sus métodos..."

# game/scripts/palace.rpy:351
translate spanish palace_bedroom_2_fb9d8be8:

    # Z "She strikes me as someone who cares for you. More so than just out of sense of duty or religious devotion."
    Z "Me parece que le importas. Más allá del deber o la devoción religiosa."

# game/scripts/palace.rpy:354
translate spanish palace_bedroom_2_ffc22130:

    # Q "I know..."
    Q "Lo sé..."

# game/scripts/palace.rpy:357
translate spanish palace_bedroom_2_84e2edaa:

    # Q "But I must be able to trust the person who is directly in charge of keeping me alive."
    Q "Pero debo poder confiar en la persona que se encarga directamente de mantenerme con vida."

# game/scripts/palace.rpy:361
translate spanish palace_bedroom_2_3f0020f5:

    # Z "I can't say I like the cranky bitch, but she has a solid reputation as a fighter, and her dislike of me, well.. it comes with the territory."
    Z "No puedo decir que me caiga bien esa zorra malhumorada, pero tiene una sólida reputación como luchadora, y su aversión hacia mí, bueno... viene con el territorio."

# game/scripts/palace.rpy:364
translate spanish palace_bedroom_2_136803c9:

    # Q "I understand that, but she can be overprotective to the point of forgetting her place."
    Q "Lo entiendo, pero puede llegar a ser tan sobreprotectora que olvida cuál es su lugar."

# game/scripts/palace.rpy:365
translate spanish palace_bedroom_2_a826caf0:

    # Q "I am not supposed to tolerate that sort of things."
    Q "No se supone que deba tolerar ese tipo de cosas."

# game/scripts/palace.rpy:369
translate spanish palace_bedroom_2_43fc5446:

    # Z "Even so, he didn't deserve to die."
    Z "Aun así, él no merecía morir."

# game/scripts/palace.rpy:372
translate spanish palace_bedroom_2_800c0243:

    # Q "He did not. But the way things went, do you think I could have handled it differently?"
    Q "No, no merecía morir. Pero, tal como ocurrieron las cosas, ¿crees que podría haber actuado de otra manera?"

# game/scripts/palace.rpy:373
translate spanish palace_bedroom_2_5d1d504a:

    # Q "The Elders raised me to be ruthless when needed! It is what am I supposed to do."
    Q "Los Ancianos me criaron para ser implacable cuando fuera necesario. Es lo que se supone que debo hacer."

# game/scripts/palace.rpy:376
translate spanish palace_bedroom_2_3337ab92:

    # Q "I can show no doubt, or fear. Never."
    Q "No puedo mostrar dudas ni miedo. Nunca."

# game/scripts/palace.rpy:379
translate spanish palace_bedroom_2_15b41086:

    # "You are reminded of the description [S] gave you of how the young Queen executed a prisoner in front of her."
    "Te acuerdas de la descripción que [S] te dio de cómo la joven Reina ejecutó a un prisionero frente a ella."

# game/scripts/palace.rpy:380
translate spanish palace_bedroom_2_7ad49782:

    # "The glee and sadism she showed make you wonder if she's being honest with herself, today."
    "El regocijo y el sadismo que mostró hacen que te preguntes si hoy es sincera consigo misma."

# game/scripts/palace.rpy:386
translate spanish pb28x4_687818b8:

    # Q "It doesn't matter anyway. I've been expected to lead my whole life."
    Q "De todos modos, no importa. Toda mi vida se ha esperado de mí que lidere."

# game/scripts/palace.rpy:387
translate spanish pb28x4_c67dd76f:

    # Q "I have known Sharifa for a long time, and yet I couldn't tell she was deceiving me."
    Q "Conozco a Sharifa desde hace mucho tiempo, y aún así no pude darme cuenta de que me estaba engañando."

# game/scripts/palace.rpy:390
translate spanish pb28x4_05248ce2:

    # Q "What does that say about me? Is it even my position at this point? Or am I just too weak?"
    Q "¿Qué dice eso de mí? ¿De verdad merezco estar en este puesto? ¿O simplemente soy demasiado débil?"

# game/scripts/palace.rpy:391
translate spanish pb28x4_ef6c80b8:

    # Q "Is there anybody who doesn't want something from me?"
    Q "¿Hay alguien que no quiera algo de mí?"

# game/scripts/palace.rpy:394
translate spanish pb28x4_bdc61a01:

    # Q "..."
    Q "..."

# game/scripts/palace.rpy:395
translate spanish pb28x4_a1dbed2e:

    # "She stares into the void for a few seconds, before gathering herself..."
    "Mira al vacío durante unos segundos antes de recomponerse..."

# game/scripts/palace.rpy:398
translate spanish pb28x4_76360a30:

    # "She gets up..."
    "Se levanta..."

# game/scripts/palace.rpy:401
translate spanish pb28x4_4f3668ed:

    # Q "I need a moment."
    Q "Necesito un momento."

# game/scripts/palace.rpy:402
translate spanish pb28x4_40971e19:

    # "She turns away from you. You stare at her back. As her shoulders go up and down, she tries to hide her quiet sobs."
    "Se da la vuelta. La miras de espaldas. Mientras sus hombros suben y bajan, ella intenta ocultar sus sollozos silenciosos."

# game/scripts/palace.rpy:403
translate spanish pb28x4_72c72d01:

    # Q "You should..."
    Q "Deberías..."

# game/scripts/palace.rpy:404
translate spanish pb28x4_90c3081a:

    # Q "...you should leave. I don't know what is... what is going on."
    Q "... deberías irte. No sé qué está... qué está pasando."

# game/scripts/palace.rpy:407
translate spanish pb28x4_86442bfe:

    # Q "Mh... {i}*whimpering*{/i}"
    Q "Mh... {i}*gimoteando*{/i}"

# game/scripts/palace.rpy:410
translate spanish pb28x4_784e7389:

    # "You get up..."
    "Te levantas..."

# game/scripts/palace.rpy:413
translate spanish pb28x4_e752e27d:

    # Q "This is pathetic. I'm..."
    Q "Esto es patético. Yo..."

# game/scripts/palace.rpy:414
translate spanish pb28x4_b6b5dfd3:

    # Q "...I'm not acting like myself."
    Q "... no estoy actuando como yo misma."

# game/scripts/palace.rpy:417
translate spanish pb28x4_17d0ddbd:

    # Q "Just... please keep it to yourself, okay?"
    Q "Sólo... por favor, guárdatelo para ti, ¿vale?"

# game/scripts/palace.rpy:418
translate spanish pb28x4_c6c9cbc1:

    # Q "I don't want... people cannot be talking about this."
    Q "No quiero... que la gente hable de esto."

# game/scripts/palace.rpy:419
translate spanish pb28x4_265d386a:

    # Q "The Elders mustn't learn about this weakness..."
    Q "Los Ancianos no deben enterarse de esta debilidad..."

# game/scripts/palace.rpy:422
translate spanish pb28x4_f185a736:

    # Z "I won't tell anyone."
    Z "No se lo diré a nadie."

# game/scripts/palace.rpy:425
translate spanish pb28x4_b250b48b:

    # Q "You should... come back another time."
    Q "Deberías... volver en otro momento."

# game/scripts/palace.rpy:426
translate spanish pb28x4_e524d2cb:

    # Q "I will sort this out...-"
    Q "Voy a solucionar esto..."

# game/scripts/palace.rpy:432
translate spanish pb28x4_7b6077fd:

    # Q "...?!"
    Q "¡¿...?!"

# game/scripts/palace.rpy:435
translate spanish pb28x4_6534a13e:

    # Q "[persistent.player_name]?!"
    Q "¡¿[persistent.player_name]?!"

# game/scripts/palace.rpy:438
translate spanish pb28x4_8b337485:

    # "She looks at you with tears in her eyes. Her expression sad and exhausted."
    "Te mira con lágrimas en los ojos. Su expresión es triste y agotada."

# game/scripts/palace.rpy:439
translate spanish pb28x4_1fd4a4c3:

    # Z "Nobody can act strong forever. Sooner or later, we all need someone to pick us up."
    Z "Nadie puede hacerse el fuerte eternamente. Tarde o temprano, todos necesitamos que alguien nos levante."

# game/scripts/palace.rpy:442
translate spanish pb28x4_19beba94:

    # Q "Not me. I'm not supposed to have anyone. I never had a father, or mother."
    Q "Yo no. Se supone que no tengo a nadie. Nunca tuve un padre, ni una madre."

# game/scripts/palace.rpy:443
translate spanish pb28x4_693e95d8:

    # Q "I'm Queen. There is nothing else for me."
    Q "Soy Reina. No hay nada más para mí."

# game/scripts/palace.rpy:446
translate spanish pb28x4_3dc0b2d5:

    # "Her words get stuck in her throat, and she tries to calm herself..."
    "Sus palabras se atascan en la garganta, e intenta calmarse..."

# game/scripts/palace.rpy:447
translate spanish pb28x4_3ce6314e:

    # Z "Do you truly think that the Queens before you didn't have friends, relationships, a shoulder to lean on?"
    Z "¿De verdad crees que las Reinas anteriores no tenían amigos, relaciones, un hombro en el que apoyarse?"

# game/scripts/palace.rpy:448
translate spanish pb28x4_d05e90f2:

    # Z "I know what I can do."
    Z "Sé lo que puedo hacer."

# game/scripts/palace.rpy:454
translate spanish pb28x4_0f1944c8:

    # Q "...!"
    Q "¡...!"

# game/scripts/palace.rpy:455
translate spanish pb28x4_27e8f7c5:

    # "You grab her and pull her in, wrapping your arms around her in a strong hug."
    "La agarras y tiras de ella, rodeándola con tus brazos en un fuerte abrazo."

# game/scripts/palace.rpy:458
translate spanish pb28x4_bdc61a01_1:

    # Q "..."
    Q "..."

# game/scripts/palace.rpy:462
translate spanish pb28x4_a0f7a548:

    # "Moments of stunned silence pass, ticking by slowly. Wide-eyed, the Queen forgets the rules for a second, standing frozen."
    "Pasan unos instantes de silencio atónito, que transcurren lentamente. Con los ojos muy abiertos, la Reina olvida las reglas por un segundo, quedándose congelada."

# game/scripts/palace.rpy:471
translate spanish pb28x4_bdc61a01_2:

    # Q "..."
    Q "..."

# game/scripts/palace.rpy:477
translate spanish pb28x4_02547240:

    # Q "{i}*sobbing*"
    Q "{i}*sollozando*"

# game/scripts/palace.rpy:480
translate spanish pb28x4_67bdd959:

    # "You hold her in a comforting embrace, as she vents her frustration."
    "La sostienes en un abrazo reconfortante, mientras ella descarga su frustración."

# game/scripts/palace.rpy:481
translate spanish pb28x4_513b9aca:

    # Q "I'm..."
    Q "Lo..."

# game/scripts/palace.rpy:482
translate spanish pb28x4_d05d315c:

    # Q "...I'm sorry."
    Q "... lo siento."

# game/scripts/palace.rpy:483
translate spanish pb28x4_fc8807a9:

    # Q "I am so tired, [persistent.player_name]..."
    Q "Estoy tan cansada,  [persistent.player_name]..."

# game/scripts/palace.rpy:485
translate spanish pb28x4_c1480bf1:

    # "Her words come out haltingly, half sobbing. Now that the barriers are down, you get a rare glimpse at the young woman behind the facade."
    "Sus palabras salen entrecortadas, medio sollozando. Ahora que han caído las barreras, puedes echar un vistazo a la joven que se esconde tras la fachada."

# game/scripts/palace.rpy:486
translate spanish pb28x4_5ae11be2:

    # "There is no authority or poise in her voice now, no commanding demands. Just a young woman in need for someone to hold her and show her with action that they are there for her."
    "Ahora no hay autoridad ni aplomo en su voz, ni exigencias dominantes. Sólo es una joven que necesita que alguien la abrace y le demuestre con hechos que está a su lado."

# game/scripts/palace.rpy:487
translate spanish pb28x4_44324285:

    # "Seconds pass, as you stand there, together, an aging veteran and a young woman in need of a genuine human connection."
    "Pasan los segundos mientras permanecéis juntos, un veterano y una joven que necesita una auténtica conexión humana."

# game/scripts/palace.rpy:490
translate spanish pb28x4_bdc61a01_3:

    # Q "..."
    Q "..."

# game/scripts/palace.rpy:491
translate spanish pb28x4_f819f92b:

    # "She hugs you tighter..."
    "Ella te abraza más fuerte..."

# game/scripts/palace.rpy:492
translate spanish pb28x4_10aa0d15:

    # "You have known the Queen since she ascended to the throne, a few years back, and you have never really felt sympathy for her like you are doing now."
    "Conoces a la Reina desde que ascendió al trono, hace unos años, y nunca habías sentido simpatía por ella como ahora."

# game/scripts/palace.rpy:493
translate spanish pb28x4_bda7b8e1:

    # "Right now, you are putting yourself in her situation, one of solitude, constant training in preparation for an impossible role, hounded into it by the Elders and the Temple."
    "Ahora mismo, te estás poniendo en su situación, de soledad, de entrenamiento constante en preparación para un papel imposible, acosada por los Ancianos y el Templo."

# game/scripts/palace.rpy:494
translate spanish pb28x4_945bcfa2:

    # "As you consider her position, you realise that you would not want such a fate bestowed upon one of your [persistent.da]s."
    "Al considerar su posición, te das cuenta de que no querrías que una de tus [persistent.da]s corriera semejante suerte."

# game/scripts/palace.rpy:495
translate spanish pb28x4_0836ed27:

    # "Then you think about [S] and about how similar your treatment of her in the past years has been, and you are taken by a different flavour of sadness."
    "Entonces piensas en [S] y en lo similar que ha sido el trato que le has dado en los últimos años, y te invade un sabor diferente de tristeza."

# game/scripts/palace.rpy:496
translate spanish pb28x4_5fb794f1:

    # Z "Don't be sorry. I am here for you. As for the Queen of Zeta, there's very little that I need from her."
    Z "No lo lamentes. Estoy aquí para ti. En cuanto a la Reina de Zeta, es muy poco lo que necesito de ella."

# game/scripts/palace.rpy:497
translate spanish pb28x4_5feb7ae4:

    # Q "{i}*muffled*{/i} Okay..."
    Q "{i}*amortiguado*{/i} Vale..."

# game/scripts/palace.rpy:500
translate spanish pb28x4_a3e65c44:

    # Q "I... I think this is enough."
    Q "Yo... Yo creo que ya es suficiente."

# game/scripts/palace.rpy:503
translate spanish pb28x4_96d82d45:

    # Z "Are you feeling better?"
    Z "¿Te encuentras mejor?"

# game/scripts/palace.rpy:506
translate spanish pb28x4_994b8fd2:

    # Q "I am..."
    Q "Lo estoy..."

# game/scripts/palace.rpy:507
translate spanish pb28x4_968a4d75:

    # Q "But..."
    Q "Pero..."

# game/scripts/palace.rpy:510
translate spanish pb28x4_fb0875c3:

    # Z "...but nobody must see us here like this, right?"
    Z "... pero nadie debe vernos aquí de esta manera, ¿verdad?"

# game/scripts/palace.rpy:511
translate spanish pb28x4_bdc61a01_4:

    # Q "..."
    Q "..."

# game/scripts/palace.rpy:512
translate spanish pb28x4_4e8dd740:

    # "Even in her private chambers, she must worry about appearing frail and clueless, should a random guard or servant enter the room."
    "Incluso en sus aposentos privados, debe preocuparse por parecer vulnerable e inexperta, en caso de que entre un guardia o sirviente al azar."

# game/scripts/palace.rpy:513
translate spanish pb28x4_5278f881:

    # "You understand it, and don't take it personally."
    "Lo entiendes y no lo tomas como algo personal."

# game/scripts/palace.rpy:514
translate spanish pb28x4_6f842496:

    # "You also understand that the liberties you took towards her are potentially a death sentence, should they be witnessed."
    "También comprendes que las libertades que tomaste hacia ella podrían ser potencialmente una sentencia de muerte si alguien las presenciara."

# game/scripts/palace.rpy:515
translate spanish pb28x4_81b1905f:

    # "Something, you sense, has changed today, in your relationship with the Queen."
    "Sientes que algo ha cambiado hoy en tu relación con la Reina."

# game/scripts/palace.rpy:516
translate spanish pb28x4_c789df22:

    # Z "I understand. Take some rest, young Queen. I will see you another time."
    Z "Lo entiendo. Descansa, joven Reina. Te visitaré de nuevo en otro momento."

# game/scripts/palace.rpy:517
translate spanish pb28x4_0632bed7:

    # Z "I will visit again soon."
    Z "Volveré a visitarte pronto."

# game/scripts/palace.rpy:520
translate spanish pb28x4_3b078dbf:

    # Q "But... [persistent.player_name]..."
    Q "Pero... [persistent.player_name]..."

# game/scripts/palace.rpy:521
translate spanish pb28x4_1fa6827d:

    # Q "Thank you for... this."
    Q "Gracias por... esto."

# game/scripts/palace.rpy:530
translate spanish pb28x4_8f5e7d79:

    # Z "It's alright, don't worry."
    Z "No pasa nada, no te preocupes."

# game/scripts/palace.rpy:532
translate spanish pb28x4_1e573402:

    # Q "I..."
    Q "Yo..."

# game/scripts/palace.rpy:533
translate spanish pb28x4_b97ab2e5:

    # Q "...I'm sorry. I'm tired lately."
    Q "... lo siento. Últimamente estoy cansada."

# game/scripts/palace.rpy:536
translate spanish pb28x4_3ed22b1e:

    # Z "Don't apologize, there's a lot of pressure on you. It's best I indeed leave for today."
    Z "No te disculpes, hay mucha presión sobre ti. De hecho, es mejor que me vaya por hoy."

# game/scripts/palace.rpy:539
translate spanish pb28x4_5feb7ae4_1:

    # Q "{i}*muffled*{/i} Okay..."
    Q "{i}*amortiguado*{/i} Vale..."

# game/scripts/palace.rpy:542
translate spanish pb28x4_de8f2c02:

    # Z "And, hey..."
    Z "Y, ey..."

# game/scripts/palace.rpy:545
translate spanish pb28x4_d65846b4:

    # Z "Didn't think you even had this side of you, miss stern-faced Queen."
    Z "No creía que tuvieras este lado tuyo, señorita Reina de rostro severo."

# game/scripts/palace.rpy:546
translate spanish pb28x4_c1a4bc51:

    # "You give her a slight smile..."
    "Le dedicas una leve sonrisa..."

# game/scripts/palace.rpy:549
translate spanish pb28x4_ed3d01a8:

    # Q "Heh, I guess..."
    Q "Je, supongo..."

# game/scripts/palace.rpy:550
translate spanish pb28x4_5451716e:

    # Q "It does feel better."
    Q "Me siento mejor."

# game/scripts/palace.rpy:553
translate spanish pb28x4_b43b2a3e:

    # Z "I will visit you again soon. In the meantime, you should get some rest."
    Z "Volveré a visitarte pronto. Mientras tanto, deberías descansar un poco."

# game/scripts/palace.rpy:564
translate spanish palace_bedroom_3_bdc61a01:

    # Q "..."
    Q "..."

# game/scripts/palace.rpy:567
translate spanish palace_bedroom_3_b0b3d1f7:

    # Q "Hm..."
    Q "Hm..."

# game/scripts/palace.rpy:570
translate spanish palace_bedroom_3_50b85eee:

    # Qw "Is this too much...?"
    Qw "¿Es esto demasiado...?"

# game/scripts/palace.rpy:577
translate spanish palace_bedroom_3_bdc61a01_1:

    # Q "..."
    Q "..."

# game/scripts/palace.rpy:580
translate spanish palace_bedroom_3_be3482cd:

    # "You step inside..."
    "Entras..."

# game/scripts/palace.rpy:583
translate spanish palace_bedroom_3_da68150b:

    # Q "Hello, [persistent.player_name]."
    Q "Hola, [persistent.player_name]."

# game/scripts/palace.rpy:584
translate spanish palace_bedroom_3_70001ff4:

    # Q "While we talk, I am figuring out a dress for an upcoming event, if you don't mind."
    Q "Mientras hablamos, estoy pensando en un vestido para un próximo evento, si no te importa."

# game/scripts/palace.rpy:587
translate spanish palace_bedroom_3_aa7e9e96:

    # Z "Sure... what event are we talking about?"
    Z "Claro... ¿De qué evento estamos hablando?"

# game/scripts/palace.rpy:590
translate spanish palace_bedroom_3_3c8092c8:

    # Q "The temple is holding an annual celebration of its highest ranking priestesses."
    Q "El templo está celebrando una fiesta anual de sus sacerdotisas de mayor rango."

# game/scripts/palace.rpy:591
translate spanish palace_bedroom_3_cffeb088:

    # Q "Those who have served the most children to the city will get acclaimed by me, the Queen."
    Q "Aquellas que han servido a más niños de la ciudad serán aclamadas por mí, la Reina."

# game/scripts/palace.rpy:594
translate spanish palace_bedroom_3_4d568605:

    # Q "Anyways, I have thought of what to do with [Sh]."
    Q "De todos modos, he pensado en qué hacer con [Sh]."

# game/scripts/palace.rpy:595
translate spanish palace_bedroom_3_59b9a790:

    # Q "Interested in hearing it?"
    Q "¿Te interesa oírlo?"

# game/scripts/palace.rpy:598
translate spanish palace_bedroom_3_61a4580f:

    # Z "I'm all ears."
    Z "Soy todo oídos."

# game/scripts/palace.rpy:601
translate spanish palace_bedroom_3_f348453f:

    # "She turns around..."
    "Ella se da vuelta..."

# game/scripts/palace.rpy:604
translate spanish palace_bedroom_3_d9fa95bf:

    # Q "The last time we talked about her, I..."
    Q "La última vez que hablamos de ella, yo..."

# game/scripts/palace.rpy:605
translate spanish palace_bedroom_3_1d03efce:

    # Q "...was in too much of a bad space to see things more clearly."
    Q "... estaba en un estado demasiado malo para ver las cosas más claramente."

# game/scripts/palace.rpy:606
