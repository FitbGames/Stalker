# game/scripts/raiders.rpy:955
translate spanish rt33_86a1bbc2:

    # Z "[As], get up, make some room for [Kit]."
    Z "[As], levántate, haz sitio a [Kit]."

# game/scripts/raiders.rpy:956
translate spanish rt33_72f1e222:

    # Z "I need to speak to her for a minute."
    Z "Necesito hablar con ella un minuto."

# game/scripts/raiders.rpy:959
translate spanish rt33_2d2fd980:

    # "The girls follow your directions..."
    "Las chicas siguen tus indicaciones..."

# game/scripts/raiders.rpy:963
translate spanish rt33_ab0434f3:

    # "She does as you say..."
    "Hace lo que le dices..."

# game/scripts/raiders.rpy:966
translate spanish rt33_9917dfc7:

    # "She sits before you, looking at you without any clear expression..."
    "Se sienta ante ti, mirándote sin ninguna expresión clara..."

# game/scripts/raiders.rpy:974
translate spanish kitty_menu_1a65d211:

    # Z "How are you feeling?"
    Z "¿Cómo te encuentras?"

# game/scripts/raiders.rpy:978
translate spanish kitty_menu_5e990086:

    # Kit "..."
    Kit "..."

# game/scripts/raiders.rpy:980
translate spanish kitty_menu_5ab3574d:

    # Z "..."
    Z "..."

# game/scripts/raiders.rpy:985
translate spanish kitty_menu_e87a1f11:

    # Z "Tell me, what is your real name?"
    Z "Dime, ¿cuál es tu verdadero nombre?"

# game/scripts/raiders.rpy:986
translate spanish kitty_menu_5a129d15:

    # Z "Were you called [Kit] your whole life, or did the General give you this petname?"
    Z "¿Te has llamado [Kit] toda la vida o fue el General quien te puso ese apodo?"

# game/scripts/raiders.rpy:987
translate spanish kitty_menu_dc83d91c:

    # Z "Did your fans call you that?"
    Z "¿Tus fans te llamaban así?"

# game/scripts/raiders.rpy:990
translate spanish kitty_menu_c9af1fd5:

    # "As expected, she does not give you an answer to your question..."
    "Como era de esperar, no te da una respuesta a tu pregunta..."

# game/scripts/raiders.rpy:996
translate spanish kitty_menu_bc6aa1cf:

    # Z "This is a chance to restart. Your brother has no influence on you anymore."
    Z "Esta es una oportunidad para volver a empezar. Tu hermano ya no tiene influencia sobre ti."

# game/scripts/raiders.rpy:1003
translate spanish kitty_not_renamed_846421ff:

    # Z "Whatever it may be. You will keep your name."
    Z "Sea lo que sea. Conservarás tu nombre."

# game/scripts/raiders.rpy:1010
translate spanish kitty_not_renamed_72e6e947:

    # Z "Your hair and eyes... are they naturally pink?"
    Z "Tu pelo y tus ojos... ¿son rosa por naturaleza?"

# game/scripts/raiders.rpy:1014
translate spanish kitty_not_renamed_347197f3:

    # Zt "I have seen similar mutations in people over the years. But her hair color... it reminds me of those ancient pop culture books I have come across."
    Zt "He visto mutaciones similares en personas a lo largo de los años. Pero el color de su cabello... me recuerda a esos antiguos libros de cultura pop con los que me he topado."

# game/scripts/raiders.rpy:1015
translate spanish kitty_not_renamed_0111e324:

    # Zt "Is it really a mutation, or did the General possess something to dye her hair?"
    Zt "¿De verdad es una mutación o el General tenía algo para teñirle el pelo?"

# game/scripts/raiders.rpy:1020
translate spanish kitty_not_renamed_ffc250d9:

    # Z "Do you miss your brother?"
    Z "¿Echas de menos a tu hermano?"

# game/scripts/raiders.rpy:1024
translate spanish kitty_not_renamed_5e990086:

    # Kit "..."
    Kit "..."

# game/scripts/raiders.rpy:1025
translate spanish kitty_not_renamed_f0f09daf:

    # "Her wide eyes continue to stare at you..."
    "Sus grandes ojos siguen mirándote..."

# game/scripts/raiders.rpy:1030
translate spanish kitty_not_renamed_71369af2:

    # Z "Do you want to leave this settlement?"
    Z "¿Quieres dejar este asentamiento?"

# game/scripts/raiders.rpy:1034
translate spanish kitty_not_renamed_5e990086_1:

    # Kit "..."
    Kit "..."

# game/scripts/raiders.rpy:1036
translate spanish kitty_not_renamed_84c1f257:

    # "Her facial expression changes minimally. You wonder if it has any meaning..."
    "Su expresión apenas cambia. Te preguntas si significará algo..."

# game/scripts/raiders.rpy:1037
translate spanish kitty_not_renamed_314dd3d8:

    # Zt "I don't know how to interpret this, or if I should."
    Zt "No sé cómo interpretar esto ni si debería intentarlo."

# game/scripts/raiders.rpy:1038
translate spanish kitty_not_renamed_173cfc9a:

    # Z "I will ask again. Do you want to be free?"
    Z "Volveré a preguntar. ¿Quieres ser libre?"

# game/scripts/raiders.rpy:1042
translate spanish kitty_not_renamed_5e990086_2:

    # Kit "..."
    Kit "..."

# game/scripts/raiders.rpy:1043
translate spanish kitty_not_renamed_5ab3574d:

    # Z "..."
    Z "..."

# game/scripts/raiders.rpy:1044
translate spanish kitty_not_renamed_efa2fecb:

    # Z "{i}*sigh*{/i}"
    Z "{i}*suspiro*{/i}"

# game/scripts/raiders.rpy:1051
translate spanish kitty_not_renamed_4c094232:

    # Z "So pretty, but so mysterious."
    Z "Tan bonita y tan misteriosa."

# game/scripts/raiders.rpy:1054
translate spanish kitty_not_renamed_9de661e0:

    # Z "I wonder what's really going on behind those pretty eyes."
    Z "Me pregunto qué se oculta realmente tras esos preciosos ojos."

# game/scripts/raiders.rpy:1055
translate spanish kitty_not_renamed_5e990086_3:

    # Kit "..."
    Kit "..."

# game/scripts/raiders.rpy:1056
translate spanish kitty_not_renamed_dc82cab4:

    # Zt "She really shows no reaction..."
    Zt "No muestra ninguna reacción..."

# game/scripts/raiders.rpy:1059
translate spanish kitty_not_renamed_649997d4:

    # Z "What are you thinking right now?"
    Z "¿En qué estás pensando ahora mismo?"

# game/scripts/raiders.rpy:1060
translate spanish kitty_not_renamed_5e990086_4:

    # Kit "..."
    Kit "..."

# game/scripts/raiders.rpy:1063
translate spanish kitty_not_renamed_5ab3574d_1:

    # Z "..."
    Z "..."

# game/scripts/raiders.rpy:1069
translate spanish kitty_not_renamed_77fa2f09:

    # Z "Smile, [Kit]."
    Z "Sonríe, [Kit]."

# game/scripts/raiders.rpy:1072
translate spanish kitty_not_renamed_5e990086_5:

    # Kit "..."
    Kit "..."

# game/scripts/raiders.rpy:1073
translate spanish kitty_not_renamed_dd78d5a5:

    # Z "A smile on command..."
    Z "Una sonrisa a la orden..."

# game/scripts/raiders.rpy:1088
translate spanish rt_send_kitty_back_eb9337d1:

    # Zt "I simply can't read her at all. She is responsive to commands, but only that."
    Zt "No consigo descifrarla en absoluto. Responde a las órdenes, pero nada más."

# game/scripts/raiders.rpy:1089
translate spanish rt_send_kitty_back_74781485:

    # Zt "There seems to be nothing else inside her. Or is there? Maybe I have barely scratched the surface."
    Zt "Parece que no hay nada más dentro de ella. ¿O no? Puede que apenas haya arañado la superficie."

# game/scripts/raiders.rpy:1091
translate spanish rt_send_kitty_back_d960ce12:

    # Z "Alright, [Kit]. You can go back to your place."
    Z "Muy bien, [Kit]. Puedes volver a tu lugar."

# game/scripts/raiders.rpy:1094
translate spanish rt_send_kitty_back_febb835a:

    # Z "I will put your mask back on for now."
    Z "Te volveré a poner la máscara por ahora."

# game/scripts/raiders.rpy:1097
translate spanish rt_send_kitty_back_5e990086:

    # Kit "..."
    Kit "..."

# game/scripts/raiders.rpy:1101
translate spanish rt_send_kitty_back_22bfe304:

    # "She gets up back to her place, as Asha kneels down again before you, resuming her work..."
    "Se levanta y regresa a su lugar, mientras Asha vuelve a arrodillarse ante ti y reanuda su trabajo..."

# game/scripts/raiders.rpy:1107
translate spanish rt_send_kitty_back_6fb79fde:

    # "She gets up back to her place. You notice Asha glaring at her for a moment..."
    "Se levanta y regresa a su sitio. Notas que Asha la mira con enojo por un momento..."

# game/scripts/raiders.rpy:1110
translate spanish rt_send_kitty_back_575e8cc2:

    # Zt "What could be the reason she is the way she is? Trauma? Some sort of mutation? Or was it really just the way she was raised by her brother?"
    Zt "¿Cuál podría ser la razón por la que es como es? ¿Trauma? ¿Algún tipo de mutación? ¿O realmente fue la forma en que la crió su hermano?"

# game/scripts/raiders.rpy:1111
translate spanish rt_send_kitty_back_18efbf2e:

    # Zt "Maybe if I ask around the people I know, I will find out more about her."
    Zt "Tal vez si pregunto a las personas que conozco, descubriré más acerca de ella."

# game/scripts/raiders.rpy:1112
translate spanish rt_send_kitty_back_90ef3706:

    # Zt "I'm not even sure if the blindfold she's wearing serves any other purpose, so for now, I won't change anything."
    Zt "Ni siquiera estoy seguro de si la venda que lleva le sirve para algún otro propósito, así que por ahora no cambiaré nada."

# game/scripts/raiders.rpy:1113
translate spanish rt_send_kitty_back_d0ace27a:

    # Zt "I should have asked her brother more questions before giving him into Zion's hands..."
    Zt "Debería haberle hecho más preguntas a su hermano antes de entregárselo a Zion..."

# game/scripts/raiders.rpy:1124
translate spanish rsa_1_a82825ac:

    # Z "How is it going around here?"
    Z "¿Cómo va por aquí?"

# game/scripts/raiders.rpy:1127
translate spanish rsa_1_2b7daea0:

    # Wic "Hey... ha, look who's left the general's hut! Our saviour!"
    Wic "Ey... ja, mira quién salió de la choza del general. ¡Nuestro salvador!"

# game/scripts/raiders.rpy:1130
translate spanish rsa_1_0ceb11d1:

    # Wic "How's that pink chick treating you, huh? I heard stories, of how you left her alive."
    Wic "¿Cómo está tratándote esa chica rosa, eh? Oí historias de cómo la dejaste viva."

# game/scripts/raiders.rpy:1131
translate spanish rsa_1_a02a8d4a:

    # Wic "...right after you got rid of her bastard of a brother, of course."
    Wic "... justo después de deshacerte del maldito hermano de ella, por supuesto."

# game/scripts/raiders.rpy:1134
translate spanish rsa_1_3231ee19:

    # Wic "Things have been looking better since your gang decided to decorate the bridge with the General's head."
    Wic "Las cosas han ido mejor desde que tu banda decidió decorar el puente con la cabeza del General."

# game/scripts/raiders.rpy:1135
translate spanish rsa_1_cb2ab920:

    # Wic "We're really doing better, especially me, of course! So I've got to thank you."
    Wic "Realmente nos va mejor, sobre todo a mí, ¡por supuesto! Así que tengo que darte las gracias."

# game/scripts/raiders.rpy:1138
translate spanish rsa_1_f24af6be:

    # Wic "...I said better though, not good. Life is still a bitch around here."
    Wic "... Aunque he dicho mejor, no bien. La vida sigue siendo una mierda por aquí."

# game/scripts/raiders.rpy:1139
translate spanish rsa_1_7820e782:

    # Wic "The workload is still shit, we can barely feed our families out here, and we need more fabric, to make better cloth-"
    Wic "La carga de trabajo sigue siendo una mierda, apenas podemos alimentar a nuestras familias aquí fuera, y necesitamos más tela, para hacer mejores ropas..."

# game/scripts/raiders.rpy:1142
translate spanish rsa_1_13e9e226:

    # SW "[Wic]... give it a rest already."
    SW "[Wic]... Déjalo ya."

# game/scripts/raiders.rpy:1145
translate spanish rsa_1_dc1f452f:

    # SW "All you do is complain. You know full well that there are a lot of people who would give their leg to work here."
    SW "Todo lo que haces es quejarte. Sabes muy bien que hay mucha gente que daría su pierna por trabajar aquí."

# game/scripts/raiders.rpy:1146
translate spanish rsa_1_e8e402a5:

    # SW "If you keep complaining... well, if the General can be replaced, so can you. and you know it."
    SW "Si sigues quejándote... bueno, si el General puede ser reemplazado, tú también puedes. Y lo sabes."

# game/scripts/raiders.rpy:1149
translate spanish rsa_1_e7c8084e:

    # Wic "I... that's not the point..."
    Wic "Yo... eso no es lo importante..."

# game/scripts/raiders.rpy:1152
translate spanish rsa_1_d5696d7f:

    # SW "Don't mind his attitude, Boss. There's more than enough of us who appreciate the better work conditions."
    SW "No te preocupes por mí, jefe. Estoy segura de que dirigir un asentamiento tampoco es fácil."

# game/scripts/raiders.rpy:1153
translate spanish rsa_1_e907682e:

    # SW "There's always things that can be improved. But at least we're not getting most of our shit stolen by those thugs. Thanks again."
    SW "Siempre hay cosas que se pueden mejorar. Pero al menos esos matones no nos roban casi nada. Gracias de nuevo."

# game/scripts/raiders.rpy:1163
translate spanish rsa_1_63467694:

    # Wic "I swear to everything, if you won't set me free, people will lay down their fucking pickaxes!"
    Wic "¡Lo juro por todo, si no me liberas, la gente dejará sus putas piquetas!"

# game/scripts/raiders.rpy:1164
translate spanish rsa_1_11836d34:

    # Zi "{i}*Sigh...*{/i}"
    Zi "{i}*suspiro*{/i}"

# game/scripts/raiders.rpy:1165
translate spanish rsa_1_92131d15:

    # Zi "I should just cut these chains loose..."
    Zi "Debería simplemente cortar estas cadenas..."

# game/scripts/raiders.rpy:1166
translate spanish rsa_1_971edda4:

    # Z "Zion."
    Z "Zion."

# game/scripts/raiders.rpy:1169
translate spanish rsa_1_5a65c3c7:

    # Zi "[persistent.player_name]... remind me again: why we didn't hang him next to the General?"
    Zi "[persistent.player_name]... Recuérdame, ¿por qué no lo ahorcamos junto al General?"

# game/scripts/raiders.rpy:1170
translate spanish rsa_1_714981b2:

    # Z "Let's see about that.."
    Z "Veamos sobre eso..."

# game/scripts/raiders.rpy:1173
translate spanish rsa_1_36680673:

    # Z "For now, you've got to endure it. People need to move on from him."
    Z "Por ahora, tienes que soportarlo. La gente necesita seguir adelante."

# game/scripts/raiders.rpy:1174
translate spanish rsa_1_d077c6d7:

    # Zi "Those assholes should be happy to get work at all, and what do they produce instead? Cunts like this fuck."
    Zi "Esos gilipollas deberían alegrarse de tener trabajo, ¿y qué producen en su lugar? Cabrones como este cabrón."

# game/scripts/raiders.rpy:1177
translate spanish rsa_1_e688b730:

    # Wic "You two... screw yourselves! We deserve more than this!"
    Wic "Vosotros dos... ¡que os den! ¡Nos merecemos más que esto!"

# game/scripts/raiders.rpy:1178
translate spanish rsa_1_c355f506:

    # Zi "The only thing you deserve is a tour through my Adira, you little shit! Would teach you what you're really worth."
    Zi "Lo único que te mereces es un recorrido por mi Adira, ¡pequeña mierda! Te enseñaría lo que vales de verdad."

# game/scripts/raiders.rpy:1181
translate spanish rsa_1_cf6029e1:

    # Zi "{i}*sigh*{/i}"
    Zi "{i}*suspiro*{/i}"

# game/scripts/raiders.rpy:1182
translate spanish rsa_1_338041ae:

    # Zi "You should really consider getting rid of him soon, [persistent.player_name]. I can always find a use for another skull..."
    Zi "Deberías plantearte deshacerte de él pronto, [persistent.player_name]. Siempre puedo encontrar un uso para otro cráneo..."

# game/scripts/raiders.rpy:1194
translate spanish rsf_1_010d980f:

    # Ky "Hey, [persistent.player_name], look what the cat dragged in..."
    Ky "Oye, [persistent.player_name], mira quién apareció..."

# game/scripts/raiders.rpy:1197
translate spanish rsf_1_87f6c62c:

    # SW "I... I don't want to disturb for long, Miss..."
    SW "No... No quiero molestar mucho tiempo, señorita..."

# game/scripts/raiders.rpy:1200
translate spanish rsf_1_ceaef6db:

    # Z "I remember you."
    Z "Te recuerdo."

# game/scripts/raiders.rpy:1201
translate spanish rsf_1_747019a5:

    # SW "I am... merely here to see her... to see Kitty, I mean!"
    SW "Solo estoy... aquí para verla... para ver a Kitty, quiero decir."

# game/scripts/raiders.rpy:1203
translate spanish rsf_1_abb759f5:

    # Z "She no longer goes by the name Kitty. That was the name the General used, and he was an idiot."
    Z "Ya no se llama Kitty. Ése era el nombre que usaba el General, y era un idiota."

# game/scripts/raiders.rpy:1204
translate spanish rsf_1_e8304ddb:

    # Z "Her name is now [Kit]. You will address her by that name, and that name only."
    Z "Ahora se llama [Kit]. Te dirigirás a ella por ese nombre y sólo por ese nombre."

# game/scripts/raiders.rpy:1205
translate spanish rsf_1_cbf224c8:

    # SW "Oh... this is... is that so? Then I am happy to finally address her correctly."
    SW "Oh... esto es... ¿es así? Entonces estoy feliz de finalmente dirigirme a ella correctamente."

# game/scripts/raiders.rpy:1206
translate spanish rsf_1_b2b6f06a:

    # SW "[Kit]... I always felt like that was wrong. Thank you for giving [Kit] her identity back!"
    SW "[Kit]... Siempre sentí que eso estaba mal. Gracias por devolverle a [Kit] su identidad."

# game/scripts/raiders.rpy:1208
translate spanish rsf_1_be9b385c:

    # Z "[Kit] is doing better, now that she is free from the General."
    Z "[Kit] está mejor ahora que está libre del General."

# game/scripts/raiders.rpy:1209
translate spanish rsf_1_dc9632eb:

    # Z "We take good care of her."
    Z "Cuidamos bien de ella."

# game/scripts/raiders.rpy:1210
translate spanish rsf_1_9b551402:

    # SW "That is... so good to hear! I am happy for her, really!"
    SW "Me alegro mucho de oírlo. ¡Me alegro por ella, de verdad!"

# game/scripts/raiders.rpy:1217
translate spanish rsf_1_ae1ca445:

    # SW "I have brought coal, m...much more than last time."
    SW "He traído carbón, m...mucho más que la última vez."

# game/scripts/raiders.rpy:1218
translate spanish rsf_1_1b498ad7:

    # SW "I wanted to see how she fares after... the Generals..."
    SW "Quería ver cómo le va después de... el General..."

# game/scripts/raiders.rpy:1225
translate spanish rsf_1_1c2815f0:

    # Z "Yeah, we have discussed this."
    Z "Sí, ya lo hemos hablado."

# game/scripts/raiders.rpy:1226
translate spanish rsf_1_93bbfd2e:

    # Z "[Kit], it looks like he brought enough tribute. Get up now, and walk to him."
    Z "[Kit], parece que trajo suficiente tributo. Levántate ahora y camina hacia él."

# game/scripts/raiders.rpy:1229
translate spanish rsf_1_95a2598e:

    # "She follows your directions almost mechanically, reacting immediately to your orders..."
    "Sigue tus instrucciones casi mecánicamente, reaccionando inmediatamente a tus órdenes..."

# game/scripts/raiders.rpy:1232
translate spanish rsf_1_5cb11211:

    # SW "Oh [Kit]... I am... beyond glad that nothing happened to you."
    SW "Oh [Kit].. Estoy más que contento de que no te haya pasado nada."

# game/scripts/raiders.rpy:1233
translate spanish rsf_1_0b8ce56e:

    # SW "In fact... you are... as beautiful as ever!"
    SW "De hecho... eres... tan hermosa como siempre."

# game/scripts/raiders.rpy:1234
translate spanish rsf_1_302a9836:

    # SW "I, uhm, hope my appearance does not annoy you, princess..."
    SW "Yo, eeh, espero que mi apariencia no te moleste, princesa..."

# game/scripts/raiders.rpy:1235
translate spanish rsf_1_abf33785:

    # Z "That was such a nice compliment. [Kit], Give him a smile."
    Z "Qué bonito cumplido. [Kit], dale una sonrisa."

# game/scripts/raiders.rpy:1238
translate spanish rsf_1_fddd4425:

    # Kit "...{w=1}{nw}"
    Kit "... {w=1}{nw}"

# game/scripts/raiders.rpy:1241
translate spanish rsf_1_07e1c8c7:

    # SW "[Kit]..."
    SW "[Kit]..."

# game/scripts/raiders.rpy:1244
translate spanish rsf_1_18548459:

    # SW "To put into words how much this meant to me..."
    SW "Expresar con palabras lo mucho que significaba para mí..."

# game/scripts/raiders.rpy:1245
translate spanish rsf_1_fe5716df:

    # SW "I can't... hold it any longer."
    SW "No puedo... contenerlo más."

# game/scripts/raiders.rpy:1248
translate spanish rsf_1_07e1c8c7_1:

    # SW "[Kit]..."
    SW "[Kit]..."

# game/scripts/raiders.rpy:1249
translate spanish rsf_1_d4aa0439:

    # Kyw "Holy shit, man..."
    Kyw "¡Ostia puta, hombre!"

# game/scripts/raiders.rpy:1252
translate spanish rsf_1_dc8811a1:

    # SW "I know that you may not understand, as we see each other only once a week."
    SW "Sé que quizás no lo entiendas, ya que solo nos vemos una vez a la semana."

# game/scripts/raiders.rpy:1253
translate spanish rsf_1_85b6ae79:

    # SW "But know that I am working hard every week to be able to see you."
    SW "Pero ten en cuenta que trabajo duro cada semana para poder verte."

# game/scripts/raiders.rpy:1254
translate spanish rsf_1_e5d310ca:

    # SW "Whatever it takes, you can be sure to rely on me, even in hard times."
    SW "Sea lo que sea, puedes estar segura de que contarás conmigo, incluso en los momentos difíciles."

# game/scripts/raiders.rpy:1257
translate spanish rsf_1_3f269368:

    # SW "To have someone so perfect, so flawless, pure and... otherworldly..."
    SW "Tener a alguien tan perfecto, tan impecable, puro y... sin palabras..."

# game/scripts/raiders.rpy:1258
translate spanish rsf_1_462a86b7:

    # SW "...stand before a flawed, miserable worker like me..."
    SW "... estar frente a un trabajador imperfecto y miserable como yo..."

# game/scripts/raiders.rpy:1261
translate spanish rsf_1_8554a38c:

    # SW "...it is the only reason I keep going. You are the highlight of my existence..."
    SW "... es la única razón por la que sigo adelante. Eres el punto culminante de mi existencia..."

# game/scripts/raiders.rpy:1264
translate spanish rsf_1_aeca80d6:

    # SW "And should I never reach your heart enough to love me back..."
    SW "Y si nunca llego a tu corazón lo suficiente como para que me ames de vuelta..."

# game/scripts/raiders.rpy:1265
translate spanish rsf_1_5e54b52e:

    # SW "...it is at least a dream... one that makes me escape the reality of this place. Of my struggles."
    SW "...al menos es un sueño... uno que me hace escapar de la realidad de este lugar. De mis luchas."

# game/scripts/raiders.rpy:1269
translate spanish rsf_1_4de43a56:

    # SW "If I only could... have a little more of you..."
    SW "Si tan solo pudiera... tener un poco más de ti..."

# game/scripts/raiders.rpy:1272
translate spanish rsf_1_07e1c8c7_2:

    # SW "[Kit]..."
    SW "[Kit]..."

# game/scripts/raiders.rpy:1275
translate spanish rsf_1_ad57163d:

    # SW "You are so..."
    SW "Eres tan..."

# game/scripts/raiders.rpy:1278
translate spanish rsf_1_c71544e8:

    # SW "Mmph..."
    SW "Mmph..."

# game/scripts/raiders.rpy:1279
translate spanish rsf_1_488aaecd:

    # SW "{i}*sucking*{/i}"
    SW "{i}*chupando*{/i}"

# game/scripts/raiders.rpy:1280
translate spanish rsf_1_9d3b4d0b:

    # SW "{i}*muffled*{/i} [Kit]..."
    SW "{i}*ahogado*{/i} [Kit]..."

# game/scripts/raiders.rpy:1283
translate spanish rsf_1_5e990086:

    # Kit "..."
    Kit "..."

# game/scripts/raiders.rpy:1284
translate spanish rsf_1_0fa3bc4c:

    # "His dirty hands caress her flawless skin while he greedily sucks her breast..."
    "Sus manos sucias acarician su piel impecable mientras él chupa ávidamente su pecho..."

# game/scripts/raiders.rpy:1285
translate spanish rsf_1_d62fa9c5:

    # SW "Mh... a... dream..."
    SW "Mh... un... sueño..."

# game/scripts/raiders.rpy:1288
translate spanish rsf_1_c91ce812:

    # Kyw "{i}*sigh*{/i} Fuck me... this guy is desperate."
    Kyw "{i}*suspiro*{/i} No me jodas... este tío está desesperado."

# game/scripts/raiders.rpy:1289
translate spanish rsf_1_27319151:

    # Ky "Hey cockface, that's enough. You'll rip her tit off if you continue like that."
    Ky "Ey, idiota, eso es suficiente. Le arrancarás la teta si sigues así."

# game/scripts/raiders.rpy:1292
translate spanish rsf_1_fef04219:

    # SW "I'm... I'm sorry, I don't know what..."
    SW "Lo siento... lo siento, no sé qué..."

# game/scripts/raiders.rpy:1293
translate spanish rsf_1_c6005b0a:

    # Z "You had your fun. Now scram!"
    Z "Ya te has divertido. ¡Ahora lárgate!"

# game/scripts/raiders.rpy:1294
translate spanish rsf_1_5f85f927:

    # Z "Don't think that what you just did isn't going to cost you, next time."
    Z "No creas que lo que acabas de hacer no te va a costar caro, la próxima vez."

# game/scripts/raiders.rpy:1295
translate spanish rsf_1_2cb25fee:

    # SW "Yes... of course. Thank you..."
    SW "Sí... por supuesto. Gracias..."

# game/scripts/raiders.rpy:1296
translate spanish rsf_1_7c9d19f3:

    # SW "I would have never... It is worth it, it is!"
    SW "Nunca lo habría hecho... ¡Vale la pena, de verdad!"

# game/scripts/raiders.rpy:1302
translate spanish rsf_1_2fd467cc:

    # Z "That's enough. Take your hands off her."
    Z "Ya está bien. Quítale las manos de encima."

# game/scripts/raiders.rpy:1303
translate spanish rsf_1_033d117e:

    # SW "I... yes... I apologize."
    SW "Yo... sí... me disculpo."

# game/scripts/raiders.rpy:1309
translate spanish rsf4_7480810f:

    # SW "Thank you again, [Kit]. I look forward to seeing you next week."
    SW "Gracias de nuevo, [Kit]. Espero verte la semana que viene."

# game/scripts/raiders.rpy:1310
translate spanish rsf4_725e86f3:

    # SW "Until then, goodbye."
    SW "Hasta entonces, adiós."

# game/scripts/raiders.rpy:1321
translate spanish rsf4_4ac482be:

    # Z "Hello, someone in there?"
    Z "Hola, ¿hay alguien ahí?"

# game/scripts/raiders.rpy:1324
translate spanish rsf4_f6bd4dca:

    # SW "You... oh, hello!"
    SW "Tú... ¡oh, hola!"

# game/scripts/raiders.rpy:1325
translate spanish rsf4_4dad1660:

    # SW "I didn't think... you'd want to talk to me, now that you freed [Kit] from the General."
    SW "No pensé... que quisieras hablar conmigo, ahora que liberaste a [Kit] del General."

# game/scripts/raiders.rpy:1328
translate spanish rsf4_31daa57e:

    # Z "I wanted to see how you're doing, and if everything went as planned."
    Z "Quería ver cómo estás y si todo salió según lo planeado."

# game/scripts/raiders.rpy:1329
translate spanish rsf4_64d118f9:

    # Z "I promised you a slave, didn't I?"
    Z "Te prometí una esclava, ¿verdad?"

# game/scripts/raiders.rpy:1332
translate spanish rsf4_71b8030a:

    # SW "..."
    SW "..."

# game/scripts/raiders.rpy:1333
translate spanish rsf4_00261fb1:

    # "He smiles..."
    "Él sonríe..."

# game/scripts/raiders.rpy:1336
translate spanish rsf4_26da3c8c:

    # SW "You really kept your word! Come here, I'll show you."
    SW "¡Realmente has cumplido tu palabra! Ven aquí, te lo enseñaré."

# game/scripts/raiders.rpy:1339
translate spanish rsf4_fc2b4e40:

    # SW "They gave me this one, for contributing so much to the settlement."
    SW "Me dieron a esta, por contribuir tanto al asentamiento."

# game/scripts/raiders.rpy:1342
translate spanish rsf4_7bc371e6:

    # Sl "..."
    Sl "..."

# game/scripts/raiders.rpy:1343
translate spanish rsf4_f2e1e03f:

    # SW "Isn't she pretty?!"
    SW "¡¿No es bonita?!"

# game/scripts/raiders.rpy:1344
translate spanish rsf4_e6fdf491:

    # SW "I will work even harder now, because I have this girl waiting for me when I come home!"
    SW "Trabajaré aún más duro ahora, ¡porque tengo a esta chica esperándome cuando llego a casa!"

# game/scripts/raiders.rpy:1345
translate spanish rsf4_cdf96d17:

    # Z "And what about [Kit]?"
    Z "¿Y qué pasa con [Kit]?"

# game/scripts/raiders.rpy:1348
translate spanish rsf4_6d624ccd:

    # SW "[Kit], ah... forget her! I finally have my own girl."
    SW "[Kit], ah... ¡olvídala! Finalmente tengo a mi propia chica."

# game/scripts/raiders.rpy:1351
translate spanish rsf4_366ac122:

    # SW "She's shy, and has not let me touch her yet... but we will get there, right?"
    SW "Es tímida y aún no me ha dejado tocarla... pero lo conseguiremos, ¿verdad?"

# game/scripts/raiders.rpy:1352
translate spanish rsf4_613059d4:

    # SW "She is my slave after all, if you know what I'm saying."
    SW "Después de todo, ella es mi esclava, si sabes a lo que me refiero."

# game/scripts/raiders.rpy:1355
translate spanish rsf4_971c0034:

    # Z "she is... well then. I will come back in a few days to see how things are going for you."
    Z "Es... Bueno, entonces. Volveré en unos días para ver cómo te va."

# game/scripts/raiders.rpy:1356
translate spanish rsf4_81d4198e:

    # Z "Take care."
    Z "Cuídate."

# game/scripts/raiders.rpy:1365
translate spanish rsf_2_48f6d4eb:

    # Z "Let's see how this guy is treating his new slave."
    Z "Veamos cómo trata este tipo a su nueva esclava."

# game/scripts/raiders.rpy:1366
translate spanish rsf_2_c6c2a290:

    # Z "He was so confident, last time. A newborn man."
    Z "Estaba tan seguro de sí mismo, la última vez. Un hombre recién nacido."

# game/scripts/raiders.rpy:1369
translate spanish rsf_2_98851f82:

    # Z "Hello, it's me again. How are you doing, man?"
    Z "Hola, soy yo otra vez. ¿Qué tal, tío?"

# game/scripts/raiders.rpy:1370
translate spanish rsf_2_58131b11:

    # "You hear mumbling coming from the other side..."
    "Oyes murmullos procedentes del otro lado..."

# game/scripts/raiders.rpy:1371
translate spanish rsf_2_707fd96d:

    # Z "Hey, you hear me?"
    Z "Oye, ¿me oyes?"

# game/scripts/raiders.rpy:1374
translate spanish rsf_2_63b7be8d:

    # Z "What on earth..."
    Z "Qué demonios..."

# game/scripts/raiders.rpy:1377
translate spanish rsf_2_1f0d1012:

    # SW "I'm so sorry, I didn't..."
    SW "Lo siento mucho, no..."

# game/scripts/raiders.rpy:1378
translate spanish rsf_2_ae50f8f5:

    # C2 "A shift of fourteen hours is all you did? Is this how you thank me?"
    C2 "¿Un turno de catorce horas es todo lo que hiciste? ¿Así me lo agradeces?"

# game/scripts/raiders.rpy:1379
translate spanish rsf_2_e91a09c2:

    # SW "Nooo... please. I tried..."
    SW "Nooo... por favor. Lo he intentado..."

# game/scripts/raiders.rpy:1382
translate spanish rsf_2_ec8f2757:

    # Sl "Such a pathetic excuse. After all the attention I gave you last night..."
    Sl "Qué excusa tan patética. Después de toda la atención que te presté anoche..."

# game/scripts/raiders.rpy:1383
translate spanish rsf_2_f86ed805:

    # Sl "I should start looking for another man after all..."
    Sl "Debería empezar a buscar otro hombre después de todo..."

# game/scripts/raiders.rpy:1384
translate spanish rsf_2_7fc73a86:

    # C2 "No... please... anything but that."
    C2 "No... por favor... cualquier cosa menos eso."

# game/scripts/raiders.rpy:1387
translate spanish rsf_2_81b9085c:

    # Sl "You said yourself I was too good for this place, and now you refuse to improve my wellbeing."
    Sl "Tú mismo dijiste que yo era demasiado buena para este lugar, y ahora te niegas a mejorar mi bienestar."

# game/scripts/raiders.rpy:1388
translate spanish rsf_2_23075990:

    # Sl "I wonder if I can really trust you..."
    Sl "Me pregunto si realmente puedo confiar en ti..."

# game/scripts/raiders.rpy:1389
translate spanish rsf_2_6e9ea000:

    # C2 "You can, I... I promise... I will make your life better, much better..."
    C2 "Puedes, yo... Te prometo... Haré que tu vida sea mejor, mucho mejor..."

# game/scripts/raiders.rpy:1392
translate spanish rsf_2_dc384165:

    # Sl "You better start delivering on your promises soon."
    Sl "Será mejor que empieces pronto a cumplir tus promesas."

# game/scripts/raiders.rpy:1393
translate spanish rsf_2_bcf2ec6d:

    # Sl "...I won't remain in this shithole of a place for long."
    Sl "... no permaneceré en este agujero de mierda por mucho tiempo."

# game/scripts/raiders.rpy:1405
translate spanish rsg_1_ff891a23:

    # Z "Hey, you. I am here to check how everything is going."
    Z "Oye, tú. Estoy aquí para comprobar cómo va todo."

# game/scripts/raiders.rpy:1408
translate spanish rsg_1_1193edd4:

    # SG "Hey Boss, everything's fine."
    SG "¡Hola, jefe, todo está bien!"

# game/scripts/raiders.rpy:1409
translate spanish rsg_1_086351c7:

    # SG "The gate is busy recently, got lots of people wanting to come in... travellers, recruits, traders..."
    SG "La puerta está ocupada últimamente, hay mucha gente que quiere entrar... Viajeros, reclutas, comerciantes..."

# game/scripts/raiders.rpy:1412
translate spanish rsg_1_0ab35e96:

    # SG "The word is going around! This settlement is going places."
    SG "¡Se corre la voz! Este asentamiento va a más."

# game/scripts/raiders.rpy:1413
translate spanish rsg_1_9d8314d2:

    # SG "Oh, and... can you ask Kyra what we are supposed to do about the caravans?"
    SG "Oh, y... ¿puedes preguntarle a Kyra qué se supone que debemos hacer con las caravanas?"

# game/scripts/raiders.rpy:1414
translate spanish rsg_1_3a2fc8c2:

    # SG "I don't want to make her mad at me for doing the wrong thing."
    SG "No quiero que se enfade conmigo por hacer lo incorrecto."

# game/scripts/raiders.rpy:1417
translate spanish rsg_1_85845275:

    # Z "Yeah, let's see, I'm busy right now. Should ask her yourself later."
    Z "Sí, veamos, ahora estoy ocupado. Deberías preguntárselo tú mismo más tarde."

# game/scripts/raiders.rpy:1424
translate spanish rsg_1_8d2dd89b:

    # Z "Hey, you. How are things at the gate?"
    Z "Oye, tú. ¿Cómo van las cosas en la puerta?"

# game/scripts/raiders.rpy:1427
translate spanish rsg_1_6845de3e:

    # SG "...?"
    SG "¿...?"

# game/scripts/raiders.rpy:1430
translate spanish rsg_1_17557f6f:

    # SG "Boss, it's you."
    SG "Jefe, eres tú."

# game/scripts/raiders.rpy:1431
translate spanish rsg_1_8701159d:

    # SG "Just had another raiding party come back. Things aren't bad. Even brought in some new workers."
    SG "Acabo de tener otro grupo de asaltantes regresar. Las cosas no van mal. Incluso trajeron a algunos trabajadores nuevos."

# game/scripts/raiders.rpy:1434
translate spanish rsg_1_3f23f22a:

    # SG "Word is going around not to mess with this place since we arrived. Other gangs stay away from our territory."
    SG "Se corre la voz de no meterse con este lugar desde que llegamos. Otras bandas se mantienen alejadas de nuestro territorio."

# game/scripts/raiders.rpy:1435
translate spanish rsg_1_bf57651f:

    # SG "I've got the occasional lost soul coming here, desperate enough, I guess."
    SG "Tengo el ocasional alma perdida que viene aquí, lo suficientemente desesperada, supongo."

# game/scripts/raiders.rpy:1438
translate spanish rsg_1_f13c2768:

    # Z "Alright man, keep it up. Else I'll send Zion."
    Z "Muy bien, amigo, sigue así. De lo contrario, enviaré a Zion."

# game/scripts/raiders.rpy:1441
translate spanish rsg_1_ec4336b2:

    # SG "Hah, that woman's no joke, boss. You should hear the stories the guys are telling about her."
    SG "Supongo que necesitas que te lo recuerden."

# game/scripts/raiders.rpy:1442
translate spanish rsg_1_15a94025:

    # SG "Anyways, see you around."
    SG "En fin, nos vemos."

# game/scripts/raiders.rpy:1445
translate spanish rsg_1_fe631a17:

    # Z "Nice decoration. Didn't know you have an artistic side."
    Z "Bonita decoración. No sabía que tuvieras un lado artístico."

# game/scripts/raiders.rpy:1448
translate spanish rsg_1_9ff8edb7:

    # SG "Ever carved your own skull trophy, boss?"
    SG "¿Alguna vez has tallado tu propio trofeo de cráneo, jefe?"

# game/scripts/raiders.rpy:1449
translate spanish rsg_1_abd8ea80:

    # SG "Thing is, this shit works, people piss their pants at the gate."
    SG "La cosa es que esta mierda funciona, la gente se mea en los pantalones en la puerta."

# game/scripts/raiders.rpy:1450
translate spanish rsg_1_15a94025_1:

    # SG "Anyways, see you around."
    SG "En fin, nos vemos."

# game/scripts/raiders.rpy:1460
translate spanish rss_1_3034efe5:

    # SW "Hey Boss! Glad to see you back!"
    SW "¡Hola, jefe! ¡Me alegra verte de nuevo!"

# game/scripts/raiders.rpy:1461
translate spanish rss_1_cabfa72f:

    # SW "What do you think of my new home?"
    SW "¿Qué piensas de mi nuevo hogar?"

# game/scripts/raiders.rpy:1464
translate spanish rss_1_7535b5bd:

    # "The man stands proudly in the doorway of his repaired shack..."
    "El hombre se yergue orgulloso en la puerta de su choza reparada..."

# game/scripts/raiders.rpy:1465
translate spanish rss_1_60080890:

    # Z "Not bad. It looks like a better place to come home to after work, for sure."
    Z "No está mal. Parece un lugar mejor para volver a casa después del trabajo, seguro."

# game/scripts/raiders.rpy:1468
translate spanish rss_1_f9ac548c:

    # SW "You have not seen the inside yet! You will not believe what I've got!"
    SW "¡Aún no has visto el interior! ¡No te vas a creer lo que tengo!"

# game/scripts/raiders.rpy:1471
translate spanish rss_1_6d7dda07:

    # Z "Alright, I'll bite... what have you got?"
    Z "Muy bien, lo escucharé... ¿Qué tienes?"

# game/scripts/raiders.rpy:1472
translate spanish rss_1_8b7ca9bf:

    # "As you step closer, you take a peek inside and see..."
    "Al acercarte, echas un vistazo al interior y ves..."

# game/scripts/raiders.rpy:1475
translate spanish rss_1_4e8e882a:

    # "...nothing. A bed and... empty space."
    "... nada. Una cama y... espacio vacío."

# game/scripts/raiders.rpy:1476
translate spanish rss_1_79897f70:

    # SW "Isn't it great? It's a high quality floor, made just for me!"
    SW "¡Es genial! Es un suelo de alta calidad, hecho especialmente para mí."

# game/scripts/raiders.rpy:1477
translate spanish rss_1_cf771b5f:

    # Z "Yeah... um... you're right."
    Z "Sí... um... tienes razón."

# game/scripts/raiders.rpy:1478
translate spanish rss_1_a6799ffb:

    # Zt "I don't know if I feel happy or sad for him. I guess that when you have nothing, even as simple as a decent floor is a start."
    Zt "No sé si me siento feliz o triste por él. Supongo que cuando no tienes nada, incluso un suelo decente es un comienzo."

# game/scripts/raiders.rpy:1481
translate spanish rss_1_87e3504f:

    # Z "Well, I'm glad for you, buddy. Hope your lucky streak stays strong."
    Z "Me alegro por ti, amigo. Espero que tu racha de suerte siga siendo fuerte."

# game/scripts/raiders.rpy:1488
translate spanish rss_1_64809ab2:

    # Z "How's it going around here?"
    Z "¿Cómo va por aquí?"

# game/scripts/raiders.rpy:1491
translate spanish rss_1_bb11badd:

    # SW "Huh? Oh... hi boss."
    SW "¿Eh? Oh... hola jefe."

# game/scripts/raiders.rpy:1492
translate spanish rss_1_d2375cc0:

    # SW "I... well, my son just joined a mining crew."
    SW "Yo... Bueno, mi hijo se acaba de unir a una tripulación minera."

# game/scripts/raiders.rpy:1495
translate spanish rss_1_d55445ce:

    # SW "He's still young, but he will do great!"
    SW "¡Todavía es joven, pero lo hará genial!"

# game/scripts/raiders.rpy:1496
translate spanish rss_1_48890ea7:

    # SW "We should be able to afford more things, soon even with the raiders in command!"
    SW "Pronto podremos permitirnos más cosas, ¡incluso con los asaltantes al mando!"

# game/scripts/raiders.rpy:1502
translate spanish rss_1_7568168b:

    # SW "...?"
    SW "¿...?"

# game/scripts/raiders.rpy:1503
translate spanish rss_1_aba1d36f:

    # SW "Heh... I... uh... can fix that."
    SW "Je... Yo... eh... puedo arreglarlo."

# game/scripts/raiders.rpy:1504
translate spanish rss_1_780cfe66:

    # SW "Don't worry about me, boss. I'm sure running a settlement is not easy, either!"
    SW "No te preocupes por mí, jefe. Seguro que dirigir un asentamiento tampoco es fácil."

# game/scripts/raiders.rpy:1516
translate spanish rst_1_131f931c:

    # "You hear mumbling from inside as you approach the trailer..."
    "Oyes murmullos procedentes del interior mientras te acercas al remolque..."

# game/scripts/raiders.rpy:1522
translate spanish rst_1_15e6d0f3:

    # Rue "I know it's difficult for you, but you have to stay strong. Your wife surely misses you."
    Rue "Sé que es difícil para ti, pero debes mantener la fortaleza. Tu esposa seguramente te extraña."

# game/scripts/raiders.rpy:1525
translate spanish rst_1_366eea2c:

    # Rue "Oh, hey boss, how can I help?"
    Rue "Oh, ey jefe, ¿cómo puedo ayudarte?"

# game/scripts/raiders.rpy:1528
translate spanish rst_1_635ea865:

    # Z "I am just checking in to see how things are going."
    Z "Solo estoy comprobando cómo van las cosas."

# game/scripts/raiders.rpy:1531
translate spanish rst_1_11684bda:

    # Rue "Gyasi, can we continue this later? Maybe after your shift?"
    Rue "Gyasi, ¿podemos continuar esto más tarde? ¿Tal vez después de tu turno?"

# game/scripts/raiders.rpy:1534
translate spanish rst_1_828fa078:

    # SW "Okay, let us do that."
    SW "De acuerdo, hagámoslo."

# game/scripts/raiders.rpy:1535
translate spanish rst_1_5307d0aa:

    # SW "Thank you, [Rue]."
    SW "Gracias, [Rue]."

# game/scripts/raiders.rpy:1538
translate spanish rst_1_3fca0ec4:

    # Rue "Remember, we all carry our burdens and insecurities. But we do not let them tear us down, agreed?"
    Rue "Recuerda, todos llevamos nuestras cargas e inseguridades. Pero no permitimos que nos destruyan, ¿de acuerdo?"

# game/scripts/raiders.rpy:1541
translate spanish rst_1_832eb9bf:

    # SW "I... you're right. I will come back later... there is something else I want to say."
    SW "Yo... tienes razón. Volveré más tarde... hay algo más que te quiero decir."

# game/scripts/raiders.rpy:1544
translate spanish rst_1_1aa4e663:

    # "The man leaves, and you take his place..."
    "El hombre se va, y tú ocupas su lugar..."

# game/scripts/raiders.rpy:1547
translate spanish rst_1_dc2b5c44:

    # Z "People seem to put their trust in you."
    Z "La gente parece confiar en ti."

# game/scripts/raiders.rpy:1550
translate spanish rst_1_caaeda94:

    # Rue "I guess I've got a thing for talking to people."
    Rue "Supongo que tengo debilidad por hablar con la gente."

# game/scripts/raiders.rpy:1551
translate spanish rst_1_21e0a978:

    # Rue "And that's thanks to you, in a way. You made things happen here, and now I am not just the village whore anymore. People actually value my brains, for a change."
    Rue "Y en cierto sentido, eso es gracias a ti. Hiciste que las cosas sucedieran aquí, y ahora ya no soy solo la puta del pueblo. La gente realmente valora mi inteligencia, para variar."

# game/scripts/raiders.rpy:1552
translate spanish rst_1_cbf9d8c7:

    # Rue "If I can help some of these poor folks get their head straight and help out my son before my sickness gets me, then that's a good thing."
    Rue "Si puedo ayudar a que algunos de estos pobres tipos se aclaren y ayudar a mi hijo antes de que mi enfermedad me alcance, entonces eso es algo bueno."

# game/scripts/raiders.rpy:1559
translate spanish re_rst1a_c95fc621:

    # Rue "Hm..."
    Rue "Hm..."

# game/scripts/raiders.rpy:1562
translate spanish re_rst1a_c79b9eb3:

    # Rue "I don't know about you, but I very strongly remember the first time we met, and the offer I made back then..."
    Rue "No sé qué piensas tú, pero yo recuerdo muy claramente la primera vez que nos encontramos y la oferta que hice en ese momento..."

# game/scripts/raiders.rpy:1563
translate spanish re_rst1a_6d5566c3:

    # Rue "Talking to people is nice, but I do sometimes miss using my mouth for something else..."
    Rue "Hablar con la gente está bien, pero a veces echo de menos usar la boca para otra cosa..."

# game/scripts/raiders.rpy:1564
translate spanish re_rst1a_693b8b59:

    # Rue "If you want, I wouldn't mind giving my hero some gratitude..."
    Rue "Si quieres, no me importaría darle algo de gratitud a mi héroe..."

# game/scripts/raiders.rpy:1571
