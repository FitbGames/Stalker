translate spanish rabiah_convi_2_4711e122:

    # Raw "But no, I am not planning on sitting by idly. It might soon be time for a little payback."
    Raw "Pero no, no pienso quedarme de brazos cruzados. Puede que pronto llegue la hora de una pequeña venganza."

# game/scripts/family.rpy:2095
translate spanish rabiah_convi_2_d8c0d4fe:

    # Zw "Now that sounds interesting..."
    Zw "Eso sí que suena interesante..."

# game/scripts/family.rpy:2096
translate spanish rabiah_convi_2_0c5b0dc7_1:

    # Om "Everything okay, you two?"
    Om "¿Todo bien, vosotros dos?"

# game/scripts/family.rpy:2099
translate spanish rabiah_convi_2_f33a6e05_1:

    # Z "Yeah. I'll be joining you soon. I just needed to tell your wife something."
    Z "Sí, pronto me reuniré contigo. Necesitaba decirle algo a tu mujer."

# game/scripts/family.rpy:2102
translate spanish rabiah_convi_2_95643631_1:

    # "...and with that, you leave."
    "... y con eso, te vas."

# game/scripts/family.rpy:2106
translate spanish rabiah_convi_1_e6ce2633:

    # Zt "Let's see how Rabiah is doing in the kitchen."
    Zt "Vamos a ver cómo le va a Rabiah en la cocina."

# game/scripts/family.rpy:2112
translate spanish rabiah_convi_1_90a9dcc5:

    # Zt "This doesn't look bad at all."
    Zt "No tiene mala pinta."

# game/scripts/family.rpy:2115
translate spanish rabiah_convi_1_7b36d04c:

    # Ra "Nghr..."
    Ra "Nghr..."

# game/scripts/family.rpy:2118
translate spanish rabiah_convi_1_984c3361:

    # Zt "She seems to be stressed out."
    Zt "Parece que está estresada."

# game/scripts/family.rpy:2121
translate spanish rabiah_convi_1_3a91e45a:

    # Ra "Dinner is not yet ready, [persistent.player_name]."
    Ra "La cena aún no está lista, [persistent.player_name]."

# game/scripts/family.rpy:2122
translate spanish rabiah_convi_1_5d23a302:

    # Ra "You can come back in ten minutes."
    Ra "Puedes volver en diez minutos."

# game/scripts/family.rpy:2123
translate spanish rabiah_convi_1_e07ed478:

    # Z "I was just wondering how you're doing."
    Z "Me preguntaba cómo estabas."

# game/scripts/family.rpy:2126
translate spanish rabiah_convi_1_9e5e6407:

    # Z "You seem to be preparing a feast."
    Z "Parece que estás preparando un festín."

# game/scripts/family.rpy:2127
translate spanish rabiah_convi_1_94d5228d:

    # Ra "Yeah, that's what good hosts do, I guess."
    Ra "Sí, eso es lo que hacen los buenos anfitriones, supongo."

# game/scripts/family.rpy:2130
translate spanish rabiah_convi_1_7c6e9f87:

    # Ra "..."
    Ra "..."

# game/scripts/family.rpy:2131
translate spanish rabiah_convi_1_e3cd028e:

    # Z "You're stressed out."
    Z "Estás estresada."

# game/scripts/family.rpy:2134
translate spanish rabiah_convi_1_24d0844d:

    # Ra "Tell me something I don't know."
    Ra "Dime algo que no sepa."

# game/scripts/family.rpy:2135
translate spanish rabiah_convi_1_8078f6c3:

    # Ra "That's what happens when your husband spends the time staring at your sister instead of helping out."
    Ra "Eso es lo que pasa cuando tu marido se pasa el tiempo mirando a tu hermana en lugar de ayudar."

# game/scripts/family.rpy:2138
translate spanish rabiah_convi_1_55b37463:

    # "You place your hand on her neck. She's very tense."
    "Le pones la mano en el cuello. Ella está muy tensa."

# game/scripts/family.rpy:2141
translate spanish rabiah_convi_1_983f9f8e:

    # Ra "What are you doing, [persistent.player_name]."
    Ra "¿Qué estás haciendo, [persistent.player_name]?"

# game/scripts/family.rpy:2142
translate spanish rabiah_convi_1_c8ac7eb1:

    # Ra "If Omar sees this, you won't step a foot in here ever again."
    Ra "Si Omar ve esto, no volverás a poner un pie aquí."

# game/scripts/family.rpy:2145
translate spanish rabiah_convi_1_fd8349a9:

    # Z "I'm just helping you relax."
    Z "Sólo te estoy ayudando a relajarte."

# game/scripts/family.rpy:2148
translate spanish rabiah_convi_1_860ded2e:

    # Ra "You know that's not how he will see it..."
    Ra "Sabes que no es así como lo verá..."

# game/scripts/family.rpy:2153
translate spanish rabiah_convi_1_bd2e0e4e:

    # Z "Fine. Do you feel better?"
    Z "Bien. ¿Te sientes mejor?"

# game/scripts/family.rpy:2154
translate spanish rabiah_convi_1_a8c8b4b9:

    # Ra "I do, yes..."
    Ra "Sí, me siento mejor..."

# game/scripts/family.rpy:2157
translate spanish rabiah_convi_1_c2ab39f9:

    # "You let go of her..."
    "La sueltas..."

# game/scripts/family.rpy:2163
translate spanish rabiah_convi_1_2d1e6dbb:

    # Z "Have you seen the way he looks at [W]?"
    Z "¿Has visto cómo mira a [W]?"

# game/scripts/family.rpy:2164
translate spanish rabiah_convi_1_c26b48ba:

    # Z "He's having fun talking with her, while you're stuck here, missing out."
    Z "Se está divirtiendo hablando con ella, mientras tú estás aquí atrapada, perdiéndote."

# game/scripts/family.rpy:2167
translate spanish rabiah_convi_1_e92888c3:

    # Ra "What should he do instead... give her a massage, as well?"
    Ra "¿Qué debería hacer en su lugar... darle un masaje a ella también?"

# game/scripts/family.rpy:2168
translate spanish rabiah_convi_1_7f2cdf08:

    # Z "The least he could do is help you out a little."
    Z "Lo menos que podría hacer es ayudarte un poco."

# game/scripts/family.rpy:2169
translate spanish rabiah_convi_1_f91ad01d:

    # Z "You always hated chores."
    Z "Siempre has odiado las tareas."

# game/scripts/family.rpy:2170
translate spanish rabiah_convi_1_c4c2c528:

    # Ra "[W] does it without your help too. You don't seem to have a problem with that."
    Ra "[W] también lo hace sin tu ayuda. No parece que tengas ningún problema con eso."

# game/scripts/family.rpy:2171
translate spanish rabiah_convi_1_c0af2546:

    # Z "You were never like your sister."
    Z "Nunca fuiste como tu hermana."

# game/scripts/family.rpy:2172
translate spanish rabiah_convi_1_df19cf25:

    # Ra "Too bad, isn't it?"
    Ra "Es una pena, ¿no?"

# game/scripts/family.rpy:2173
translate spanish rabiah_convi_1_d2e94fc0:

    # Z "Why would it be. I always liked that about you."
    Z "Por qué iba a serlo. Siempre me gustó eso de ti."

# game/scripts/family.rpy:2176
translate spanish rabiah_convi_1_7c6e9f87_1:

    # Ra "..."
    Ra "..."

# game/scripts/family.rpy:2177
translate spanish rabiah_convi_1_94018960:

    # Z "I'm just wondering what made you change your mind?"
    Z "Me pregunto qué te ha hecho cambiar de opinión."

# game/scripts/family.rpy:2180
translate spanish rabiah_convi_1_98c9ae26:

    # Z "Did Omar really convince you that this is what you want to do?"
    Z "¿Te convenció Omar de que esto es lo que quieres hacer?"

# game/scripts/family.rpy:2183
translate spanish rabiah_convi_1_e00d6d10:

    # Ra "People change, [persistent.player_name]. We were barely adults back then."
    Ra "La gente cambia, [persistent.player_name]. Entonces apenas éramos adultos."

# game/scripts/family.rpy:2184
translate spanish rabiah_convi_1_54d717e0:

    # Ra "I have my responsibilities now, like he has his."
    Ra "Ahora tengo mis responsabilidades, como él tiene las suyas."

# game/scripts/family.rpy:2187
translate spanish rabiah_convi_1_b9cafb76:

    # Z "Well then, why are you so stressed at the family gathering? Clearly something is not sitting well with you."
    Z "Entonces, ¿por qué estás tan estresada en la reunión familiar? Está claro que algo no te sienta bien."

# game/scripts/family.rpy:2188
translate spanish rabiah_convi_1_2e3ee557:

    # Ra "We actually had a servant, back in the village. She would have been a great help today. Omar is dragging his feet finding a new one."
    Ra "En realidad teníamos una sirvienta, allá en la aldea. Hoy habría sido de gran ayuda. Omar está arrastrando los pies para encontrar una nueva."

# game/scripts/family.rpy:2191
translate spanish rabiah_convi_1_2abf4d9a:

    # Ra "Omar could come in any moment, [persistent.player_name]..."
    Ra "Omar podría llegar en cualquier momento, [persistent.player_name]..."

# game/scripts/family.rpy:2196
translate spanish rabiah_convi_1_304316f0:

    # Z "Do you feel better?"
    Z "¿Te sientes mejor?"

# game/scripts/family.rpy:2197
translate spanish rabiah_convi_1_a8c8b4b9_1:

    # Ra "I do, yes..."
    Ra "Sí, me siento mejor..."

# game/scripts/family.rpy:2200
translate spanish rabiah_convi_1_c2ab39f9_1:

    # "You let go of her..."
    "La sueltas..."

# game/scripts/family.rpy:2206
translate spanish rabiah_convi_1_bbc6e233:

    # "You keep massaging her regardless..."
    "Sigues masajeándola a pesar de todo..."

# game/scripts/family.rpy:2207
translate spanish rabiah_convi_1_87aec051:

    # Ra "[persistent.player_name]..."
    Ra "[persistent.player_name]..."

# game/scripts/family.rpy:2211
translate spanish rabiah_convi_1_80996c20:

    # Z "I'm just helping you relax. Don't act like we never touched each other."
    Z "Sólo te estoy ayudando a relajarte. No actúes como si nunca nos hubiéramos tocado."

# game/scripts/family.rpy:2212
translate spanish rabiah_convi_1_5f71a13b:

    # Ra "[persistent.player_name], we're not together anymore."
    Ra "[persistent.player_name], ya no estamos juntos."

# game/scripts/family.rpy:2213
translate spanish rabiah_convi_1_962f8045:

    # Ra "You're being inappropriate."
    Ra "Estás siendo inapropiado."

# game/scripts/family.rpy:2216
translate spanish rabiah_convi_1_66de47e8:

    # Z "You act like I'm about to undress you."
    Z "Actúas como si estuviera a punto de desnudarte."

# game/scripts/family.rpy:2217
translate spanish rabiah_convi_1_7984c32f:

    # Ra "It's enough for him, and you know it."
    Ra "Es suficiente para él, y lo sabes."

# game/scripts/family.rpy:2220
translate spanish rabiah_convi_1_ea4ab059:

    # "You keep massaging her firmly..."
    "Sigues masajeándola con firmeza..."

# game/scripts/family.rpy:2223
translate spanish rabiah_convi_1_588f42f2:

    # Z "You don't seem to be enjoying doing all this."
    Z "No parece que disfrutes haciendo todo esto."

# game/scripts/family.rpy:2226
translate spanish rabiah_convi_1_06e11f4c:

    # Ra "Why... because I am stressed?"
    Ra "¿Por qué... porque estoy estresada?"

# game/scripts/family.rpy:2231
translate spanish rabiah_convi_1_4199bc55:

    # Z "I see how you're looking at Omar."
    Z "Veo cómo miras a Omar."

# game/scripts/family.rpy:2232
translate spanish rabiah_convi_1_87367717:

    # Z "You're frustrated and bored."
    Z "Estás frustrada y aburrida."

# game/scripts/family.rpy:2233
translate spanish rabiah_convi_1_9cdca82c:

    # Z "You were never the patient type. He annoys you."
    Z "Nunca fuiste del tipo paciente. El te molesta."

# game/scripts/family.rpy:2236
translate spanish rabiah_convi_1_fbf50c62:

    # Ra "He has his moments... that's how marriages go."
    Ra "El tiene sus momentos... así son los matrimonios."

# game/scripts/family.rpy:2237
translate spanish rabiah_convi_1_03142e53:

    # Ra "At least he's not... touching other people's women."
    Ra "Al menos no está... tocando a las mujeres de otros."

# game/scripts/family.rpy:2240
translate spanish rabiah_convi_1_6819ba6c:

    # Ra "Mh..."
    Ra "Mh..."

# game/scripts/family.rpy:2241
translate spanish rabiah_convi_1_b5a0e85c:

    # "You keep massaging her..."
    "Sigues masajeándola..."

# game/scripts/family.rpy:2242
translate spanish rabiah_convi_1_ef0a450f:

    # Z "The way you two behave, I'm not sure that he touches anything."
    Z "Por el modo en que os comportáis, no estoy seguro de que él toque nada."

# game/scripts/family.rpy:2245
translate spanish rabiah_convi_1_8b684aeb:

    # Z "We haven't talked at all since you moved back to the city."
    Z "No hemos hablado en absoluto desde que volviste a la ciudad."

# game/scripts/family.rpy:2246
translate spanish rabiah_convi_1_3a278840:

    # Z "I think we should catch up properly, one of these days."
    Z "Creo que deberíamos ponernos al día como es debido, un día de estos."

# game/scripts/family.rpy:2247
translate spanish rabiah_convi_1_7c6e9f87_2:

    # Ra "..."
    Ra "..."

# game/scripts/family.rpy:2253
translate spanish rabiah_convi_1_4014f798:

    # Z "You always hated doing chores or taking care of the household."
    Z "Siempre has odiado hacer las tareas o ocuparte de la casa."

# game/scripts/family.rpy:2254
translate spanish rabiah_convi_1_fd38565a:

    # Z "Why isn't he pitching in, or have you changed that much?"
    Z "¿Por qué no colaboras, o has cambiado tanto?"

# game/scripts/family.rpy:2257
translate spanish rabiah_convi_1_8c79bc62:

    # Ra "That's how it works, he runs his trading business, I take care of the house and the children."
    Ra "Así es como funciona, él lleva su negocio comercial, yo me encargo de la casa y de los niños."

# game/scripts/family.rpy:2258
translate spanish rabiah_convi_1_0550ee4b:

    # Ra "Not everyone can just take off into the sunset, [persistent.player_name]."
    Ra "No todo el mundo puede marcharse al atardecer, [persistent.player_name]."

# game/scripts/family.rpy:2261
translate spanish rabiah_convi_1_7c6e9f87_3:

    # Ra "..."
    Ra "..."

# game/scripts/family.rpy:2262
translate spanish rabiah_convi_1_ef3d1e68:

    # "your hands dig into her, as your massage continues..."
    "tus manos se clavan en ella, mientras tu masaje continúa..."

# game/scripts/family.rpy:2263
translate spanish rabiah_convi_1_4c3b02ca:

    # Z "I wonder if this is what young Rabiah was hoping for her future self."
    Z "Me pregunto si esto es lo que la joven Rabiah esperaba para su futuro yo."

# game/scripts/family.rpy:2266
translate spanish rabiah_convi_1_c051c44b:

    # Z "We haven't had a chance to reconnect since you moved back to Zeta. We should catch up on old times."
    Z "No hemos tenido la oportunidad de reconectar desde que volviste a Zeta. Deberíamos ponernos al día de los viejos tiempos."

# game/scripts/family.rpy:2267
translate spanish rabiah_convi_1_0b2e660e:

    # Z "Who knows, maybe the Rabiah I knew is still somewhere to be found."
    Z "Quién sabe, tal vez la Rabiah que conocí todavía se encuentre en algún lugar."

# game/scripts/family.rpy:2268
translate spanish rabiah_convi_1_7c6e9f87_4:

    # Ra "..."
    Ra "..."

# game/scripts/family.rpy:2272
translate spanish rabiah_convi_1_0242dd72:

    # Z "You have changed, Rabiah."
    Z "Has cambiado, Rabiah."

# game/scripts/family.rpy:2275
translate spanish rabiah_convi_1_7b7a3c37:

    # Ra "What does that mean..."
    Ra "Qué significa eso..."

# game/scripts/family.rpy:2280
translate spanish rabiah_convi_1_31e496b4:

    # Z "To be honest... you've become boring."
    Z "Para ser sincero... te has vuelto aburrida."

# game/scripts/family.rpy:2281
translate spanish rabiah_convi_1_96ab25ee:

    # Z "You used to speak up more, be the life of any gathering and ignore chores like they were a plague."
    Z "Antes hablabas más, eras el alma de cualquier reunión e ignorabas las tareas como si fueran una plaga."

# game/scripts/family.rpy:2282
translate spanish rabiah_convi_1_36ff72a4:

    # Z "And here you are, less the lady of a House, and more a common housewife."
    Z "Y aquí estás, menos la señora de una Casa y más una vulgar ama de casa."

# game/scripts/family.rpy:2285
translate spanish rabiah_convi_1_4cd6897e:

    # Z "What happened to the old Rabiah?"
    Z "¿Qué ha pasado con la antigua Rabiah?"

# game/scripts/family.rpy:2286
translate spanish rabiah_convi_1_d89aa2f7:

    # Z "Enthusiastic, spontaneous, cocky..."
    Z "Entusiasta, espontánea, arrogante..."

# game/scripts/family.rpy:2287
translate spanish rabiah_convi_1_51a3e8f6:

    # Z "What happened?"
    Z "¿Qué ha pasado?"

# game/scripts/family.rpy:2290
translate spanish rabiah_convi_1_01f11647:

    # Ra "People change, [persistent.player_name]."
    Ra "La gente cambia, [persistent.player_name]."

# game/scripts/family.rpy:2291
translate spanish rabiah_convi_1_06eae559:

    # Ra "You will have noticed that the house is currently out of a servant, so..."
    Ra "Te habrás dado cuenta de que la casa se ha quedado sin criado, así que..."

# game/scripts/family.rpy:2292
translate spanish rabiah_convi_1_fca8042c:

    # Ra "I have to take care of things, just like your wife does."
    Ra "Tengo que ocuparme de las cosas, como hace tu mujer."

# game/scripts/family.rpy:2295
translate spanish rabiah_convi_1_6819ba6c_1:

    # Ra "Mh..."
    Ra "Mh..."

# game/scripts/family.rpy:2296
translate spanish rabiah_convi_1_b4c9b656:

    # "You massage her more thoroughly..."
    "La masajeas más a fondo..."

# game/scripts/family.rpy:2297
translate spanish rabiah_convi_1_c0af2546_1:

    # Z "You were never like your sister."
    Z "Nunca fuiste como tu hermana."

# game/scripts/family.rpy:2303
translate spanish rabiah_convi_1_42c8a19b:

    # Z "Remember that we always used to give it straight to each other?"
    Z "¿Recuerdas que siempre solíamos decirnos las cosas directamente?"

# game/scripts/family.rpy:2304
translate spanish rabiah_convi_1_879c11ee:

    # Z "I can't shake the feeling that you've become a stuck up bitch."
    Z "No puedo evitar la sensación de que te has convertido en una perra engreída."

# game/scripts/family.rpy:2307
translate spanish rabiah_convi_1_94957ec7:

    # Ra "And you've always been an asshole, [persistent.player_name]."
    Ra "Y tú siempre has sido un gilipollas, [persistent.player_name]."

# game/scripts/family.rpy:2308
translate spanish rabiah_convi_1_fb07f0ca:

    # Ra "You barely see me anyway."
    Ra "De todos modos, apenas me ves."

# game/scripts/family.rpy:2311
translate spanish rabiah_convi_1_7c6e9f87_5:

    # Ra "..."
    Ra "..."

# game/scripts/family.rpy:2312
translate spanish rabiah_convi_1_5b04ac26:

    # "You massage her more strongly..."
    "La masajeas con más fuerza..."

# game/scripts/family.rpy:2313
translate spanish rabiah_convi_1_847fe02e:

    # Z "I have had a look at your face since I set foot here."
    Z "He visto tu cara desde que puse un pie aquí."

# game/scripts/family.rpy:2316
translate spanish rabiah_convi_1_1401eb3d:

    # Z "You were never good at hiding how you feel."
    Z "Nunca se te dio bien ocultar lo que sientes."

# game/scripts/family.rpy:2317
translate spanish rabiah_convi_1_67a32546:

    # Z "All I can see, right now, is that you hate your life."
    Z "Todo lo que puedo ver, ahora mismo, es que odias tu vida."

# game/scripts/family.rpy:2323
translate spanish vfr19_d30d4d86:

    # Om "..."
    Om "..."

# game/scripts/family.rpy:2326
translate spanish vfr19_5da37bef:

    # Z "See, that helps, doesn't it?"
    Z "Ves, eso ayuda, ¿verdad?"

# game/scripts/family.rpy:2327
translate spanish vfr19_7c6e9f87:

    # Ra "..."
    Ra "..."

# game/scripts/family.rpy:2330
translate spanish vfr19_d30d4d86_1:

    # Om "..."
    Om "..."

# game/scripts/family.rpy:2333
translate spanish vfr19_058d9ce7:

    # Om "Ra...biah?"
    Om "¿Ra... biah?"

# game/scripts/family.rpy:2336
translate spanish vfr19_1aa77994:

    # Om "What are you doing?"
    Om "¿Qué estás haciendo?"

# game/scripts/family.rpy:2342
translate spanish vfr19_7c6e9f87_1:

    # Ra "..."
    Ra "..."

# game/scripts/family.rpy:2345
translate spanish vfr19_8cf56c6d:

    # Ra "I..."
    Ra "Yo..."

# game/scripts/family.rpy:2346
translate spanish vfr19_5192d980:

    # Ra "Omar?"
    Ra "¿Omar?"

# game/scripts/family.rpy:2347
translate spanish vfr19_7d04765a:

    # Ra "I wasn't..."
    Ra "Yo no estaba..."

# game/scripts/family.rpy:2350
translate spanish vfr19_749227b4:

    # Z "Relax, Omar."
    Z "Relájate, Omar."

# game/scripts/family.rpy:2351
translate spanish vfr19_1b74e3ac:

    # Z "Rabiah had a cramp. I just helped her out."
    Z "Rabiah tenía un calambre. La ayudé a librarse de él."

# game/scripts/family.rpy:2354
translate spanish vfr19_4085c32a:

    # Z "She seems to be overworked."
    Z "Parece que está sobrecargada de trabajo."

# game/scripts/family.rpy:2355
translate spanish vfr19_4f39a22f:

    # Z "She needed a hand."
    Z "Necesitaba una mano."

# game/scripts/family.rpy:2358
translate spanish vfr19_929b63b0:

    # "You walk over to him..."
    "Te acercas a él..."

# game/scripts/family.rpy:2361
translate spanish vfr19_73e58dc1:

    # Z "Now that you're here, you should take over."
    Z "Ahora que estás aquí, deberías hacerte cargo."

# game/scripts/family.rpy:2364
translate spanish vfr19_a4a05c8a:

    # "You head towards the door..."
    "Te diriges hacia la puerta..."

# game/scripts/family.rpy:2365
translate spanish vfr19_3962cee0:

    # Om "D-do you need anything, sweetie?"
    Om "¿N-necesitas algo, cariño?"

# game/scripts/family.rpy:2366
translate spanish vfr19_157e51ad:

    # Ra "No, I'm fine. I just had a cramp, like he said. It's gone now."
    Ra "No, estoy bien. Sólo he tenido un calambre, como él ha dicho. Ya se me ha pasado."

# game/scripts/family.rpy:2373
translate spanish vfr19x_1ef3ef8c:

    # Om "Sweetheart?"
    Om "¿Cariño?"

# game/scripts/family.rpy:2376
translate spanish vfr19x_6f04ee4c:

    # Om "I wanted to ask how dinner is going?"
    Om "Quería preguntarte cómo va la cena..."

# game/scripts/family.rpy:2383
translate spanish omar_convi_3_6a3ecc0c:

    # Om "...{i}*laughs*{/i} No way, he did?"
    Om "...{i}*risas*{/i} No puede ser, ¿él lo hizo?"

# game/scripts/family.rpy:2384
translate spanish omar_convi_3_c63f57c0:

    # W "Yup. It's true."
    W "Sí. Es verdad."

# game/scripts/family.rpy:2387
translate spanish omar_convi_3_83e92d34:

    # W "I wouldn't have thought so, but that's what happened."
    W "No lo habría pensado, pero eso es lo que pasó."

# game/scripts/family.rpy:2390
translate spanish omar_convi_3_cbd81b1d:

    # Z "Hey, girl."
    Z "Oye, chica."

# game/scripts/family.rpy:2391
translate spanish omar_convi_3_137cbde9:

    # W "Hey..."
    W "Oye..."

# game/scripts/family.rpy:2392
translate spanish omar_convi_3_1eb702c2:

    # W "{i}*kissing*"
    W "{i}*besando*{/i}"

# game/scripts/family.rpy:2395
translate spanish omar_convi_3_d30d4d86:

    # Om "..."
    Om "..."

# game/scripts/family.rpy:2396
translate spanish omar_convi_3_10d3f691:

    # Z "Omar."
    Z "Omar."

# game/scripts/family.rpy:2399
translate spanish omar_convi_3_e1857eff:

    # Z "Let's take a seat..."
    Z "Tomemos asiento..."

# game/scripts/family.rpy:2402
translate spanish omar_convi_3_6c857780:

    # Om "S-sure. Why not?"
    Om "Por supuesto. ¿Por qué no?"

# game/scripts/family.rpy:2405
translate spanish omar_convi_3_096c1f59:

    # "You make yourselves comfortable..."
    "Os ponéis cómodos..."

# game/scripts/family.rpy:2408
translate spanish omar_convi_3_54ee0962:

    # Om "Anyway, I was saying, I am thinking of expanding in a new market and maybe I could have use for a man with your talents... and I..."
    Om "En fin, te decía que estoy pensando en expandirme en un nuevo mercado y quizá me vendría bien un hombre con tu talento... y yo..."

# game/scripts/family.rpy:2411
translate spanish omar_convi_3_e4923433:

    # "[W] seems intent on following the conversation closely..."
    "[W] parece decidida a seguir de cerca la conversación..."

# game/scripts/family.rpy:2415
translate spanish omar_convi_3_dafb624b:

    # Ww "You and my sister had an argument earlier."
    Ww "Mi hermana y tú discutisteis antes."

# game/scripts/family.rpy:2416
translate spanish omar_convi_3_8f231fb2:

    # Ww "Should I worry about it?"
    Ww "¿Debería preocuparme?"

# game/scripts/family.rpy:2419
translate spanish omar_convi_3_d47bb79f:

    # Zw "Well. She caught me and Nadia together..."
    Zw "Bueno... Ella nos pilló a Nadia y a mí juntos..."

# game/scripts/family.rpy:2422
translate spanish omar_convi_3_fba4f520:

    # Ww "I see. That's why she left the room so flustered. It makes sense, now."
    Ww "Ya veo. Por eso salió de la habitación tan alterada. Ahora tiene sentido."

# game/scripts/family.rpy:2425
translate spanish omar_convi_3_f9939534:

    # Zw "You think she's going to tell Omar?"
    Zw "¿Crees que se lo dirá a Omar?"

# game/scripts/family.rpy:2428
translate spanish omar_convi_3_e28a4b6b:

    # Ww "What I think, is that he's a hypocrite who should learn not to use two measures."
    Ww "Lo que pienso, es que él es un hipócrita que debería aprender a no usar dos medidas."

# game/scripts/family.rpy:2429
translate spanish omar_convi_3_4def8a21:

    # Ww "And no, I don't think she'll be telling him. Actually..."
    Ww "Y no, no creo que se lo cuente. En realidad..."

# game/scripts/family.rpy:2431
translate spanish omar_convi_3_59d35aaa:

    # Ww "Do you think Rabiah realises how her husband behaves?"
    Ww "¿Crees que Rabiah se da cuenta de cómo se comporta su marido?"

# game/scripts/family.rpy:2432
translate spanish omar_convi_3_0e52ada9:

    # Ww "I mean, he's a bit of a hypocrite, isn't he?"
    Ww "Es un poco hipócrita, ¿no?"

# game/scripts/family.rpy:2435
translate spanish omar_convi_3_c3204bb8:

    # Zw "Well... Any man with eyes would look at you admiringly."
    Zw "Bueno... Cualquier hombre con ojos te miraría con admiración."

# game/scripts/family.rpy:2438
translate spanish omar_convi_3_60dae3b1:

    # Ww "Well, of course, but that same man should not try and chastise his own wife the way Omar does."
    Ww "Bueno, por supuesto, pero ese mismo hombre no debería intentar reprender a su propia mujer como lo hace Omar."

# game/scripts/family.rpy:2441
translate spanish omar_convi_3_3e78e7d3:

    # Zw "So you think she hasn't noticed?"
    Zw "¿Crees que no se ha dado cuenta?"

# game/scripts/family.rpy:2444
translate spanish omar_convi_3_abd7ad04:

    # Ww "Maybe; or maybe she's just trying to ignore it."
    Ww "Tal vez; o tal vez sólo intenta ignorarlo."

# game/scripts/family.rpy:2447
translate spanish omar_convi_3_de5fd3a7:

    # Ww "Let me try something..."
    Ww "Déjame probar algo..."

# game/scripts/family.rpy:2450
translate spanish omar_convi_3_76360a30:

    # "She gets up..."
    "Se levanta..."

# game/scripts/family.rpy:2453
translate spanish omar_convi_3_f0ff066c:

    # W "I'm getting another round of drinks. Do you want anything?"
    W "Voy a por otra ronda de bebidas. ¿Queréis algo?"

# game/scripts/family.rpy:2454
translate spanish omar_convi_3_5bdbda84:

    # Om "Oh, uh..."
    Om "Oh, eh..."

# game/scripts/family.rpy:2455
translate spanish omar_convi_3_b04cf2f1:

    # Z "Not me, thank you."
    Z "Yo no, gracias."

# game/scripts/family.rpy:2458
translate spanish omar_convi_3_b372672d:

    # Om "Sure, why not. Thank you, [W]!"
    Om "Claro, por qué no. ¡Gracias, [W]!"

# game/scripts/family.rpy:2459
translate spanish omar_convi_3_b0aa12eb:

    # W "I will be right back. Don't have too much fun without me..."
    W "Ahora vuelvo. No te diviertas demasiado sin mí..."

# game/scripts/family.rpy:2462
translate spanish omar_convi_3_39e0278a:

    # "A short while later..."
    "Poco después..."

# game/scripts/family.rpy:2465
translate spanish omar_convi_3_6beb5088:

    # W "You ordered a drink?"
    W "¿Has pedido algo de beber?"

# game/scripts/family.rpy:2468
translate spanish omar_convi_3_47544e53:

    # Om "Heh, yes. How do I deserve to be served by guests in my own house?"
    Om "Eh, sí. ¿Cómo puedo merecer que me sirvan invitados en mi propia casa?"

# game/scripts/family.rpy:2471
translate spanish omar_convi_3_6ec171c3:

    # W "Oh, nonsense, you are family."
    W "Oh, tonterías, eres de la familia."

# game/scripts/family.rpy:2474
translate spanish omar_convi_3_748f5e5e:

    # W "And, you know..."
    W "Y, ya sabes..."

# game/scripts/family.rpy:2477
translate spanish omar_convi_3_54c4dc96:

    # W "...we look after our family, in these parts..."
    W "... cuidamos de nuestra familia, por estos lares..."

# game/scripts/family.rpy:2478
translate spanish omar_convi_3_0862764a:

    # "Omar has never been this close to [W]. He can't avoid staring at the chest that's swaying right in front of him."
    "Omar nunca ha estado tan cerca de [W]. No puede evitar mirar fijamente el pecho que se balancea justo delante de él."

# game/scripts/family.rpy:2479
translate spanish omar_convi_3_eb154e5e:

    # "...his mind going back to her sultry voice as she spoke about family."
    "... su mente volvía a su sensual voz cuando hablaba de la familia."

# game/scripts/family.rpy:2482
translate spanish omar_convi_3_c839cc54:

    # "When she offered him the glass, he ignored it, staring instead at her beautiful body, his eyes darting around to check if he was in the clear."
    "Cuando ella le ofreció el vaso, él lo ignoró, mirando en su lugar el hermoso cuerpo de ella, con los ojos desviados para comprobar si estaba libre de sospecha."

# game/scripts/family.rpy:2483
translate spanish omar_convi_3_8c674ec9:

    # "With his wife in the kitchen, and [persistent.player_name]'s view obscured by [W] herself, he used every precious second to take in the sight of his sister-in-law's body."
    "Con su mujer en la cocina, y la vista de [persistent.player_name] oscurecida por la propia [W], aprovecha cada precioso segundo para contemplar el cuerpo de su cuñada."

# game/scripts/family.rpy:2484
translate spanish omar_convi_3_324e7a72:

    # "...And then the spell broke."
    "... Y entonces se rompió el hechizo."

# game/scripts/family.rpy:2488
translate spanish omar_convi_3_5f214158:

    # "The glass almost slips out of [W]'s hand..."
    "El vaso casi resbala de la mano de [W]..."

# game/scripts/family.rpy:2491
translate spanish omar_convi_3_8779b955:

    # Om "[W]! Why...! My top!"
    Om "¡[W]! ¿Por qué...? ¡Mi camisa!"

# game/scripts/family.rpy:2492
translate spanish omar_convi_3_2911ef9f:

    # W "Oh, dear. The glass... it slipped. I am so terribly sorry."
    W "Oh, vaya. El vaso... se me resbaló. Lo siento muchísimo."

# game/scripts/family.rpy:2493
translate spanish omar_convi_3_7031be6b:

    # Om "It's... okay, I guess. Thank you anyway."
    Om "Está... bien, supongo. Gracias de todas formas."

# game/scripts/family.rpy:2494
translate spanish omar_convi_3_f469a33b:

    # Om "Maybe we should... have a toast? You got yourself one, too?"
    Om "Quizá deberíamos... ¿brindar? ¿Tú también tienes uno?"

# game/scripts/family.rpy:2497
translate spanish omar_convi_3_53c2bdab:

    # W "Oh, no, I'm good, thanks."
    W "Oh, no, yo estoy bien, gracias."

# game/scripts/family.rpy:2498
translate spanish omar_convi_3_67c05753:

    # W "I didn't bring it for me."
    W "No la he traído para mí."

# game/scripts/family.rpy:2501
translate spanish omar_convi_3_d5a0b829:

    # W "...but your wife wanted one."
    W "... pero tu mujer quería una."

# game/scripts/family.rpy:2503
translate spanish omar_convi_3_576f6e3f:

    # Om "Wait, wha...-"
    Om "Espera, ¿qué...?"

# game/scripts/family.rpy:2508
translate spanish omar_convi_3_ae7f1ba0:

    # Om "Oh..."
    Om "Oh..."

# game/scripts/family.rpy:2512
translate spanish omar_convi_3_b9c4d13b:

    # W "Hey husband."
    W "Ey marido."

# game/scripts/family.rpy:2513
translate spanish omar_convi_3_0395d470:

    # Z "Hey wife."
    Z "Ey esposa."

# game/scripts/family.rpy:2514
translate spanish omar_convi_3_e43f0872:

    # Zw "Did you have fun getting the poor little man in trouble?"
    Zw "¿Te divertiste metiendo en líos al pobrecito?"

# game/scripts/family.rpy:2517
translate spanish omar_convi_3_a24a053c:

    # "Arguing can be heard in the background..."
    "Se oyen discusiones de fondo..."

# game/scripts/family.rpy:2518
translate spanish omar_convi_3_285c352c:

    # Ra "Care to explain to me why you were oggling her like a bunch of hungry sandrats spotting a chicken?!"
    Ra "¿¡Me puedes explicar por qué la estabas mirando como un puñado de... de ratones de arena hambrientos que ven un pollo!?"

# game/scripts/family.rpy:2519
translate spanish omar_convi_3_61e2dca5:

    # Om "I... look, she was standing-"
    Om "Yo... mira, ella estaba de pie..."

# game/scripts/family.rpy:2520
translate spanish omar_convi_3_e206b004:

    # Ra "Save it! You told me just this morning that a chain bra would be too skimpy, and now I catch you drooling over my sister's tits! You hypocrite!"
    Ra "Ahórratelo. Esta misma mañana me dijiste que un sujetador de cadena sería demasiado escaso, ¡y ahora te pillo babeando por las tetas de mi hermana! ¡Hipócrita!"

# game/scripts/family.rpy:2521
translate spanish omar_convi_3_3594ed1e:

    # Zw "You're evil..."
    Zw "Eres malvada..."

# game/scripts/family.rpy:2524
translate spanish omar_convi_3_c358ad3a:

    # Ww "I wouldn't call it evil."
    Ww "Yo no lo llamaría maldad."

# game/scripts/family.rpy:2525
translate spanish omar_convi_3_e870aa91:

    # Ww "I think my big sister should focus on where her problems really are, so I pointed her at it..."
    Ww "Creo que mi hermana mayor debería centrarse en dónde están realmente sus problemas, así que la señalé..."

# game/scripts/family.rpy:2527
translate spanish omar_convi_3_024a5488:

    # Ww "...and, if it just happens to distract her from worrying about her daughter, then so be it."
    Ww "... y, si resulta que eso la distrae de preocuparse por su hija, pues que así sea."

# game/scripts/family.rpy:2530
translate spanish omar_convi_3_100ea271:

    # Zw "You're still devious. I knew there was a reason I keep you around."
    Zw "Sigues siendo retorcida. Sabía que había una razón para tenerte cerca."

# game/scripts/family.rpy:2531
translate spanish omar_convi_3_5140c7bd:

    # Ww "Don't you ever forget it."
    Ww "No lo olvides nunca."

# game/scripts/family.rpy:2534
translate spanish omar_convi_3_8f95dbd2:

    # "Judging by Rabiah's reaction, it looks as if the events of the day indeed brought to light several issues that were bubbling under the surface."
    "A juzgar por la reacción de Rabiah, parece como si los acontecimientos del día hubieran sacado a la luz varias cuestiones que bullían bajo la superficie."

# game/scripts/family.rpy:2535
translate spanish omar_convi_3_f66467e9:

    # "It will be interesting to see where this leads..."
    "Será interesante ver adónde lleva esto..."

# game/scripts/family.rpy:2540
translate spanish omar_convi_2_f6c35e2d:

    # Zt "..."
    Zt "..."

# game/scripts/family.rpy:2552
translate spanish omar_convi_2_c2c9cc07:

    # W "..."
    W "..."

# game/scripts/family.rpy:2555
translate spanish omar_convi_2_d30d4d86:

    # Om "..."
    Om "..."

# game/scripts/family.rpy:2558
translate spanish omar_convi_2_55090e12:

    # Om "Eh, I-I'm not sure if this is appropriate..."
    Om "Eh, no estoy seguro de si esto es apropiado..."

# game/scripts/family.rpy:2561
translate spanish omar_convi_2_3d8dad01:

    # Z "Why not? Does my wife not seem happy?"
    Z "¿Por qué no? ¿Mi mujer no parece feliz?"

# game/scripts/family.rpy:2564
translate spanish omar_convi_2_a11f226b:

    # Om "N-no, no, that isn't..."
    Om "N-no, no, eso no es..."

# game/scripts/family.rpy:2567
translate spanish omar_convi_2_9324b392:

    # Om "But shouldn't you do this in private..."
    Om "Pero no deberías hacer eso en privado..."

# game/scripts/family.rpy:2570
translate spanish omar_convi_2_1b39297d:

    # Z "You really are new to this city, aren't you?"
    Z "Realmente eres nuevo en esta ciudad, ¿no?"

# game/scripts/family.rpy:2573
translate spanish omar_convi_2_d71a38bb:

    # Z "I'm just appreciating my wife, that's all I'm doing."
    Z "Sólo estoy apreciando a mi mujer, eso es todo lo que estoy haciendo."

# game/scripts/family.rpy:2578
translate spanish omar_convi_2_050d2fc7:

    # "You turn her around"
    "La das la vuelta"

# game/scripts/family.rpy:2579
translate spanish omar_convi_2_2ad034eb:

    # W "Mh..."
    W "Mh..."

# game/scripts/family.rpy:2582
translate spanish omar_convi_2_465bce42:

    # Z "Let's be honest, you have been staring at her every time you have met her."
    Z "Seamos sinceros, te has quedado mirando cada vez que te has encontrado con ella."

# game/scripts/family.rpy:2583
translate spanish omar_convi_2_6131686e:

    # Om "Well... you..."
    Om "Bueno... tú..."

# game/scripts/family.rpy:2586
translate spanish omar_convi_2_f49cead2:

    # Om "I'm not against that but... right here? Like that? Is she not...?"
    Om "No estoy en contra de eso, pero... aquí? ¿Así? ¿Acaso ella no...?"

# game/scripts/family.rpy:2591
translate spanish omar_convi_2_9374246b:

    # W "...why would I be against it...?"
    W "... ¿por qué iba a estar en contra...?"

# game/scripts/family.rpy:2592
translate spanish omar_convi_2_a5d4a24a:

    # W "I like when he appreciates me."
    W "Me gusta cuando él me aprecia."

# game/scripts/family.rpy:2595
translate spanish omar_convi_2_e5acf046:

    # W "Nh..."
    W "Nh..."

# game/scripts/family.rpy:2596
translate spanish omar_convi_2_cc3c8647:

    # "You keep fondling her..."
    "Sigues acariciándola..."

# game/scripts/family.rpy:2597
translate spanish omar_convi_2_bd5f6354:

    # Om "Even in front of others?"
    Om "¿Incluso delante de los demás?"

# game/scripts/family.rpy:2598
translate spanish omar_convi_2_e14ca3b0:

    # W "Mh?"
    W "¿Mh-?"

# game/scripts/family.rpy:2601
translate spanish omar_convi_2_3d0ce771:

    # W "Why would I dislike the attention...?"
    W "¿Por qué me iba a disgustar la atención...?"

# game/scripts/family.rpy:2602
translate spanish omar_convi_2_63531c9b:

    # W "You seem to enjoy the view too."
    W "Parece que tú también disfrutas de la vista."

# game/scripts/family.rpy:2603
translate spanish omar_convi_2_64d17561:

    # W "Could it be that you are interested in me?"
    W "¿Podría ser que estuvieras interesado en mí?"

# game/scripts/family.rpy:2606
translate spanish omar_convi_2_c032bbdf:

    # Om "I... I'm loyal to my wife..."
    Om "Yo... soy leal a mi mujer..."

# game/scripts/family.rpy:2609
translate spanish omar_convi_2_a7146f0a:

    # Z "I think he likes you a lot, [W]..."
    Z "Creo que le gustas mucho, [W]..."

# game/scripts/family.rpy:2612
translate spanish omar_convi_2_661ba212:

    # Ww "Let him dream, then..."
    Ww "Déjale soñar, entonces..."

# game/scripts/family.rpy:2618
translate spanish omar_convi_2_1096b047:

    # Z "She's my wife. I touch her whenever I please."
    Z "Es mi mujer. La toco siempre que me apetece."

# game/scripts/family.rpy:2621
translate spanish omar_convi_2_7bdfe923:

    # Z "I could take her whenever I want, and she would never complain."
    Z "Podría tenerla siempre que quisiera, y ella nunca se quejaría."

# game/scripts/family.rpy:2624
translate spanish omar_convi_2_5f411c3b:

    # Z "That's part of why she's the best woman I could ever have."
    Z "En parte por eso es la mejor mujer que podría tener."

# game/scripts/family.rpy:2625
translate spanish omar_convi_2_c2c9cc07_1:

    # W "..."
    W "..."

# game/scripts/family.rpy:2626
translate spanish omar_convi_2_4bfac920:

    # Om "But... even in the city? Does no one object?"
    Om "Pero... ¿incluso en la ciudad? ¿Nadie se opone?"

# game/scripts/family.rpy:2631
translate spanish omar_convi_2_fa31bd8b:

    # Z "That's how things work around here."
    Z "Así es como funcionan las cosas por aquí."

# game/scripts/family.rpy:2632
translate spanish omar_convi_2_de722891:

    # Z "Why would anyone be against a woman as beautiful as her showing herself off?"
    Z "¿Por qué alguien se opondría a que una mujer tan bella como ella se exhibiera?"

# game/scripts/family.rpy:2633
translate spanish omar_convi_2_fb2e74ea:

    # Z "You are not the only person who admires her and is intrigued. Let people be intrigued, if they so please."
    Z "No eres la única persona que la admira y está intrigada. Deja que la gente se sienta intrigada, si así lo desea."

# game/scripts/family.rpy:2636
translate spanish omar_convi_2_d30d4d86_1:

    # Om "..."
    Om "..."

# game/scripts/family.rpy:2637
translate spanish omar_convi_2_886c04a2:

    # Z "It doesn't look like your wife is as interested, though."
    Z "Sin embargo, no parece que tu mujer esté tan interesada."

# game/scripts/family.rpy:2640
translate spanish omar_convi_2_5c53730b:

    # Z "Loving your wife like that, and her loving you back."
    Z "Ama a tu mujer así, y que ella te corresponda."

# game/scripts/family.rpy:2641
translate spanish omar_convi_2_f5d3959d:

    # Zw "Not a bad thing at all."
    Zw "No es algo malo en absoluto."

# game/scripts/family.rpy:2644
translate spanish omar_convi_2_5cbf7d15:

    # W "I know that as her man you might not want to hear this, Omar..."
    W "Sé que como hombre de ella puede que no quieras oír esto, Omar..."

# game/scripts/family.rpy:2645
translate spanish omar_convi_2_3200c040:

    # W "But my sister was a bigger flirt than me, back before she met you..."
    W "Pero mi hermana era más coqueta que yo, antes de conocerte..."

# game/scripts/family.rpy:2648
translate spanish omar_convi_2_34e41922:

    # Om "What... do you mean by that?"
    Om "¿Qué... quieres decir con eso?"

# game/scripts/family.rpy:2649
translate spanish omar_convi_2_9df8dfb0:

    # Om "With whom?"
    Om "¿Con quién?"

# game/scripts/family.rpy:2652
translate spanish omar_convi_2_c48cc944:

    # W "You know that before we became a couple, [persistent.player_name] had my sister."
    W "Sabes que antes de que fuéramos pareja, [persistent.player_name] tenía a mi hermana."

# game/scripts/family.rpy:2653
translate spanish omar_convi_2_a1f7f15d:

    # W "She was not shy about wanting sex often, and the place did not matter. She was quite aggressive, too..."
    W "No era tímida a la hora de querer sexo a menudo, y no importaba el lugar. También era bastante agresiva..."

# game/scripts/family.rpy:2656
translate spanish omar_convi_2_498467d3:

    # Z "She was feisty."
    Z "Ella era luchadora."

# game/scripts/family.rpy:2657
translate spanish omar_convi_2_b289467c:

    # Z "Turn around now, [W]."
    Z "Date la vuelta ahora, [W]."

# game/scripts/family.rpy:2660
translate spanish omar_convi_2_ea88ee5c:

    # "She slowly rotates allowing you to fix her clothes..."
    "Se gira lentamente permitiéndote arreglar su ropa..."

# game/scripts/family.rpy:2666
