    # "She cums violently..."
    "Ella se corre violentamente..."

# game/scripts/family.rpy:1578
translate spanish vfn160_b2529e4e:

    # Na "{i}*pants*"
    Na "{i}*jadeos*"

# game/scripts/family.rpy:1579
translate spanish vfn160_5fc43e63:

    # Naw "Thank you, uncle... I... that..."
    Naw "Gracias, tío... yo... esto..."

# game/scripts/family.rpy:1580
translate spanish vfn160_8e788a17:

    # Zw "Always here for my niece. You should get dressed, now. Come on, let's get up."
    Zw "Siempre aquí para mi sobrina. Deberías vestirte ya. Venga, vamos a levantarnos."

# game/scripts/family.rpy:1584
translate spanish vfn160_cf8d458e:

    # "Later, at the dinner table..."
    "Más tarde, en la mesa..."

# game/scripts/family.rpy:1588
