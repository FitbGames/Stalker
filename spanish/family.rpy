    # Z "It seems like my sweet not-so-innocent niece needed that badly."
    Z "Parece que mi dulce y no tan inocente sobrina lo necesitaba con urgencia."

# game/scripts/family.rpy:1554
translate spanish vfn160_f4c13f51:

    # Na "Yeess... I still can't believe... he... nh... didn't catch us..."
    Na "Sí... Todavía no puedo creer... que... nh... no nos pillara..."

# game/scripts/family.rpy:1558
translate spanish vfn160_4af87190:

    # Z "Maybe he saw how I was touching you, and enjoyed it?"
    Z "¿Quizá vio cómo te tocaba y disfrutó con ello?"

# game/scripts/family.rpy:1559
