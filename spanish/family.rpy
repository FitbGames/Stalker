    Z "Nadia debería estar en su habitación."

# game/scripts/family.rpy:1591
translate spanish nadia_convi_1_be1fb605:

    # Na "{i}*humming*"
    Na "{i}*tarareando*"

# game/scripts/family.rpy:1594
translate spanish nadia_convi_1_0aa2a467:

    # Na "Hmm..."
    Na "Hmm..."

# game/scripts/family.rpy:1596
translate spanish nadia_convi_1_d483bae9:

