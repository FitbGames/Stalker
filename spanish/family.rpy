    Na "Ya está... sigamos con algo especial... {i}*risitas*"

# game/scripts/family.rpy:1051
translate spanish vfn80_f929740d:

    # Na "You don't mind if I change right here, uncle?"
    Na "¿No te importa que me cambie aquí mismo, tío?"

# game/scripts/family.rpy:1053
