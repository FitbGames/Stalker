    Z "Seguro que nos estarán esperando. Deberías correrte pronto, pequeña."

# game/scripts/family.rpy:1564
translate spanish vfn160_bd9df085:

    # Z "I don't think you want your mother to find out what we're doing."
    Z "No creo que quieras que tu madre se entere de lo que estamos haciendo."

# game/scripts/family.rpy:1565
